  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C."
    },
    {
      "heading": null,
      "description": "Place the nigella seeds, coriander seeds, pepper and urfa chilli flakes in a spice grinder or pestle and mortar and blitz or crush to a fine powder. Stir the spices through the honey and set aside."
    },
    {
      "heading": null,
      "description": "Halve each block of halloumi so you're left with 4 thick pieces. Heat a dash of olive oil in a frying pan over a medium-high heat, then pan fry for 3-5 minutes on each side until golden and crisp. Transfer to the oven to heat through for 5 minutes. By this point, it should be gooey."
    },
    {
      "heading": null,
      "description": "To serve, place a slice of halloumi on each plate and season with a little lemon juice and zest. Drizzle over the spiced honey and serve immediately."
    }
