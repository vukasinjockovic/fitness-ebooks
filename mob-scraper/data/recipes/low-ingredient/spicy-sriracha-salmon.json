  "method": [
    {
      "heading": null,
      "description": "First, grate your garlic cloves. Then, in a large bowl, whisk together all the sauce ingredients. Cut the salmon into large cubes (about 3 per fillet) and finely slice the spring onions."
    },
    {
      "heading": null,
      "description": "Add the salmon cubes to the bowl and toss well to coat. Transfer to a container and leave to marinate in the fridge for at least 10 mins."
    },
    {
      "heading": null,
      "description": "Preheat your air fryer to 240°C."
    },
    {
      "heading": null,
      "description": "Add the marinated salmon to the air fryer basket and cook for 3-4 mins, until caramelised and cooked through."
    },
    {
      "heading": null,
      "description": "Serve with a sprinkle of sesame seeds, sliced spring onions, and lemon wedges."
    }
