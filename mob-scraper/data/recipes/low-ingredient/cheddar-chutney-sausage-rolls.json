  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/365°F."
    },
    {
      "heading": null,
      "description": "Grate the cheese. Squeeze the sausages out of their skins into a bowl."
    },
    {
      "heading": null,
      "description": "Mix the grated cheese, thyme leaves and mustard into the sausage meat. Add some seasoning."
    },
    {
      "heading": null,
      "description": "Warm the chutney slightly so it spreads more easily."
    },
    {
      "heading": null,
      "description": "Unravel the sheet of puff pastry and cut in half length-ways. Spread red onion chutney over each rectangle."
    },
    {
      "heading": null,
      "description": "Divide the sausage mixture into two equal parts. Lay out the mixture along the length of each pastry strip in a cylindrical shape - you want there to be a 1cm border."
    },
    {
      "heading": null,
      "description": "Brush the top of the sausage meat and borders with beaten egg yolk. Tightly roll the pastry over the sausage to encase it. Cut into 12 sausage rolls and chill for 15 minutes."
    },
    {
      "heading": null,
      "description": "Brush the remaining egg over the sausage rolls and sprinkle over the sesame seeds. Bake for 30 minutes until cooked through and a deep golden brown."
    }
