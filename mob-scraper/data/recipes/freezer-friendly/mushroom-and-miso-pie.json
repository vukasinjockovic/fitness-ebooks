  "method": [
    {
      "heading": null,
      "description": "Finely chop the onions and garlic before slicing up the mushrooms."
    },
    {
      "heading": null,
      "description": "Pick the leaves off the thyme and finely chop the tarragon."
    },
    {
      "heading": null,
      "description": "Sauté the onions in a pan with a glug of oil. Cook for 5 mins until softened, then add in the mushrooms with a big pinch of salt. Cook for 15 mins until the water has evaporated and the mushrooms start to crisp up."
    },
    {
      "heading": null,
      "description": "Add in the garlic and cook for 1 minute until fragrant."
    },
    {
      "heading": null,
      "description": "Add in the flour and mix well so that there are no large bits."
    },
    {
      "heading": null,
      "description": "Combine the miso paste with 300ml of hot water, whisk until it's dissolved."
    },
    {
      "heading": null,
      "description": "Slowly pour the miso liquid into the mushrooms, mixing well in between so the flour doesn't form lumps."
    },
    {
      "heading": null,
      "description": "Add in the Quorn Pieces and bring to a bubble. Grate in the comté cheese and stir through the crème fraîche, thyme and tarragon."
    },
    {
      "heading": null,
      "description": "Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Pour this into your pie dish and allow it to cool down for 20 mins."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 190°C."
    },
    {
      "heading": null,
      "description": "Cover the pie with the puff pastry, trim the edges and crimp them with your thumb and forefinger."
    },
    {
      "heading": null,
      "description": "Brush with egg yolk and pop into the oven for 30 mins until the pastry is puffed and golden."
    },
    {
      "heading": null,
      "description": "Allow to cool for 30 mins, slice and serve."
    }
  ],
