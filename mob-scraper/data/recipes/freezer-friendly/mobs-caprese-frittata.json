  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Drizzle a generous amount of olive oil into a deep frying pan. Halve your tomatoes and add them to the pan. Give them good stir on a medium heat and allow them to slightly soften."
    },
    {
      "heading": null,
      "description": "Next, chop up your garlic and chilli and add this to the tomatoes and mix together. Add the basil and spinach and allow everything wilt. Add some pepper and a pinch of salt."
    },
    {
      "heading": null,
      "description": "Egg time! Crack your eggs into a bowl, add your milk and some salt and pepper. Whisk it all together until smooth."
    },
    {
      "heading": null,
      "description": "Take half of the tomatoes out of the pan and set aside for later."
    },
    {
      "heading": null,
      "description": "Add three-quarters of the egg mix to the frying pan, making sure it covers the tomatoes. Break up one of your mozzarella balls and distribute it around the pan. Add roughly 5 tbsp of the tomato mixture (leaving some for later)."
    },
    {
      "heading": null,
      "description": "Pour the last of the egg mixture into the pan. Break up the remaining mozzarella ball and distribute it around the pan. Finish with a grinding of pepper, a pinch of salt and good drizzle of olive oil. Place in the oven for 12 minutes."
    },
    {
      "heading": null,
      "description": "Once cooked, take it out of the oven and pour the remaining tomatoes over the top of the frittata. Drizzle a generous amount of balsamic glaze over the top and you are ready to devour this beauty of a dish."
    }
  ],
