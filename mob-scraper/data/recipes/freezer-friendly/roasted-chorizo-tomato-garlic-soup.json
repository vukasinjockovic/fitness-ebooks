  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Grab a baking tray. Add tomatoes, roughly chopped peppers, a whole bulb of garlic and a heaped tablespoon of rosemary leaves along with a glug of oil. Season with salt and pepper and place in the oven for 30 minutes."
    },
    {
      "heading": null,
      "description": "Crumble your chorizo into a frying pan. Cook over a medium heat until crispy. Remove the chorizo and save for the end. Pour the chorizo fat into your roasting vegetable tray, making sure everything is coated. Place the tray back in the oven for another 15 minutes."
    },
    {
      "heading": null,
      "description": "When the vegetables are cooked and caramelised, remove the tray from the oven."
    },
    {
      "heading": null,
      "description": "Pour the vegetables into a large saucepan. Add 500ml of chicken stock, a large handful of basil leaves and red wine vinegar. Bring to a simmer and blitz the soup with a hand blender until smooth."
    },
    {
      "heading": null,
      "description": "Serve with the crispy chorizo scattered on top and a nice hunk of crusty bread."
    }
