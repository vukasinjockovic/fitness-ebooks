  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion and red peppers, then dice the potato."
    },
    {
      "heading": null,
      "description": "Bash the garlic, ginger and red chillies in a pestle and mortar with a big pinch of salt to make a thick paste."
    },
    {
      "heading": null,
      "description": "Add a big glug of oil to a pan and fry off the onions for 10 mins until soft and slightly golden. Add in the tomato purée and cook for 5 mins until it has darkened. Then add the chilli paste and cook for 2 mins until fragrant. Add in the turmeric, allspice and paprika and give it a mix."
    },
    {
      "heading": null,
      "description": "Add in the lamb mince and cook for 10 mins until it’s cooked through."
    },
    {
      "heading": null,
      "description": "Add in the potatoes with 100ml of water and cook for 5 mins just until the potatoes are half cooked."
    },
    {
      "heading": null,
      "description": "Mix in the chopped red peppers."
    },
    {
      "heading": null,
      "description": "Season with salt and pepper, then allow this filling to cool fully in a bowl."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Melt the butter and combine with 150ml of water."
    },
    {
      "heading": null,
      "description": "Brush the butter water mixture over the filo pastry, and lay out 3 sheets in the bottom of a 20cm cake tin. Fill with the lamb mixture and cover the top with more brushed filo pastry."
    },
    {
      "heading": null,
      "description": "Bake in the oven for 30 mins or until the top is golden brown."
    },
    {
      "heading": null,
      "description": "Allow to cool for 10 mins before cutting."
    },
    {
      "heading": null,
      "description": "Slice up and serve warm!"
    }
  ],
