  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Halve the courgette lengthways, then cut into irregular 3cm pieces. Halve the cherry tomatoes. Drain and rinse the chickpeas. Pick the mint leaves. Cut the feta block in half horizontally to make two thin slabs, then cut into triangles."
    },
    {
      "heading": null,
      "description": "Chuck the courgette, tomatoes, chickpeas and olives into a roasting tin. Drizzle with olive oil, season with salt and black pepper, then toss everything together. Nestle in the feta triangles. Slide the tray into the oven and roast for 20 mins, or until the feta is golden and the veg is juicy."
    },
    {
      "heading": null,
      "description": "Take it out of the oven and finish with a drizzle of honey, a scattering of sesame seeds and the fresh mint leaves. Serve straight from the tray."
    }
  ],
