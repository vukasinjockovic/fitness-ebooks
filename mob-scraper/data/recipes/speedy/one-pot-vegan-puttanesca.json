  "method": [
    {
      "heading": null,
      "description": "Finely slice the shallot and mince the garlic."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of oil in a large lidded frying pan or pot set over a medium heat. Add the shallot and sauté for 4-5 mins, then add the garlic, tomato paste, chilli flakes and harissa (or skip the chilli flakes and/or harissa if you prefer it less spicy) and cook for another minute."
    },
    {
      "heading": null,
      "description": "Drain the chickpeas and add to the pot with the tinned tomatoes, olives, capers, artichokes, veg stock cube, balsamic vinegar, pasta and water. Mix to combine and season very well with plenty of salt and pepper."
    },
    {
      "heading": null,
      "description": "Bring to a boil, then reduce the heat to low-medium and leave to simmer for 5 mins with a lid on slightly ajar to let some steam out."
    },
    {
      "heading": null,
      "description": "Give everything a stir and cook for another 10-15 mins with the lid on. Give it another good stir and make sure the pasta is cooked through; most of the water should have been absorbed."
    },
    {
      "heading": null,
      "description": "Toast the pine nuts in a dry frying pan over a low-medium heat until golden and fragrant."
    },
    {
      "heading": null,
      "description": "To serve, divide the pasta between plates and top with some freshly cut chives and a handful of toasted pine nuts."
    }
  ],
