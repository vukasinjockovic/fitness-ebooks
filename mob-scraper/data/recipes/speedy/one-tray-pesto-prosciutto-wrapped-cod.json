  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 210°C. Cut the cod into 4 equal pieces. Season with salt and black pepper, then spread the tops with pesto. Wrap each piece in a slice of prosciutto ."
    },
    {
      "heading": null,
      "description": "Drain the chickpeas and add them to a large roasting tray along with the frozen peppers and cherry tomatoes. Toss everything together gently, and season with salt and pepper then place the cod on top."
    },
    {
      "heading": null,
      "description": "Drizzle over the olive oil, then bake for 10-12 mins, or until the cod is opaque and cooked through."
    },
    {
      "heading": null,
      "description": "Carefully lift the cod and tomatoes out of the tray. Spoon the chickpeas and veg onto plates, top with the cod and finish with an extra drizzle of pesto, if you fancy."
    }
