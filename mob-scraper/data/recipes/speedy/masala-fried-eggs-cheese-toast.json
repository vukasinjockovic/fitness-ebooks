  "method": [
    {
      "heading": null,
      "description": "Grate cheddar and mix with sliced chilli and coriander set aside."
    },
    {
      "heading": null,
      "description": "Dice onion, tomato and a big handful of coriander and set aside."
    },
    {
      "heading": null,
      "description": "Grab a medium-sized pan and get it on a medium heat. Slice your bun in half and butter the bread on both sides. Toast the bun halves, butter-side down, until lightly golden. Flip the bun halves and add the grated cheese on top. Cover with a lid and allow to melt 1-2 mins before removing and setting aside on a different pan. Make sure the pan is not too hot or it will burn the bread."
    },
    {
      "heading": null,
      "description": "Into the same pan you fried your bread, add a tbsp of neutral oil. Add in your onion and cook for 2 mins. Add diced tomato and curry paste and cook for 1 min then a big handful of chopped coriander and toss for an extra minute. Make two wells and crack your eggs on top. Let the aromatics create a crust on the whites and fry until the eggs have set."
    },
    {
      "heading": null,
      "description": "Place eggs on top of your cheesy toast. Add fresh chilli, coriander and a squeeze of lime."
    }
