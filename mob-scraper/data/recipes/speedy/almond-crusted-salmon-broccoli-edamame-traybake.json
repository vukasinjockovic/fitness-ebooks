  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C and line a baking tray with foil."
    },
    {
      "heading": null,
      "description": "Cut the broccoli into small florets. Tip the broccoli and edamame onto the tray, drizzle with olive oil and season with salt and black pepper. Toss everything together to coat."
    },
    {
      "heading": null,
      "description": "Season the salmon fillets with salt and pepper, then spread a teaspoon of Dijon mustard over each fillet."
    },
    {
      "heading": null,
      "description": "Finely chop the almonds and parsley, finely grate the lemon zest and toss it all together, then press onto the mustard-topped salmon."
    },
    {
      "heading": null,
      "description": "Nestle the salmon into the tray with the veg and bake for 10–12 mins, until the salmon is opaque throughout and the broccoli is starting to char. Cut the lemon into wedges for serving"
    },
    {
      "heading": null,
      "description": "To serve, swirl the remaining dijon through the yoghurt and spoon onto plates."
    }
