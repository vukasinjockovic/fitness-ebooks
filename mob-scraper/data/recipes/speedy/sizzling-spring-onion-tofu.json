  "method": [
    {
      "heading": null,
      "description": "Thinly slice the spring onions on a deep diagonal."
    },
    {
      "heading": null,
      "description": "Pour the vegetable oil in a frying pan and heat to 180°C. Fry the spring onions until evenly browned. Strain the oil into a bowl, leaving the spring onions to cool in the sieve. They will crisp up as they cool."
    },
    {
      "heading": null,
      "description": "Roughly chop the garlic and ginger. Deseed and roughly chop the red chilli. Transfer to a mortar and pound with a pestle until a rough paste forms. Once the paste is suitably pounded, transfer it to a heatproof bowl.Add the light soy sauce, dark soy sauce and sugar and mix until the sugar is dissolved."
    },
    {
      "heading": null,
      "description": "Place 60ml of the spring onion oil back into the frying pan. Heat the oil to 180°C. Then, carefully pour it into the sauce and stir to combine. (Cool the remaining oil then store it in a jar for future use. It will keep in the fridge for a month.)"
    },
    {
      "heading": null,
      "description": "Place the silken tofu blocks on a plate. Slice the tofu into 1-2cm slices. Reheat the rice according to package instructions, and pick the coriander leaves, discarding the stems."
    },
    {
      "heading": null,
      "description": "Share the rice between plates and top with silken tofu. Spoon the sauce over and serve with some coriander leaves and sesame seeds."
    }
  ],
