  "method": [
    {
      "heading": null,
      "description": "Add half the feta to a food processor with the yoghurt, mustard, finely grated\ngarlic clove and the zest and juice of the lemon. Whizz until smooth and scoop\nout into the bottom of a big salad bowl."
    },
    {
      "heading": null,
      "description": "Roughly tear the herbs straight into the bowl, cut up the celery into chunky\nslices (on the angle is nice!) and get them in there too."
    },
    {
      "heading": null,
      "description": "Scatter in the lettuce leaves and 2 tbsp of the seeds. Toss to combine, season to\ntaste and get onto a big platter. Finish with the remaining seeds, feta cheese and\na drizzle of olive oil."
    }
  ],
