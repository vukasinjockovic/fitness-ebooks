  "method": [
    {
      "heading": null,
      "description": "Cut the potatoes in half, place them in a pan of cold water and bring it to a boil. Simmer for 15 mins or until cooked."
    },
    {
      "heading": null,
      "description": "Slice the leek in half length ways, then slice into roughly 1cm strips. Wash to get any dirt out."
    },
    {
      "heading": null,
      "description": "Place a frying pan on a medium heat and sweat off the leeks in a glug of olive oil and the butter. Gently cook until softened before adding the garlic and cooking for a couple more mins."
    },
    {
      "heading": null,
      "description": "Add the cream and the white wine and reduce for a few mins until the sauce has thickened and is glossy. Then grate in the parmesan."
    },
    {
      "heading": null,
      "description": "Once the potatoes are cooked, strain them and add them to the creamy leeks. Season with salt and pepper, finish with the chopped parsley and tuck in."
    }
