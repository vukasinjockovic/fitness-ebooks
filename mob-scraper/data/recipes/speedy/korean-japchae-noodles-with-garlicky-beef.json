  "method": [
    {
      "heading": null,
      "description": "Soak the sweet potato noodles in warm water. Drain and set aside."
    },
    {
      "heading": null,
      "description": "Slice the beef into 1 inch strips and set aside any large chunks of fat from the steak (you can use this later for frying). Mix all the marinade ingredients together in a large container and add the beef. Massage the marinade into the meat for 1 min then set aside in the fridge."
    },
    {
      "heading": null,
      "description": "Bring a medium-sized pot of water to a boil. Add all the spinach and cook for 1 min, then use a sieve to remove. Leave to cool then squeeze out all the excess water with your hands. Set aside in a large mixing bowl. In the same boiling water add your eggs and cook for 5 mins (go for a little shorter if you've got smaller eggs), then remove, peel and set aside for later."
    },
    {
      "heading": null,
      "description": "Cook the noodles in the same boiling water following pack instructions then drain and set aside in a large mixing bowl. Add a generous glug of sesame oil and toss well to prevent sticking. Cut the noodles a few times with scissors (this will make them easier to mix later)."
    },
    {
      "heading": null,
      "description": "In the meantime, finely slice the white onion, carrot, bell peppers, and shiitake mushroom into matchsticks, mince the garlic and slice the spring onions into chunks."
    },
    {
      "heading": null,
      "description": "Heat a large pan over a high heat then add a splash of sesame oil along with any leftover pieces of beef fat (if using) and cook until lightly golden. Add the white onions and spring onions with a pinch of salt for 2 mins until lightly charred then tip into the large mixing bowl with the noodles."
    },
    {
      "heading": null,
      "description": "Next add the bell peppers and carrots to the pan and cook for another minute, adding a splash more sesame oil if needed. Cook just until lightly charred then tip into the large mixing bowl with the noodles and other veggies."
    },
    {
      "heading": null,
      "description": "Heat up the same pan with a splash of sesame oil. Add the mushrooms and cook for 2 mins until golden."
    },
    {
      "heading": null,
      "description": "Add the beef and its marinade to the pan, give it a quick toss and then lay each piece of beef flat against the pan. Cook for a minute on each side then turn off the heat."
    },
    {
      "heading": null,
      "description": "Add the beef and mushrooms to the bowl with the noodles and veggies and toss well to combine. Add the rice vinegar to the hot pan to deglaze it then scrape all the juices into the mixing bowl."
    },
    {
      "heading": null,
      "description": "To make the noodle sauce, crush the garlic and mix all the ingredients together in a medium bowl. Then add this sauce to the large mixing bowl with the noodles, veggies and beef. Toss very well, using tongs or clean/gloved hands."
    },
    {
      "heading": null,
      "description": "Divide between bowls and top with the sesame seeds. Serve with lettuce cups, boiled eggs and kimchi, if you like."
    }
  ],
