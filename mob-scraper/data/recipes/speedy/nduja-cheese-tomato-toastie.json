  "method": [
    {
      "heading": null,
      "description": "Place a frying pan over a medium heat, add the ‘nduja and a splash of olive oil. Cook for a minute until the 'nduja melts."
    },
    {
      "heading": null,
      "description": "Slice the tomatoes into 1cm thick rounds and then fry for a minute either side in the pan with the ‘nduja."
    },
    {
      "heading": null,
      "description": "Pop the cooked tomatoes onto 4 slices of bread and pour over the melted 'nduja. Season with a pinch of salt and the oregano."
    },
    {
      "heading": null,
      "description": "Grate over the Cheddar and top with the remaining slices of bread."
    },
    {
      "heading": null,
      "description": "Place the sandwiches back into the same pan over a medium heat and cook for about 4 mins on each side until the outside is golden brown and the cheese is melted."
    },
    {
      "heading": null,
      "description": "Plate up and serve hot. Enjoy!"
    }
