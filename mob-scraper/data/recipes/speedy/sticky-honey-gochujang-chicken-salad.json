  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Add the chicken breasts to a baking tray, drizzle with the olive oil and season with salt and black pepper. Roast for 20 minutes, until cooked through, then remove and leave to cool slightly before shredding into bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Bring a pan of well-salted water to the boil. Halve the tenderstem broccoli and cook for 4 minutes, until just tender. Drain and leave to steam dry and cool. Meanwhile, cook the rice according to the packet instructions."
    },
    {
      "heading": null,
      "description": "Halve the cucumber lengthways and cut into chunky, irregular pieces. Roughly crush the peanuts. Pick the coriander and mint leaves."
    },
    {
      "heading": null,
      "description": "Now for the dressing. Peel and finely grate in the garlic into a bowl, then add the honey, gochujang, rice vinegar, sesame oil, soy sauce, water and sesame seeds. Whisk until everything's smooth and glossy."
    },
    {
      "heading": null,
      "description": "Add the chicken, rice, broccoli, cucumber, herbs and peanuts to a large bowl. Pour over the dressing and toss everything together until well coated. Taste and season with a little salt if needed, then serve."
    }
  ],
