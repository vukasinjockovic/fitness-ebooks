  "method": [
    {
      "heading": null,
      "description": "Finely chop your dark chocolate, then rim your martini glass with the sauce and dunk it in the chocolate shavings to create a double chocolate rim."
    },
    {
      "heading": null,
      "description": "Using the sauce create a swirl pattern, or go artistic and make any pattern you like, on the inside of the glass."
    },
    {
      "heading": null,
