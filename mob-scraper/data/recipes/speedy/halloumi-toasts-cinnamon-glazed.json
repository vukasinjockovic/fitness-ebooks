  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C and add the walnuts to a baking tray. Cook for 8-10 mins until golden and toasty. In the meantime, dice the halloumi into 2cm pieces. Mix the halloumi with the cinnamon, ground coriander and 2 tsp cumin, then zest in the lemon, setting aside for later."
    },
    {
      "heading": null,
      "description": "For the red pepper spread, add drained roasted red peppers to a blender along with 200g of your toasted walnuts, ½ tsp of cumin, garlic and the juice of 1 lemon. Blend until smooth, then taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Toast the bread and pick the parsley leaves. Heat a frying pan over a medium heat with 2 tbsp of olive oil, add the halloumi, cooking on both sides for 2-3 mins until nice and golden, before adding the honey and tossing to coat. Spread the roasted pepper mixture onto the toast and top with the halloumi. Drizzle with extra honey, scatter with parsley."
    }
