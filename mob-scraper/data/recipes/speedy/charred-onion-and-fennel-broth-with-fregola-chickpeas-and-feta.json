  "method": [
    {
      "heading": null,
      "description": "Trim and peel the onions but leave the root on and cut each one into 8 wedges."
    },
    {
      "heading": null,
      "description": "Add a splash of olive oil to a large saucepan over a medium-high heat and add the onion wedges in a single layer. Cook until very golden/slightly charred on each side."
    },
    {
      "heading": null,
      "description": "Roughly chop and add the fennel, fennel seeds and garlic cloves. Cook for a few minutes until starting to soften, then pour in the chicken stock and bay leaves."
    },
    {
      "heading": null,
      "description": "Bring to a simmer, then add the fregola and cook for about 10 mins. Drain and add the chickpeas and the parsley, basil and mint all roughly chopped (you can keep a pinch of the herbs aside for garnish). Cook for another 2 mins."
    },
    {
      "heading": null,
      "description": "Taste and season with salt, squeeze in the lemon juice and then spoon into bowls. Top with the remaining herbs, crumble over the feta and finish with a drizzle of olive oil and grind of black pepper."
    }
  ],
