  "method": [
    {
      "heading": null,
      "description": "Trim and finely slice the cabbage and chilli, pick the basil leaves and halve your tomatoes."
    },
    {
      "heading": null,
      "description": "Set a saucepan over a medium heat, and drizzle in a lug of olive oil, add the prawns and cook for 2 mins. Add the chilli and cook for another 2 mins. Add the garlic puree and cook for 1 more minute. Remove from the pan."
    },
    {
      "heading": null,
      "description": "Add your sliced cabbage, tomatoes, lentils, pickled onions, basil leaves and the cooked garlic and chilli prawns to a large bowl and toss together. Sprinkle with salt and pepper to season and mix again."
    },
    {
      "heading": null,
      "description": "Dress the salad with a splash of the pickled onion brine, and a little more oil to taste. Share onto a large platter or individual plates. Get stuck in!"
