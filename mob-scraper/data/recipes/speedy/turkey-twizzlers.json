  "method": [
    {
      "heading": null,
      "description": "Get a pan of water on to the boil, then pop the sausages in, Cooking for 1 min until just set. Drain and steam dry, before skewering through the middle vertically. Using a small knife, cut around the sausage from top to bottom to create a spiral (take care not to cut all the way through, as the sausage should still be intact), then spread the sausage out a bit."
    },
    {
      "heading": null,
      "description": "Whisk the eggs on a shallow plate. Tip the flour, mustard powder, garlic powder, onion powder, smoked paprika and some salt and pepper onto another shallow plate. Add the breadcrumbs to a third plate. Dip the skewers into the flour, making sure to get it in all the gaps, then roll in the egg (drain off the excess), before rolling in the breadcrumbs."
    },
    {
      "heading": null,
      "description": "Heat an air-fryer to 200°C and add the skewers. Cook for 12-15 mins. Serve with potato smileys and a big blob of ketchup."
    }
  ],
