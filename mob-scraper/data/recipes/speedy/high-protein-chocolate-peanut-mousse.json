  "method": [
    {
      "heading": null,
      "description": "Finely chop the chocolate and add to a microwave-safe bowl. Melt the chocolate pieces in the microwave in 30-second bursts, taking the bowl out and stirring after each burst to get rid of any lumps. Set aside to cool slightly."
    },
    {
      "heading": null,
      "description": "Add the silken tofu, cottage cheese, peanut butter, cocoa powder, maple syrup and vanilla to a blender. Zest in the peel of the orange and add a pinch of salt, then blitz until smooth. Add the melted, cooled dark chocolate and the protein powder, if using, and blitz again."
    },
    {
      "heading": null,
      "description": "Pour the mixture into a small baking dish or individual ramekins."
    },
    {
      "heading": null,
      "description": "Serve immediately, or leave in the fridge to set overnight if you prefer a thicker texture. Top with greek yoghurt, cherries, olive oil or granola, if you like."
    }
  ],
