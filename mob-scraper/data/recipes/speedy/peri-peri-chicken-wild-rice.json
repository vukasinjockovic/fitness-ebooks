  "method": [
    {
      "heading": null,
      "description": "Get two large frying pans over a high heat and add a knob of\nbutter to each along with a splash of oil. Season the chicken fillets\nwith salt and black pepper and chuck into one of the pans. Fry for\n4 mins, stirring occasionally."
    },
    {
      "heading": null,
      "description": "Meanwhile, crush the unpeeled garlic cloves into the other pan,\nstir and cook for 30 seconds. Squeeze the unopened wild rice\npouches with your hands to break up the grains, then open and\ntip the rice into the pan with the garlic. Open and empty in the\ntin of sweetcorn with its juices and add the kale. Season with salt,\npepper and chilli flakes to taste. Leave to heat through."
    },
    {
      "heading": null,
      "description": "Back to the chicken. Pour in the peri peri sauce and cook,\noccasionally basting the chicken with the sauce, for 2 more\nmins until the chicken is cooked through."
    },
    {
      "heading": null,
      "description": "Cut the lime into four wedges."
    },
    {
      "heading": null,
      "description": "Divide the rice between four bowls and top with the peri peri\nchicken. Add a lime wedge to each bowl and tear over some\ncoriander to serve."
    }
  ],
