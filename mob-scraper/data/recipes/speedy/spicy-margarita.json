  "method": [
    {
      "heading": null,
      "description": "Cut a small wedge of lime and rub it on the rim of your glass to help the salt and chilli flakes stick. Juice the rest of the lime and set aside."
    },
    {
      "heading": null,
      "description": "Cut 4 slices of the jalapeño."
    },
    {
      "heading": null,
      "description": "On a small plate, sprinkle the salt and chilli flakes in a circle the same circumference as your glass."
    },
    {
      "heading": null,
      "description": "Rub the rim of your glass gently in the chilli salt, fill it with ice and then set it aside."
    },
    {
      "heading": null,
      "description": "Add a handful of ice, the tequila, Cointreau, sliced jalapeño and lime juice to your cocktail shaker."
    },
    {
      "heading": null,
      "description": "Shake hard for 20 seconds."
    },
    {
      "heading": null,
      "description": "Double strain into your glass and garnish with a slice of chilli."
