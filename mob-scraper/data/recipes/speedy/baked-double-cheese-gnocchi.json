  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Place a large saucepan over a medium heat, add the butter and when it begins to foam, add the flour and whisk well. Cook for about a minute until lightly golden."
    },
    {
      "heading": null,
      "description": "Now slowly pour in the milk, whisking constantly until smooth. Finely chop and add the sage and grate in the parmesan and gruyere."
    },
    {
      "heading": null,
      "description": "Mix until the cheese has melted and then add the nutmeg and grind in a generous amount of black pepper. Taste and add salt as needed."
    },
    {
      "heading": null,
      "description": "Now, if you’re using the soft fresh gnocchi from the fridge in the supermarket you can go ahead and add it straight into the creamy sauce. If using dried, cook it first, drain and add."
    },
    {
      "heading": null,
      "description": "Give it all a good stir and then pour into a baking dish and bake in the oven for about 20 mins until bubbling and golden brown."
    },
    {
      "heading": null,
      "description": "Serve hot, great with a little green salad on the side."
    }
