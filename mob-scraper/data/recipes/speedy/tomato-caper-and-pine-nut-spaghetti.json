  "method": [
    {
      "heading": null,
      "description": "Toast your pine nuts in a dry frying pan until golden. Set aside until later."
    },
    {
      "heading": null,
      "description": "Slice your garlic and finely chop your parsley, including your stalks. Halve your cherry tomatoes."
    },
    {
      "heading": null,
      "description": "Bring a large pot of water to a boil. Salt generously, then add your spaghetti. Cook until al dente."
    },
    {
      "heading": null,
      "description": "Heat a sauté pan over a medium heat. Add a glug of olive oil, then tip in your sliced garlic, chilli flakes and parsley stalks. Fry over a gentle heat for a couple of mins until your garlic is fragrant, but not yet changing colour."
    },
    {
      "heading": null,
      "description": "Add your cherry tomatoes to the pan and simmer for 3 mins, breaking up with the back of your spoon as you go."
    },
    {
      "heading": null,
      "description": "Tip in your raisins, capers and red wine vinegar, then stir to combine."
    },
    {
      "heading": null,
      "description": "Ladle some pasta water from the pot into your veg pan and let it bubble up."
    },
    {
      "heading": null,
      "description": "Add your spaghetti and toss until evenly coated, adding more pasta water until you have a glossy emulsion which coats your pasta. Sprinkle in your parsley leaves and add your pine nuts back to the pan. Season with salt, then give it one last mix."
    },
    {
      "heading": null,
      "description": "Serve and enjoy."
    }
  ],
