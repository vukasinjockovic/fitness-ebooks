  "method": [
    {
      "heading": null,
      "description": "Boil your green beans in water until soft, drain, and then allow to cool."
    },
    {
      "heading": null,
      "description": "Chop and discard the heads off the pickled guindilla chillies. Add your beans to a chopping board along with your tuna and chillies and roughly chop them up."
    },
    {
      "heading": null,
      "description": "Add in your capers and continue to chop."
    },
    {
      "heading": null,
      "description": "Add all of your chopped ingredients to a bowl and squeeze in the juice from your lemons. Add in a good glug of olive oil and season generously with salt and pepper."
    },
    {
      "heading": null,
      "description": "Divide the salad between Tupperware containers and box up. Pop in the fridge until needed - these will keep for up to 3 days."
    }
