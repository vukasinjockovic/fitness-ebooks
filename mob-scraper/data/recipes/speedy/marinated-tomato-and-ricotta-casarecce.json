  "method": [
    {
      "heading": null,
      "description": "Finely chop your tomatoes, then add them to a bowl. Grate in your garlic clove and lemon zest, then add the juice of ½ your lemon, 2 tbsp olive oil and a pinch of salt. Leave them to sit at room temperature."
    },
    {
      "heading": null,
      "description": "Bring a large pan of water to a boil. Salt it well."
    },
    {
      "heading": null,
      "description": "Pour your pasta into your water and cook it until al dente."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop your dill."
    },
    {
      "heading": null,
      "description": "Add your ricotta to a bowl along with 2 tbsp olive oil and then grate in your parmesan. Give it a good whisk until it is totally smooth."
    },
    {
      "heading": null,
      "description": "When your pasta is cooked, add a ladle of your pasta water to the ricotta mix, and whisk until it comes together."
    },
    {
      "heading": null,
      "description": "Drain your pasta, then combine with your ricotta, tomatoes and herbs. Give it a good mix."
    },
    {
      "heading": null,
      "description": "Spoon into bowls and finish with some more fresh herbs and some black pepper. Serve and enjoy!"
    }
  ],
