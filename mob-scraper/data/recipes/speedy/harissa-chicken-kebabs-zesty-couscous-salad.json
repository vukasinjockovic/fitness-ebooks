  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 220°C. \nIf using wooden skewers, soak them in water to stop them catching under the grill."
    },
    {
      "heading": null,
      "description": "Chop the chicken into 3cm chunks and chuck into a bowl. Grate in the garlic and stir through the Al'Fez Harissa Paste. Season with salt and pepper, then thread the chicken onto skewers. Drizzle a little olive oil onto a baking tray, arrange the skewers on top and roast for 10–15 mins, until cooked through and golden."
    },
    {
      "heading": null,
      "description": "Tip the Al'Fez Moroccan Spiced Couscous into a bowl, pour over the boiling water and cover with a plate or lid. Let it steam for 5 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, halve the olives. Drain the peppers and finely chop. Chop the cherry tomatoes into 2cm chunks (halve the small ones). Thinly slice the red onion. Add the onion to a large bowl with the red wine vinegar and a pinch of salt. Give it a toss and set aside to pickle."
    },
    {
      "heading": null,
      "description": "Pick the parsley leaves, discarding the stalks. Then fluff the couscous with a fork, then chuck the chopped tomatoes, peppers and olives into the pickled onion bowl."
    },
    {
      "heading": null,
      "description": "Just before serving, toss the parsley through the couscous along with the contents from pickled onion bowl. Season to taste. Spoon the couscous salad into bowls and top with the harissa chicken and a dollop of yoghurt and get stuck in!"
    }
  ],
