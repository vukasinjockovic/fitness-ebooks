  "method": [
    {
      "heading": null,
      "description": "Chop up the bacon into 3cm pieces and mince the garlic. Grate your Parmesan."
    },
    {
      "heading": null,
      "description": "Add the bacon to a large frying pan set over a medium-high heat. Fry until golden brown and very crispy. Take out ¼ of the crispy bacon and reserve for later."
    },
    {
      "heading": null,
      "description": "Add the chopped garlic to the bacon pan and cook for 1 min until fragrant. Add in the spinach and cook for a further 2 mins until the spinach has wilted."
    },
    {
      "heading": null,
      "description": "Pour in 400ml of water and bring it to a simmer. Add your gnocchi and simmer for 5 mins. Add in your mascarpone and pesto. Grate in the parmesan. Give it a good stir so that the mascarpone melts and the sauce is hot. Season with black pepper to taste."
    },
    {
      "heading": null,
      "description": "Sprinkle with the reserved crispy bacon and more Parmesan to serve. Enjoy."
    }
