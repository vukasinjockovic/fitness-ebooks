  "method": [
    {
      "heading": null,
      "description": "Finely slice onion, red chilli and garlic. Set them aside."
    },
    {
      "heading": null,
      "description": "Add 1 part rice to 2 parts boiling water. Cook until the water has been absorbed."
    },
    {
      "heading": null,
      "description": "Put a wok or a large frying pan on the heat. Add a splash of vegetable oil and add the ground chicken. Break it up into lots of little pieces with a spatula ."
    },
    {
      "heading": null,
      "description": "Once the chicken has turned white, add your chilli, garlic, onion and lemongrass puree. Mix them in."
    },
    {
      "heading": null,
      "description": "Once they have softened, add a tbsp and a half of fish sauce, soy sauce, and sugar. Mix it all in."
    },
    {
      "heading": null,
      "description": "Once the sugar has dissolved, pour in 150ml of water. Simmer it down for 30 seconds. Throw in your basil."
    },
    {
      "heading": null,
      "description": "Allow the basil to wilt. Cook the chicken until the water has evaporated."
    },
    {
      "heading": null,
      "description": "Remove the wok from the heat and set on a board."
    },
    {
      "heading": null,
      "description": "Serve the chicken on top of the steaming hot basmati rice. Enjoy!"
    }
  ],
