  "method": [
    {
      "heading": null,
      "description": "Thinly slice the onion and chuck it into a bowl of ice-cold water. Leave it to crisp up while you crack on with everything else. Bash the ginger with the side of your knife and gently crush the cardamom pods."
    },
    {
      "heading": null,
      "description": "Place a saucepan over a medium-high heat and toast the star anise and cardamom for about a minute until fragrant. Add the ginger and a small drizzle of olive oil. Let it sizzle for 30 seconds, then pour in the beef stock. Bring to the boil, turn the heat down and leave to gently simmer."
    },
    {
      "heading": null,
      "description": "Place a frying pan over a high heat with a drizzle of olive oil. Add the beef mince and cook, breaking it up, until well browned and starting to crisp."
    },
    {
      "heading": null,
      "description": "Mix the oyster sauce, sugar, sriracha, beef stock, soy sauce and rice vinegar together in a small bowl. Pour the sauce into the pan with the beef and let it bubble and reduce until sticky and caramelised, taste and season with salt and pepper if needed. Then finish by stirring through the butter."
    },
    {
      "heading": null,
      "description": "Divide the hot rice between bowls. Just before serving, season the broth with lime juice and fish sauce, to taste. Ladle over the hot broth onto the rice, then top with the beef."
    },
    {
      "heading": null,
      "description": "Serve with the sliced onion, coriander and sliced red chilli, and some extra lime wedges on the side if you fancy some more zing. Dig in!"
    }
  ],
