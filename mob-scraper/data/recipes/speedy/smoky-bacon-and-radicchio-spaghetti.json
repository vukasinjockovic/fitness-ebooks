  "method": [
    {
      "heading": null,
      "description": "Finely chop your red onion. Finely slice your radicchio and your streaky bacon."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium heat with a little olive oil. Get your streaky bacon in the pan and fry for 5 mins until the fat has rendered and the bacon is starting to crisp up."
    },
    {
      "heading": null,
      "description": "Add your onion and cook for 15 mins until softened. Tip in your radicchio and cook for 5 mins more until everything is lovely and caramelised. Tip in your wine and allow it to bubble down and reduce a little."
    },
    {
      "heading": null,
      "description": "Get a large pan of water on to boil. Salt generously, then add your Napolina Spaghetti and cook according to packet instructions."
    },
    {
      "heading": null,
      "description": "Lift the spaghetti out of the water and into the bacon pan. Add a little pasta water and mix until your sauce has emulsified a little and the pasta looks glossy. Add more pasta water until you get the desired consistency, then season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Tong your pasta onto plates, then finish with a sprinkle of parmesan and a drizzle of olive oil. Serve and enjoy."
    }
  ],
