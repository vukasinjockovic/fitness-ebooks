  "method": [
    {
      "heading": null,
      "description": "Bash your lemongrass and peel off the excess woody bits. Roughly chop the rest. Roughly chop your chillies and garlic."
    },
    {
      "heading": null,
      "description": "Add your lemongrass, chillies and garlic to a pestle and mortar and bash to a paste."
    },
    {
      "heading": null,
      "description": "Zest in your lime and add the juice of half. Add your fish sauce and sugar, then continue bashing until you have a purée situation."
    },
    {
      "heading": null,
      "description": "Place a box grater in a bowl. Halve your tomatoes, then grate with the cut side on the coarsest setting - you should just be left with the skins."
    },
    {
      "heading": null,
      "description": "Add your lemongrass paste to your tomatoes along with a generous pinch of salt, then mix to combine."
    },
    {
      "heading": null,
      "description": "Set a sieve over a bowl and pour your tomato mix into it. Leave to sit for a minute to strain off any excess water."
    },
    {
      "heading": null,
      "description": "Heat a skillet pan over a medium-high heat. Drizzle your pan with olive oil, then add your bread. Toast for a few mins on each side until it is deeply crispy."
    },
    {
      "heading": null,
      "description": "Spoon your tomato mix over your toast, then top with coriander leaves and crispy shallots. Serve and enjoy!"
    }
  ],
