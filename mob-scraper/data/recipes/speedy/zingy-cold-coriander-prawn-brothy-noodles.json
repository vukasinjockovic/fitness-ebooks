  "method": [
    {
      "heading": null,
      "description": "Pick ¼ of the coriander leaves and set them aside. Thinly slice the red onion and one jalapeño. Chuck them into a bowl of ice water with the picked coriander leaves and let them chill."
    },
    {
      "heading": null,
      "description": "Add the miso, garlic, cucumber, avocado, cold water (you can substitute half of the water with ice cubes if you’ve got a good blender), the rest of the coriander (stalks and all) and the remaining jalapeños to a blender. Blitz until smooth. Season with lime juice, salt and black pepper. Pour into an airtight container and chill in the fridge or freezer until properly cold."
    },
    {
      "heading": null,
      "description": "Cook the rice noodles following pack instructions, then rinse under cold water until totally cool."
    },
    {
      "heading": null,
      "description": "Drain the coriander and onion. Toss with the prawns, sliced jalapeño, a good squeeze of lime and a drizzle of olive oil."
    },
    {
      "heading": null,
      "description": "Divide the noodles between bowls. Pour over the cold broth and top with the zingy prawn salad. Eat straight away while cold."
    }
  ],
  "tips": [
    "Want it milder? Swap some jalapeños for green peppers.",
