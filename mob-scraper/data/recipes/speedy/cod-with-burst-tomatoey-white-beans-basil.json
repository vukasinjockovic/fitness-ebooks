  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Halve the cherry tomatoes. Drain and slice the roasted peppers. Drain and rinse the white beans. Slice the basil and set aside."
    },
    {
      "heading": null,
      "description": "Lay out a large rectangle of baking paper in front of you (per person), portrait. Add the beans, cherry tomatoes, roasted peppers, red wine vinegar, olives and olive oil to the bottom half of the baking paper, leaving a 10cm gap between the food and the edge closest to you. Season with salt and black pepper, then give it all a gentle mix. Pat the cod fillets dry and lay them on top of the veg. Season with a little more salt and pepper."
    },
    {
      "heading": null,
      "description": "Fold the top half of the baking paper over the food then fold the outside edges over each other to seal (like a cornish pasty), creating a steam-tight parcel."
    },
    {
      "heading": null,
      "description": "Bake for 15–18 mins, until the cod is cooked through and flakes easily."
    },
    {
      "heading": null,
      "description": "Remove from the oven, open the parcel and remove the cod onto plates. Mix the basil through the veg and serve up."
    }
  ],
