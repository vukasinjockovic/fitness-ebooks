  "method": [
    {
      "heading": null,
      "description": "Squeeze the sausage meat out of the sausages and form into little balls. Splash some olive oil into a frying pan, add the balls and fry until browning. Add a sliced garlic clove and a teaspoon of chilli flakes."
    },
    {
      "heading": null,
      "description": "After 20 seconds, add your kale. Add a small splash of water and cook for 5 minutes until the kale has wilted."
    },
    {
      "heading": null,
      "description": "Place your gnocchi in a bowl and cover with boiling water. Leave for 5 minutes."
    },
    {
      "heading": null,
      "description": "Add your ricotta to the sauce and mix it in. Add 4 or 5 tablespoons of the starchy gnocchi water. Season with salt and pepper and mix everything together."
    },
    {
      "heading": null,
      "description": "Drain the gnocchi and add to a baking dish. Place the kale sausage mix on top of the gnocchi and mix together. Top the gnocchi with thin slices of taleggio and add another tsp of chilli flakes."
    },
    {
      "heading": null,
      "description": "Place under the grill for 10 minutes or until golden and bubbling. Dole out and enjoy!"
    }
  ],
