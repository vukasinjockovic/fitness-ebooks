  "method": [
    {
      "heading": null,
      "description": "Heat the olive oil in a medium-sized saucepan over a medium-low heat and grate in the garlic, cook for 1 min. Then add the peas and spinach and pour in the vegetable stock."
    },
    {
      "heading": null,
      "description": "Bring to a boil, then reduce to a simmer for 5 mins, until the veg is tender. Using a stick blender, blitz the soup until smooth, then stir through the pesto and squeeze in the juice of half a lemon. Finely chop the chives."
    },
    {
      "heading": null,
      "description": "Pour the soup into bowls and top with ham hock, a scattering of chives and a drizzle of cream if you have it."
