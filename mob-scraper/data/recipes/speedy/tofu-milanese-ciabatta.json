  "method": [
    {
      "heading": null,
      "description": "Cut your ciabattas in half and toast cut side down in a dry frying pan."
    },
    {
      "heading": null,
      "description": "Slice each tofu block into 6 thin slices."
    },
    {
      "heading": null,
      "description": "Mix your flour, oat milk and 4 tbsp Sacla Vegan Pesto in a bowl until it forms a thick batter. Pour your panko breadcrumbs into a separate bowl."
    },
    {
      "heading": null,
      "description": "Dip a tofu slice into your batter, then straight into the breadcrumbs so that it is fully coated. Repeat with your remaining tofu slices."
    },
    {
      "heading": null,
      "description": "Heat a good glug of vegetable oil in a frying pan over a medium-high heat. Add your tofu slices and fry for 3 minutes on each side until crispy and golden. Remove from the pan and drain on a plate lined with paper towel."
    },
    {
      "heading": null,
      "description": "Mix your remaining pesto with your vegan mayo in a bowl."
    },
    {
      "heading": null,
      "description": "Slice your tomatoes and drain your jarred red peppers, patting dry with some paper towel if they feel a little wet."
    },
    {
      "heading": null,
      "description": "Assembly time. Spread the base of your ciabatta with your pesto mayo, then top with your crispy tofu, red peppers, sliced tomato and rocket. Top with the other side of your bread, then serve."
    }
  ],
