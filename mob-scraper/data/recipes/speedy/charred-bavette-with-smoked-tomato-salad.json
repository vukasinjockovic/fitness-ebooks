  "method": [
    {
      "heading": null,
      "description": "Preheat the air fryer to 230°C."
    },
    {
      "heading": null,
      "description": "Season the steak with salt and pepper and rub it with a little olive oil. Coarsely grind the fennel seeds and sprinkle over the steaks with the chilli flakes. Set aside."
    },
    {
      "heading": null,
      "description": "Make the dressing by peeling the charred skin from the chillies, finely chop and add to a bowl with the sherry vinegar, honey and olive oil. Mix to combine then season well."
    },
    {
      "heading": null,
      "description": "Now, cook the steaks on the Ninja grill until they hit 47°C for a perfect medium. Remove the steak off the grill and rest for 5-6 mins."
    },
    {
      "heading": null,
      "description": "While the steaks rest, toss the tomatoes with some olive oil and salt and add to the grill. If smoking, add some pellets to the smoke box and use the smoke function to grill and smoke the tomatoes for 10 mins, otherwise just grill as normal."
    },
    {
      "heading": null,
      "description": "Peel the charred skin from the shallots and roughly chop up the flesh. Tip into a bowl with the smoky tomatoes, roughly chopped roasted peppers, rocket and freshly picked basil leaves. Toss with half of the dressing and salt and pepper. Tip onto a platter."
    },
    {
      "heading": null,
      "description": "Carve the steaks against the grain and serve over top of the salad. Top with the remaining dressing, more basil leaves and shaved Parm."
    }
  ],
