  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 220°C. Core the peppers and slice into strips. Peel and thinly slice the onions. Slice the chicken breasts into thin strips."
    },
    {
      "heading": null,
      "description": "Chuck everything onto a large baking tray lined with foil, drizzle with olive oil and scatter over the taco seasoning. Toss well to coat evenly. Slide the tray into the oven and roast for 15–20 mins, until the chicken is cooked through and the veg is soft and golden at the edges."
    },
    {
      "heading": null,
      "description": "Meanwhile, warm the tortillas following the pack instructions. Grate your cheddar and shred the lettuce."
    },
    {
      "heading": null,
      "description": "To serve, pile the chicken and veg into the tortillas and load up with sour cream, guacamole, lettuce and cheese, or any other toppings you fancy."
    }
