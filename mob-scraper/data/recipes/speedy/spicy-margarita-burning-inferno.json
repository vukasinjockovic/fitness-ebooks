  "method": [
    {
      "heading": null,
      "description": "Finely slice your jalapeño and juice a lime, saving a slice for garnish."
    },
    {
      "heading": null,
      "description": "In a pan add your water and sugar and gently heat until the sugar is dissolved. Then add ½ of your jalapeño and simmer on a low heat for 3 mins."
    },
    {
      "heading": null,
      "description": "Fill a cocktail shaker half way with ice, then add your vodka, lime juice, 25ml of your jalapeño-infused sugar syrup, triple sec and Tabasco."
    },
    {
      "heading": null,
      "description": "Shake for 5-7 seconds until all the ingredients are combined."
    },
    {
      "heading": null,
      "description": "Double strain into a glass filled with large ice cubes."
    },
    {
      "heading": null,
      "description": "Garnish with remaining jalapeño and lime slice. Enjoy."
