  "method": [
    {
      "heading": null,
      "description": "Finely chop your onion and garlic. Grate your parmesan."
    },
    {
      "heading": null,
      "description": "Heat a sauté pan over a medium heat with a glug of olive oil. Tip in your onion and fry for 15 mins until totally soft."
    },
    {
      "heading": null,
      "description": "Add your garlic and chilli flakes, then cook out for a minute. Add all your tomato purée and cook for about 5 mins. It should get nice and dark, and begin sticking to the bottom of your pan."
    },
    {
      "heading": null,
      "description": "Pour in the vodka and scrape the base of the pan to deglaze it, then add your cream."
    },
    {
      "heading": null,
      "description": "Heat your grill to high."
    },
    {
      "heading": null,
      "description": "Bring a large pan of salted water to a boil, then tip in your gnocchi. Cook until it rises to the surface, this should take about 2 mins."
    },
    {
      "heading": null,
      "description": "Lift your gnocchi into the saucepan with a slotted spoon, then add in 3/4 of your cheese and a splash of gnocchi cooking water to loosen. Season to taste with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Tip your mixture into a baking dish, then add your basil and tear over your mozzarella. Sprinkle over your remaining parmesan, then pop your dish under the grill. Grill for about 5 mins until bubbly and golden."
    },
    {
      "heading": null,
      "description": "Grind your black pepper over the top. Serve and enjoy."
    }
  ],
