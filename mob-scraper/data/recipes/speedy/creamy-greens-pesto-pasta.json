  "method": [
    {
      "heading": null,
      "description": "Boil some water in a saucepan, add a generous amount of salt, then tip in the pasta and broccoli. After 3 mins, scoop out the broccoli and transfer to a food processor. Allow the pasta to continue cooking in the boiling water."
    },
    {
      "heading": null,
      "description": "Juice the lemon into a food processor and add all of the remaining ingredients (except the pasta), along with 150ml pasta water. Blitz until smooth."
    },
    {
      "heading": null,
      "description": "Drain the pasta once it’s al dente (just about cooked but still a little firm), reserving some of the pasta water in case you need a little extra to thicken up the sauce."
    },
    {
      "heading": null,
      "description": "Pour the sauce into the saucepan and stir through the pasta. Cook over a low heat for a few more minutes until the pasta is at the desired tenderness and the sauce is hot."
    },
    {
      "heading": null,
      "description": "Plate up and sprinkle over some Parmesan shavings."
    }
  ],
