  "method": [
    {
      "heading": null,
      "description": "Peel and slice the red onion and add it to a large mixing bowl. Pour in the red wine vinegar, add the dried oregano, capers and olive oil, then season with salt and pepper. Whisk everything together to make a punchy dressing."
    },
    {
      "heading": null,
      "description": "Finely chop the mint and stir it through the dressing."
    },
    {
      "heading": null,
      "description": "Drain and rinse the lentils and butter beans, then chuck them into the bowl and toss well to coat."
    },
    {
      "heading": null,
      "description": "Drain the tuna and crumble the feta."
    },
    {
      "heading": null,
      "description": "Serve up the salad into Tupperware containers and top with the tuna and feta. Finish with a crack of black pepper. Box up and pop in the fridge, ready for when you need it. These keep for 3 days in the fridge."
    }
  ],
