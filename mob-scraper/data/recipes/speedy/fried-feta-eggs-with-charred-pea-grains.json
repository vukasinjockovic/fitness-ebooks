  "method": [
    {
      "heading": null,
      "description": "Defrost the peas and drain off any excess water."
    },
    {
      "heading": null,
      "description": "Heat a large frying pan over a high heat. Once hot, chuck in the peas and leave them to char for 2-3 mins until smoky and blistered. Add the grains, spinach and half of the pumpkin seeds. Stir through the garlic purée and cook everything together for a few mins, until the spinach has wilted. Season with salt."
    },
    {
      "heading": null,
      "description": "Meanwhile, crumble the feta. Heat a drizzle of olive oil in another frying pan over a medium-high heat. Once hot, scatter in the feta, then crack the eggs straight on top. Let them cook for a few mins until the whites are set and the feta is golden and crispy around the edges. Season with salt and plenty of black pepper."
    },
    {
      "heading": null,
      "description": "Zest the lemon, then cut it into wedges. Then spoon the pea grain mix onto plates. Top with the feta eggs, grate over the lemon zest and finish with a sprinkle of chilli flakes. Serve with a lemon wedge on the side."
    }
  ],
