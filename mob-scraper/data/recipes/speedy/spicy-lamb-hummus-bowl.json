  "method": [
    {
      "heading": null,
      "description": "Get a large frying pan over a super high heat and drizzle in a splash of oil. Tip in the minced lamb and use the back of a\nwooden spoon to break up the meat into small chunks. Fry,\nstirring occasionally, for about 8 minutes until all the water has\nevaporated and the mince is getting brown and crisp."
    },
    {
      "heading": null,
      "description": "Meanwhile, cut and deseed the peppers and cut the cucumber\ninto rough finger-sized crudités and put on a serving plate. Spoon\nboth tubs of hummus into one large serving bowl."
    },
    {
      "heading": null,
      "description": "Back to the lamb. Add the harissa and season with salt and\nblack pepper. Give everything a good mix and then leave to cook\nfor a few minutes more."
    },
    {
      "heading": null,
      "description": "Toast the flatbreads while you are waiting."
    },
    {
      "heading": null,
      "description": "Tip the lamb on top of the hummus in the bowl, then scatter over\nthe pomegranate seeds. Tear over the mint and parsley. Serve\nwith the vegetable crudités and toasted flatbreads."
    }
  ],
