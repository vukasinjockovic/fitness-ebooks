  "method": [
    {
      "heading": null,
      "description": "Soak your skewers in water (this prevents them from burning)."
    },
    {
      "heading": null,
      "description": "Slice your chicken into rough 3cm chunks and add all the sauces, a glug of oil and chilli flakes. Grate in the garlic and add chopped basil. Season with salt and leave to marinate in the fridge."
    },
    {
      "heading": null,
      "description": "Peel your mango and slice it into 1cm slices before slicing it once again into even thinner slices and adding to a big bowl. Halve your tomatoes and get them into the same bowl. Chop up your basil and mint and add them to your mango salad."
    },
    {
      "heading": null,
      "description": "Add your garlic and peanuts to a pestle and mortar and bash them up. Mix fish sauce, palm sugar and lime juice together. Get this all into your salad, season with a pinch of salt and toss together."
    },
    {
      "heading": null,
      "description": "Skewer assembly time – thread 5 chicken pieces onto each skewer."
    },
    {
      "heading": null,
      "description": "On medium heat, grill the skewers on an oiled pan, brush with the reserving marinade and cook until golden and the juices run clear on each side (should take about 12 mins)."
    },
    {
      "heading": null,
      "description": "Serve the skewers with the mango salad and enjoy!"
    }
  ],
