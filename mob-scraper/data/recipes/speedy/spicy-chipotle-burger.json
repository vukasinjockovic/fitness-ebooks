  "method": [
    {
      "heading": null,
      "description": "Thinly slice the red onions and place in a bowl. Add the cornflour and ground cumin and toss to coat."
    },
    {
      "heading": null,
      "description": "Fill a saucepan halfway with vegetable oil and set over a medium heat. Shake off any excess cornflour, then add the onions to the cold oil, stirring to separate."
    },
    {
      "heading": null,
      "description": "Cook, stirring often, until golden brown and crispy, then drain and season with salt."
    },
    {
      "heading": null,
      "description": "Mash the avocado flesh. Finely dice the mango. Finely chop the red onion, green chilli and fresh coriander. Juice the lime."
    },
    {
      "heading": null,
      "description": "Place in a bowl, season with salt and pepper, and mix well to combine."
    },
    {
      "heading": null,
      "description": "Combine the chipotle paste, garlic powder and smoked paprika with 4 tablespoons of vegetable oil and a pinch of salt and pepper."
    },
    {
      "heading": null,
      "description": "Heat a non-stick frying pan over medium heat. Toast the buns then set aside."
    },
    {
      "heading": null,
      "description": "Brush the veggie burgers with a little vegetable oil."
    },
    {
      "heading": null,
      "description": "Heat the same non-stick frying pan over medium heat. Add theburger patties and cook for 2 mins."
    },
    {
      "heading": null,
      "description": "Flip and spoon a third of the chipotle sauce over the burgers. Cook for a further 2 mins."
    },
    {
      "heading": null,
      "description": "Flip again, spoon another third of the chipotle sauce over the burgers, and cook for a further 2 mins."
    },
    {
      "heading": null,
      "description": "Flip one last time, spooning the remaining chipotle sauce over the burgers, and cook for a final 2 mins."
    },
    {
      "heading": null,
      "description": "To assemble, get a good dollop of the mango guacamole on the base of each burger. Top with the burger patties, followed by a good handful of crispy onions and the top bun. Tuck in and enjoy!"
    }
  ],
