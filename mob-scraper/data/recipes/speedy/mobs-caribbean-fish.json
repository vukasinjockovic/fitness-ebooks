  "method": [
    {
      "heading": null,
      "description": "Coat your cod with a drizzle of olive oil, allspice, and salt. Grate one of your scotch bonnets over the cod and rub everything in, then marinate for 15 minutes."
    },
    {
      "heading": null,
      "description": "To make your salsa, slice half of the tomatoes in half, chop up the mango, spring onion, and coriander, then squeeze the juice of the lime on top. Mix it all up in a bowl with some salt, pepper and olive oil."
    },
    {
      "heading": null,
      "description": "Heat up a glug of olive oil in a pan whilst you slice your onions and peppers. Then, add your onions and peppers to the pan along with allspice, cinnamon, thyme; grate in your other scotch bonnet and cook on a low heat. Fry until the onions have softened, then add the remaining tomatoes."
    },
    {
      "heading": null,
      "description": "Once the tomatoes have softened, add your veggie stock and bring to the boil before adding your cod. Cover to steam for 10 minutes."
    },
    {
      "heading": null,
      "description": "Cook your Caribbean rice &amp; peas according to the packet instructions."
    },
    {
      "heading": null,
      "description": "Portion up your rice with the cod then garnish with your salsa and get stuck in!"
    }
  ],
