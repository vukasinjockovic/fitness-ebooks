  "method": [
    {
      "heading": null,
      "description": "In a medium saucepan, mix the hotpot soup base with boiling water following packet instructions. (You’ll need 500-600ml per person; if you don’t have access to a hotpot base, see notes.) Bring to a boil over a medium-high heat."
    },
    {
      "heading": null,
      "description": "Wash all your veg and slice your napa cabbage. Add the napa cabbage and shiitake mushrooms to the boiling broth and cook for 5-6 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the dipping sauce: mince the garlic and chop the spring onion. Combine with all the ingredients for the dipping sauce in a small bowl and adjust to taste. Set aside."
    },
    {
      "heading": null,
      "description": "Add the fish balls, pak choi, enoki mushroom and noodles to the hot pot and cook for 3 mins (the fish balls will float to the top when cooked)."
    },
    {
      "heading": null,
      "description": "Add the sliced beef and cook for a final 30 seconds or until the beef changes colour."
    },
    {
      "heading": null,
      "description": "Garnish with coriander and enjoy your hot pot with the dipping sauce!"
    }
  ],
