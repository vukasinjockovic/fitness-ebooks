  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Grate the ginger and add to a small bowl. Add the brown sugar, soy sauce, five-spice and whisk together until the sugar has dissolved."
    },
    {
      "heading": null,
      "description": "Lightly season the cod with salt and place onto a foil-lined baking tray brushed with a little olive oil. Spoon over about 1 Tbsp of the sweet soy mix, then slide into the oven. Bake for 13-15 mins, basting the fish with more sauce halfway through. It should turn dark, caramelised and sticky. Once cooked, remove from the oven and let it rest for a couple of minutes."
    },
    {
      "heading": null,
      "description": "Meanwhile, bring a saucepan of salted water to the boil. Add the broccoli and cook for 2 mins until just tender. Drain and set aside."
    },
    {
      "heading": null,
      "description": "In a large bowl, stir the mayonnaise, sriracha, soy sauce, lemon juice, brown sugar until smooth. Add the warm broccoli and toss to coat in the dressing."
    },
    {
      "heading": null,
      "description": "Plate the cod alongside the dressed broccoli. Sprinkle with sesame seeds, a drizzle of chilli oil, and crushed peanuts. Serve with rice and dig in."
    }
  ],
