  "method": [
    {
      "heading": null,
      "description": "Finely slice the garlic, chop the olives and kale, discarding any tough stalks (these can be saved for soups and stews)."
    },
    {
      "heading": null,
      "description": "Bring a pot of salted water to a boil, drop in your pasta and cook for one min less than the pack instructs."
    },
    {
      "heading": null,
      "description": "While the pasta is cooking, set a frying pan over a medium heat with a good glug of olive oil."
    },
    {
      "heading": null,
      "description": "When the oil is hot add the garlic, chilli flakes and olives and allow to gently fry for a couple of mins. Turn up the heat, add the kale and a ladle of pasta water and allow the kale to wilt."
    },
    {
      "heading": null,
      "description": "When the pasta is cooked, transfer it to the frying pan using tongs."
    },
    {
      "heading": null,
      "description": "Grate in a good amount of Parmesan and toss well to create a glossy sauce."
    },
    {
      "heading": null,
      "description": "Add a squeeze of lemon juice, season with salt and pepper to taste and tuck in."
    }
