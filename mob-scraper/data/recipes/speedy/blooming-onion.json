  "method": [
    {
      "heading": null,
      "description": "Peel your brown onion and cut off the top and bottom. Using a large knife, slice down the centre of the onion, three quarters of the way down. Be careful not to cut all the way through. Turn the onion 90 degrees and slice again. Repeat the process until you have at least 16 little sections. You should now be able to open up the onion like a flower."
    },
    {
      "heading": null,
      "description": "To make the dredge, combine the ingredients in a mixing bowl and whisk to combine. Season with a little salt."
    },
    {
      "heading": null,
      "description": "Pour the milk into another bowl. Dust your prepped onion in the dredge, then pass through the milk, and then back into the flour again. Make sure all the sections are thoroughly coated."
    },
    {
      "heading": null,
      "description": "Preheat a pot of vegetable oil to 150°C and carefully fry the dredged onion until golden brown and cooked through, this will take 10-12 mins. While still hot, season with five-spice and salt."
    },
    {
      "heading": null,
      "description": "To make the ranch dip, add all ingredients to a mixing bowl and whisk until combined. Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve the fried onion with the ranch and sweet chilli sauce on the side for dipping. Get stuck in."
    }
  ],
