  "method": [
    {
      "heading": null,
      "description": "Peel and roughly chop the pumpkin and onion."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil in a large saucepan over a medium heat. Sauté the pumpkin and onion for about 10 mins until starting to soften then add the chicken stock and leave to simmer for 15 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, grate the Parmesan, finely chop the sage leaves and roughly chop the hazelnuts."
    },
    {
      "heading": null,
      "description": "Remove the saucepan from the heat and add the cream, ⅕ of the chopped sage and the Parmesan. Blitz with a stick blender then season to taste with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Heat the butter in a small pan over a medium-high heat until sizzling then stir through the remaining chopped sage, hazelnuts and chilli flakes."
    },
    {
      "heading": null,
      "description": "Divide the soup between bowls and drizzle over the fragrant butter."
    }
