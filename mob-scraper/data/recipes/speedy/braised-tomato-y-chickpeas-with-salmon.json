  "method": [
    {
      "heading": null,
      "description": "Finely slice the garlic cloves. Pat the salmon dry with kitchen paper and season well on both sides with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Place a medium lidded saucepan over a medium heat and add the olive oil, cumin and garlic. Cook for 2–3 mins until the garlic is fragrant and starting to soften. Stir in the harissa paste and cook for another minute."
    },
    {
      "heading": null,
      "description": "Pour in the passata and chickpeas. Bring to a gentle simmer, then carefully place the salmon on top. Turn the heat down to low, pop the lid on and simmer gently for 6 mins until the salmon is just cooked through."
    },
    {
      "heading": null,
      "description": "Lift the salmon out and set aside. Squeeze in the juice of half the lemon and stir through half of the dill."
    },
    {
      "heading": null,
      "description": "Divide the tomato-y chickpeas between bowls and top with the salmon. Finish with the rest of the dill, a generous dollop of yoghurt and a lemon wedge on the side."
    }
  ],
