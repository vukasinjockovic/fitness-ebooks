  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Slice the ciabatta in half and then score the inside with a cross-hatch pattern."
    },
    {
      "heading": null,
      "description": "Grate the cheddar cheese."
    },
    {
      "heading": null,
      "description": "Blitz the garlic, butter, parsley, 3 tbsp of olive oil, salt and pepper in a food processor."
    },
    {
      "heading": null,
      "description": "Scoop out a tablespoon of garlic butter in a small bowl and microwave for 30 secs until melted."
    },
    {
      "heading": null,
      "description": "Add ¾ of the cheddar and cream cheese to the food processor and blitz with the remaining garlic butter."
    },
    {
      "heading": null,
      "description": "Spread the cheesy garlic butter on the ciabatta."
    },
    {
      "heading": null,
      "description": "Push the remaining cheddar and cream cheese into the crevices of your ciabatta along with some torn-up chunks of mozzarella cheese."
    },
    {
      "heading": null,
      "description": "Drizzle on the melted garlic butter and pop in the oven for 20 mins or until the cheese has melted and golden."
    },
    {
      "heading": null,
      "description": "Slice into sticks and serve hot."
    }
