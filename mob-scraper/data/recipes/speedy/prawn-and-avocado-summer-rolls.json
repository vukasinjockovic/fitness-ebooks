  "method": [
    {
      "heading": null,
      "description": "Pan fry your prawns for 2 mins on a medium heat until they curl and turn pink. Season with paprika."
    },
    {
      "heading": null,
      "description": "Slice the carrot, cabbage and avocado into thin strips."
    },
    {
      "heading": null,
      "description": "Cook the noodles according to package instructions and soak in cold water (this prevents it from cooking further)."
    },
    {
      "heading": null,
      "description": "Mix everything together for the dipping sauce."
    },
    {
      "heading": null,
      "description": "Dip the rice paper sheets in cold water for a few seconds until softened - don't over-soak them as they will continue to soften."
    },
    {
      "heading": null,
      "description": "Assemble time. Add some of the prawns, veg and noodles to the bottom third of the rice paper. Top with a spoonful of the dipping sauce and herbs. Carefully roll, tucking the ends in."
    },
    {
      "heading": null,
      "description": "Cut the rolls in half and serve with the dipping sauce - enjoy!"
    }
