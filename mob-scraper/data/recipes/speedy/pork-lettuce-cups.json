  "method": [
    {
      "heading": null,
      "description": "Mince your garlic, finely slice your chilli and red onion then set aside in three separate bowls."
    },
    {
      "heading": null,
      "description": "Make a quick red onion pickle by squeezing the juice of half a lime onto the onions before giving it a mix with a sprinkle of sea salt. Set aside until later."
    },
    {
      "heading": null,
      "description": "Squeeze the sausages out of their casings then add to a pan and fry with a small glug of oil until crispy. Add your garlic to the pan and fry for a few mins until fragrant. Now go in with your curry paste, soy sauce, sugar and the juice of half a lime – fry for around 5 mins on low heat. Once it’s nearly done, add most of your coriander and mint leaves and fry for just a minute."
    },
    {
      "heading": null,
      "description": "Crush your peanuts in a pestle and mortar."
    },
    {
      "heading": null,
      "description": "Wash your lettuce leaves and pat down dry with a towel."
    },
    {
      "heading": null,
      "description": "Assembly time: spoon the pork into the lettuce cups, top with pickled red onions, sliced red chilli and the remaining herbs. Sprinkle over your crushed peanuts."
    },
    {
      "heading": null,
      "description": "Serve with sweet chilli sauce and enjoy."
    }
  ],
