  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Slice the bread thickly and remove the crusts, then cut roughly into large cubes. Place into a baking tray and drizzle generously with olive oil and a large pinch of salt."
    },
    {
      "heading": null,
      "description": "Toast the bread in the oven for about 8 mins until golden and crunchy all over, then remove and set aside."
    },
    {
      "heading": null,
      "description": "While the bread toasts, fill a large mixing bowl about half full with cold water (add a few ice cubes if you have them. Finely slice the red onion and add to the bowl with the water. Stir and leave to sit for about 5 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, trim and finely slice the fennel. If you have a mandolin, now is the time to use it. If not, a sharp knife will do the job nicely."
    },
    {
      "heading": null,
      "description": "Use a knife to peel and slice the orange into rounds about 1cm thick."
    },
    {
      "heading": null,
      "description": "Drain the onions and add the fennel and oranges to the bowl. Drain the butterbeans and add those too, then tear in the basil and roughly chop and add the parsley."
    },
    {
      "heading": null,
      "description": "Squeeze in the juice of a lemon, a generous pinch of flaky salt and plenty of olive oil (at least 3 or 4 tbsp)."
    },
    {
      "heading": null,
      "description": "Mix really well and then taste and add more salt or lemon as needed, it should be sweet, tangy, crunchy and very fresh."
    }
  ],
