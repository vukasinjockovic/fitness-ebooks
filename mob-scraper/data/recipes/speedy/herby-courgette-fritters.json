  "method": [
    {
      "heading": null,
      "description": "Grate the courgettes into a colander, mix with a large pinch of salt and squeeze out as much liquid as you can."
    },
    {
      "heading": null,
      "description": "Finely chop the basil and parsley and add to a large bowl along with the courgette, eggs, flour, cumin, a large pinch of salt and plenty of black pepper. Mix well and set aside."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix the mayo with the tahini, a squeeze of lemon juice and a pinch of salt."
    },
    {
      "heading": null,
      "description": "Add three tablespoons of olive oil to a frying pan and place over a medium heat. Once the oil is shimmering, add a large spoonful of the mix into the pan and flatten slightly."
    },
    {
      "heading": null,
      "description": "Fry for about 2 mins, then flip and repeat, until both sides are golden brown."
    },
    {
      "heading": null,
      "description": "Transfer to a plate lined with kitchen paper to cool for a minute, and then plate up."
    },
    {
      "heading": null,
      "description": "Sprinkle with a pinch of chilli and some flaky salt and serve up along with the tahini mayo."
    }
