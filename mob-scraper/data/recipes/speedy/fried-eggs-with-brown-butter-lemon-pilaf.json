  "method": [
    {
      "heading": null,
      "description": "Add the butter to a frying pan set over a medium heat. Let it melt, then add the pumpkin seeds and cook, stirring occasionally, until the butter is browned, nutty and the seeds are toasted."
    },
    {
      "heading": null,
      "description": "Stir the garlic purée and half the crispy onions into the butter. Cook for 20–30 secs until fragrant, then tip in the kale and cook for 2–4 mins until wilted. Add the rice and stir until everything is piping hot. Season with salt, black pepper, lemon zest and juice."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of olive oil in a separate frying pan over a medium-high heat. Crack in the eggs and fry until cooked to your liking. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Spoon the rice onto plates and top with the fried eggs. Add a dollop of Greek yoghurt and finish with a lemon wedge and the rest of the crispy onions."
    }
  ],
