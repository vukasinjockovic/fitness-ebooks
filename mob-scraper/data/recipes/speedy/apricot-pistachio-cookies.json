  "method": [
    {
      "heading": null,
      "description": "Set oven to 175°C/347°F and line two baking trays with greaseproof paper."
    },
    {
      "heading": null,
      "description": "Blitz 75g of the oats until you get a flour consistency and set to the side in a mixing bowl."
    },
    {
      "heading": null,
      "description": "Add in the flour, spices (cinnamon, ginger, allspice) and baking powder."
    },
    {
      "heading": null,
      "description": "In a separate large bowl beat the softened butter and sugars together. Then add your egg and whisk together."
    },
    {
      "heading": null,
      "description": "Add the sugar mixture, remaining oats and tbsp of water to the flour combination."
    },
    {
      "heading": null,
      "description": "Roughly chop the pistachios (chopping extra to garnish your cookie dough). Finely dice the apricots and add both ingredients to your cookie mixture."
    },
    {
      "heading": null,
      "description": "Roll the dough into walnut size balls and place on a baking tray, leaving space in between and lightly flatten each ball down."
    },
    {
      "heading": null,
      "description": "Sprinkle a generous amount of salt and your extra pistachio crumbs on each portion."
    },
    {
      "heading": null,
      "description": "Cook for 13 minutes, turning your tray around halfway through."
    },
    {
      "heading": null,
      "description": "Once ready, leave to cool on a rack."
    }
  ],
