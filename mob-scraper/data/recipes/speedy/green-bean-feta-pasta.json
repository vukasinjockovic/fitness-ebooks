  "method": [
    {
      "heading": null,
      "description": "Bring a pan of salted water to the boil. Once boiling, add the spaghetti and cook according to packet instructions. Finely chop most of the parsley, saving some leaves for serving."
    },
    {
      "heading": null,
      "description": "Peel and slice the garlic and green chilli. Add olive oil to the pan and add green beans and cook for 2 mins, then add the garlic along with the fennel seeds and green chilli."
    },
    {
      "heading": null,
      "description": "Add the white wine, and cook until reduced by half. Add the cooked spaghetti. Squeeze in the juice of the lemon and add the chopped parsley. Season to taste, then tip into bowls and top with the feta and toasted hazelnuts and a scattering of parsley leaves."
    }
