  "method": [
    {
      "heading": null,
      "description": "Bring a large pan of water to a gentle boil."
    },
    {
      "heading": null,
      "description": "Start by roughly chopping the mushrooms to similar sized pieces."
    },
    {
      "heading": null,
      "description": "Heat 3 tbsp olive oil to a large frying pan over a high heat. Add the mushrooms with a pinch of salt and cook for 5 mins, until golden."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the garlic, remove the leaves from the thyme and finely chop the parsley (stalks and all)."
    },
    {
      "heading": null,
      "description": "Add the finely chopped or grated garlic, thyme and parsley to the mushrooms to fry for another minute before adding in the white wine to bubble. Turn down the heat to low"
    },
    {
      "heading": null,
      "description": "Empty the La Famiglia Rana Mushroom &amp; Mascarpone Tortelloni into the boiling water and cook for only 2 mins. Use a slotted spoon to transfer the pasta to the mushroom sauce with a big splash of pasta water. Finely grate the parmesan into the pan and add the lemon juice. Toss until the silky sauce coats the pasta. Season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Tip onto plates and serve with extra grated Parmesan and a scattering of walnuts."
    }
