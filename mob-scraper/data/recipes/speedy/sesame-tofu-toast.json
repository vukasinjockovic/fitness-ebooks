  "method": [
    {
      "heading": null,
      "description": "Roughly chop your spring onion, ginger, garlic and coriander."
    },
    {
      "heading": null,
      "description": "Place your tofu in a food processor or blender along with your spring onions, ginger, garlic and coriander. Add your cornflour, soy sauce, sesame oil, sugar and a good pinch of salt and pepper. Whizz up until you have a thick paste."
    },
    {
      "heading": null,
      "description": "Cut your crusts off your slices of bread. Spread each slice with a thick layer of your tofu mixture. Sprinkle the surface of each with sesame seeds and press down with your fingers so that they stick."
    },
    {
      "heading": null,
      "description": "Heat a generous glug of vegetable oil in a medium sized frying pan. Add your slices of toast tofu side up and fry for 2 minutes until you have a crispy golden base. Carefully flip over and cook for 2 minutes on the other side until crisp."
    },
    {
      "heading": null,
      "description": "Drain your toast on a plate lined with kitchen paper whilst you repeat the frying with your remaining toast slices."
    },
    {
      "heading": null,
      "description": "Cut each slice of toast into 4 triangles and serve up with crispy chilli oil."
    }
  ],
