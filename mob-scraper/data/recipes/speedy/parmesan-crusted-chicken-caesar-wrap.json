  "method": [
    {
      "heading": null,
      "description": "Slice the chicken into thin strips, transfer to a bowl and add both the chargrilled chicken seasoning and the garlic Italian seasoning."
    },
    {
      "heading": null,
      "description": "Roughly chop the lettuce. Thinly slice half of the Parmesan into shavings, then finely grate the other half."
    },
    {
      "heading": null,
      "description": "Spray a non-stick frying pan with the oil over a high heat, then add the chicken strips. Leave to turn nice and golden on one side, then flip. Meanwhile, combine all the caesar dressing ingredients in a bowl and set aside."
    },
    {
      "heading": null,
      "description": "Combine one-third of the dressing with the lettuce in a large bowl, then combine another one-third of the dressing with the soft cheese and grated cheese mix in another bowl."
    },
    {
      "heading": null,
      "description": "Heat the wrap for 10-15 seconds in the microwave to make it more flexible. Layer the dressing/cheese mix into the centre of 1 wrap, followed by the lettuce mix, the sliced chicken, the parmesan shavings and a sprinkle of garlic &amp; herb breadcrumbs."
    },
    {
      "heading": null,
      "description": "Fold either side in, flattening the mixture down a bit, then flip the wrap over the filling, tuck it under and roll it up."
    },
    {
      "heading": null,
      "description": "Give the frying pan you used for the chicken a quick wipe (no need to clean properly), then add some more oil spray to the pan and sprinkle some grated Parmesan in. Pop the wrap on top for a few minutes over a medium heat until it starts to go crispy, then add some more Parmesan next to it and flip the wrap over onto that."
    },
    {
      "heading": null,
      "description": "Once golden and crispy, leave to cool (difficult but important step!) for 5 mins. Slice in half and use the remaining Caesar dressing for drizzling or dipping."
    }
  ],
