  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion, thinly slice the garlic and cut the chorizo into small bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil in a large, deep ovenproof frying pan set over a medium-high heat. Add the chorizo and cook for 3–4 mins, stirring occasionally, until it’s crisp and the oil has turned a deep red."
    },
    {
      "heading": null,
      "description": "Turn the heat down to medium and chuck in the onion, garlic and a pinch of salt. Cook for 6–8 mins until soft and translucent."
    },
    {
      "heading": null,
      "description": "Add the gnocchi to the pan and toss it through all that lovely oil. Pour in the chicken stock, bring to the boil, then simmer for 3–4 mins until the gnocchi is just cooked."
    },
    {
      "heading": null,
      "description": "Stir through the shredded kale and soft cheese, and cook for a further minute to wilt the kale and melt the cheese."
    },
    {
      "heading": null,
      "description": "Finely grate over the parmesan, drizzle with a little more oil and crack over some black pepper to finish."
    }
  ],
