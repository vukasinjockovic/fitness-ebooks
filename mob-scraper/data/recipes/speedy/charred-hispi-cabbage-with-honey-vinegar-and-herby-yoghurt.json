  "method": [
    {
      "heading": null,
      "description": "Start by removing the outer leaves of the cabbage and giving it a rinse, then slice into quarters."
    },
    {
      "heading": null,
      "description": "Heat a large frying pan over a medium heat and add a splash of olive oil. Place the cabbages with the outer side down and cook for about 5 mins, moving around a little as they cook."
    },
    {
      "heading": null,
      "description": "Season the cabbages all over with salt and pepper, then flip on to the cut side. You’ll want to cook each cut side for about 3 or 4 mins until it has a lovely golden brown colour."
    },
    {
      "heading": null,
      "description": "While the cabbages cook, mix the honey, white wine vinegar, zest and juice of the lime in a small bowl."
    },
    {
      "heading": null,
      "description": "Finely chop both chillies and all of the herbs. Mix the chillies into the honey vinegar and the herbs into the yoghurt."
    },
    {
      "heading": null,
      "description": "Once the cabbage is cooked, remove from the pan and drizzle all over with the honey vinegar while still warm."
    },
    {
      "heading": null,
      "description": "Spread 2 tablespoons of yoghurt on each plate, top with a wedge of the hispi cabbage and enjoy."
    }
  ],
