  "method": [
    {
      "heading": null,
      "description": "Mix together the yoghurt and mint with a squeeze of lemon and a pinch of salt."
    },
    {
      "heading": null,
      "description": "Mix together a tablespoon of curry powder with the mango chutney and mayo."
    },
    {
      "heading": null,
      "description": "Combine the cabbage, chilli, spring onion, coriander, and mango. Season with salt and a big squeeze of lemon."
    },
    {
      "heading": null,
      "description": "Drain the pickled cucumbers."
    },
    {
      "heading": null,
      "description": "Season the cod loin with salt. Whisk together the flours with the baking powder, remaining curry powder, and a pinch of salt. Whisk in the lager until smooth."
    },
    {
      "heading": null,
      "description": "Heat a pan of vegetable oil to 190°C. Dredge the fish in some extra rice flour, pass it through the spiced beer batter and fry for 10-12 minutes until cooked through, crispy, and golden. Season with salt and drain on kitchen paper."
    },
    {
      "heading": null,
      "description": "Toast the buns and build your burgers. Start with a layer of mint yoghurt, then follow it up with some pickled cucumbers. Lay the fish down, add a handful of slaw, and slather the top bun with your curried mayo. Crown your creation and give it a squish. Get stuck in."
    }
  ],
