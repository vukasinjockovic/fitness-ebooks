  "method": [
    {
      "heading": null,
      "description": "Using a peeler, peel your entire orange, or as much as you are able. Juice your orange and set aside the juice for later."
    },
    {
      "heading": null,
      "description": "Tightly wrap up the orange rind into a tight roll, then spear it with a toothpick to create a guide hole. Take the toothpick out and now spear it with the rosemary sprig to create the garnish."
    },
    {
      "heading": null,
      "description": "In a large mixing glass, add ice and then the gin, Campari, sweet vermouth and orange juice then stir."
    },
    {
      "heading": null,
      "description": "Strain out into a large glass and top with Peroni Nastro Azzurro."
    },
    {
      "heading": null,
      "description": "Dash a couple of drops of Angostura Bitters on top and garnish with your orange rose. Enjoy!"
    }
