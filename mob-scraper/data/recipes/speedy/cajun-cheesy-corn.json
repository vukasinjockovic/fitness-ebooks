  "method": [
    {
      "heading": null,
      "description": "Set the grill to high. Slice the corn kernels off the cob. Trim and finely chop the bell pepper. Finely chop the chives."
    },
    {
      "heading": null,
      "description": "Melt the butter in a small ovenproof frying pan set over a medium-high heat. Add the corn and pepper, then cook for 3-4 mins until softened."
    },
    {
      "heading": null,
      "description": "Remove from the heat, stir in the cajun seasoning, mayo, sugar, half the chives and half the cheese. Mix well, then scatter the remaining cheese on top."
    },
    {
      "heading": null,
      "description": "Grill until the cheese is bubbly and golden, 3-6 mins. Sprinkle with the remaining chives."
    }
