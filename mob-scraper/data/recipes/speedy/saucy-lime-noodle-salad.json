  "method": [
    {
      "heading": null,
      "description": "Boil Soba noodles according to package directions, drain and rinse with cold water."
    },
    {
      "heading": null,
      "description": "Roughly chop the broccoli."
    },
    {
      "heading": null,
      "description": "Boil broccoli for 2 minutes in salted water, add edamame for another 1 minute. Drain and run under cold water to cool down."
    },
    {
      "heading": null,
      "description": "Slice the courgette and carrot into thin batons using a knife or a julienne peeler."
    },
    {
      "heading": null,
      "description": "To make the dressing, add the coriander, tahini, water, juice of 3 limes, ginger, miso and agave and blend until smooth."
    },
    {
      "heading": null,
      "description": "To serve, add all of the vegetables to the noodles and top with plenty of dressing. Sprinkle some sesame seeds on top and finish with chilli oil, if using. Serve with the crispy seaweed on top and on the side."
    }
  ],
