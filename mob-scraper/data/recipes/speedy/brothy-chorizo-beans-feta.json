  "method": [
    {
      "heading": null,
      "description": "Add the chorizo to a large saucepan and set over a medium heat. Let it cook for a couple of minutes until it starts to leach its oil."
    },
    {
      "heading": null,
      "description": "Stir in the onion, garlic purée and fennel seeds. Cook for 4–5 mins until the onion is soft and translucent."
    },
    {
      "heading": null,
      "description": "Pour in the black beans and their liquid, followed by the chicken stock. Whack up the heat and bring to the boil."
    },
    {
      "heading": null,
      "description": "Once boiling, add the kale and simmer for 3–4 mins until wilted. Taste the broth and season with salt, black pepper and lemon juice."
    },
    {
      "heading": null,
      "description": "Ladle the brothy beans into bowls. Finish with some lemon zest and a scattering of crumbled feta."
    }
