  "method": [
    {
      "heading": null,
      "description": "Cut the aubergine into roughly 2cm dice, pop into a large saucepan over a high heat with a big pinch of salt and cook for 3 or 4 mins until browning at the edges."
    },
    {
      "heading": null,
      "description": "Add 3 tbsp of olive oil and cook for another 5 mins until soft. Remove from the pan and set aside."
    },
    {
      "heading": null,
      "description": "Meanwhile, dice the onion and celery. Once the aubergine is cooked, return the empty pan to a medium heat and add a generous splash of olive oil."
    },
    {
      "heading": null,
      "description": "Add the onion and celery and a pinch of salt. Cook for about 5 mins until softened."
    },
    {
      "heading": null,
      "description": "Crush the olives in half using your palm or side of a knife and add to the pan for a minute along with the capers and basil, then pour in the vinegar and bubble for 30 seconds."
    },
    {
      "heading": null,
      "description": "Add the tomatoes, crush up with your spoon and let it cook down for about 15 mins."
    },
    {
      "heading": null,
      "description": "Return the aubergines to the pan with the the tomato sauce, along add the sugar and mix well. Set aside while you cook the pasta in plenty of boiling salted water."
    },
    {
      "heading": null,
      "description": "While the pasta cooks, toast the almonds in a dry pan over a medium heat until golden brown. Set aside."
    },
    {
      "heading": null,
      "description": "Mix the pasta and sauce together, plate up and top with the flaked almonds, some more basil and a drizzle of olive oil."
    }
  ],
