  "method": [
    {
      "heading": null,
      "description": "If using courgette and carrot, finely slice them into thin batons with a julienne peeler or a knife. You could also peel them into thin ribbons with a speed peeler."
    },
    {
      "heading": null,
      "description": "Boil a pot of water on the hob with 1 stock cube. Add the noodles, courgette and carrot and boil for 4 mins (or as long as the noodle package states)."
    },
    {
      "heading": null,
      "description": "Set a cup of the cooking water (stock) aside and drain the noodles."
    },
    {
      "heading": null,
      "description": "Pour the cup of stock into a medium sided serving bowl. Pour in the tahini and squeeze the lemon into the stock and whisk until well combined into smooth sauce."
    },
    {
      "heading": null,
      "description": "Add the noodles and veg into the bowl with the lemon tahini sauce and mix well until all of the noodles are covered in sauce."
    },
    {
      "heading": null,
      "description": "Top with a tablespoon of chilli oil and sesame seeds."
    }
  ],
