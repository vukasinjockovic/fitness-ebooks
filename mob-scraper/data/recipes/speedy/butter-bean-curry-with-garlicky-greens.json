  "method": [
    {
      "heading": null,
      "description": "Place a saucepan over a medium heat. Once hot, add the butter and let it melt. Stir in the onion and cumin seeds, and cook for 3–4 mins until the onion is soft and fragrant."
    },
    {
      "heading": null,
      "description": "Add the korma paste, tomato purée and garlic purée. Cook for 2–3 mins until the paste darkens and smells toasty."
    },
    {
      "heading": null,
      "description": "Tip in the butter beans and their liquid, along with the kale. Bring to the boil and cook, stirring now and then, until the kale has wilted. Stir the spinach through and cook until wilted. Taste and season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Share the curry between bowls, top with the crispy onions and a big dollop of yoghurt. Serve with the naans on the side."
    }
  ],
