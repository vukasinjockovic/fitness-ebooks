  "method": [
    {
      "heading": null,
      "description": "Tip the bread flour, sugar, polenta, salt and baking powder into a bowl and whisk together. In a separate bowl, pour in the milk and then crack in the eggs. Mix the wet mixture into the dry mixture until smooth and thick. Pour into a pint glass or tall container."
    },
    {
      "heading": null,
      "description": "Cut the hotdogs to size. You want them just shorter than your tall container so they’ll fully submerge in the corn mixture. Insert the lollipop stick into the sausage."
    },
    {
      "heading": null,
      "description": "Preheat a pot filled halfway with vegetable oil to 180°C."
    },
    {
      "heading": null,
      "description": "Dip a sausage into the corn mixture until thoroughly coated and then carefully lower into the hot oil. Fry for 4-5 mins until a deep golden brown. Remove and drain on kitchen paper. Repeat with the remaining hot dogs."
    },
    {
      "heading": null,
      "description": "Serve with ketchup and mustard."
    }
