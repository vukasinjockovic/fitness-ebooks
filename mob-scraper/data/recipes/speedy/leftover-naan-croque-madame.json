  "method": [
    {
      "heading": null,
      "description": "Finely chop the spring onions and green chilli. Grate the cheddar cheese and cut the naan into four equal pieces."
    },
    {
      "heading": null,
      "description": "Spread the mango chutney onto two pieces of naan and sprinkle on half your cheese. Add the spring onions, green chilli and ham on top, then finish with the remaining cheese. Close the sandwich with the remaining pieces of naan."
    },
    {
      "heading": null,
      "description": "Heat up a frying pan and melt a knob of butter."
    },
    {
      "heading": null,
      "description": "Gently heat the sandwiches for 3 mins on either side until the cheese has melted. Take them off the heat and put them aside."
    },
    {
      "heading": null,
      "description": "Add a big glug of oil into the frying pan and fry 4 eggs for British Lion 3 mins, until the whites are set but the yolks are still soft."
    },
    {
      "heading": null,
      "description": "Serve the sandwiches with the fried eggs on top and enjoy."
    }
