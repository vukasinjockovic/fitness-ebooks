  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 160°C."
    },
    {
      "heading": null,
      "description": "Toast the pine nuts for 10-11 mins until golden brown."
    },
    {
      "heading": null,
      "description": "Bring a large pan of water to a rolling boil and season generously with salt. Drop in your spaghetti and cook according to the pack instructions."
    },
    {
      "heading": null,
      "description": "Roughly chop the artichokes and finely chop the garlic, chilli and rosemary."
    },
    {
      "heading": null,
      "description": "Add the chopped garlic, chilli and rosemary to a large saucepan with plenty of good olive oil and set it over a medium-low heat."
    },
    {
      "heading": null,
      "description": "Cook for 4-5 mins until starting to sizzle and the room is filled with the smell of toasting rosemary, garlic and chilli."
    },
    {
      "heading": null,
      "description": "Add the chopped artichokes and stir together, cook for another couple of mins until the artichokes start to break down a little."
    },
    {
      "heading": null,
      "description": "Transfer the cooked spaghetti to the artichoke sauce and toss to combine until you have a creamy, emulsified, glossy sauce that coats the pasta."
    },
    {
      "heading": null,
      "description": "Add in a handful of pine nuts, plenty of black pepper, roughly chopped mint, lemon zest and juice."
    },
    {
      "heading": null,
      "description": "Give it another toss, divide between warm plates and top with extra pine nuts and lemon zest."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
