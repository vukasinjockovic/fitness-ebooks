  "method": [
    {
      "heading": null,
      "description": "Finely chop the red onion, crush the garlic, finely chop the jalapeño and slice the pepper. Heat a shot of oil in a frying pan, then tip in the red onion, jalapeño and garlic. Cook for 5-7 mins until softened and fragrant."
    },
    {
      "heading": null,
      "description": "Add the beans, paprika, cumin, chipotle paste and tomato purée, then cook for 3 mins, stirring often, until everything is caramelised and starting to brown. Add the red pepper and cook for 1-2 mins, then add the chopped tomatoes, stock cube and water. Simmer for 15 -20 mins until everything is cooked and the beans have softened. Add ⅓ of the yoghurt and stir through before stirring."
    },
    {
      "heading": null,
      "description": "Finely chop the pickled jalapeños and coriander."
    },
    {
      "heading": null,
      "description": "To serve, ladle the soup into bowls and top with the pickled jalapeño, the rest of the yoghurt and chopped coriander. Crumble over the tortilla chips."
    }
  ],
