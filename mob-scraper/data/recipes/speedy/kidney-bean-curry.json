  "method": [
    {
      "heading": null,
      "description": "Finely chop the onions, ginger, and garlic."
    },
    {
      "heading": null,
      "description": "Get a large saucepan over a medium heat. Pour in a good glug of neutral oil. Add the onion along with a pinch of salt. Fry, stirring regularly for 5 minutes until soft then scrape in the ginger and garlic. Cook for a minute more."
    },
    {
      "heading": null,
      "description": "Spoon in the curry powder and the coriander, cumin and mustard seeds into the pan. Cook, stirring for a minute until smelling fragrant then tip in the chopped tomatoes and kidney beans along with their water. Season well with salt and pepper, bring the curry to the boil then turn down the heat and simmer gently for 15 minutes until thickened. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Squeeze in the lime juice and season to taste.  Reheat the rice and serve into bowls. Top with the curry and tear over some coriander. Serve with a dollop of mango chutney."
    }
  ],
