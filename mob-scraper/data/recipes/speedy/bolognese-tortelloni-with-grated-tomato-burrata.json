  "method": [
    {
      "heading": null,
      "description": "Grate the whole tomato on the largest side of a box grater into a wide bowl, then season generously with salt and add the extra virgin olive oil and sherry vinegar. Give this a try – it should taste like summer! Stir through the capers and finely grate in the garlic clove. Finely chop the parsley and add to the sauce."
    },
    {
      "heading": null,
      "description": "Bring a large pot of water to the boil, then tip in the La Famiglia Rana Bolognese Tortellini to cook for just 2 mins before draining. Add the fresh tomato sauce to the pasta and give it a toss so it’s all coated."
    },
    {
      "heading": null,
      "description": "Divide between two bowls and serve with large pieces of torn burrata or mozzarella, an extra drizzle of olive oil and a little more salt and pepper to finish."
    }
