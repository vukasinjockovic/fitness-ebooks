  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 190°C. Coarsely grate the courgette. Roughly chop the spinach. Tear the basil. Grate the garlic. Zest the lemon, then cut it in half."
    },
    {
      "heading": null,
      "description": "Add the prawns to a bowl with the grated garlic and olive oil. Season well with salt and black pepper."
    },
    {
      "heading": null,
      "description": "In another bowl, mix the orzo, double cream, Dijon mustard, courgette, spinach and basil. Season with salt and pepper, then grate in the lemon zest. Give it all a good stir."
    },
    {
      "heading": null,
      "description": "Lay a large piece of baking paper per person in front of you, portion out the orzo and top with the prawns. . Fold the top half of the baking paper over the food, then seal the edges to create a steam-tight parcel, similar to a cornish pasty in shape. Repeat with the remaining ingredients."
    },
    {
      "heading": null,
      "description": "Bake in the oven for 20 mins. Unwrap carefully and finish with a good squeeze of lemon juice over the top before serving."
    }
  ],
