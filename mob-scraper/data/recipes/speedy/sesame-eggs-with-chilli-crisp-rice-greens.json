  "method": [
    {
      "heading": null,
      "description": "Add the olive oil to a frying pan and place over a high heat. Once hot, add the rice and cook for 5–6 mins, tossing occasionally, until the grains are crispy and the surface is golden or starting to char."
    },
    {
      "heading": null,
      "description": "Add the garlic purée, peas and spinach to the pan. Toss everything together and cook for another couple of minutes until the spinach is wilted and the peas are defrosted. Remove from the heat and stir through the chilli oil."
    },
    {
      "heading": null,
      "description": "Meanwhile, set another frying pan over a medium heat with a drizzle of olive oil. Once hot, add the sesame seeds and crack in the eggs. Fry to your liking, spooning the sesame oil over the eggs as they cook. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Share the rice between plates and top with the sesame eggs."
    }
