  "method": [
    {
      "heading": null,
      "description": "De-stone, roughly chop and blitz your peaches until you’ve got a smoothish purée."
    },
    {
      "heading": null,
      "description": "Strain the blitzed peaches through a sieve to create a really smooth, silky peach juice. Set aside."
    },
    {
      "heading": null,
      "description": "Zest the lime onto a plate, add the sugar and mix to create the rim."
    },
    {
      "heading": null,
      "description": "Rub a wedge of lime around the rim of your glass and dip it in the sugary zest."
    },
    {
      "heading": null,
      "description": "Juice your lime."
    },
    {
      "heading": null,
      "description": "Add the strained peaches, tequila, triple sec, peach liquor, lime juice and agave to a cocktail shaker with ice."
    },
    {
      "heading": null,
      "description": "Shake hard for 20 seconds to mix well and chill."
    },
    {
      "heading": null,
      "description": "Put a large ice cube into your rimmed glass and strain in your cocktail."
    },
    {
      "heading": null,
      "description": "Garnish with some slices of fresh peach and enjoy."
    }
  ],
