  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Get your griddle pan on and prepare the cabbages. Remove the outer leaves from the cabbage and slice into half then into quarters. Brush the quarters with sesame oil and when the griddle pan is hot, add in the cabbage quarters, two at a time, until nicely charred. Turn the cabbages half way through and brush each side with extra oil."
    },
    {
      "heading": null,
      "description": "Once griddled, put all the cabbage halves into a baking tray and lightly roast in the oven for 8 minutes."
    },
    {
      "heading": null,
      "description": "For the dressing, mix together the miso, tahini, soy, grated ginger, mirin and a splash of water."
    },
    {
      "heading": null,
      "description": "Separate the coriander leaves and stalks. Plate up the cabbage and drizzle over your miso dressing. Sprinkle the sesame seeds and coriander leaves on top then tuck in!"
    }
  ],
