  "method": [
    {
      "heading": null,
      "description": "Get the marinade ingredients in a mixing bowl, season with salt and black pepper and stir to combine. Slice the chicken thighs into 1cm strips then add to the marinade. Mix to thoroughly coat then set aside."
    },
    {
      "heading": null,
      "description": "In a separate small bowl, add the ingredients for the sauce, season with salt and black pepper and stir to combine. Set aside."
    },
    {
      "heading": null,
      "description": "Mince the garlic and ginger, thinly slice the spring onions on a diagonal, thinly slice the red chilli and roughly chop the coriander. Cut the lime into wedges."
    },
    {
      "heading": null,
      "description": "Bring a large saucepan of water to a boil. Add the udon noodles and cook for a minute less than the packet instructions. Drain and rinse with cold water until just warm to the touch. Set aside."
    },
    {
      "heading": null,
      "description": "Heat a large dry frying pan or wok over a high heat for 1-2 mins. Add a glug of vegetable oil and the chicken thighs and stir fry for 2-3 mins until the chicken is slightly browned and golden. Add the garlic and ginger and stir fry for a further 1-2 mins until fragrant. Add the spring onion and udon noodles, mix to combine and cook for a further minute."
    },
    {
      "heading": null,
      "description": "Push the noodles to one side and add a small glug of vegetable oil to the pan. Crack in the eggs and use a wooden spoon to break the yolks and scramble them with the whites. Let the eggs cook for 30 seconds then mix everything in the pan together, combining the egg with the noodles and chicken."
    },
    {
      "heading": null,
      "description": "Pour the sauce into the pan and mix until the sauce is fully combined with the noodles. Add the beansprouts, fresh coriander and red chilli and stir fry for a final 1-2 mins."
    },
    {
      "heading": null,
      "description": "Transfer the noodles to bowls immediately. Sprinkle with shichimi powder (or chilli powder if you prefer) and sesame seeds, drizzle with chilli oil and garnish with a wedge of lime."
    }
  ],
