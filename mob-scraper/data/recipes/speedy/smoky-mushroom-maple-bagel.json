  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Slice the mushrooms to about half a centimetre thick and place in a wide, shallow bowl or large tupperware box."
    },
    {
      "heading": null,
      "description": "Mix the olive oil, maple syrup, apple cider vinegar, soy sauce, smoked paprika, miso, and black pepper until combined to make the marinade."
    },
    {
      "heading": null,
      "description": "Pour the marinade over the mushrooms and carefully mix to make sure each slice is covered."
    },
    {
      "heading": null,
      "description": "Lay the mushrooms out onto baking paper on a large baking tray. If you have a wire rack, this will help them cook more evenly. Roast at 180°C for 10 mins, flipping halfway through. Alternatively, air fry for 6 mins at 180°C."
    },
    {
      "heading": null,
      "description": "To serve, slice the bagel open and toast in the oven or on a hot pan until crispy. Slice your tomato. Spread vegan cream cheese, if using, on the bottom half of the bagel, then layer up the mushrooms, tomato, and lettuce on top. Spread the mayo onto the top half, close, and enjoy."
    }
