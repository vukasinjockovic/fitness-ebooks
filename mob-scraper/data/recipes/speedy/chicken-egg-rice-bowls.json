  "method": [
    {
      "heading": null,
      "description": "Thinly slice the onion, green chillies and garlic. Thinly slice the\nchicken thighs."
    },
    {
      "heading": null,
      "description": "Heat the vegetable oil in a large frying pan, add the onion and\ngreen chillies and fry over a medium-high heat for about 5 minutes\nuntil softened but not coloured. Add in the garlic and cook for 1 min more."
    },
    {
      "heading": null,
      "description": "Add the sliced chicken, chicken stock, soy sauce and Shaoxing\nwine. Bring to a bubble and cook for 10 mins over a medium-low\nheat."
    },
    {
      "heading": null,
      "description": "Meanwhile, crack the eggs into a bowl and very gently mix a few\ntimes – you don’t want the whites and eggs to be completely mixed.\nThinly slice the spring onions (both green and white parts)."
    },
    {
      "heading": null,
      "description": "Pour the eggs over the chicken and gently swirl in with a wooden\nspoon and then sprinkle over three-quarters of the spring onions.\nPop a lid on the pan and cook for 3 mins until the eggs have set."
    },
    {
      "heading": null,
      "description": "Spoon the chicken and eggs over bowls of steamed rice and then\npour over any remaining liquid for the rice to absorb."
    },
    {
      "heading": null,
      "description": "Sprinkle with the remaining spring onions and enjoy."
    }
  ],
