  "method": [
    {
      "heading": null,
      "description": "Fill a saucepan full of water and place over a high heat. Once boiling, turn the heat down to medium, gently drop the eggs in and simmer for 7 mins. Transfer to an ice bath to cool down. Rinse out the pan."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely mince the coriander, parsley and dill (stalks and all) and thinly slice the garlic."
    },
    {
      "heading": null,
      "description": "Place the rinsed pan onto medium heat with a drizzle of olive oil. Once hot, add the turmeric, garlic, fresh chopped herbs, dried mint and ¾ of the crispy onions. Cook, stirring, until the herbs have softened. Pour in the vegetable stock and let it heat up."
    },
    {
      "heading": null,
      "description": "In the meantime, reheat the cooked rice and lentils then stir together."
    },
    {
      "heading": null,
      "description": "Before serving, bring the broth off the heat and leave to slightly cool for a minute. Stir the kefir through the broth then taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Share the rice and lentils between bowls and ladle the broth over. Top each with 3 jammy egg halves and the remaining crispy onions."
    }
  ],
