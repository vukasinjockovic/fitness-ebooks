  "method": [
    {
      "heading": null,
      "description": "Thinly slice the onion and place into a bowl of ice-cold water, set aside."
    },
    {
      "heading": null,
      "description": "Meanwhile, add the beef into a bowl with the oyster sauce, mix together and set aside."
    },
    {
      "heading": null,
      "description": "Bash the ginger, and gently crush the cardamom pods open."
    },
    {
      "heading": null,
      "description": "Place a saucepan onto medium-high heat. Once hot, add the star anise and cardamom, toast until fragrant, then add the ginger with a drizzle of oil. Let it simmer for a couple of seconds before pouring the broth/stock in. Let it come to a boil, then turn the heat down to low to keep it hot. Before serving, taste and season with lime juice and fish sauce."
    },
    {
      "heading": null,
      "description": "Place a frying pan over high heat. Once hot, add the beef and cook until seared."
    },
    {
      "heading": null,
      "description": "Share the cooked rice between bowls. Ladle in the broth, top with the steak strips, onion, coriander and chilli."
    }
