  "method": [
    {
      "heading": null,
      "description": "Thinly slice the shallots and garlic and grate the ginger. Cut the chicken breasts into 1⁄2cm-thin strips."
    },
    {
      "heading": null,
      "description": "Get a large frying pan over a medium-high heat. Add 1 tbsp of the coconut oil, then once melted, add half the chicken to the pan with a pinch of salt. Fry for a few mins until it is browned on all sides, then use tongs to transfer to a bowl. Repeat with the remaining chicken."
    },
    {
      "heading": null,
      "description": "Add the remaining tbsp of coconut oil to the pan, then turn down the heat to low. Add the curry leaves, cumin seeds and black mustard seeds to the pan and cook for 1 min until fragrant. The seeds will pop in the heat, so be careful."
    },
    {
      "heading": null,
      "description": "Add the shallots to the pan, then cook for 5 mins until completely softened. Add the chilli powder, turmeric, garlic and ginger and cook for 1 min more."
    },
    {
      "heading": null,
      "description": "Return the chicken to the pan along with 500ml of water, then bring the curry to a gentle simmer. Cook for 5 mins over a medium-low heat."
    },
    {
      "heading": null,
      "description": "Meanwhile, roughly chop the coriander and peanuts."
    },
    {
      "heading": null,
      "description": "Once your 5 mins are up, add the spinach to the curry and allow it to fully wilt. Stir in the yoghurt and peanut butter and season to taste with salt."
    },
    {
      "heading": null,
      "description": "Sprinkle the curry with the coriander and peanuts and serve."
    }
  ],
