  "method": [
    {
      "heading": null,
      "description": "Finely slice your chicken. Peel and roughly chop your chorizo and place in a bowl with the chicken."
    },
    {
      "heading": null,
      "description": "Add the herbs and spices and season with salt and pepper and set aside."
    },
    {
      "heading": null,
      "description": "Roughly dice your peppers, finely slice your red onion and mince the garlic."
    },
    {
      "heading": null,
      "description": "Place a frying pan on a high heat and fry the chicken and chorizo in veg oil for 5 mins."
    },
    {
      "heading": null,
      "description": "Then add your peppers, onions and garlic and fry for a few mins."
    },
    {
      "heading": null,
      "description": "Remove the contents into a bowl and place the pan back on the heat."
    },
    {
      "heading": null,
      "description": "Drizzle some more veg oil in the pan and add your tortilla."
    },
    {
      "heading": null,
      "description": "Sprinkle a layer of cheese across the bottom on the tortilla and then add some of the chicken and chorizo mixture. Finally top with some extra cheese before putting another tortilla on top."
    },
    {
      "heading": null,
      "description": "Once the bottom tortilla is golden brown use a spatula to flip it to get some colour on the other side. The cheese on either side of the quesadilla will act as glue holding everything together so it doesn’t spill out the sides."
    },
    {
      "heading": null,
      "description": "Once golden on both sides. Cut the quesadilla into quarters and serve with some tomato salsa, sour cream and guacamole. Enjoy!"
    }
  ],
