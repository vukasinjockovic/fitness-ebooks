  "method": [
    {
      "heading": null,
      "description": "Peel and chop the citrus into segments, slices and other random shapes, and add to a bowl along with any excess juice. Finely dice the shallot and lob those in too. Sprinkle in the capers and then season the lot with salt and a splash of olive oil."
    },
    {
      "heading": null,
      "description": "Thinly slice the fennel on a mandolin or with a sharp knife and separate the radicchio leaves, halving or tearing any larger leaves. Combine the marinated citrus with the fennel, bitter leaves, crumbled feta, vinegar and mint."
    },
    {
      "heading": null,
      "description": "Add a good glug of olive oil, season with salt and Aleppo pepper and toss everything together."
    },
    {
      "heading": null,
      "description": "Divide the yoghurt between plates, swoosh across the bottoms, and serve the salad on top. Get stuck in."
    }
  ],
