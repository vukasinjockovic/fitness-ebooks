  "method": [
    {
      "heading": null,
      "description": "Descale and skin the salmon. Dice into small cubes."
    },
    {
      "heading": null,
      "description": "Finely chop the red chilli, ¾ of the ginger and coriander."
    },
    {
      "heading": null,
      "description": "Add the salmon to a bowl along with the juice and zest of ½ the limes, ½ the chopped chilli, ginger and ½ the coriander. Leave this in the fridge to marinate."
    },
    {
      "heading": null,
      "description": "Grate the carrot and shred the red cabbage and savoy cabbage."
    },
    {
      "heading": null,
      "description": "For the slaw dressing, combine the soy sauce, honey, rice wine vinegar, juice of ½ the remaining lime and sesame oil. Grate in the garlic and remaining ginger and give it a mix."
    },
    {
      "heading": null,
      "description": "Massage ½ the dressing into the carrots and cabbage."
    },
    {
      "heading": null,
      "description": "Peel the mangos with a speed peeler and cut down the side of the stone and side into small cubes. Add the remaining chilli and coriander."
    },
    {
      "heading": null,
      "description": "Get a pan on medium to high heat and cook the soft taco shells for 30 seconds. Brush the inside of what will be your taco with a little of the soy dressing. Take the tacos out of the pan."
    },
    {
      "heading": null,
      "description": "Reduce the remaining dressing in your pan over a low heat to make a sticky glaze."
    },
    {
      "heading": null,
      "description": "Get your marinated salmon out of the fridge. Pile up the slaw onto your taco shells before topping with the salmon, mango salsa, and final drizzle of soy glaze. Serve with a lime wedge, if you like. Enjoy."
    }
  ],
