  "method": [
    {
      "heading": null,
      "description": "Coarsely grate the onion and beets into a saucepan. Add a drizzle of olive oil then set the pan over a medium heat. Cook the beet mixture for 3-5 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice garlic and chop the cabbage into 3cm chunks."
    },
    {
      "heading": null,
      "description": "Add the garlic, bay leaf and tomato purée and cook for 3-4 mins until the garlic is fragrant and the tomato paste has darkened. Pour the vegetable stock and vinegar in and let it come to the boil then turn the heat down to a gentle simmer to keep the broth hot until ready to serve. Taste and season with salt, pepper and a dash more of vinegar, if needed."
    },
    {
      "heading": null,
      "description": "Set a frying pan over a high heat. Once hot, add the cabbage and cook for 6-10 mins until starting to char then remove from the heat and stir the butter through. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, reheat the cooked rice. Pick and roughly chop the dill fronds and finely slice the stalks. Fold through the rice. Dissolve the miso in the broth."
    },
    {
      "heading": null,
      "description": "Share the rice between bowls and ladle over the broth. Top with the cabbage and a dollop of soured cream."
    }
  ],
