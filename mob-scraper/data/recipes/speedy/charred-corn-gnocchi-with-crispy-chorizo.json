  "method": [
    {
      "heading": null,
      "description": "Drain the sweetcorn and thinly slice the garlic."
    },
    {
      "heading": null,
      "description": "Brush a cast iron skillet with oil and set over a high heat."
    },
    {
      "heading": null,
      "description": "Add the sweetcorn and cook, stirring occasionally, until charred in places."
    },
    {
      "heading": null,
      "description": "Turn the heat down to low, add the garlic and cook for 1 minute, then transfer to a blender."
    },
    {
      "heading": null,
      "description": "Grate the parmesan."
    },
    {
      "heading": null,
      "description": "Add the parmesan, double cream, whole milk, smoked paprika, cayenne pepper to the corn and season generously with salt and pepper. Blitz until nice and smooth and set aside."
    },
    {
      "heading": null,
      "description": "Finely chop the chorizo. Add it to a pan with a little bit of olive oil and set over a medium heat."
    },
    {
      "heading": null,
      "description": "Cook until some of the fat has rendered out and the chorizo is nice and crisp."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook your gnocchi in plenty of salted boiling water according to the package instructions."
    },
    {
      "heading": null,
      "description": "Drain the gnocchi, reserving some of the cooking water. Add the charred corn sauce and cook over a low heat until the sauce nicely coats the gnocchi, adding some of the gnocchi cooking water as needed."
    },
    {
      "heading": null,
      "description": "Squeeze in the lemon juice and stir to combine. Season with salt and pepper, to taste."
    },
    {
      "heading": null,
      "description": "Plate up the gnocchi, top with the crispy chorizo and basil leaves, then tuck in and enjoy."
    }
  ],
