  "method": [
    {
      "heading": null,
      "description": "Cut the courgettes in half lengthways, then slice into half moons. Cut the red onions into large chunks."
    },
    {
      "heading": null,
      "description": "Place a medium frying pan over medium heat and drizzle with olive oil."
    },
    {
      "heading": null,
      "description": "Once hot, add the red onions, courgettes, smoked paprika, cumin, and coriander to the pan. Grate in the garlic and cook until softened, stirring occasionally. If anything catches on the pan, add a splash of water to deglaze."
    },
    {
      "heading": null,
      "description": "Add the drained chickpeas and cooked rice to the pan. Stir everything together and cook for 2–3 minutes until heated through."
    },
    {
      "heading": null,
      "description": "Season with salt, black pepper, and MSG (if using). Store in a Tupperware container along with your favourite protein, or by itself and pop in the fridge until needed."
    }
  ],
  "tips": [
    "Store leftovers in an airtight container in the fridge for up to 4 days.",
    "To freeze, portion into containers and freeze for up to 3 months. Defrost in the fridge overnight and reheat in a pan or microwave.",
