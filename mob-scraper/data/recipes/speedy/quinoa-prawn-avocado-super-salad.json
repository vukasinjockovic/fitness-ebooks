  "method": [
    {
      "heading": null,
      "description": "Get your quinoa on. It should take 15 minutes in boiling water but check the packet for cooking directions."
    },
    {
      "heading": null,
      "description": "Place the prawns in a bowl. Season with salt and pepper and add 1 tbsp of olive oil. Mix together. Throw the prawns onto a hot griddle pan. They should take 1 ½ minutes on each side."
    },
    {
      "heading": null,
      "description": "In the meantime, cut avocados into small cubes and add to a salad bowl. Peel and de-seed cucumber, chop into small chunks and add that too."
    },
    {
      "heading": null,
      "description": "Once the prawns are pink and cooked through, remove them from the heat and add to a bowl, along with the cooked quinoa. Add a handful of chopped basil."
    },
    {
      "heading": null,
      "description": "Dressing time. Add cider vinegar to a jar with olive oil. Season with salt and pepper. Mix it all together."
    },
    {
      "heading": null,
      "description": "Pour the dressing over the salad, toss it together and serve! Enjoy!"
    }
