  "method": [
    {
      "heading": null,
      "description": "Place a frying pan over a medium heat with a drizzle of olive oil. Drain the corn."
    },
    {
      "heading": null,
      "description": "Split the halloumi down the crease and chop into 2cm chunks. Add to the hot pan along with the corn and cook for 3–4 mins until the halloumi is golden on all sides."
    },
    {
      "heading": null,
      "description": "Meanwhile, reheat the quinoa. Drain and roughly chop the roasted peppers and coriander. Toss the three together with a squeeze of lime and a drizzle of olive oil. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Take the pan off the heat and toss the halloumi with the hot honey. Taste and season with salt, if needed."
    },
    {
      "heading": null,
      "description": "Spoon the quinoa mix onto plates and top with the hot halloumi and corn. Finish with some lime zest and a lime wedge on the side."
    }
