  "method": [
    {
      "heading": null,
      "description": "Thinly slice one of the red onions and place in a small bowl. Add the juice of the lemon, season with a good pinch of salt and scrunch with your hand to quick pickle."
    },
    {
      "heading": null,
      "description": "Finely dice the garlic, ginger and the other onion."
    },
    {
      "heading": null,
      "description": "Heat a splash of vegetable oil in a saucepan over medium heat. Add the cumin seeds and cook for 1 min."
    },
    {
      "heading": null,
      "description": "Add the onion and cook until softened and beginning to brown, then add the garlic and ginger and cook for 1 min."
    },
    {
      "heading": null,
      "description": "Add the garam masala, ground turmeric and Kashmiri chilli powder and cook for 30 seconds. Precise, I know, but ground spices can burn very quickly!"
    },
    {
      "heading": null,
      "description": "Stir in the chutney and transfer to a mixing bowl to cool."
    },
    {
      "heading": null,
      "description": "Heat your oven grill to high."
    },
    {
      "heading": null,
      "description": "Place the sourdough slices on a baking sheet and toast on both sides."
    },
    {
      "heading": null,
      "description": "Meanwhile, grate the Cheddar. Add it to the curry paste with the milk and mix to combine."
    },
    {
      "heading": null,
      "description": "Spread the mixture over the toasts. Pop them back under the grill until melted and bubbling."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the fresh coriander."
    },
    {
      "heading": null,
      "description": "Top the toasts with fresh coriander and some quick pickled onions, then tuck in and enjoy!"
    }
  ],
