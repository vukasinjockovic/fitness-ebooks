  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Super Greens &amp; Garlic Sauce."
    },
    {
      "heading": null,
      "description": "Peel and slice the ginger into thin matchsticks. Thinly slice the chilli."
    },
    {
      "heading": null,
      "description": "Add the olive oil to a small frying pan along with the ginger and chilli. Set over a medium heat and cook until the oil starts to shimmer. Drop in the cumin seeds and let them sizzle for 1 min until fragrant, then take off the heat."
    },
    {
      "heading": null,
      "description": "Pour the Super Greens &amp; Garlic Sauce into a large saucepan set over a medium heat. Add the garam masala and frozen spinach. Cook for 5–6 mins, stirring now and then, until the spinach has fully defrosted and everything’s warmed through."
    },
    {
      "heading": null,
      "description": "Break the feta into bite-sized pieces and stir it through the green sauce. Taste and season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Reheat the rice according to pack instructions, then divide between bowls. Spoon the green feta saag over the top and drizzle with the spiced ginger oil."
    }
