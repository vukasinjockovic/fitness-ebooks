  "method": [
    {
      "heading": null,
      "description": "Shuck the corn to remove the kernels. Slice the jalapeño and remove the seeds if you like less heat."
    },
    {
      "heading": null,
      "description": "In a large blender, add in the heirloom tomatoes, bell peppers, corn kernels, jalapeño slices, and the juice from one lime. Add in the vinegar and olive oil. If you’re using a nutribullet, you’ll have to halve the recipe and blend it in two goes."
    },
    {
      "heading": null,
      "description": "Once it’s all blended, strain the mixture through a fine mesh strainer."
    },
    {
      "heading": null,
      "description": "If your gazpacho is too thick, add 2 tbsp of ice water at a time, as needed, to help the blending process."
    },
    {
      "heading": null,
      "description": "Pour the gazpacho into a bowl, season with salt and pepper to taste, and add olive oil as needed. Set this in the fridge to chill, until you are ready to serve."
    },
    {
      "heading": null,
      "description": "To make the sambol, finely chop the chilli and cherry tomatoes. In a bowl, add in your tomatoes, chilli, and desiccated coconut along with 1 tbsp of lime juice and ½ tsp salt. Mix well."
    },
    {
      "heading": null,
      "description": "To serve, pour the gazpacho into a wide and shallow bowl, top with the sambol and drizzle with olive oil."
    }
  ],
