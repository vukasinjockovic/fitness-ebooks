  "method": [
    {
      "heading": null,
      "description": "Melt the butter in a pan over a medium heat. Finely chop the onions and add along with a pinch of salt. Allow to cook down for about 20 mins until soft and sticky, then add the vinegar and sugar and cook for another 5 mins."
    },
    {
      "heading": null,
      "description": "Mix the ketchup, mustard and curry powder in a small bowl. If you want to make them look a bit fancy, add the mix to a squeezy bottle."
    },
    {
      "heading": null,
      "description": "Cook the sausages until golden brown and cooked through. Meanwhile, slice open the hotdog buns and spread with a layer of the onion jam."
    },
    {
      "heading": null,
      "description": "Load the sausages into the buns, squeeze over the curried ketchup and finish with a sprinkling of finely chopped chives."
    }
