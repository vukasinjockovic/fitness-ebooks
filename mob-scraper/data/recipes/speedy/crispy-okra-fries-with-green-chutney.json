  "method": [
    {
      "heading": null,
      "description": "Start by thoroughly washing your okra and letting it dry completely on a kitchen towel."
    },
    {
      "heading": null,
      "description": "Slice each okra lengthways down the middle once, and then into quarters. Set aside."
    },
    {
      "heading": null,
      "description": "Combine the salt, chilli powder, ground coriander and ground cumin, sprinkle over the sliced okra and mix it all together."
    },
    {
      "heading": null,
      "description": "To make the batter, combine the chickpea flour and potato starch with the spices."
    },
    {
      "heading": null,
      "description": "Split the dry mix into two bowls, adding 230ml of water to one to create a batter."
    },
    {
      "heading": null,
      "description": "Preheat a pot of oil to 180°C."
    },
    {
      "heading": null,
      "description": "Dip the okra in the wet batter and then dry, then deep fry in batches until crispy. This will take 4-5 mins. Scoop out the crispy fries and drain on kitchen paper."
    },
    {
      "heading": null,
      "description": "To make the green chutney, combine all the ingredients in a blender and blitz, season to taste."
    },
    {
      "heading": null,
      "description": "Serve the crispy okra fries with a pot of the zingy green chutney and get stuck in."
    }
  ],
