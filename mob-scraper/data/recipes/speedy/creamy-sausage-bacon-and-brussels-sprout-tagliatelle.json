  "method": [
    {
      "heading": null,
      "description": "Place a large pot of well-salted water onto a boil."
    },
    {
      "heading": null,
      "description": "Slice the bacon into ¼ inch thick strips, add to a large pan on a medium heat."
    },
    {
      "heading": null,
      "description": "After a few mins, crumble the sausage onto your pan. At this point, add your pasta to the pot of boiling water."
    },
    {
      "heading": null,
      "description": "Finely slice the Brussels sprouts and add to your pan. Cook for 4-5 mins until the sausage and bacon is turning golden brown and the sprouts have some good colour. Deglaze with a splash of white wine."
    },
    {
      "heading": null,
      "description": "Reduce the heat to low, add the cream, a tsp of black pepper and half a mug of the pasta cooking water."
    },
    {
      "heading": null,
      "description": "Drain the pasta (saving another mug of the water) and add to the pan. Toss well, adding more water as needed to create a thick, glossy sauce."
    },
    {
      "heading": null,
      "description": "Plate up and serve with grated parmesan and a little more black pepper."
    }
