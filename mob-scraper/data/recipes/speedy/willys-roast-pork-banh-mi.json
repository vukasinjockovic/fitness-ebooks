  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Slice up the cucumber into rounds, coarsely grate the carrot and thinly slice the red onion and chilli. Add to a bowl with the vinegar, 1 tbsp of soy and a pinch of salt to quickly pickle."
    },
    {
      "heading": null,
      "description": "Thinly slice the roast pork and chuck the baguettes into the oven for 5 mins."
    },
    {
      "heading": null,
      "description": "To make the bánh mì sauce, mix the mayo, sriracha, hoisin and remaining soy in a bowl."
    },
    {
      "heading": null,
      "description": "Now slice the baguettes in half lengthways and spread the bottom half with the bánh mì sauce. Top with roast pork and ham and the quick pickles."
    },
    {
      "heading": null,
      "description": "Slice the spring onions and add it to your sandwich with some of the herbs. Spread pâté over the top half of the baguette and smash it on top."
    },
    {
      "heading": null,
      "description": "YUM."
    }
