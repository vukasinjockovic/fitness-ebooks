  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Smoky Chorizo &amp; Pepper Sauce."
    },
    {
      "heading": null,
      "description": "Drain the black beans and tip them into a small saucepan with the chorizo pepper sauce. Set over a medium heat and gently warm through, stirring now and then."
    },
    {
      "heading": null,
      "description": "Meanwhile, pick the coriander leaves and set aside."
    },
    {
      "heading": null,
      "description": "Place a frying pan over a medium heat with a drizzle of olive oil. Once hot, scatter in the crumbled feta, then crack the eggs straight over the top. Let them cook until the whites are set and the feta is golden and crisp around the edges. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Spoon the hot beans onto plates and top with the feta fried eggs. Finish with the coriander leaves and serve up."
    }
  ],
