  "method": [
    {
      "heading": null,
      "description": "Halve your hot cross buns."
    },
    {
      "heading": null,
      "description": "Crack your eggs into a bowl and add your milk, caster sugar and cinnamon. Beat with a fork until you have a totally combined mixture."
    },
    {
      "heading": null,
      "description": "Pop a knob of butter in a large frying pan and heat it over a medium-high heat."
    },
    {
      "heading": null,
      "description": "Dip your hot cross buns in the egg mixture, turning so that all sides are coated."
    },
    {
      "heading": null,
      "description": "Place your hot cross buns in the frying pan a few at a time, frying for 2 mins on each side until golden."
    },
    {
      "heading": null,
      "description": "Time to plate up. Arrange your hot cross buns on a plate and top with a dollop of yoghurt. Slice your banana onto the plate, then drizzle with honey. Serve and enjoy."
