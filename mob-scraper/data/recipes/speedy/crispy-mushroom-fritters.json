  "method": [
    {
      "heading": null,
      "description": "Trim the enoki, place them into a bowl and pull them into smaller chunks. Tear the remaining mushrooms into similar sizes and add them to the enoki. Tear up the sheet of nori into small flakes and add to the mushrooms."
    },
    {
      "heading": null,
      "description": "Add both flours along with your smoked paprika, sesame seeds, and 1 tsp of salt into the mushrooms. Toss well."
    },
    {
      "heading": null,
      "description": "Whisk the egg with the sparkling water together, then pour onto the mushrooms and toss well, until the flours have rehydrated and the mushrooms are covered in a paste."
    },
    {
      "heading": null,
      "description": "Fill a deep saucepan halfway up with oil. Place it over a high heat and heat to 180°C. Line a plate with kitchen paper."
    },
    {
      "heading": null,
      "description": "Drop batches of the mushroom batter into the oil and cook for 2-4 mins until crispy."
    },
    {
      "heading": null,
      "description": "Mix the mayo with your chilli oil, set aside."
    },
    {
      "heading": null,
      "description": "Serve the crispy mushroom fritters with the spicy mayo and a side of Spotify's Mushroom Jazz Mix playlist."
    }
  ],
