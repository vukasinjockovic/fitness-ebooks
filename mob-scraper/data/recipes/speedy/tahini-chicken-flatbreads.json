  "method": [
    {
      "heading": null,
      "description": "Finely chop all of the herbs and add to a large bowl along with the tahini, a tablespoon of water and the juice of half a lemon. Drizzle in two tablespoons of olive oil and mix well. Set aside."
    },
    {
      "heading": null,
      "description": "Grate the clove of garlic into the greek yoghurt, add a tablespoon of water and a pinch of salt. Mix."
    },
    {
      "heading": null,
      "description": "Drizzle the Impeckable Chicken Breasts with a splash of olive oil and toss in the ras el hanout."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium high heat and add a drizzle of olive oil."
    },
    {
      "heading": null,
      "description": "Add the Impeckable Chicken Breasts and cook for about 3 mins on each side until golden brown, remove and slice into roughly 1cm-thick slices."
    },
    {
      "heading": null,
      "description": "Spread the yoghurt over the flatbreads, top with the Chicken Breasts, drizzle over the tahini sauce and add a spoonful of pickled cabbage."
    },
    {
      "heading": null,
      "description": "Sprinkle over the chilli flakes, drizzle with olive oil and serve with a wedge of lime."
    }
  ],
