  "method": [
    {
      "heading": null,
      "description": "Wash the red lentils at least 3 times in warm water until the water comes out clear. Place in a large pot with the water and boil for 15 minutes."
    },
    {
      "heading": null,
      "description": "Blend the chopped tomatoes in a hand blender."
    },
    {
      "heading": null,
      "description": "In a mortar and pestle, bash the ginger, garlic and half of the chilli powder to form a thick paste."
    },
    {
      "heading": null,
      "description": "In a large pan, pour two glugs of vegetable oil and heat on medium. Add in the black mustard seeds and cumin seeds. Once they start bubbling add in the chopped tomatoes. Quickly pop a lid on - they will spit out so be careful."
    },
    {
      "heading": null,
      "description": "Add in the turmeric, cumin powder, coriander powder, the rest of the chilli powder, the salt and the pounded garlic and ginger paste. Cook on a medium heat for 10 minutes, stirring frequently."
    },
    {
      "heading": null,
      "description": "Thinly slice 6 cloves of garlic and the jalepenos, finely chop the coriander and chop 4cm ginger into matchsticks."
    },
    {
      "heading": null,
      "description": "For the garlicky oil, heat up the vegetable oil in a small pan and gently cook the thinly sliced garlic and curry leaves until golden."
    },
    {
      "heading": null,
      "description": "To check if the dhal is cooked, press a few grains between your fingers to feel if they are tender. Drain the dhal and add it into the curried tomatoes. Add in a mug or so more of water and continue cooking for 2 minutes. Season to taste and stir in ¾ of the coriander."
    },
    {
      "heading": null,
      "description": "Pour over garlicky oil over the dhal and put a lid on to allow the garlic flavour to infuse through."
    },
    {
      "heading": null,
      "description": "Finish with the remaining ginger, chopped chilli and coriander and serve with a big bowl of rice or just on its own."
    }
  ],
