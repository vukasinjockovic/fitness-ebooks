  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Finely slice the red pepper and roughly chop the basil, saving a few leaves for serving."
    },
    {
      "heading": null,
      "description": "Tear off one large sheet of parchment paper per portion and lay them in front of you, facing portrait."
    },
    {
      "heading": null,
      "description": "Divide the grains between the parchment sheets, then scatter over the peppers, olives and chunks of tofu, leaving a 10cm gap between the food and the edge closest to you. Season with salt and black pepper and drizzle with olive oil. Spoon over the red pesto, Fold the top half of the baking paper over the food then fold the outside edges over each other to seal (like a cornish pasty), creating a steam-tight parcel. Bake for 20 mins."
    },
    {
      "heading": null,
      "description": "Remove from the oven, carefully open your parcel, give it all a quick mix and top with the reserved basil leaves. Dig in!"
    }
