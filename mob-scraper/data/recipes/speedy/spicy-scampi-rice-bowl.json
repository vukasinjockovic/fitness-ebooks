  "method": [
    {
      "heading": null,
      "description": "Cook the scampi following the pack instructions until super golden and crunchy."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the red onion and chuck it into a bowl with a pinch of salt and the juice of half a lime. Scrunch with clean hands for a minute until it turns bright pink. Set aside."
    },
    {
      "heading": null,
      "description": "Tip the kale into a mixing bowl. Use the juice of the other half of the lime, add a pinch of salt and massage for a minute until softened. Use a mandolin to finely shave in the brussels sprouts, then toss everything together."
    },
    {
      "heading": null,
      "description": "Cut carrots into matchsticks (or grate if easier)"
    },
    {
      "heading": null,
      "description": "In a small bowl, mix the sriracha, mayo and the juice of half a lime. Give it a taste and adjust the heat if needed."
    },
    {
      "heading": null,
      "description": "Heat the coconut rice following the pack instructions and divide between two bowls."
    },
    {
      "heading": null,
      "description": "Arrange the scampi, pickled onions, sprout-kale slaw and carrot on top of the rice in little piles. Drizzle over the sriracha mayo and finish with a scattering of coriander."
    }
