  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion, celery and tomatoes. Rinse the capers. Drizzle the diced aubergine with olive oil and season with salt and pepper. Cook in the air fryer on roast function at 190°C for 15 mins or until tender and slightly browned."
    },
    {
      "heading": null,
      "description": "Heat a splash of olive oil in a medium pan over a medium heat. Add the onion and celery and fry gently for 5 mins, stirring often."
    },
    {
      "heading": null,
      "description": "Add the diced tomatoes, olives and capers to the pan. Simmer over a medium heat for 15 mins, stirring occasionally. Add a splash of water if it’s too dry."
    },
    {
      "heading": null,
      "description": "In a small bowl, combine the vinegar and sugar and add it to the pan. Season and add more vinegar or sugar depending on how acidic or sweet you like it."
    },
    {
      "heading": null,
      "description": "When the aubergines are finished roasting in the air fryer, add them to the pan along with the butter beans, and tear in the fresh basil leaves. Stir to combine and leave for five mins to heat through. Remove from the heat and leave to sit for another 5 mins."
    },
    {
      "heading": null,
      "description": "Divide between bowls and serve with toasted sourdough, if you like."
    }
  ],
