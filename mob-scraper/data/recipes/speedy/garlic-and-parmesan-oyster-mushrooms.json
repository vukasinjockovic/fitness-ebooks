  "method": [
    {
      "heading": null,
      "description": "Combine the garlic powder with 1 tsp of salt. Finely chop the parsley."
    },
    {
      "heading": null,
      "description": "Get a large pot of oil heating on medium-high heat, ready for deep frying."
    },
    {
      "heading": null,
      "description": "Place your flour in a bowl, crack the eggs in another, and fill the third bowl with panko breadcrumbs. Season them all with salt."
    },
    {
      "heading": null,
      "description": "Dunk the mushrooms in flour and then the eggs and finally press on the panko breadcrumbs."
    },
    {
      "heading": null,
      "description": "Deep fry the mushrooms for 3 mins until golden brown and crispy."
    },
    {
      "heading": null,
      "description": "Toss them in the garlic salt, grate on lots of parmesan on both sides of the mushroom and sprinkle with parsley."
    },
    {
      "heading": null,
      "description": "Eat whilst still hot and enjoy the beautiful crunch."
