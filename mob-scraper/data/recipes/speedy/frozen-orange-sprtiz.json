  "method": [
    {
      "heading": null,
      "description": "Pour your Aperol and orange juice into an ice cube tray and freeze for 4-5 hours or overnight. Freeze your strawberries at the same time."
    },
    {
      "heading": null,
      "description": "Peel some rind off your grapefruit using a peeler and then juice it."
    },
    {
      "heading": null,
      "description": "Add your frozen Aperol, orange juice, strawberries, grapefruit juice and Prosecco into a blender with the crushed ice."
    },
    {
      "heading": null,
      "description": "Blend until it has a slushy consistency."
    },
    {
      "heading": null,
      "description": "Wrap up the grapefruit rind tightly and spear it with a cocktail stick for garnish."
    }
