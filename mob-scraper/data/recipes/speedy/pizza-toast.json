  "method": [
    {
      "heading": null,
      "description": "Preheat the grill to high."
    },
    {
      "heading": null,
      "description": "Thinly slice the garlic cloves and add to a cold pan. Thinly slice the red onion and add half to the pan. Cover with olive oil and set over a medium heat. Cook until the onions and garlic are golden brown, 10-12 mins. Meanwhile, halve the cherry tomatoes using a couple of small plates. Add a handful of tomatoes to the bottom plate and place the second, facedown over the tomatoes. Run a bread knife through the middle, halving all the tomatoes at once."
    },
    {
      "heading": null,
      "description": "Slice the ciabatta in half, rub with oil and grate over half of the cheese. Slide under the grill until golden brown."
    },
    {
      "heading": null,
      "description": "Fish the crispy garlic and onions out of the pan and tip in the tomatoes. Cook for 2 mins in the hot oil and add a big pinch of salt and the sherry vinegar. Cook for 30 secs and add the remaining red onion and basil. Season and toss everything together."
    },
    {
      "heading": null,
      "description": "Add the bread to four plates and top with the warm tomatoes. Scatter over the crispy garlic and onion oil and serve topped with remaining grated cheese."
    }
  ],
