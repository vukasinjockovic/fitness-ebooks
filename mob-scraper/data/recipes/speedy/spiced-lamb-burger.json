  "method": [
    {
      "heading": null,
      "description": "Peel and thinly slice the red onion into rings. Separate the rings and pop them into a heatproof bowl."
    },
    {
      "heading": null,
      "description": "Add the vinegar and sugar to a small saucepan and bring to a boil. Add 30ml of water, a bay leaf and the coriander seeds. Pour over the onions and set aside."
    },
    {
      "heading": null,
      "description": "Combine the lamb, harissa, and smoked paprika in a mixing bowl. Season with salt and mix thoroughly for 2-3 mins."
    },
    {
      "heading": null,
      "description": "Fry off a small piece and taste for seasoning. Add a little more salt or spice if you fancy, and form into four burger patties."
    },
    {
      "heading": null,
      "description": "Slice up your feta, drain your pickled onions, and wash the watercress."
    },
    {
      "heading": null,
      "description": "Coarsely grate the cucumber, season with salt and squeeze over a sieve to remove the excess moisture."
    },
    {
      "heading": null,
      "description": "Add to a bowl with the yoghurt, season with salt and mix."
    },
    {
      "heading": null,
      "description": "Toast off your buns and slice up and season the tomato with salt, pepper and olive oil."
    },
    {
      "heading": null,
      "description": "Preheat your cast iron pan over a medium-high heat."
    },
    {
      "heading": null,
      "description": "Cook the burgers, giving them a gentle smash as they hit the pan, until they’re sitting around medium doneness. This should take about 4-5 mins on each side."
    },
    {
      "heading": null,
      "description": "Now, time to build. Start with the bottom bun, a spoon of the cucumber yoghurt, top with a slice of tomato and the lamb burger. Now add some sliced feta, a handful of pickled onions and watercress. Finish with more cucumber yoghurt and the lid."
    },
    {
      "heading": null,
      "description": "Smash it in half, and get stuck in."
    }
  ],
