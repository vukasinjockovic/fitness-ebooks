  "method": [
    {
      "heading": null,
      "description": "Chop up your Brussels sprouts in half and then slice thinly and slice your onions. Roughly chop the coriander, finely chop the chilli and grate the ginger. Finally, crush the cumin seeds and black pepper."
    },
    {
      "heading": null,
      "description": "In a bowl combine turmeric, chilli powder, coriander, chilli, ginger, cumin, black pepper, gram flour and water with 1 tsp of salt. Mix well and then add the onions and Brussels sprouts. This should create a thick batter."
    },
    {
      "heading": null,
      "description": "Heat up a wok about halfway of oil."
    },
    {
      "heading": null,
      "description": "Using a spoon, drop in small balls of the batter and fry for 2 minutes on either side until golden brown. Drain on paper towels."
    },
    {
      "heading": null,
      "description": "For the chutney, roughly chop the mint and peel the ginger. In a bowl mix the cranberry sauce, honey and water. Grate in the ginger, add the mint and squeeze in the lemon juice. Mix well and enjoy with your crispy pakoras."
    }
  ],
