  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 220°C / fan 200°C."
    },
    {
      "heading": null,
      "description": "Pat the tofu dry with kitchen towel then cut into 2cm cubes. Place in a bowl, season lightly with salt and pepper, drizzle with vegetable oil and toss to coat. Arrange in a single layer in a large roasting tin."
    },
    {
      "heading": null,
      "description": "Quarter the tenderstem broccoli. Remove the root and quarter the pak choi. Core the bell peppers and cut into medium-sized chunks. Quarter the spring onions."
    },
    {
      "heading": null,
      "description": "Place the veg in a separate large baking tray. Drizzle with vegetable oil, season with salt and pepper and toss to coat. Arrange in a single layer; some overlap is ok."
    },
    {
      "heading": null,
      "description": "Roast the tofu and veg for 15 minutes, or until the tofu is golden and the veg is cooked and charred in places."
    },
    {
      "heading": null,
      "description": "Meanwhile, crush the sesame seeds with a pestle and mortar. Add the apple cider vinegar, honey and white miso paste, along with the juice of the lime and 4 tablespoons of vegetable oil. Whisk until well-combined."
    },
    {
      "heading": null,
      "description": "Thinly slice the red chilli and pick the coriander leaves."
    },
    {
      "heading": null,
      "description": "To assemble the dish, place the tofu and veg in a large bowl. Top with the red chilli, coriander leaves and as much of dressing as you'd like. Enjoy!"
    }
  ],
