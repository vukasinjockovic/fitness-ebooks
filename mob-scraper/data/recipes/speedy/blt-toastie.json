  "method": [
    {
      "heading": null,
      "description": "Lay the bacon in an even layer in a large, cold frying pan. Set the pan over a medium heat and allow the bacon fat to render and the rashers to crisp. This should take between 10-11 mins."
    },
    {
      "heading": null,
      "description": "Remove the crispy bacon from the pan, leaving the residual fat, this is what we'll use to cook our toasties."
    },
    {
      "heading": null,
      "description": "Thickly slice the tomatoes and season generously with salt and black pepper. Separate the lettuce into leaves and coarsely grate the cheddar cheese."
    },
    {
      "heading": null,
      "description": "To build your sandwiches, start with a slice of sourdough, top with mayo, black pepper, cheese, bacon, a couple of thick slices of tomato, more cheese and crown with a mayo'd lid."
    },
    {
      "heading": null,
      "description": "Cook the sandwiches over a medium heat in the bacon fat, turning regularly, for 10-12 mins until fully melted and warm all the way through."
    },
    {
      "heading": null,
      "description": "Dress the lettuce with olive oil, salt and lemon and serve on the side of your warm, gooey BLT toasties for a hit of fresh crunch."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
