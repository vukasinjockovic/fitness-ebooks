  "method": [
    {
      "heading": null,
      "description": "Cut one avocado in half, remove the pit and scoop out the flesh\ninto a mini food processor. Cut the lemons in half and squeeze all\nthe juice into the food processor. Add the ground coriander,\na generous pinch of salt, some black pepper, a glug of extra virgin\nolive oil and chilli flakes to taste. Blitz to a dressing."
    },
    {
      "heading": null,
      "description": "Tip the dressing into a large serving bowl. Add the bag of kale.\nUse your hands to massage the dressing into the kale. Set aside."
    },
    {
      "heading": null,
      "description": "Halve, pit, peel and slice the remaining avocado. Pile on top of the\nsalad. Do not mix."
    },
    {
      "heading": null,
      "description": "Get a dry frying pan over a medium heat and add the mixed\nseeds. Let the seeds toast while you deseed and roughly chop\nthe yellow peppers and chop the radishes. Tip the veg and\ntoasted seeds into the salad."
    },
    {
      "heading": null,
      "description": "Crumble over the feta and give everything a toss to combine.\nAdjust the seasoning to taste, then serve the salad at the table for\npeople to help themselves."
    }
  ],
