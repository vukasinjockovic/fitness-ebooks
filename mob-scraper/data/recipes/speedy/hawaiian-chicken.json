  "method": [
    {
      "heading": null,
      "description": "Cut your chicken thighs into chunks and add to a bowl. Add cornflour, salt &amp; pepper. Mix together."
    },
    {
      "heading": null,
      "description": "Heat oil in a large wok (or large frying pan). When the oil is hot, add the chicken and cook until golden. Remove the chicken and wipe down the pan."
    },
    {
      "heading": null,
      "description": "Slice up your onions and peppers and add them to the pan with a splash of olive oil. Once the onions have softened, add the chicken again."
    },
    {
      "heading": null,
      "description": "Drain the pineapple (but reserve the juice). Add the pineapple chunks to the wok and cook for a further two minutes. Grate your ginger and slice your garlic, then stir in and cook for a further minute."
    },
    {
      "heading": null,
      "description": "Combine the reserved pineapple juice, soy sauce, lime juice, sriracha and the tomato puree in a bowl. Mix together and add to the wok."
    },
    {
      "heading": null,
      "description": "Continue cooking on a high heat until the sauce is nice and thick. Once cooked, turn off the heat and serve over boiled rice. Sprinkle with coriander and tuck in!"
    }
  ],
