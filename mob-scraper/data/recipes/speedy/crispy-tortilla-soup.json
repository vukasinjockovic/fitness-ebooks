  "method": [
    {
      "heading": null,
      "description": "Add the crispy onions, chipotle paste and garlic purée to a saucepan with a drizzle of olive oil. Set over a medium heat and stir-fry for 1-3 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Pour in the passata, stock and kidney beans (including the liquid from the can). Turn the heat up to high, bring to the boil and let it simmer for 5 mins."
    },
    {
      "heading": null,
      "description": "Taste and season with salt and a good squeeze of lime juice."
    },
    {
      "heading": null,
      "description": "Ladle the soup into bowls. Top with grated cheese, some lightly crushed tortilla crisps and coriander leaves. Serve with any remaining lime wedges on the side."
    }
