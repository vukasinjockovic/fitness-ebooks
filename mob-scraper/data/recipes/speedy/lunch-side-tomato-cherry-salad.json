  "method": [
    {
      "heading": null,
      "description": "Thinly slice the shallots into rounds, separating the rounds into individual rings. Tip into a bowl and add the vinegar. Set aside for 5 mins to quickly pickle."
    },
    {
      "heading": null,
      "description": "Now it’s time to marinate the other veggies. Chop the tomatoes into random chunks and toss into a bowl. Thinly slice your courgette and add to the bowl. Pit the cherries and add to the bowl"
    },
    {
      "heading": null,
      "description": "Season well with salt and pepper. Tear in the dill and toss through olive oil, stir the shallots through the salad. Leave this to hang out for 30 mins."
    },
    {
      "heading": null,
      "description": "Serve the salad with your favourite protein and base."
    }
