  "method": [
    {
      "heading": null,
      "description": "Katsu mayo time. Add mayo, veggie stock cube, garam masala, curry powder and runny honey to a bowl. Mix well and set aside."
    },
    {
      "heading": null,
      "description": "Zingy slaw. Grate your radishes and half a cabbage. Add to a bowl with sesame oil, the juice of a lime and a large handful of chopped coriander. Mix everything together and set aside."
    },
    {
      "heading": null,
      "description": "Chicken time. Get three bowls out. Add flour to one, eggs to another (whisk them up) and breadcrumbs to the third. Dip your chicken thigh in flour, followed by the eggs and then the breadcrumbs."
    },
    {
      "heading": null,
      "description": "Get a pan on the heat and add a very large glug of vegetable oil. Once the oil is hot, add your chicken thighs. Cook for 4 minutes on each side until the breadcrumbs are golden. Keep turning the chicken until it is cooked through."
    },
    {
      "heading": null,
      "description": "Toast your brioche buns."
    },
    {
      "heading": null,
      "description": "Assemble time. Add a very large dollop of katsu mayo to your bun. Add your chicken. Add a large spoonful of the zingy slaw. Dollop some more katsu mayo on the top half of the bun and place that on top of the burger. Take a bite and enjoy!"
    }
  ],
