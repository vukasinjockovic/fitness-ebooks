  "method": [
    {
      "heading": null,
      "description": "Chop up your potatoes into small chunks and parboil for 10 minutes and remove when still slightly al dente."
    },
    {
      "heading": null,
      "description": "In a separate pan, heat a large glug of oil, add your sausages and fry until browned."
    },
    {
      "heading": null,
      "description": "Finely chop the onion and dice your black pudding and bacon. Then add these to the sausages along with the drained potatoes."
    },
    {
      "heading": null,
      "description": "Remove the sausages and set them aside."
    },
    {
      "heading": null,
      "description": "Chop the mushrooms and tomatoes into small chunks, then toss them into the dish and give it a good stir."
    },
    {
      "heading": null,
      "description": "Slice the sausages into bite-sized pieces, add them back into the dish and mix it together."
    },
    {
      "heading": null,
      "description": "Crack in your eggs, then cover with foil for 6 minutes."
    },
    {
      "heading": null,
      "description": "Remove the foil, serve up and season with salt and pepper. Enjoy!"
    }
