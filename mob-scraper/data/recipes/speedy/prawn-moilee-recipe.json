  "method": [
    {
      "heading": null,
      "description": "Put the prawns, turmeric and a squeeze of lime into a bowl. Season with salt and pepper. Marinate for 15 mins."
    },
    {
      "heading": null,
      "description": "Thinly slice the garlic. Mince the ginger. Halve the tomatoes (if using) and green chillies."
    },
    {
      "heading": null,
      "description": "Place a frying pan over a medium heat and add the coconut oil. Once hot, add the fenugreek seeds if using, mustard seeds and curry leaves. Once they all sizzle, add the shallots, ginger and garlic, season with salt and give it a good stir. Cook for 2-4 mins until softened."
    },
    {
      "heading": null,
      "description": "Pour in the coconut milk followed by the prawns, tomatoes and green chillies. Reduce the heat to low, then simmer for 10 mins."
    },
    {
      "heading": null,
      "description": "Serve with a drizzle of chilli oil on top."
    }
  ],
