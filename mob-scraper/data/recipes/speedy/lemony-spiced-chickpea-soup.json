  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion before grating or mincing the garlic and ginger. Zest the lemons and slice them in half. Set aside."
    },
    {
      "heading": null,
      "description": "Drain and rinse two cans of chickpeas."
    },
    {
      "heading": null,
      "description": "Add 2 tbsp of oil to a medium pan and sauté the onion for 3-5 mins, then add the spices, chilli flakes, ginger, and garlic."
    },
    {
      "heading": null,
      "description": "Sauté for a further 2 mins and then add the drained chickpeas. Fry for 5-8 mins, stirring often, until the chickpeas start to soften and slightly crisp up. Remove 3-4 tbsp of chickpeas from the pot and save on the side for garnish."
    },
    {
      "heading": null,
      "description": "Add the coconut milk and stock and stir well."
    },
    {
      "heading": null,
      "description": "If you like, you can use a potato masher to mash some of the chickpeas in the soup. This will give it a chunky texture. Stir through the spinach."
    },
    {
      "heading": null,
      "description": "Simmer for 10 mins and then add the juice and zest of the two lemons. Start with one and taste it, adding more to your liking. Season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "To serve, ladle the soup into two bowls, topping with a big dollop of coconut yogurt and some fresh mint leaves, if using. Finish with a sprinkle of chilli flakes if you like."
    }
  ],
