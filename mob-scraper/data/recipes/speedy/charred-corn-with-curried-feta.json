  "method": [
    {
      "heading": null,
      "description": "Finely chop ¾ of the coriander and 1 of the cloves of garlic, then combine with 100g of the feta, the mayonnaise, sour cream and curry powder in a large bowl. Mix well until creamy."
    },
    {
      "heading": null,
      "description": "Finely slice the remaining 2 cloves of garlic and set aside."
    },
    {
      "heading": null,
      "description": "Heat a griddle pan over a high heat. Grill the corn on all sides until it has some good colour and char and is cooked through."
    },
    {
      "heading": null,
      "description": "Slather all over with the cheese mix and pop onto a plate. Squeeze over the lime, sprinkle with the remaining coriander and crumble over the rest of the feta."
    },
    {
      "heading": null,
      "description": "Heat 3 tbsp of neutral oil in a small saucepan over a medium heat. Add the sliced garlic and fry for 2 mins until just turning brown."
    },
    {
      "heading": null,
      "description": "Add the cumin and mustard seeds and fry for another 30 seconds. Add the chilli powder and remove from the heat, pour over the corn and serve hot."
    },
    {
      "heading": null,
      "description": "Season to taste with a pinch of salt and finish with another dash of chilli powder, if you like."
    }
  ],
