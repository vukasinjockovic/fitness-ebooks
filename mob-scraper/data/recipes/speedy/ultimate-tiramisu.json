  "method": [
    {
      "heading": null,
      "description": "Make the coffee by dissolving the espresso powder into the boiling water. Set aside."
    },
    {
      "heading": null,
      "description": "Get the double cream, mascarpone, marsala wine and caster sugar in a mixing bowl. Use an electric whisk to beat until you have a smooth mixture the consistency of thick whipped cream. You can also do this by hand, but it will take longer."
    },
    {
      "heading": null,
      "description": "Pour your coffee into a shallow dish, then dip in your sponge fingers, a few at a time, turning each for a few seconds until they are soaked but not soggy."
    },
    {
      "heading": null,
      "description": "Place a layer of soaked sponge fingers into a large shallow dish until you’ve used half of the fingers, then spread over half of the creamy mixture. Coarsely grate most of the dark chocolate over the top."
    },
    {
      "heading": null,
      "description": "Repeat the layers, using up all the coffee, and finishing with a layer of boozy cream."
    },
    {
      "heading": null,
      "description": "Cover the tiramisu with tin foil and chill in the fridge for 2 hours or overnight."
    },
    {
      "heading": null,
      "description": "When ready to serve - dust with the cocoa powder and grate over the remainder of the chocolate."
    }
  ],
