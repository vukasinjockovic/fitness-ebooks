  "method": [
    {
      "heading": null,
      "description": "Place a frying pan over a high heat. Once hot, add the beef mince and frozen onion. Break the mince up and cook, stirring occasionally, for 3–5 mins until browned."
    },
    {
      "heading": null,
      "description": "Meanwhile, drain the roasted peppers and roughly chop into bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Stir the garlic purée and garam masala through the beef and cook for 1 min until fragrant. Toss in the kale and chopped peppers, and cook for another 1–2 mins until the kale has wilted."
    },
    {
      "heading": null,
      "description": "Season with salt, squeeze in the lemon juice and drizzle over the honey. Mix everything together well."
    },
    {
      "heading": null,
      "description": "Spread the hummus across the base of two shallow bowls. Top with the beef mixture and serve with flatbreads on the side."
    }
  ],
