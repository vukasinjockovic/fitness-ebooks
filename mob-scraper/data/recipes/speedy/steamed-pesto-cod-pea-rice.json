  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Lay out one large rectangle of baking paper (per person), portrait."
    },
    {
      "heading": null,
      "description": "Divide the rice, frozen peas, and cumin seeds in a single layer on the bottom half of the paper leaving a 10cm gap between the edge closest to you and the food. Drizzle with olive oil, season with salt and black pepper, then mix everything together. Top with the tenderstem and the cod, followed by a spoon of pesto. Fold the top half of the baking paper over the food then fold the outside edges over each other to seal (like a Cornish pasty), creating a steam-tight parcel. Repeat with the remaining ingredients."
    },
    {
      "heading": null,
      "description": "Bake for 18–20 mins, depending on the thickness of your cod. Once cooked, carefully open the parcel and scatter over the parsley and chilli flakes before serving."
    }
  ],
