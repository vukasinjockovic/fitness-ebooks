  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 160°C. Peel and grate the ginger and garlic. Add to a bowl with the soy sauce, the zest of the lime and the juice of half of it. Pat the salmon fillets dry, then spoon over the marinade. Leave to marinate for 10 mins."
    },
    {
      "heading": null,
      "description": "Finely slice the chilli. Cut the remaining lime into wedges. Lay out a large sheet of parchment paper per person, portrait. Add the rice and kale, then place the salmon on top, leaving a 10cm gap between the food and the edge closest to you. Drizzle over any leftover marinade. Scatter with the sesame seeds and chilli."
    },
    {
      "heading": null,
      "description": "Fold the top half of the baking paper over the food then fold the outside edges over each other to seal (like a cornish pasty), creating a steam-tight parcel. Bake for 15–20 mins, depending on the thickness of your salmon."
    },
    {
      "heading": null,
      "description": "Remove from the oven and serve with the lime wedges on the side."
    }
  ],
