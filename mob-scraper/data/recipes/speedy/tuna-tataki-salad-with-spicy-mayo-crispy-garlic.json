  "method": [
    {
      "heading": null,
      "description": "Slice the garlic. Heat the vegetable oil in a small frying pan set over a medium heat. Once hot, add the sliced garlic and fry for 1–2 mins until golden. Lift out with a slotted spoon and drain on kitchen paper. Sprinkle with a pinch of salt and set aside."
    },
    {
      "heading": null,
      "description": "Juice the lemon into a bowl and add the remaining ponzu dressing ingredients. Whisk together until combined, then set aside."
    },
    {
      "heading": null,
      "description": "In a separate bowl, mix the mayo and sriracha with lime zest and half the lime juice, until smooth. Taste and add extra lime juice if needed. Set aside."
    },
    {
      "heading": null,
      "description": "Prep the veg. Thinly slice the onion and cucumber, halve the cherry tomatoes and slice the avocado. Pick the coriander leaves from their stems and set aside."
    },
    {
      "heading": null,
      "description": "Add the onion, tomato, cucumber, salad leaves, and coriander to a serving bowl and toss to combine. \nDrain the tuna, tear it into chunks, and scatter over the top. Fan out the sliced avocado, then dollop over the spicy mayo. \nDrizzle with the ponzu dressing and finish with the crispy garlic chips and a sprinkle of sesame seeds."
    }
  ],
  "tips": [
    "The dressing and mayo can be made ahead and stored in the fridge for 2–3 days.",
    "If you’re not into raw onion, soak it in a little cold water to mellow the flavour."
  ],
