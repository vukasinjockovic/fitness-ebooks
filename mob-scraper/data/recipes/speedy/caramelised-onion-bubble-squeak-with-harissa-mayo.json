  "method": [
    {
      "heading": null,
      "description": "Thinly slice your red onions and toss them into a pan with a shot of oil. Set over a medium heat. Season with salt and add the cumin seeds. Cook for 10 mins until softened and caramelised."
    },
    {
      "heading": null,
      "description": "Remove the core from the hispi cabbage and thinly slice the leaves. Add to the pan with the thyme and cook for 3 mins until wilted."
    },
    {
      "heading": null,
      "description": "Roughly chop your parsley."
    },
    {
      "heading": null,
      "description": "Add the leftover mash, most of the parsley and the zest from the lemon and fold everything together. Taste and add salt and pepper to taste."
    },
    {
      "heading": null,
      "description": "Now preheat a large non-stick pan over medium heat. Add a splash of oil and a quarter of the mix. Form into a patty and cook for 4 mins on each side until crispy. Transfer to a low oven to keep warm and repeat with the rest of the mix."
    },
    {
      "heading": null,
      "description": "Mix together the vegan mayo and harissa with a squeeze of lemon juice. Season to taste."
    },
    {
      "heading": null,
      "description": "Serve topped with the remaining parsley and a big dollop of harissa mayo."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
