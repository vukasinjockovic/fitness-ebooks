  "method": [
    {
      "heading": null,
      "description": "Chop the tomatoes into chunks, add a big pinch of salt and rub together. This will remove the excess water. Place the colander over a bowl and allow to sit for 15 minutes."
    },
    {
      "heading": null,
      "description": "Dressing time. Add the olive oil, red wine vinegar, a tsp of salt, pepper and a tsp of chilli flakes into a jar. Shake until completely combined."
    },
    {
      "heading": null,
      "description": "Chop up your mozzarella, and avocados into big chunks and add them into a bowl along with the tomatoes."
    },
    {
      "heading": null,
      "description": "Finely chop your basil and scatter over (saving some for garnish). Pour over your dressing and toss all together."
    },
    {
      "heading": null,
      "description": "Serve up and garnish with more chilli flakes, salt, pepper and the leftover basil. Tuck in!"
    }
