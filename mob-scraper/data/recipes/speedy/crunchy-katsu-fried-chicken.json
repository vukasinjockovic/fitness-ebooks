  "method": [
    {
      "heading": null,
      "description": "Season the chicken thighs with salt and black pepper and set up 3 bowls. Add 100g of flour to one, crack the two eggs into another and pop the panko breadcrumbs into the third. Beat the eggs with a splash of cold water and a big pinch of salt."
    },
    {
      "heading": null,
      "description": "Pass the chicken thighs through the flour, egg and breadcrumbs to coat. Set the chicken aside."
    },
    {
      "heading": null,
      "description": "To make the gravy, add the butter to a saucepan and cook over a medium heat until nutty brown, then add the flour and cook for 2 mins. Throw in the spices and cook for 4-5 mins then gradually add the chicken stock, whisking constantly. Season with salt and pepper and keep warm."
    },
    {
      "heading": null,
      "description": "Finely shred the cabbage and red onion and coarsely grate the carrot. Add to a large mixing bowl with the vinegar and mayo. Season with salt and black pepper and toss to combine."
    },
    {
      "heading": null,
      "description": "Heat a good glug of oil in a frying pan and add the breaded chicken. Cook over medium heat for 4-5 minutes on each side, until nicely golden and cooked through. If the breadcrumbs are colouring too much and the chicken isn't cooked, then pop in the oven to finish cooking through. Serve with a big handful of coleslaw and a pot of gravy for dipping."
    }
  ],
