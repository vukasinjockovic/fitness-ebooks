  "method": [
    {
      "heading": null,
      "description": "Dice ¾ of the beetroot into small chunks and toss in a bowl with the za’atar, two thirds of the balsamic vinegar, a splash of olive oil and a good pinch of salt. Set aside to marinate."
    },
    {
      "heading": null,
      "description": "Roughly chop the remaining beetroot and add to a blender with the crème fraîche, remaining balsamic, the garlic clove, cumin, and a squeeze of lemon juice. Blitz until completely smooth. Season with salt and pepper to taste."
    },
    {
      "heading": null,
      "description": "Finely slice the roasted red peppers and set aside. Chop the mint finely, reserving a little for garnish."
    },
    {
      "heading": null,
      "description": "Warm the grain pouches in the microwave according to the pack instructions, then tip into a large bowl. Stir through the red peppers, most of the mint, and a little lemon zest. Taste and season."
    },
    {
      "heading": null,
      "description": "Spread a spoonful of the beetroot sauce on each plate. Top with a handful of lamb’s lettuce, a pile of the minty grains, spoonfuls of marinated beetroot, and crumbled feta. Finish with extra mint and a final drizzle of olive oil, if you fancy."
    }
  ],
  "tips": [
    "Fridge: Store the grains, beetroot, and sauce in separate airtight containers for up to 4 days. Assemble when ready to eat.",
    "Freezing: Not recommended. The beetroot and grains can be frozen, but the textures of the mint and crème fraîche won’t hold up well.",
    "Feta: Sub for goat’s cheese or vegan feta if needed.",
    "Crème fraîche: Use Greek yoghurt or coconut yoghurt for a dairy-free version.",
    "Mixed grains: Swap for cooked quinoa, couscous, or bulgur wheat.",
    "Lamb’s lettuce: Use rocket, spinach, or any soft leafy green."
  ],
