  "method": [
    {
      "heading": null,
      "description": "In a bowl combine the flour, salt and oil. Slowly add the water and bring the dough together. You might not need all the water or need a bit more. Knead for a few seconds. Put a few drops of oil in the palm of your hands and knead the dough for a last time, cover and let it rest for 10 mins."
    },
    {
      "heading": null,
      "description": "In another bowl combine all the filling ingredients."
    },
    {
      "heading": null,
      "description": "Preheat a skillet to medium heat. Divide the dough into 4 portions, roll each portion to a small circle around 3-4 inches big. Now take a quarter of the cheese filling and place it in the centre of the circle and bring the outside together and seal the cheese. Roll this in some flour and roll to a thinner circle around 8-9 inches big."
    },
    {
      "heading": null,
      "description": "Place on the hot pan and cook for a minute before turning over. Cook for another minute then add a tsp of oil on each side and cook for another minute until golden and crispy."
    },
    {
      "heading": null,
      "description": "In a blender add all the chutney ingredients (squeezing in the juice of the lime but discarding the skin) except for the yoghurt and blitz to a purée. Now add the yoghurt and blitz again. Serve immediately. You can store this in the fridge for 3-4 days."
    },
    {
      "heading": null,
      "description": "Spread some salted butter on top and serve hot."
    }
  ],
