  "method": [
    {
      "heading": null,
      "description": "Chop your peppers and onions into 3cm chunks. Chop the tofu into 2-3cm cubes. Add your cornflour to a bowl. Dip each cube in cornflour, make sure to cover the cubes fully."
    },
    {
      "heading": null,
      "description": "Fill your wok with an inch of vegetable oil. Add your tofu and fry until golden brown and set aside. Pour the oil out and place back over the heat."
    },
    {
      "heading": null,
      "description": "Get the rice on. See pack instructions."
    },
    {
      "heading": null,
      "description": "Add the onions and peppers into the wok, and cook on a high heat, until softening and starting to char."
    },
    {
      "heading": null,
      "description": "Once softened, chop up your pineapple into chunks and add to the wok. Next, Stir all the sauce ingredients together. Pour into the veggies, and toss the tofu through until thickened. Taste and season with salt, if needed."
    },
    {
      "heading": null,
      "description": "Slice up your spring onions for garnish. Serve on a bed of rice and tuck into this delicious dish. Enjoy!"
    }
  ],
