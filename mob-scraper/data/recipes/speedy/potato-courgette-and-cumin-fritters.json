  "method": [
    {
      "heading": null,
      "description": "Wash, peel and use the coarse side of a box grater to grate the potatoes into a large bowl."
    },
    {
      "heading": null,
      "description": "Peel the skin off your onion, then grate it. Grate your courgette."
    },
    {
      "heading": null,
      "description": "Add a tsp of salt and mix well. Now empty the mix into a colander and squeeze out as much liquid as possible. Return to the bowl."
    },
    {
      "heading": null,
      "description": "Add the eggs, cumin, cornflour and 10 turns of a pepper mill. Mix well."
    },
    {
      "heading": null,
      "description": "Set a frying pan over a medium heat and add a generous glug of sunflower oil."
    },
    {
      "heading": null,
      "description": "Take a little ball of the mixture and check to see if the oil is hot by frying for a couple of minutes on each side until golden brown. Let it cool and then check for seasoning."
    },
    {
      "heading": null,
      "description": "Now take about 2 tbsp worth of the mix, squeeze and press into a patty. Fry for about 3 mins on either side until crisp and golden brown. Repeat."
    },
    {
      "heading": null,
      "description": "Place on a tray lined with kitchen paper and into a warm oven while you repeat with the rest of the mix."
    },
    {
      "heading": null,
      "description": "Finely chop 3 tbsps of dill and mix into the yoghurt along with the zest and juice of half a lemon, and a pinch of salt."
    },
    {
      "heading": null,
      "description": "Plate up the fritters, sprinkle with flaky salt and a good spoon of yoghurt for dipping."
    }
  ],
