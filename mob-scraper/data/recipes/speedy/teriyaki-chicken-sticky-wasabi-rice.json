  "method": [
    {
      "heading": null,
      "description": "Get your sushi rice on (follow pack instructions)."
    },
    {
      "heading": null,
      "description": "De-bone your chicken thighs and keep the skins on. Add thighs to a bowl and salt the skins."
    },
    {
      "heading": null,
      "description": "Add a splash of oil to a frying pan. Add the chicken, skin side down, and cook for 5 minutes until the skin is nice and brown. Turn the chicken over and cook for another 4 minutes. Keep turning the thighs until they are cooked through. Leave them on a board to rest."
    },
    {
      "heading": null,
      "description": "Teriyaki time. Add soy sauce, mirin, 3 tbsp of water and a tsp of ginger to a pan. Mix them all together. Add a level tbsp of sugar. Stir it in. Cook the sauce until it is nice and thick. Remove from the heat."
    },
    {
      "heading": null,
      "description": "Once the rice is ready, add a heaped tsp of wasabi paste to it. Mix it in."
    },
    {
      "heading": null,
      "description": "Slice up your chicken thighs. Add a big spoonful of the sticky rice to a plate. Top with 2 thighs and pour over your thick teriyaki sauce. Tuck in! Enjoy!"
    }
  ],
