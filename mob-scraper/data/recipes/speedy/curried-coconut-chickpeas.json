  "method": [
    {
      "heading": null,
      "description": "Open the tins of chickpeas, drain into a sieve and rinse with fresh\nwater. Leave in the sieve to drain again while you make the base\nof the curry."
    },
    {
      "heading": null,
      "description": "Get a large frying pan over a low heat and dollop in a generous\ntablespoon of coconut oil. While it is melting, finely grate the\ngarlic cloves and ginger straight into the pan. Turn up the heat to\nhigh and add the curry powder. Fry for 1 minute, stirring, to cook\nout the spices."
    },
    {
      "heading": null,
      "description": "Tip in the chickpeas and give everything a good mix. Leave to fry,\nstirring occasionally, while you toast the sourdough bread."
    },
    {
      "heading": null,
      "description": "Empty the coconut yogurt into the pan, then half-fill the pot with\nwater and pour that in too and mix everything together. Bring to\nthe boil and let the chickpeas bubble away in the creamy sauce\nfor a minute or two. Season with salt and black pepper to taste."
    },
    {
      "heading": null,
      "description": "Cut one lime into four wedges and the other lime in half. Squeeze\nthe juice of the halved lime over the chickpeas in the pan, then\nscatter over the nigella seeds and tear over the coriander."
    },
    {
      "heading": null,
      "description": "Divide the toast between four plates and top with mounds of\nthe curried chickpeas. Serve with the lime wedges on the side\nfor squeezing over."
    }
  ],
