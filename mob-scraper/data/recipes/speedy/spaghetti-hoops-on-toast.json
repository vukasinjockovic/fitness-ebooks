  "method": [
    {
      "heading": null,
      "description": "Mince the garlic, lightly crush the fennel seeds in a pestle and mortar and finely chop the fresh oregano."
    },
    {
      "heading": null,
      "description": "Grate the tomatoes and discard the skin."
    },
    {
      "heading": null,
      "description": "Heat butter and a drizzle of olive oil in a large/deep non-stick frying pan over a medium heat. Add in the garlic, crushed fennel seeds, fresh oregano and chili flakes to fry for 1 min."
    },
    {
      "heading": null,
      "description": "Then stir in the tomato purée, freshly grated tomatoes and paprika, season with salt and cook for 4 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, warm up your veg stock in a saucepan."
    },
    {
      "heading": null,
      "description": "Add the dried pasta to the tomato pan along with the stock and sugar. Simmer for around 20 min stirring occasionally to stop the pasta from sticking."
    },
    {
      "heading": null,
      "description": "Thickly slice, toast and butter your bread just before serving."
    },
    {
      "heading": null,
      "description": "Pile the hoops on top of your toast and grate over your favourite cheese."
    }
