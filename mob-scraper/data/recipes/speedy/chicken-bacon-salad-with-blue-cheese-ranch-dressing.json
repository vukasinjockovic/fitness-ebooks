  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Dice the sourdough and toss with the olive oil, salt and black pepper. Add the breaded chicken steaks and croutons to a large baking tray and bake for 20–25 minutes, until the chicken is cooked through and the croutons are golden and crisp."
    },
    {
      "heading": null,
      "description": "Meanwhile, add the pancetta to a cold frying pan and set over a medium heat. Fry until the fat has rendered and the bacon's become all golden and crispy, then transfer to a plate with kitchen paper to remove the excess fat."
    },
    {
      "heading": null,
      "description": "Slice the celery, quarter the radishes and separate the gem lettuce leaves. Finely chop the chives and set them aside for the dressing."
    },
    {
      "heading": null,
      "description": "Next add the blue cheese, mayonnaise, buttermilk, Worcestershire sauce, garlic powder and lemon juice to a high-speed blender. Blitz until smooth, then season with salt and black pepper and taste. Finally, stir through the chopped chives."
    },
    {
      "heading": null,
      "description": "Add the lettuce, celery, radishes, croutons and most of the pancetta to a large bowl. Drizzle over the dressing and toss gently until everything is nicely coated."
    },
    {
      "heading": null,
      "description": "Slice the chicken and arrange over the salad. Finish with the remaining pancetta and serve straight away."
    }
  ],
