  "method": [
    {
      "heading": null,
      "description": "To make the blitzed pea mixture, add the garlic, pistachios, parmesan, the peas, the juice of your lemon and the basil leaves (saving a few for garnish) into a blender along with 3 tbsp of olive oil, 3 tbsp of water and a pinch of salt. Blitz until smooth."
    },
    {
      "heading": null,
      "description": "Put the pasta onto boil in plenty of salted water. While it cooks, prepare the asparagus by removing the tough bottoms and the tips (make sure to reserve the tips). Now shave the main part of the stalks into strips using a vegetable peeler and set aside."
    },
    {
      "heading": null,
      "description": "Once the pasta is about 2 mins from being ready, add the asparagus and the rest of your peas in along with the asparagus tips you saved earlier."
    },
    {
      "heading": null,
      "description": "Drain everything (reserving a mug of cooking water) and return to the pan, add in the blitzed pea mixture along with a big splash of cooking water and mix well until creamy and saucy. Taste and add salt and another squeeze of lemon, if you like."
    },
    {
      "heading": null,
      "description": "Plate up and top with a little more grated cheese and a pinch of chilli flakes."
    }
  ],
