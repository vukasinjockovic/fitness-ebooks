  "method": [
    {
      "heading": null,
      "description": "In a medium pot, add the sugar, water and rosemary. Bring to the boil and simmer for 3 mins, then turn off the heat and set aside to infuse for another 10 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, warm the blueberries gently in a pan on the stove or in the microwave until they burst and start to release their juices."
    },
    {
      "heading": null,
      "description": "Crush the ice, if you like (I used a small food processor). Cut the lime into wedges."
    },
    {
      "heading": null,
      "description": "To make one drink, add 2 tbsp of blueberries to a small glass followed by 2 tbsp of rosemary syrup and some ice. Top up with sparkling water and garnish with a wedge of lime."
    }
