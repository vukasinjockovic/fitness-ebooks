  "method": [
    {
      "heading": null,
      "description": "Heat up a large glug of oil in a hot pan. De-case your sausages into the pan. Add the chilli flakes and cook until well browned for about 6 mins."
    },
    {
      "heading": null,
      "description": "Pop the pasta in boiling salted water and cook for 8 mins, or however long that the package instructions state."
    },
    {
      "heading": null,
      "description": "Meanwhile, chop up the cabbage into large 5cm pieces"
    },
    {
      "heading": null,
      "description": "Grate in the garlic and add the cabbage. Mix well until the cabbage has wilted."
    },
    {
      "heading": null,
      "description": "Mix the miso, mirin and butter with 250ml pasta water, and add it to the browned pork."
    },
    {
      "heading": null,
      "description": "Toss in the cooked pasta, grate in the parmesan and lots of freshly ground black pepper. Mix well, adding more pasta water if it starts to look dry."
    },
    {
      "heading": null,
      "description": "Serve up with more parmesan and black pepper, and enjoy."
    }
