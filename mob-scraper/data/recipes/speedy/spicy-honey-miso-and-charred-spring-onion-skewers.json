  "method": [
    {
      "heading": null,
      "description": "Chop the peppers into 2cm sized chunks and spring onions into 3cm parts lengthways."
    },
    {
      "heading": null,
      "description": "Roughly chop your veggie chicken chunks into 2cm-size pieces."
    },
    {
      "heading": null,
      "description": "Start assembling your skewers by threading two plant-based pieces followed by a chunk of pepper and spring onion onto your skewer in that order. Continue that pattern until each skewer is filled. Repeat for the remaining skewers."
    },
    {
      "heading": null,
      "description": "Grate your ginger and garlic into a bowl. Add miso, soy sauce, honey, chilli flakes, sesame oil and rice wine vinegar, and give it a good mix."
    },
    {
      "heading": null,
      "description": "Brush your skewers with the sauce mix and leave to marinate for 10-15 mins."
    },
    {
      "heading": null,
      "description": "On medium heat, add the skewers to a griddle pan and lightly brush your skewers with a drizzle of sesame oil. Cook for a few mins on each side until the skewers are golden. Enjoy!"
