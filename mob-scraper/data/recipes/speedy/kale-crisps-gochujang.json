  "method": [
    {
      "heading": null,
      "description": "Wash and dry the kale well."
    },
    {
      "heading": null,
      "description": "Remove the tough stems from the kale and place in a large bowl. The weight of the kale in the ingredients list is after removing the stems."
    },
    {
      "heading": null,
      "description": "Whisk together the gochujang and olive oil in a small bowl."
    },
    {
      "heading": null,
      "description": "Pour the gochujang and olive oil mixture over the kale and massage with your fingers so that each leaf is covered and marinated. Sprinkle over the sesame seeds, if using."
    },
    {
      "heading": null,
      "description": "Air fry at 150ºC for 5 mins, tossing once or twice. Or bake in the oven in a single layer, at 150ºC for 20-25 mins, tossing once or twice until perfectly crispy."
    },
    {
      "heading": null,
      "description": "Enjoy immediately, on their own or sprinkled over rice or a stir fry. Store for up to 3 days in a sealed container at room temperature."
    }
