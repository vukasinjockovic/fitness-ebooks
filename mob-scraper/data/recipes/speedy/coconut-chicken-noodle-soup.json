  "method": [
    {
      "heading": null,
      "description": "Smash your garlic and lemongrass. Roughly slice your shallot, chillies and ginger."
    },
    {
      "heading": null,
      "description": "Mix your veg stock cubes with 1.2 litres of hot water."
    },
    {
      "heading": null,
      "description": "Pour your coconut milk and vegetable stock into a pot and add your aromatics. Bring to a boil then let it simmer on low heat for 15 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, slice your courgette width-wise into coins and fry on a griddle pan along with your chicken pieces and a glug of oil until crispy and golden."
    },
    {
      "heading": null,
      "description": "Chop the ends of your pak choi and tenderstem broccoli. Add the broccoli into the broth for a few mins then add your pak choi and peas. Squeeze in the juice of half a lime, season with salt and pepper and let this all simmer on low heat."
    },
    {
      "heading": null,
      "description": "Place your rice noodles into a heatproof bowl and cover with boiling water. Leave for a few mins then drain."
    },
    {
      "heading": null,
      "description": "Take the pot off the hob and add a ¼ of the noodles into a bowl along with a ladle or two of the broth. Add a portion of your fried “chicken” and courgette, repeat for the remaining 3 bowls."
    },
    {
      "heading": null,
      "description": "Slice your spring onion and add to each bowl along with a small handful of coriander and tuck in."
    }
  ],
