  "method": [
    {
      "heading": null,
      "description": "On medium-low heat, fry the paste with a small glug of oil for a few mins until aromatic then pour in the hot water. Let it simmer for a bit then pour in your coconut milk and boil for 10 mins."
    },
    {
      "heading": null,
      "description": "Cut all of your tofu puffs in half."
    },
    {
      "heading": null,
      "description": "Cook your vermicelli noodles in a heatproof bowl of boiling water. Meanwhile, cook your green beans and beansprouts for a few mins in a pot of boiling water. Use the same pot of cooking water to boil your eggs."
    },
    {
      "heading": null,
      "description": "Add palm sugar and fish sauce to your laksa along with pak choi, fried tofu puffs, green beans and beansprouts. Give it a stir."
    },
    {
      "heading": null,
      "description": "Add a portion of your vermicelli noodles to a bowl, pour in your hot laksa soup and serve with a boiled egg and fresh coriander per bowl. Enjoy!"
    }
  ],
