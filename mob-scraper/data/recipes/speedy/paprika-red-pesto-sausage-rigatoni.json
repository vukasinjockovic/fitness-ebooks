  "method": [
    {
      "heading": null,
      "description": "Finely dice the shallot and thinly slice the garlic. Score the skins of the sausages open. Heat the oil in a pan and add the shallots, cooking until translucent, then add the garlic and crumble in the sausage meat. Cook until the sausage is crispy and golden, around 5-7 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, add all the pesto ingredients into a blender with the juice of the lemon and blitz together."
    },
    {
      "heading": null,
      "description": "Bring a large pan of water to the boil and cook the rigatoni according to pack instructions. Drain, reserving some pasta water. Grate the parmesan. Add the cooked pasta directly to the sausage pan, then add the pesto. Add a good slosh of pasta water and mix vigorously until emulsified. Pick the basil leaves and add most of them to the pan, along with the cream and seasoning."
    },
    {
      "heading": null,
      "description": "Serve in bowls and finish with extra parmesan and fresh basil, if you like."
    }
  ],
