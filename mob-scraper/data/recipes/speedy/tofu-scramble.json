  "method": [
    {
      "heading": null,
      "description": "Drain and pat the tofu dry with a teatowel. No need to press it as we want to keep some of the moisture here."
    },
    {
      "heading": null,
      "description": "Melt the butter in a large saucepan over medium heat and then crumble the tofu in large chunks into the pan. Season well with salt and pepper and fry. Stirring often for about 8-10 mins until the edges turn golden brown."
    },
    {
      "heading": null,
      "description": "Meanwhile, blend all the other ingredients in a blender until smooth."
    },
    {
      "heading": null,
      "description": "Turn off the heat and stir through the blender mix. Add a little more milk to the pan if you’d prefer it more runny. Taste and season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve in a sandwich with mustard, mayo and cress or as a scramble with toast or on a lovely crumpet (yes most crumpets are vegan!)"
    }
