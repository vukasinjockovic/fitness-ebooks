  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Chop your garlic and add it to a blender with the red peppers, sun-dried tomatoes, pine nuts, 2 tbsp of olive oil and most of the parmesan, leaving a handful to scatter over the pasta before baking. Give it a big old blend to get that delicious pesto consistency."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of water to a boil, add 1 tbsp of salt and cook the penne (see pack instructions)."
    },
    {
      "heading": null,
      "description": "Chop your chorizo and add it to a frying pan on a medium heat. Fry until crispy, then add the pasta to the chorizo. Pour in your pesto and fold everything together so it’s coated in the pesto."
    },
    {
      "heading": null,
      "description": "Transfer the pesto pasta into a large baking dish. Slice up the mozzarella and sprinkle it onto the pasta with the rest of the parmesan."
    },
    {
      "heading": null,
      "description": "Whack the dish in the oven for 15 minutes or until the cheese is completely melted and crispy."
    },
    {
      "heading": null,
      "description": "Serve the pasta with a crack of black pepper and a pinch of chilli flakes. Chop up your basil for garnish and dig in!"
    }
  ],
