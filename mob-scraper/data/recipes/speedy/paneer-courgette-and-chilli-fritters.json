  "method": [
    {
      "heading": null,
      "description": "In a dry pan, toast the sesame seeds on a low heat for 5 mins until fragrant. Leave to oneside."
    },
    {
      "heading": null,
      "description": "Grate courgette and place in a large sieve over the sink/a bowl."
    },
    {
      "heading": null,
      "description": "Grate Apetina paneer, ginger and garlic in a bowl."
    },
    {
      "heading": null,
      "description": "Finely dice one chilli, 2 spring onions and add to the paneer mixture, along with the toastedsesame seeds and chilli flakes. Mix until combined."
    },
    {
      "heading": null,
      "description": "Press out as much water as you can from the courgette, then add it to the paneer mixture."
    },
    {
      "heading": null,
      "description": "Finally add in the flour and mix together."
    },
    {
      "heading": null,
      "description": "In a separate bowl, beat 2 eggs with salt, pepper, gochujang and soy sauce until wellcombined. Add this to the paneer mixture."
    },
    {
      "heading": null,
      "description": "Heat up roughly 2 tablespoons of coconut oil in a frying pan on medium heat, then add 4large tablespoons of the paneer mixture and flatten them out to form four even-sized fritters.Fry for 3 mins on each side."
    },
    {
      "heading": null,
      "description": "Then, add some more coconut oil to the pan, and fry two eggs."
    },
    {
      "heading": null,
      "description": "Arrange fritters on a plate and squeeze over some lime juice. Top them with your fried eggsand garnish with sesame seeds, spring onions and more chilli flakes if desired."
    }
  ],
