  "method": [
    {
      "heading": null,
      "description": "Peel and slice a finger of fresh ginger, and slice into four rounds of ginger."
    },
    {
      "heading": null,
      "description": "Into a medium sized pot, on medium high heat, add the coconut cream (white part on the top of the can) and cook the ginger slices for 2 mins or until lightly fragrant. Add in all the rice and cook for 1 minute or until fragrant, then add all the remaining coconut milk along with the water, sugar, and salt, then mix well. Bring to a boil, add a lid and reduce the heat to the lowest fire. Cook for 20 mins."
    },
    {
      "heading": null,
      "description": "In the meantime, add the peanut, desiccated coconut, sesame seeds into a small pan and toast until the coconut is lightly golden, then remove, into a mortar and pestle, or blender. Add sugar and salt and crush well into a coarse crumble."
    },
    {
      "heading": null,
      "description": "In a small cup combine the cornstarch slurry."
    },
    {
      "heading": null,
      "description": "After 20 mins, remove the lid, and whisk vigorously for 1 minute to release rice starches. Mix the cornstarch slurry well, then pour into the coconut rice pudding, bring to a boil and cook for 1 minute or until creamy and silky. Serve with nutty sesame crumble sprinkled all over."
    }
  ],
