  "method": [
    {
      "heading": null,
      "description": "Finely chop your onion and cloves of garlic."
    },
    {
      "heading": null,
      "description": "Gently fry them until soft, then your cumin."
    },
    {
      "heading": null,
      "description": "Remove from the heat and tip into a bowl. Add the lamb mince and chopped parsley. Mix together and then make 8 thin patties."
    },
    {
      "heading": null,
      "description": "Place on a plate and put into the fridge for 20 minutes to firm up."
    },
    {
      "heading": null,
      "description": "Now for the feta topping. Add your feta, yoghurt, a handful of chopped mint, the juice of half a lemon and the pomegranate seeds to a bowl. Mix them all together. Done."
    },
    {
      "heading": null,
      "description": "Take out your patties. Place on a very hot griddle pan and cook for 3 minutes each side. At the same time, toast your ciabatta rolls."
    },
    {
      "heading": null,
      "description": "To serve, place a dollop of the feta topping on the base of the roll. Then add a patty. Then more topping, then another patty, then any leftover mint leaves and pomegranate seeds you have, and then the top of the roll. Enjoy!"
    }
