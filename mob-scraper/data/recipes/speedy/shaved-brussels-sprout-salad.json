  "method": [
    {
      "heading": null,
      "description": "Trim and wash the brussels. Slice them as thinly as you can and add to a large mixing bowl. Season with salt and toss."
    },
    {
      "heading": null,
      "description": "Place the pancetta into a cold pan and begin to fry on a medium heat until it becomes crispy. Remove the meat from the pan and set aside. You can clean off your pan after this."
    },
    {
      "heading": null,
      "description": "Add the butter to a small saucepan and cook until nut brown."
    },
    {
      "heading": null,
      "description": "Thinly slice the pear and onion and roughly chop the parsley, add to the bowl with the shaved sprouts."
    },
    {
      "heading": null,
      "description": "To make the dressing, combine the brown butter and orange juice in a small mixing bowl. Whisk in the vinegar and mustard. Season with salt and pepper to taste. The dressing should be tart, sweet, rich and smoky, with a decent punch of mustard."
    },
    {
      "heading": null,
      "description": "Toss the dressing with the shaved veggies and finish with the crispy pancetta lardons and a good grating of parmesan. Toss everything together and serve."
    }
  ],
