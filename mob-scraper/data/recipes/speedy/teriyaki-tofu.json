  "method": [
    {
      "heading": null,
      "description": "Chop your tofu up into chunks. Cook your rice following pack instructions."
    },
    {
      "heading": null,
      "description": "Cover the chunks in cornflour."
    },
    {
      "heading": null,
      "description": "Add a splash of olive oil to a hot pan."
    },
    {
      "heading": null,
      "description": "Once the oil is hot enough, add the tofu chunks. Turn until each side is golden brown."
    },
    {
      "heading": null,
      "description": "Teriyaki time. Add soy sauce, rice wine vinegar, 10 tbsp of water and a tsp of ginger to a bowl. Mix together. Add 1 1/2 tablespoons of agave nectar."
    },
    {
      "heading": null,
      "description": "Add your teriyaki sauce to the pan to warm and bubble for a couple of mins until thickened."
    },
    {
      "heading": null,
      "description": "Put the pomegranate seeds in a sieve over the pan. Press a teaspoon down onto them, allowing the juices to drip into the pan."
    },
    {
      "heading": null,
      "description": "Add the mint and the tofu and mix together."
    },
    {
      "heading": null,
      "description": "Place the tofu on a bed of rice. Garnish with pomegranate and tuck in!"
    }
