  "method": [
    {
      "heading": null,
      "description": "In a medium bowl, mix together all the ingredients. The batter should be slightly thicker than pancake mixture."
    },
    {
      "heading": null,
      "description": "Place your frying pan on a very low heat."
    },
    {
      "heading": null,
      "description": "Place a lightly oiled egg ring into your frying pan."
    },
    {
      "heading": null,
      "description": "Pour in the mixture until the egg ring is about half full."
    },
    {
      "heading": null,
      "description": "When the bubbles have formed on the crumpets, and when the surface has dried out (at least 6 minutes) gently pull up the egg rings and let the crumpets drop back into the pan, then set aside the egg rings."
    },
    {
      "heading": null,
      "description": "Flip the crumpet around and cook the top for 5 minutes until golden brown."
    },
    {
      "heading": null,
      "description": "Repeat this with all the crumpets. Serve and enjoy with marmite or honey!"
    }
