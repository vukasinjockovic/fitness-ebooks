  "method": [
    {
      "heading": null,
      "description": "Zest and juice the lemon."
    },
    {
      "heading": null,
      "description": "Pour the milk into a measuring jug. Whisk in the lemon zest and juice and leave to sit."
    },
    {
      "heading": null,
      "description": "Place the blueberries and maple syrup in a small saucepan. Bring to a simmer over medium heat, then turn the heat down to low and simmer for 5 mins. Transfer to a bowl to cool."
    },
    {
      "heading": null,
      "description": "Sift the self-raising flour, bicarbonate of soda and 1⁄2 tsp salt into a large mixing bowl."
    },
    {
      "heading": null,
      "description": "Separate the eggs and drain the ricotta. Melt the butter in a small pan over a low heat."
    },
    {
      "heading": null,
      "description": "Place the egg yolks, sugar, melted butter, vanilla extract and ricotta in a separate mixing bowl. Add the now-curdled milk and whisk until mostly smooth – a few lumps here and there is fine."
    },
    {
      "heading": null,
      "description": "Pour the wet mixture into the dry mixture and whisk until just combined."
    },
    {
      "heading": null,
      "description": "Whisk the egg whites to stiff peaks, then, working in three batches, gently fold them into the batter using a large metal spoon."
    },
    {
      "heading": null,
      "description": "Heat a non-stick frying pan over medium-low heat and grease lightly with butter. Pour in a ladleful of batter and cook until bubbles appear on the top of the pancake and the bottom is golden brown and set, around 2 mins."
    }
  ],
