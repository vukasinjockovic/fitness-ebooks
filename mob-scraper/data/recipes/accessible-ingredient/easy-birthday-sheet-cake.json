  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180˚C fan. Grease and line a 20 x 30cm roasting tin."
    },
    {
      "heading": null,
      "description": "Sift the flour into a bowl. Add the sugar, salt and baking powder and whisk together. Use an electric whisk to beat in the butter until it is incorporated and the mixture appears to be evenly coated and looks like a fine crumble mix – 2–3 mins on medium speed."
    },
    {
      "heading": null,
      "description": "Add the eggs and beat, first on medium, then on high, just until incorporated. Add the milk and vanilla and beat, on medium and then on high, for about 2-3 mins until the mixture is smooth and combined; it will appear a bit lighter in colour."
    },
    {
      "heading": null,
      "description": "Pour the mixture into the prepared tin and level out to the edges. Bake in the oven for 25–30 mins, or until a toothpick inserted into the centre comes out clean."
    },
    {
      "heading": null,
      "description": "Remove from the oven and leave to cool in the tin for 10 mins before turning out on to a wire rack to cool completely."
    },
    {
      "heading": null,
      "description": "Spread a generous layer of buttercream over the sponge and top with sprinkles of your choice."
    }
  ],
