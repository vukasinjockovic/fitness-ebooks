  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C."
    },
    {
      "heading": null,
      "description": "Finely chop the courgettes, red onion and peppers into bite-size pieces. Break cauliflower up into little florets. Place on a baking tray. Pour in a tin of chickpeas with some of the starchy water."
    },
    {
      "heading": null,
      "description": "Pour over a good glug of olive oil, add cayenne pepper, garam masala, a sprinkle of salt and pepper, and mix everything together. Place in oven for 30 minutes."
    },
    {
      "heading": null,
      "description": "Tzatziki time. Pour a pot of yoghurt into a bowl. Add a small bunch of finely chopped mint, the juice of one lemon, and one grated cucumber. Grate in a clove of garlic, season well and mix it all together."
    },
    {
      "heading": null,
      "description": "After 30 minutes, remove the vegetables from the oven, mix them about, and then place back in the oven for 15 more minutes."
    },
    {
      "heading": null,
      "description": "Assemble time. Take a warm pitta. Load it with your spiced vegetables, tzatziki, pomegranate seeds, some more vegetables, more tzatziki, more pomegranate seeds, and tuck in."
    }
  ],
