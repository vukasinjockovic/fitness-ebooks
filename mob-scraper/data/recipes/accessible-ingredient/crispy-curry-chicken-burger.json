  "method": [
    {
      "heading": null,
      "description": "Finely slice your onion."
    },
    {
      "heading": null,
      "description": "Heat a pan over a medium heat and add a glug of veg oil. Tip in your cumin seeds and toast for a minute until fragrant. Add your onions and cook for 20 mins until totally softened and caramelised."
    },
    {
      "heading": null,
      "description": "Add your tomato purée and curry powder to the mix, then cook out for 2 mins. Leave to cool."
    },
    {
      "heading": null,
      "description": "Finely shred your cabbage and radishes (use a mandoline, if you have one) and then finely chop your pickled chillies."
    },
    {
      "heading": null,
      "description": "Add this to a bowl along with your coriander leaves, chillies and juice of your lime. Season to taste with salt."
    },
    {
      "heading": null,
      "description": "Whizz up your onion mixture in a food processor, then mix it with your mayonnaise and hot sauce."
    },
    {
      "heading": null,
      "description": "Cook your Happy Go Clucky burgers in the oven according to packet instructions."
    },
    {
      "heading": null,
      "description": "Toast your buns in a dry frying pan."
    },
    {
      "heading": null,
      "description": "Assembly time. Spread your mayo on the base of your bun, then top with your burger and slaw. Spread more mayo on the lid, then pop this on top. Serve and enjoy."
    }
  ],
