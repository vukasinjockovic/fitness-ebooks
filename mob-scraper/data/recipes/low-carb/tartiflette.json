  "method": [
    {
      "heading": null,
      "description": "Peel and slice the potatoes (3 to 4 mm thick) and pour into a medium pan filled with cold water and 1 tsp of salt. Cover, and cook for 15 mins. Drain and set aside."
    },
    {
      "heading": null,
      "description": "Finely slice your onions. Fry the sliced onions with the butter in a large frying pan for 3 to 5 mins under medium heat. Add the white wine and cook until it evaporates. Set aside."
    },
    {
      "heading": null,
      "description": "Fry the lardons in the same pan, until golden and crispy, for 5 to 7 mins then remove the fat from the pan."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Put half the potatoes in the bottom of your casserole dish or deep tray. Spread half of the onions, topped with half of the lardons and half of the cream. Top it with the rest of the potatoes then add in the rest of your onions and lardon, and finally the cream."
    },
    {
      "heading": null,
      "description": "Slice the Reblochon lengthways, then place on top, crust-side facing up. Pepper to taste."
    },
    {
      "heading": null,
      "description": "Cook for 30 mins, until the Reblochon has fully melted and golden on top."
    },
    {
      "heading": null,
      "description": "Serve with a dressed salad."
    }
