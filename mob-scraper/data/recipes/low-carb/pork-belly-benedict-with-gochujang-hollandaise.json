  "method": [
    {
      "heading": null,
      "description": "Ribbon the cucumber and apple and finely slice your green chilli."
    },
    {
      "heading": null,
      "description": "Add the above to a pickle of rice vinegar, water, salt and sugar."
    },
    {
      "heading": null,
      "description": "Create the marinade by mixing teriyaki, dark soy, lime and rice vinegar."
    },
    {
      "heading": null,
      "description": "Marinate pork belly (in strips) before adding to a covered dish and roast for 45 mins at 180°C."
    },
    {
      "heading": null,
      "description": "Remove the cover from the dish and further cook for 45 mins until dark and crispy."
    },
    {
      "heading": null,
      "description": "To make the hollandaise, vigorously whisk the egg yolks and rice vinegar until frothy."
    },
    {
      "heading": null,
      "description": "In a separate pan, slowly melt butter and gochujang together until warm."
    },
    {
      "heading": null,
      "description": "Gradually pour the melted butter mix into the egg yolks and continue to whisk. Once mixed, set aside. You can slowly reheat later if needed."
    },
    {
      "heading": null,
      "description": "Poach the eggs until almost done and set aside, allowing to cook through."
    },
    {
      "heading": null,
      "description": "Toast the crumpet and bring everything together."
    },
    {
      "heading": null,
      "description": "Top the Benedict with sesame seeds (we like a mixture of white and black) and long slices of spring onion."
    }
  ],
