  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 180°C."
    },
    {
      "heading": null,
      "description": "Place the blanched hazelnuts, pistachios, sesame seeds, cumin seeds, coriander seeds and fennel seeds in a small baking tray. Roast for 10 mins, or until nice and fragrant."
    },
    {
      "heading": null,
      "description": "Leave to cool then transfer to a food processor, season well with salt and pepper and blitz until finely chopped. Set aside."
    },
    {
      "heading": null,
      "description": "Quarter the cauliflower heads."
    },
    {
      "heading": null,
      "description": "Heat a splash of olive oil in a large frying pan over medium-high heat."
    },
    {
      "heading": null,
      "description": "Place the cauliflower cut-side down and cook for 3 mins, or until nicely browned. Flip and repeat on the other cut side, then transfer to a baking dish."
    },
    {
      "heading": null,
      "description": "Combine the turmeric with 4 tbsp olive oil and season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Brush the turmeric oil over the cauliflower and roast for 30 mins, or until cooked through but not mushy."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop your red onions and garlic."
    },
    {
      "heading": null,
      "description": "Wipe out any fallen bits of cauliflower out of your frying pan, then add a splash of olive oil and place over a medium heat."
    },
    {
      "heading": null,
      "description": "Add the red onions, along with a good pinch of salt and pepper, and cook for 10 mins, or until softened but not browned."
    },
    {
      "heading": null,
      "description": "Add the garlic and Aleppo pepper and cook for 1 min, then add the raisins, pomegranate molasses, sugar and 200ml water."
    },
    {
      "heading": null,
      "description": "Season with salt and pepper and cook until slightly reduced and thickened, 3 to 5 mins."
    },
    {
      "heading": null,
      "description": "Finely chop the fresh mint."
    },
    {
      "heading": null,
      "description": "To assemble, spoon the jammy onions over the cauliflower. Add a good sprinkle of the dukkah and finish with the fresh mint. Tuck in and enjoy!"
    }
  ],
