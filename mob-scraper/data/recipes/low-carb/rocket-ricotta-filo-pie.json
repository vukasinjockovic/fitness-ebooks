  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Dunk the rocket into boiling salted water for 1 minute and refresh in icy cold water."
    },
    {
      "heading": null,
      "description": "Squeeze out the excess water and roughly chop."
    },
    {
      "heading": null,
      "description": "Add the rocket to a mixing bowl with the ricotta and feta cheese. Season with salt, pepper and the zest of your lemon. Beat together."
    },
    {
      "heading": null,
      "description": "Melt the butter over a very low heat and then beat in the egg."
    },
    {
      "heading": null,
      "description": "Now to build. Lay out a sheet of filo, with the longer side running along the bottom, and brush with the butter and egg wash. Lay another sheet, slightly overlapping, again with the longer side running over along the bottom. You’ll now have a very long sheet of filo."
    },
    {
      "heading": null,
      "description": "Brush with more of the butter and egg wash and keep layering up the pastry, each time slightly overlapping until you have four layers."
    },
    {
      "heading": null,
      "description": "Spoon your filling into a long sausage along the bottom edge of the pastry sheets. Roll up like a big cigar."
    },
    {
      "heading": null,
      "description": "Now, gently coil the roll into a spiral shape. Don’t worry if it cracks a little, it’s not the end of the world."
    },
    {
      "heading": null,
      "description": "Now brush liberally with the butter and egg wash and sprinkle with flaky sea salt and sesame seeds."
    },
    {
      "heading": null,
      "description": "Pop it onto a baking tray lined with parchment and bake for 25-30 mins until golden brown."
    },
    {
      "heading": null,
      "description": "Take it straight out the oven and drizzle with honey."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
  ],
