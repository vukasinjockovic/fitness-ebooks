  "method": [
    {
      "heading": null,
      "description": "Start by patting the lamb shanks dry with a kitchen towel and season with salt. Sear in 1 tsp of veg oil and ghee, then put aside."
    },
    {
      "heading": null,
      "description": "To a pan, add finely chopped onion, brown for 5 mins on high, then add ginger and garlic paste, cook for 2 mins then add everything listed under ‘for the base’, cook down for 5 mins."
    },
    {
      "heading": null,
      "description": "Whisk yoghurt and add it, keep stirring."
    },
    {
      "heading": null,
      "description": "Combine all the spices for the nihari masala and grind to a fine powder, save a tsp and add the rest to the pan (with the yoghurt) and keep stirring for 2 mins."
    },
    {
      "heading": null,
      "description": "Add the lamb and the curry base (comprised of ingredients listed in the 'For The Base' section) to the pressure cooker along with 2 green chillies, ½ inch of sliced ginger, and 6 cups of water."
    },
    {
      "heading": null,
      "description": "Bring it to the boil then pop the lid on, once the pressure is high, turn the heat down to low and cook for 18 mins."
    },
    {
      "heading": null,
      "description": "Release the pressure and skim off the excess oil, save this for later."
    },
    {
      "heading": null,
      "description": "Turn the heat up and let the sauce reduce for 5 mins."
    },
    {
      "heading": null,
      "description": "Mix flour with water to create a slurry and add it to the nihari ."
    },
    {
      "heading": null,
      "description": "Simmer till the sauce has thickened and reduced by a quarter."
    },
    {
      "heading": null,
      "description": "Serve with julienned ginger, coriander, chopped chillies and reserved oil."
    }
  ],
