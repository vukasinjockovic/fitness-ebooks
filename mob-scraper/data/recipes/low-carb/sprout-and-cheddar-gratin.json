  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 180°C fan. Thinly slice the onion."
    },
    {
      "heading": null,
      "description": "Heat ½ the butter in a saucepan set over a medium heat. Tip in the onion and add a pinch of salt, then cook for about 5 mins, stirring occasionally, until soft."
    },
    {
      "heading": null,
      "description": "Meanwhile, quarter the sprouts and cut the broccoli into 2 inch pieces."
    },
    {
      "heading": null,
      "description": "Add the sprouts and broccoli to the onions and season generously with salt and pepper. Add the water, stir, cover with a lid and cook for 3 or 4 mins until the veg starts to soften a little."
    },
    {
      "heading": null,
      "description": "Remove the lid, pour in the cream and mustard and grate in ½ the cheese. Stir and cook gently for a couple of minutes until the cheese has melted. Taste and season if needed then pour the mix into an oven dish."
    },
    {
      "heading": null,
      "description": "Into a small bowl, grate the remaining cheese and add the breadcrumbs and a pinch of salt. Mix to combine then sprinkle the breadcrumb mix evenly over the top of the gratin."
    },
    {
      "heading": null,
      "description": "Add the rest of the butter in little dots around the top. Bake for 25 mins until golden."
    },
    {
      "heading": null,
      "description": "Leave to rest for 5 mins before serving."
    }
  ],
