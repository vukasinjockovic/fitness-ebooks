  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 220°C/428°F."
    },
    {
      "heading": null,
      "description": "Cut your cauliflower into large florets, halve your tomatoes and cut your red onion into wedges. Place all the veg in a large high-sided baking dish."
    },
    {
      "heading": null,
      "description": "Mince your garlic and ginger then sprinkle them over the vegetables, along with the cumin, ground coriander, turmeric, chilli powder, ground cardamom and a generous pinch of sea salt. Drizzle with a little vegetable oil, then toss your cauliflower around in your hands until it is totally coated. Roast for 20 minutes, or until the cauliflower is charred and caramelised on the outside."
    },
    {
      "heading": null,
      "description": "Turn the heat down to 200°C/392°F."
    },
    {
      "heading": null,
      "description": "Pour your ground almonds, vegetable stock and coconut milk into the baking dish and give it a good stir. Return your dish to the oven for 25 minutes, or until your sauce has reduced to a thick consistency."
    },
    {
      "heading": null,
      "description": "Meanwhile, roughly chop your coriander."
    },
    {
      "heading": null,
      "description": "Pour your flaked almonds into a dry frying pan and toast over a medium heat for a few minutes, by which time you should have crisp and golden flakes."
    },
    {
      "heading": null,
      "description": "Check the seasoning of your curry, then serve it over rice. Scatter with your coriander and flaked almonds, then dig in."
    }
  ],
