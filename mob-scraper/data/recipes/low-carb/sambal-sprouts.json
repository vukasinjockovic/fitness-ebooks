  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Cut all the Brussels sprouts in half and toss with olive oil and salt."
    },
    {
      "heading": null,
      "description": "Pop these onto a baking tray cut-side down and bake for 30 mins, turning halfway through until caramelised and crisp."
    },
    {
      "heading": null,
      "description": "Now, make the sambal. Blend up the red chillies with 2 tbsp of water until smooth and transfer into a bowl. Blend up the shallots, ginger, garlic and lemongrass with 2 tbsp of water until smooth."
    },
    {
      "heading": null,
      "description": "Heat up 100ml of vegetable oil in a large wok and add in the red chillies. Cook for 10 mins until the oil is stained red and the chillies darken."
    },
    {
      "heading": null,
      "description": "Add in the shallot mix and continue cooking for another 10 mins."
    },
    {
      "heading": null,
      "description": "Pour in the tomato purée and cook for 5 mins until the purée has darkened, then add in the chopped tomatoes, brown sugar, fish sauce and 1 tsp salt. Cook for 5 mins or until the oil separates."
    },
    {
      "heading": null,
      "description": "Add in the sprouts and toss well. Taste and adjust the seasoning if necessary."
    },
    {
      "heading": null,
      "description": "Toast the peanuts and lightly crush them. Sprinkle the peanuts over the sprouts and serve."
    }
  ],
