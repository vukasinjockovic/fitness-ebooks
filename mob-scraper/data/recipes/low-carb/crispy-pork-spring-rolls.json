  "method": [
    {
      "heading": null,
      "description": "Finely chop the bacon, spring onions, chilli, carrot and watercress. Add this into a bowl along with the minced pork."
    },
    {
      "heading": null,
      "description": "Grate in the garlic and ginger, and mix in eggs, cornflour, soy sauce, fish sauce."
    },
    {
      "heading": null,
      "description": "Mix the filling very well so it is evenly coated."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 230°C."
    },
    {
      "heading": null,
      "description": "Fill a bowl with water and dunk the rice paper into the water only for 1 second."
    },
    {
      "heading": null,
      "description": "Put onto your chopping board, after 30 seconds the paper will have hydrated and will be ready to use. If you oversoak then it will become too soft to handle."
    },
    {
      "heading": null,
      "description": "Add two tbsp of the pork filling onto the paper. Wrap up the spring roll, it should stick to itself easily and then put to the side. Continue with the rest of the rolls, be careful not to place them next to each other otherwise they will stick."
    },
    {
      "heading": null,
      "description": "Get a small bowl and fill it with vegetable oil."
    },
    {
      "heading": null,
      "description": "Dunk the rolls into the oil and then place them directly onto your baking tray (this helps them get super crispy in the oven without having to deep fry!)."
    },
    {
      "heading": null,
      "description": "Bake for 12 mins, turning half way through."
    },
    {
      "heading": null,
      "description": "Place onto your serving plate and serve with sweet chilli sauce."
    }
  ],
