  "method": [
    {
      "heading": null,
      "description": "Cut open your vanilla pod and place it in the bottle of tequila. Leave that overnight in a safe space."
    },
    {
      "heading": null,
      "description": "Add the freshly ground coffee to the bottle and put in the freezer for 5/6 hours to allow it to cold brew."
    },
    {
      "heading": null,
      "description": "Take out and strain through a coffee filter into a large jug."
    },
    {
      "heading": null,
      "description": "Now add your water and sugar to a pan and bring it to a simmer."
    },
    {
      "heading": null,
      "description": "When the sugar mixture has dissolved, add the sieved coffee tequila to the bottle along with the sugar syrup and give it a good shake."
    },
    {
      "heading": null,
      "description": "Serve up a big old shot and enjoy."
    }
