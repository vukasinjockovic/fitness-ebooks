  "method": [
    {
      "heading": null,
      "description": "Make the Juicy Pulled Chipotle Chicken."
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Finely slice the red onion an dpop in a small bowl. Add the juice of 2/3 lime over, mixing well. Leave to pickle."
    },
    {
      "heading": null,
      "description": "Trim the sweet potatoes and slice into wedges. Tip onto a baking tray, drizzle with olive oil and season with salt and black pepper. Toss to coat, then roast for 20–25 mins until tender and golden."
    },
    {
      "heading": null,
      "description": "Meanwhile, warm the pulled chipotle chicken in a saucepan over a low heat until piping hot. Finely grate the cheddar. Pick the coriander leaves and set aside."
    },
    {
      "heading": null,
      "description": "Once the wedges are ready, divide between plates and scatter over half the grated cheddar. Top with the hot pulled chicken, dollops of soured cream and salsa, then finish with remaining cheddar and coriander.\nDrain the liquid from the pickled red onions and scatter over each plate."
    },
    {
      "heading": null,
      "description": "Serve with extra lime wedges for squeezing."
    }
