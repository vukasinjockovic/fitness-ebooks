  "method": [
    {
      "heading": null,
      "description": "Make the Greek Tomato Rice Traybake batch recipe."
    },
    {
      "heading": null,
      "description": "Finely grate the garlic into a bowl, and add a drizzle of olive oil, Season generously with salt and pepper. Add the chicken thighs and rub well to coat. Leave to marinate."
    },
    {
      "heading": null,
      "description": "Heat a non-stick frying pan over a medium-high heat. Add the chicken and fry for 8-10 mins until golden and cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, warm the leftover Greek tomato rice in a saucepan over a low heat with a splash of water, stirring until piping hot throughout."
    },
    {
      "heading": null,
      "description": "Pick the parsley leaves, and finely chop most of it, keeping a few whole for the garnish. Stir most of the chopped parsley through the rice, taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Slice the chicken, then plate up the rice with the garlicky chicken on top. Add a dollop of yoghurt and scatter over the whole parsley leaves. Dig in."
    }
