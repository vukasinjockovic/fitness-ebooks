  "method": [
    {
      "heading": null,
      "description": "Before you begin make the No Fuss Roast Chicken."
    },
    {
      "heading": null,
      "description": "Mix the mayonnaise, Worcestershire sauce and mustard in a medium mixing bowl. Finely grate in the garlic clove and roughly half of the Parmesan. Add the zest and juice of the lemon, plenty of black pepper and mix."
    },
    {
      "heading": null,
      "description": "Roughly chop the chicken and finely chop the anchovies. Mix these through the dressing."
    },
    {
      "heading": null,
      "description": "Remove 4-6 large leaves from the iceberg and then roughly chop half of the remaining lettuce. Mix through the dressing along with some cubed avocado and the croutons. Grate in the remaining Parmesan."
    },
    {
      "heading": null,
      "description": "Toast the wraps and build. Lay out two sheets of greaseproof paper and lay on your large leaves of lettuce. Nestle the flour tortillas inside and load up with your Caesar salad. Wrap the lettuce and tortillas up and around the salad. Wrap with paper, slice in half and serve."
    }
