  "method": [
    {
      "heading": null,
      "description": "Make the Roast Chicken &amp; Peppers."
    },
    {
      "heading": null,
      "description": "Shred the leftover roast chicken. If cold, warm it with the peppers in a saucepan set over a low heat with a splash of water until piping hot."
    },
    {
      "heading": null,
      "description": "Finely chop the parsley. Reheat the rice, then stir through the chopped parsley."
    },
    {
      "heading": null,
      "description": "Warm the tortillas in a dry frying pan for 30 seconds on each side until flexible."
    },
    {
      "heading": null,
      "description": "Grate the cheddar and sprinkle down the centre of each tortilla. Spoon over the soured cream and herby rice, then add the chicken and pepper mixture. Roll up each tortilla tightly into a burrito – tuck in the sides, then roll from the bottom up."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of olive oil in a frying pan set over a medium heat. Once hot, place the burritos seam-side down and cook for 5-8 mins, flipping halfway, until toasted and golden."
    },
    {
      "heading": null,
      "description": "Serve hot with some chilli sauce on the side."
    }
