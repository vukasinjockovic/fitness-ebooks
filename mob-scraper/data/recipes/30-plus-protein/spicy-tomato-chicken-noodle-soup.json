  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Ancho Chilli Chicken Traybake batch recipe."
    },
    {
      "heading": null,
      "description": "Shred the chicken from the traybake. Thinly slice the garlic and red chilli. Pick the coriander leaves and thinly slice the stalks."
    },
    {
      "heading": null,
      "description": "Set a large saucepan over a medium heat with a drizzle of olive oil. Once hot, add the tomato purée, coriander stalks, garlic and half the chilli. Cook, stirring, for a couple of minutes until softened and the tomato purée has darkened."
    },
    {
      "heading": null,
      "description": "Pour in the chicken stock and bring to the boil. Tip in the pasta and cook following pack instructions until al dente."
    },
    {
      "heading": null,
      "description": "Five minutes before the pasta is done, stir the shredded chicken into the pan and cook for the remainder of the time. Taste and season with salt and pepper, adding a splash of water if you prefer a runnier soup."
    },
    {
      "heading": null,
      "description": "Ladle the soup into bowls, top with a dollop of soured cream, and scatter over the coriander leaves and remaining chilli."
    }
  ],
