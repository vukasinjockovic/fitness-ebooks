  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Sumac Chicken &amp; Roasted Veg Traybake."
    },
    {
      "heading": null,
      "description": "Shred the chicken from the Sumac Chicken &amp; Roasted Veg Traybake. Add it to a large saucepan with the chicken stock and set over a medium-high heat. Once boiling, tip in the giant couscous and cook according to the packet instructions."
    },
    {
      "heading": null,
      "description": "Meanwhile, place a small frying pan over a medium heat with the ghee or butter. Once melted, add the cumin seeds and cook for 1-2 mins until fragrant. Remove from the heat, stir through the smoked paprika and season with salt and pepper. Set aside."
    },
    {
      "heading": null,
      "description": "Once the giant couscous is cooked, stir the roasted vegetables from the traybake through the soup, topping up with water if needed. Taste and adjust the seasoning."
    },
    {
      "heading": null,
      "description": "Ladle the soup into bowls, then top with a dollop of Greek yoghurt, a drizzle of the cumin butter and a few parsley leaves."
    }
