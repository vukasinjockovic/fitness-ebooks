  "method": [
    {
      "heading": null,
      "description": "Add the cottage cheese and all the basil leaves to a blender with water. Grate in most of the Parmesan, saving some for finishing later. Blitz until smooth and bright green."
    },
    {
      "heading": null,
      "description": "Halve the cherry tomatoes."
    },
    {
      "heading": null,
      "description": "Cook the fusilli in a pan of salted boiling water until al dente. Drain, reserving a ladle of pasta water."
    },
    {
      "heading": null,
      "description": "Return the pasta to the pan and toss over a low heat with the green sauce, spinach, tomatoes and a splash of the reserved pasta water to help it all come together."
    },
    {
      "heading": null,
      "description": "Divide between two bowls and finish with the remaining Parmesan and a crack of black pepper."
    }
