  "method": [
    {
      "heading": null,
      "description": "Bash the green chilli and pop into a large bowl. Add the rest of the marinade ingredients and thoroughly mix. Tip in the meat. Allow to marinate for 1 hr or ideally overnight."
    },
    {
      "heading": null,
      "description": "Add a glug of mustard oil to a frying pan with high sides (ideally one with a lid, which you’ll need later). Set the pan over a medium heat. Once hot, add the bay leaves, cinnamon stick, cloves, cardamom, black peppercorns and dried red chillies. Cook for 30-45 seconds until fragrant, stirring constantly. Stir through the ginger and garlic paste. Add the fried onions with a splash of water and cook until they’ve softened."
    },
    {
      "heading": null,
      "description": "Add the marinated meat to the pan and fry for 4-5 mins until browned. Add the ground coriander, cumin and garam masala, then mix well. Stir through the yoghurt and water, then season with salt and sugar. Bring the mixture to the boil, place a lid on top, turn the heat down to low and simmer for 45 mins-1 hr until the meat is tender (stir occasionally, so the bottom doesn’t catch)."
    },
    {
      "heading": null,
      "description": "Meanwhile, chop the coriander and green chillies."
    },
    {
      "heading": null,
      "description": "Before serving, taste and season with salt and more sugar, if needed. Garnish with the coriander and green chillies."
    }
  ],
