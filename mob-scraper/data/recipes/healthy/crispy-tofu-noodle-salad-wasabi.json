  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C fan. Line a baking tray with baking parchment."
    },
    {
      "heading": null,
      "description": "Dice the tofu into 2cm pieces. Mix the cornflour, curry powder, and a pinch of salt in a tray, then toss the tofu in the mix to coat evenly. Spread onto the tray, drizzle with sesame oil, and roast for 20-25 mins until crisp and golden."
    },
    {
      "heading": null,
      "description": "Cook the noodles following pack instructions, then drain and rinse under cold water. Toss in a large bowl with ⅓ of the sesame oil to prevent sticking."
    },
    {
      "heading": null,
      "description": "Cut the mange tout in half. Shred the romaine and roughly chop the coriander. Add to the noodles and toss to combine. Thinly slice the radishes and set aside."
    },
    {
      "heading": null,
      "description": "In a bowl, whisk together the soy sauce, light brown sugar, rice vinegar, wasabi paste, and remaining sesame oil. Finely grate in the garlic and whisk until emulsified. Taste and adjust seasoning if needed."
    },
    {
      "heading": null,
      "description": "Box up the noodle salad and top with the crispy tofu, radishes and sesame seeds. If eating later, store the dressing separately in an airtight container. If eating now, drizzle the dressing over the top. Everything will keep well in the fridge for 3 days."
    }
  ],
