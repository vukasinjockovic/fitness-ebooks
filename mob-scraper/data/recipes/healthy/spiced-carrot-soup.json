  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 175°C."
    },
    {
      "heading": null,
      "description": "Finely chop your shallots, garlic and ginger. Finely dice your carrots into cubes."
    },
    {
      "heading": null,
      "description": "Fry the shallots in the coconut oil for 5 mins then add the garlic, ginger and curry paste and fry for a minute."
    },
    {
      "heading": null,
      "description": "Stir in the carrots and season the dish, then add the stock and coconut milk. Simmer for 30 mins."
    },
    {
      "heading": null,
      "description": "While the soup is simmering, make your topping. Roughly chop your almonds. Mix the almonds, tamari and maple together and roast for 15 minutes. Then leave to cool."
    },
    {
      "heading": null,
      "description": "Back to the soup. Add the juice of a lime and your peanut butter to the liquid, then blend until smooth with a hand blender."
    },
    {
      "heading": null,
      "description": "To serve, pour the soup into bowls. Add the almonds, basil leaves, yoghurt and chopped spring onions. Serve and enjoy."
    }
  ],
