  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 220°C."
    },
    {
      "heading": null,
      "description": "Cut the carrots in half lengthways and add to a large roasting tin. Peel, top and tail the red onion and cut into 6 wedges. Separate the onion petals and toss them into the tray along with the Garden Gourmet Chargrilled Pieces and the drained and rinsed chickpeas."
    },
    {
      "heading": null,
      "description": "Add a generous glug of olive oil to the tray along with the fennel seeds and 1 tbsp of the paprika. Season generously with salt and pepper and toss to coat."
    },
    {
      "heading": null,
      "description": "Pop into the oven for 30-40 mins, or until the carrots are gnarly and tender, and the chickpeas and Garden Gourmet Chargrilled Pieces are crispy."
    },
    {
      "heading": null,
      "description": "Cut the tomatoes into bite sized chunks and add to a large mixing bowl. Add the bulgur to the bowl along with the juice of one lime and a glug of olive oil. Season with salt and pepper and mix thoroughly."
    },
    {
      "heading": null,
      "description": "To make the tahini sauce combine the tahini with the remaining paprika and the juice of the remaining lime. Grate in the garlic clove and mix in enough cold water to create a creamy dressing."
    },
    {
      "heading": null,
      "description": "Pull the traybake out of the oven. Toss the bulgur and tomatoes through the other ingredients and pile generously onto a platter. Top with the creamy, smoky tahini dressing, lime zest and torn dill fronds. Serve with extra lime wedges for squeezing."
    }
  ],
