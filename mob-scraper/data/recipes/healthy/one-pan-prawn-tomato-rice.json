  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 190°C. Peel and slice the garlic. Set a shallow casserole dish over a medium heat with the olive oil. Once hot, cook the garlic for about 1 min until softened but not coloured."
    },
    {
      "heading": null,
      "description": "Tip in the frozen peppers with a pinch of salt and pepper and cook for 3 mins or until defrosted, tossing occasionally. Add the cherry tomatoes and cook, stirring, for 3 mins to reduce the liquid a bit."
    },
    {
      "heading": null,
      "description": "In a jug, dissolve the chicken stock pot in the boiling water."
    },
    {
      "heading": null,
      "description": "Pour the rice into the dish, then add the hot stock. Bring to the boil, give everything a quick stir, then cover and transfer to the oven for 20 mins, or until the water is nearly all absorbed."
    },
    {
      "heading": null,
      "description": "Fold in the prawns and return to the oven, uncovered, for another 5 mins until the prawns are pink and cooked through."
    },
    {
      "heading": null,
      "description": "Pick the dill and fold most of it through the rice. Season with salt and black pepper to taste. Dish up the rice and prawns, then top with the remaining dill and lemon wedges for squeezing over."
    }
  ],
