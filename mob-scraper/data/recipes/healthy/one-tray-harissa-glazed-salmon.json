  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Line a baking tray with foil to prevent sticking. Peel the sweet potato and chop into 2cm chunks. Tip onto a baking tray, season with salt and black pepper and spritz with olive oil. Roast for 15 mins until nearly tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, mix the honey, harissa and soy sauce in a small bowl to make your glaze. Season the salmon fillets and brush them all over with the glaze, reserving some to drizzle at the end."
    },
    {
      "heading": null,
      "description": "Once the sweet potatoes have cooked, nestle the salmon and broccoli onto the same tray. Spritz the broccoli with a little olive oil, then spoon over half the remaining glaze."
    },
    {
      "heading": null,
      "description": "Return the tray to the oven and roast for another 8–10 mins until the salmon is cooked through and the broccoli is just charred."
    },
    {
      "heading": null,
      "description": "Heat the rice following pack instructions."
    },
    {
      "heading": null,
      "description": "To serve, divide the rice between bowls and top with the sweet potato, broccoli and salmon. Drizzle over the remaining glaze and finish with a dollop of Greek yoghurt."
    }
  ],
