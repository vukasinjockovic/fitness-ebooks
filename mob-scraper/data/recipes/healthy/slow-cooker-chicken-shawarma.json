  "method": [
    {
      "heading": null,
      "description": "Finely zest both lemons into a large bowl, then squeeze in the juice from one half. Add the yoghurt, shawarma spice blend, a big pinch of salt and black pepper, and mix to combine. Toss in the chicken thighs and coat well. You can cook this straight away, or leave to marinate in the fridge for 30 mins or even overnight if you like."
    },
    {
      "heading": null,
      "description": "Peel the onion and cut into six wedges. Slice the peppers into 1cm strips. Add both to the insert of a slow cooker and drizzle with olive oil. Give it a quick mix."
    },
    {
      "heading": null,
      "description": "Lay the chicken on top of the veg, then cover and cook on high for 3 hrs or low for 6 hrs, until the chicken is cooked and tender."
    },
    {
      "heading": null,
      "description": "Stir in the couscous, then cover again and leave to sit for 5 mins so the couscous absorbs all the flavour."
    },
    {
      "heading": null,
      "description": "Pick most of the coriander leaves and toss through the pot. Cut the remaining lemon into wedges."
    },
    {
      "heading": null,
      "description": "To serve, spoon  into bowls and top with a spoonful of yoghurt, the rest of the coriander and a lemon wedge."
    }
  ],
