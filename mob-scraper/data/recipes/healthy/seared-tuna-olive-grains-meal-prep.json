  "method": [
    {
      "heading": null,
      "description": "Season the tuna steaks with salt and pepper. Set aside."
    },
    {
      "heading": null,
      "description": "Finely dice the shallot and add to a bowl with the juice of the lemon. Stir in the honey, oregano and a pinch of salt. Whisk in the olive oil to make your dressing."
    },
    {
      "heading": null,
      "description": "Finely mince the olives, sundried tomatoes and roasted peppers. Stir into the dressing, then add the hot grains and toss well to coat."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of water to the boil. Once boiling, reduce to a medium heat, gently lower in the eggs and cook for 7 mins until jammy. Transfer to an ice bath, leave to cool, then peel."
    },
    {
      "heading": null,
      "description": "Place a frying pan over a high heat with the remaining olive oil. Once hot, add the tuna steaks and sear on both sides until golden and just cooked through. Transfer to a board to rest for a couple of minutes."
    },
    {
      "heading": null,
      "description": "Toss the grains and parsley leaves together, then divide between Tupperware containers. Slice the tuna and halve the eggs, then top both onto the grain mix. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
