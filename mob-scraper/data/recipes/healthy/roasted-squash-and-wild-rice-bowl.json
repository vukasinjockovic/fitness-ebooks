  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Peel and slice up the butternut into thin slices. Toss in a tbsp of olive oil, a pinch of salt and thyme leaves. Bake for 20-30 mins until tender, turning halfway through."
    },
    {
      "heading": null,
      "description": "Split the halloumi down the crease and chop into 2cm chunks. When theres 10 mins left for the squash, add the halloumi to the tray, drizzle with some oil and cook for the remainder of the time, until golden."
    },
    {
      "heading": null,
      "description": "Zest the lemon and pour the tahini into a bowl. Add a squeeze of lemon juice and season with salt and a touch of honey or sugar. Stir together, adding 1 tbsp of cold water at a time, until you get a velvety, creamy consistency."
    },
    {
      "heading": null,
      "description": "Reheat the rice and share between bowls. Top with the squash and halloumi, drizzle over the tahini and finish with a scattering of pomegranate seeds and dill."
    }
