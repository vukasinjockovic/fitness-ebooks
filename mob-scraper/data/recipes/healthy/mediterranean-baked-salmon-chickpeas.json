  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Halve the olives. Strip the oregano leaves from their stalks and chop them. Zest the lemon and cut one half into thin slices. Set everything aside."
    },
    {
      "heading": null,
      "description": "Halve the cherry tomatoes. Tip the chickpeas into a medium ovenproof casserole dish (juice and all). Grate in the garlic, then add the cherry tomatoes and drizzle over the olive oil. Stir through half the lemon zest and oregano, plus all of the olives. Season well."
    },
    {
      "heading": null,
      "description": "Nestle the salmon fillets into the chickpeas. Spread over the sundried tomato pesto. Season with salt and black pepper, then scatter over the remaining lemon zest and oregano. Crumble the feta on top and tuck the lemon slices into the dish."
    },
    {
      "heading": null,
      "description": "Bake for 8 to 10 mins, until the salmon is just cooked through and opaque."
    },
    {
      "heading": null,
      "description": "To serve, dish out the chickpeas and top with the salmon. Serve with lemon wedges from the remaining half."
    }
  ],
