  "method": [
    {
      "heading": null,
      "description": "Cut the chorizo into 1cm cubes. Dice the red onion and thinly slice the garlic."
    },
    {
      "heading": null,
      "description": "Add the chorizo to a cold medium saucepan and place over a medium heat. Cook gently for 5–6 mins until the fat has rendered and the chorizo is crispy. Remove with a slotted spoon and set aside, leaving the fat in the pan."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix half of the paprika with the olive oil and a good pinch of salt. Rub this all over the cod fillets. Place on a lined tray and roast at 190°C for 8–10 mins until just cooked through and flaky."
    },
    {
      "heading": null,
      "description": "Back to the pan: add the onion, garlic and the remaining paprika. Cook for 3–4 mins, stirring occasionally, until softened and starting to caramelise."
    },
    {
      "heading": null,
      "description": "Pour in the tinned tomatoes and chuck in the kale. Simmer for 10 mins until slightly thickened."
    },
    {
      "heading": null,
      "description": "Add the butter beans along with water to loosen. Simmer for 2–3 more mins to warm everything through, then stir in half of the crispy chorizo. Squeeze in a little lemon juice and season to taste."
    },
    {
      "heading": null,
      "description": "Divide the stew between bowls and top with the roasted cod. Finish with the remaining chorizo, a dollop of yoghurt and a handful of chopped parsley."
    }
  ],
