  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 190°C."
    },
    {
      "heading": null,
      "description": "Wash the sprouts and remove any black outer leaves. Wash the kale and remove the very tough stems."
    },
    {
      "heading": null,
      "description": "Finely slice the sprouts and place them onto a baking tray. Drizzle with olive oil and season well with salt and pepper. Bake for 20-25 mins, until crispy, tossing once or twice to ensure they bake evenly."
    },
    {
      "heading": null,
      "description": "Tear the kale into bite-sized pieces and spread on another baking tray. Drizzle with olive oil and season well with salt and pepper. Bake for 15 mins, on the lower shelf, until crispy, tossing once or twice to ensure they bake evenly."
    },
    {
      "heading": null,
      "description": "Spread the pecans on a small tray and bake for 7-10 mins, until toasted and fragrant. Roughly chop and set aside."
    },
    {
      "heading": null,
      "description": "Meanwhile, make your dressing. Whisk together the mayonnaise, miso, mustard, the juice of half a lemon and the maple syrup. Taste and adjust as you like."
    },
    {
      "heading": null,
      "description": "Deseed the pomegranate."
    },
    {
      "heading": null,
      "description": "Assemble the salad by adding the kale, sprouts and half of the pomegranate and pecans with the dressing. Finish by sprinkling the rest of the pomegranate seeds and pecans on top."
    },
    {
      "heading": null,
      "description": "Best served fresh while it's crispy, but will keep in the fridge for a couple of days."
    }
  ],
