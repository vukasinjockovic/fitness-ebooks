  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Tip the chicken wings into a large oven tray. Halve the potatoes and get them into the tray, too. Drizzle the lot with olive oil and season with plenty of salt and pepper. Toss to coat and slide into the oven for 45 mins. Toss and turn the wings and potatoes a few times during the cook."
    },
    {
      "heading": null,
      "description": "While the wings are roasting, whip up the salad. Add the yoghurt to a large mixing bowl and crumble in the blue cheese. Add the juice of a lemon, plenty of black pepper, and mix to combine."
    },
    {
      "heading": null,
      "description": "Finely slice the hispi cabbage and celery. Core and thinly slice the apple. Add all three to the bowl and toss in the yoghurt and blue cheese dressing. Finely chop and add the dill to the salad."
    },
    {
      "heading": null,
      "description": "Whip the tray out of the oven and pour over the buffalo-style hot sauce sauce. Toss to coat then return to the oven for 4-5 mins to warm through."
    },
    {
      "heading": null,
      "description": "Divide the salad between plates and serve the traybake in the middle of the table, family-style."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
  ],
