  "method": [
    {
      "heading": null,
      "description": "Finely grate two-thirds of the garlic cloves. Add to a mixing bowl with the chicken thighs, half of the yoghurt, onion powder, paprika, cumin, oregano, zest and juice of half the lemon, and salt. Season with black pepper and mix well. Set aside to marinate while you prep the rest."
    },
    {
      "heading": null,
      "description": "Grate the cucumber and squeeze out any excess liquid using your hands or a clean tea towel. Add to a bowl with the remaining yoghurt, the juice of the other lemon half, the last garlic clove (grated), and a good pinch of salt. Mix together to make your tzatziki and set aside."
    },
    {
      "heading": null,
      "description": "Finely slice the red onion and tomato."
    },
    {
      "heading": null,
      "description": "Tip the frozen fries into the bottom of your air fryer basket and lay the marinated chicken thighs on top. Cook at 200°C for 10–15 mins until the fries are crisp and the chicken is golden and cooked through."
    },
    {
      "heading": null,
      "description": "Toast the flatbreads in a dry pan until warm and slightly charred."
    },
    {
      "heading": null,
      "description": "To assemble, spread a generous spoonful of tzatziki over each flatbread. Top with tomato, red onion and slices of the cooked chicken. Add the fries, if using, then wrap it all up."
    }
  ],
