  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 220°C. Season the chicken legs with salt. Cut the aubergine into 2cm chunks."
    },
    {
      "heading": null,
      "description": "Add the aubergine chunks to a high sided roasting tray. Season with salt and drizzle with olive oil then roast in the oven for 20-25 mins until golden and softened, turning half way through."
    },
    {
      "heading": null,
      "description": "Remove the tray from the oven. Add the cherry tomatoes, whole unpeeled garlic cloves and chilli flakes to the tray and give it a mix. Place the chicken legs on top and drizzle generously with olive oil then sprinkle with the oregano. Place in the oven for another 20 mins then lower the heat to 170°C and roast for another 20 mins or until the chicken is golden and the tomatoes have burst to create a sauce underneath."
    },
    {
      "heading": null,
      "description": "Serve with plenty of fresh basil and grated Parmesan. And some crusty bread, if you like."
    }
  ],
