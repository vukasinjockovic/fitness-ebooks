  "method": [
    {
      "heading": null,
      "description": "Add the vinegar and sugar to a small saucepan. Bring to a boil, stir to combine and then add the ice. Leave to cool to room temperature."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice 1/4 of the chillies and the red onion. Add to the pickle liquor and set aside."
    },
    {
      "heading": null,
      "description": "Add the salad potatoes to a large pan and cover with cold water. Season with salt, bring to a boil and simmer until just tender. This should take around 13 mins."
    },
    {
      "heading": null,
      "description": "Drain and leave to steam dry for a few minutes."
    },
    {
      "heading": null,
      "description": "Coat the remaining chillies with olive oil and grill on a hot barbecue until thoroughly charred. Finely chop until almost a paste and mix with the mayo. Add a big squeeze of lemon juice and season."
    },
    {
      "heading": null,
      "description": "Now toss the potatoes in olive oil and get them onto the grill. Grill until charred, crispy and smoky."
    },
    {
      "heading": null,
      "description": "Chuck the potatoes on a plate and cover with the chilli mayo and pickles. Thinly slice the spring onions and scatter over. Get stuck in."
    }
  ],
