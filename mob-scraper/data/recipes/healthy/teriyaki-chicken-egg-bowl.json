  "method": [
    {
      "heading": null,
      "description": "Cook the rice using your preferred method. Boil the eggs for 7 mins, then run under cold water and peel."
    },
    {
      "heading": null,
      "description": "Finely grate the garlic and ginger. Trim and finely slice the spring onions, keeping the whites and greens separate."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix the soy sauces, brown sugar, grated garlic, ginger, sesame oil, water and cornflour. Mix well until there are no lumps."
    },
    {
      "heading": null,
      "description": "Chop the chicken into bite-sized pieces and season with a pinch of salt."
    },
    {
      "heading": null,
      "description": "Set a large frying pan over a medium-high heat with the vegetable oil. Once hot, add the chicken and cook for 6–7 mins, stirring occasionally, until golden and cooked through."
    },
    {
      "heading": null,
      "description": "Pour in the sauce and the spring onion whites. Cook for 3-5 minutes until reduced and becomes thick and glossy."
    },
    {
      "heading": null,
      "description": "Halve the boiled eggs."
    },
    {
      "heading": null,
      "description": "To serve, spoon the rice into bowls. Top with the teriyaki chicken and sauce, the halved eggs and the edamame. Finish with spring onion greens and a scattering of sesame seeds."
    }
  ],
