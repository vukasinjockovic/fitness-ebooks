  "method": [
    {
      "heading": null,
      "description": "Cook the couscous following pack instructions. Drain."
    },
    {
      "heading": null,
      "description": "Slice the leeks into 4cm pieces and wash well to remove any dirt. Drain well."
    },
    {
      "heading": null,
      "description": "Add the olive oil, the leeks and a big pinch of salt and pepper to a large frying pan. Cook over a medium heat, stirring to coat in the oil, until nicely coloured around 3 - 4 minutes. Turn the heat down to low, cover the pan and cook the leeks gently for 15-20 mins, stirring halfway through until they are very tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the garlic, coriander stalks, green olives and preserved lemon. Once the leeks are tender, add your chopped ingredients (plus the coriander seeds) to the leek pan and cook for 1-2 mins until fragrant. Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Blend the coriander leaves, lemon juice and yoghurt, adding salt and pepper to taste, until you have a smooth green sauce. Stir this into the cooked couscous and season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "To serve, spoon and spread the dressed couscous over plates or a platter and top with the leek mixture. Crumble the feta and sprinkle the chilli and sumac (if using) on top."
    }
  ],
