  "method": [
    {
      "heading": null,
      "description": "Cut the courgette into chunks. Chop the mint, setting aside a few leaves to garnish later. Cut the halloumi into 2cm chunks."
    },
    {
      "heading": null,
      "description": "Chuck the courgette into the drawer of an air fryer. Spritz with olive oil, season with salt and pepper, then cook at 200°C for 15 mins. Toss in the cherry tomatoes, dried oregano and halloumi for the final 6 mins."
    },
    {
      "heading": null,
      "description": "Peel the garlic. Zest the lemon, then juice it."
    },
    {
      "heading": null,
      "description": "Blitz the garlic, cottage cheese, Dijon mustard, lemon zest and juice in a blender with enough water to make a drizzling consistency (start with a tablespoon). Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Drain the lentils and chickpeas and tip them into a large bowl. Toss with the chopped mint and half the dressing."
    },
    {
      "heading": null,
      "description": "Spoon the salad onto plates, top with the roasted halloumi and tomatoes, drizzle with the remaining dressing and garnish with the reserved mint leaves."
    }
  ],
