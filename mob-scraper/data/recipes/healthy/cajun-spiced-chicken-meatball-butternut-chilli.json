  "method": [
    {
      "heading": null,
      "description": "Mix the chicken mince with half of the Cajun seasoning, then shape into small balls."
    },
    {
      "heading": null,
      "description": "Heat the olive oil in a large saucepan over a medium-high heat. Add the chicken meatballs and fry for about 5 mins until browned on all sides."
    },
    {
      "heading": null,
      "description": "Add the sofrito mix and cook, stirring, for 2 mins. Finely slice the garlic and chuck it in with the chopped butternut squash. Cook for 1 min, then stir through the Cajun seasoning and cook for another minute until fragrant."
    },
    {
      "heading": null,
      "description": "Pour in the plum tomatoes, squashing them with the back of a spoon. Fill one of the empty cans with water, swirl and tip into the pan. Add the beans — liquid and all — then bring everything to a simmer."
    },
    {
      "heading": null,
      "description": "Turn the heat down and cook for 30 mins until thickened and the squash is soft. Stir through the balsamic and season to taste with salt and black pepper. Grate the cheddar and pick the coriander."
    },
    {
      "heading": null,
      "description": "To serve, ladle the chilli into bowls and top with a dollop of Greek yoghurt, fresh coriander leaves and a little extra Cajun seasoning."
    }
  ],
