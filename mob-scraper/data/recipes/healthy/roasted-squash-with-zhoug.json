  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°c"
    },
    {
      "heading": null,
      "description": "Wash, peel and slice the butternut squash into roughly 2cm thick slices. Toss in a roasting tray with a good drizzle of olive oil and a big pinch of salt and roast for about 40 mins until golden."
    },
    {
      "heading": null,
      "description": "In a bowl, mix together the greek yogurt and goat's cheese with a pinch of salt and a squeeze of lemon. Set aside."
    },
    {
      "heading": null,
      "description": "Grate the garlic into a blender before chopping up your chilli and adding to the blender along with the coriander, cardamom, cumin and chilli flakes."
    },
    {
      "heading": null,
      "description": "Squeeze in the juice of a lemon and add about 100ml of olive oil. Whizz until not quite smooth."
    },
    {
      "heading": null,
      "description": "Once the squash is cooked, remove and allow to cool slightly. Spread the yoghurt and goat's cheese mixture across a large plate and then pile up the squash, drizzling each layer with some of the zhoug."
    },
    {
      "heading": null,
      "description": "Roughly chop and toast the hazelnuts, sprinkle over the top and finish with the rest of the zhoug and some more chilli flakes, if you like."
    }
  ],
