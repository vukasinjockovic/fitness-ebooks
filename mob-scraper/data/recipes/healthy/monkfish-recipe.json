  "method": [
    {
      "heading": null,
      "description": "Remove any sinew from the monkfish, then cut into large bite-sized pieces. Dust over the smoked paprika and season well. Toss well and chill while you make the sauce."
    },
    {
      "heading": null,
      "description": "Thinly slice the fennel and peel then thinly slice the garlic cloves."
    },
    {
      "heading": null,
      "description": "Heat a splash of olive oil in a large, deep frying pan (that you have a lid for) and fry the fennel over a medium-high heat for 6-7 minutes until caramelising."
    },
    {
      "heading": null,
      "description": "Turn the heat down to medium and add the garlic, 'nduja and fennel seeds. Stir and toss everything around for 2-3 minutes, breaking the 'nduja up with the back of the spoon."
    },
    {
      "heading": null,
      "description": "Pour in the white wine and bubble away for 2 minutes."
    },
    {
      "heading": null,
      "description": "Tip the cherry tomatoes into the pan, then drain the butter beans and add to the pan. Season with salt and black pepper, then bubble away for 30 minutes until the sauce has reduced."
    },
    {
      "heading": null,
      "description": "Remove the monkfish pieces from the fridge and nestle into the sauce. Put on a lid and simmer for another 8 minutes until the fish is cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, toss the rocket in the sherry vinegar."
    },
    {
      "heading": null,
      "description": "Once the fish is cooked, drape a little of the rocket over the top of the stew, then divide between shallow bowls, along with the rest of the rocket salad."
    }
  ],
