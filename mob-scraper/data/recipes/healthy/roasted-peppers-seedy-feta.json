  "method": [
    {
      "heading": null,
      "description": "Preheat the grill to max."
    },
    {
      "heading": null,
      "description": "Toss the peppers with oil and salt and add to a roasting tin. Slide under the grill\nto blister and char for 6-7 mins, turning regularly until they’re very blackened.\nPull out and cover with an upturned tray or add to a covered bowl, to steam\nthrough."
    },
    {
      "heading": null,
      "description": "Grab a large mixing bowl and add 5 tbsp of olive oil with the red wine vinegar.\nGrate in the garlic cloves. Then thinly slice the red onion and chop the cucumber into half moons, add both into the bowl. Scatter\nin the herbs. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Peel the blackened skin from the peppers and toss through the herby dressing.\nSet aside to marinate."
    },
    {
      "heading": null,
      "description": "Tip the seeds out onto a plate and season with pepper. Unpack the feta and dip\neach side in the seeds, they will stick naturally to the cheese."
    },
    {
      "heading": null,
      "description": "Drizzle with olive oil and slide under the hot grill for 3-4 mins until golden\nbrown."
    },
    {
      "heading": null,
      "description": "Spread the peppers over a large serving plate and serve the feta in the middle.\nSlice up some crusty bread to eat alongside."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
  ],
