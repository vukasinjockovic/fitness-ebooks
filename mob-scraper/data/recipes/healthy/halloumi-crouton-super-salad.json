  "method": [
    {
      "heading": null,
      "description": "Preheat the oven 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Cut your peppers into chunks. Add to a roasting tray with salt, pepper and a drizzle of olive oil. Roast for 40 minutes or until charred and soft."
    },
    {
      "heading": null,
      "description": "Pesto time. Into a blender, add a handful of basil leaves, the juice of a lemon, garlic clove, toasted pine nuts and Parmesan. Add 5 tbsp of olive oil and blend until smooth."
    },
    {
      "heading": null,
      "description": "Courgette time. Cut your courgettes into thin strips. Drizzle with olive oil, salt and pepper. Add to a hot griddle pan and cook for 6 minutes on each side."
    },
    {
      "heading": null,
      "description": "Halloumi time. Cut your halloumi into small cubes. Get three bowls out. Add plain flour to one, eggs to another (whisk them up) and breadcrumbs to the third. Dip your halloumi in the flour, then the eggs and then the breadcrumbs."
    },
    {
      "heading": null,
      "description": "Get a pan on the heat. Fill it up 2cm high with vegetable oil. Heat the oil. Add the croutons to the pan. Cook for 4 minutes until golden brown."
    },
    {
      "heading": null,
      "description": "Remove croutons from the heat and place them on some kitchen roll."
    },
    {
      "heading": null,
      "description": "Halve your cherry tomatoes."
    },
    {
      "heading": null,
      "description": "Add all of your ingredients, along with a bag of rocket and any leftover pine nuts, to a large salad bowl. Pour over your pesto dressing, toss it all together and serve it up. Enjoy!"
    }
  ],
