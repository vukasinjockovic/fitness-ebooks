  "method": [
    {
      "heading": null,
      "description": "Bring a large saucepan of salted water to the boil."
    },
    {
      "heading": null,
      "description": "Peel and thinly slice the garlic. Heat the olive oil in a wide saucepan over a medium heat, then add the garlic and cook for 1–2 mins until just golden."
    },
    {
      "heading": null,
      "description": "Tip in the chopped tomatoes, season well and let the sauce gently simmer while you prep the chicken."
    },
    {
      "heading": null,
      "description": "Place the chicken breasts between two sheets of baking paper and bash them to about 1cm thick."
    },
    {
      "heading": null,
      "description": "Set up a breading station with three plates — one with the flour, one with the beaten egg and one with the breadcrumbs. Season the chicken on both sides with salt and pepper. Dip each piece in the flour, then the egg, then the panko."
    },
    {
      "heading": null,
      "description": "Cook the spaghetti following pack instructions, reserving a splash of pasta water before draining."
    },
    {
      "heading": null,
      "description": "Spray the chicken with some oil spray on each side. Transfer the breaded chicken to an air fryer basket and cook at 200°C for 8 mins. Flip and cook for another 8 mins until golden and cooked through."
    },
    {
      "heading": null,
      "description": "Add the cooked spaghetti to the tomato sauce with half the parmesan and a splash of pasta water. Toss until the sauce clings to the pasta."
    },
    {
      "heading": null,
      "description": "Divide the saucy spaghetti between two plates. Slice the crispy chicken and lay it on top. Finish with a generous grating of Parmesan and a big dollop of cottage cheese."
    }
  ],
