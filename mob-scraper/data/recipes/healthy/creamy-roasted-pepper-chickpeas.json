  "method": [
    {
      "heading": null,
      "description": "Finely slice the garlic. Drain and rinse the chickpeas. Roughly chop the roasted peppers and halve the cherry tomatoes."
    },
    {
      "heading": null,
      "description": "Add the spinach to a colander in the sink and pour over two full kettles of boiling water until wilted. Set aside to drain."
    },
    {
      "heading": null,
      "description": "Add the roasted peppers to a blender with the silken tofu, half the red chilli, and the juice of the lemon. Season generously with salt and pepper, then blitz until smooth. Finely slice the remaining chilli."
    },
    {
      "heading": null,
      "description": "Heat a splash of the olive oil in a large pan over a medium-high heat. Add the cherry tomatoes and cook for 3–4 mins until just starting to soften. Add the remaining oil along with the garlic and smoked paprika, and cook for another 2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Tip in the chickpeas and pour over the roasted pepper sauce. Bring to a simmer and cook for 5 mins, then stir through the spinach until heated through. Taste and adjust the seasoning if needed."
    },
    {
      "heading": null,
      "description": "Serve up in bowls, scattered with the sliced red chilli and fresh parsley."
    }
  ],
