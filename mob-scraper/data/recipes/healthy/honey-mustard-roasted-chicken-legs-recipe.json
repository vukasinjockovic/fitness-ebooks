  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 190°C. Season the chicken legs well with salt and pepper. Lay them skin-side up in your largest roasting tray, then drizzle over 1 tbsp olive oil. Roast for 30 mins."
    },
    {
      "heading": null,
      "description": "Add olive oil, mustard, honey and the zest and lemon juice into a separate salad bowl. Whisk together and season with salt and pepper to taste – this is your salad dressing."
    },
    {
      "heading": null,
      "description": "Now mix the olive oil, mustard and honey into a small bowl for the chicken. Whisk together with a fork and set aside."
    },
    {
      "heading": null,
      "description": "Toast the pumpkin seeds in a small, dry frying pan over a high heat until browned and beginning to pop. Set aside."
    },
    {
      "heading": null,
      "description": "Once the chicken has been roasting for 30 mins, add the grapes to the tray then pour the honey and mustard mix over the chicken legs. Baste with some of the chicken fat from the bottom of the pan, then return to the oven for 20 mins until the chicken is cooked through and crisp and the grapes are starting to burst."
    },
    {
      "heading": null,
      "description": "While the chicken is having its final roast, make your salad. Very finely slice the fennel, saving the green fronds, then toss in the salad dressing. Slice the cucumber, then add this too. Separate and tear the Little Gem leaves, add to the salad along with the toasted pumpkin seeds, then toss everything together. Taste and add more lemon juice if it needs it."
    },
    {
      "heading": null,
      "description": "Serve the roasted chicken legs and grapes alongside the salad in the middle of the table for people to help themselves, alongside a baguette for mopping up."
    }
  ],
