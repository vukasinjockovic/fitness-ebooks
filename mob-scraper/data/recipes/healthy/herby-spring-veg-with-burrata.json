  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 220°C."
    },
    {
      "heading": null,
      "description": "Wash and thinly slice the leek and courgette. Cut the pepper into medium-sized chunks and the asparagus into small chunks."
    },
    {
      "heading": null,
      "description": "Transfer the leek, courgette and green bell pepper to a large roasting tin, drizzle with olive oil and season generously with salt and pepper. Toss to coat, arrange in a single layer and roast for 15 mins."
    },
    {
      "heading": null,
      "description": "Take the veg out of the oven and add the asparagus. Toss to coat, then pop back into the oven for 10 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, boil and drain the peas according to the package instructions."
    },
    {
      "heading": null,
      "description": "Place the garlic in a mortar and pound to a paste with a pestle. Add the basil and olive oil and pound until well combined. Alternatively, you can do this in a food processor."
    },
    {
      "heading": null,
      "description": "Transfer the roasted veg to a large bowl. Add the peas, a big squeeze of lemon juice and the basil mixture and toss everything together. Taste, adjust the seasoning and leave to cool."
    },
    {
      "heading": null,
      "description": "Cut the bread into slices, chuck it into the same tray and drizzle with olive oil. Bake in the oven for 10 to 15 mins, or until crisp. Meanwhile, deseed and chop the chilli. Leave the bread to cool for 5 min then blitz in a food processor with the chilli, salt and pepper."
    },
    {
      "heading": null,
      "description": "To serve, plate up the veg on the bottom of a large plate or platter. Top with the burrata and chilli crumb then tuck in and enjoy!"
    }
  ],
