  "method": [
    {
      "heading": null,
      "description": "Whisk together the Dijon mustard and honey in a bowl with a pinch of salt and black pepper. Cut the salmon into 3–4cm chunks and toss them through the glaze until coated."
    },
    {
      "heading": null,
      "description": "Spray the rack of your air fryer with non-stick spray. Add the salmon chunks and cook at 200°C for 6 mins until golden and cooked through. Remove and set aside, then chuck in the edamame and cook for 2 mins until piping hot."
    },
    {
      "heading": null,
      "description": "Thinly slice the cucumber, spring onions and avocado. Toss the cucumber with the white parts of the spring onions (reserving the greens to garnish), rice vinegar and a third of the sriracha. Set aside."
    },
    {
      "heading": null,
      "description": "In a small bowl, loosen the Greek yoghurt with the remaining sriracha and water until you’ve got a drizzling consistency."
    },
    {
      "heading": null,
      "description": "Heat the sticky rice according to packet instructions. To serve, spoon the sticky rice into bowls and top with the sticky salmon, cucumber salad and sliced avocado. Drizzle over the yoghurt sauce and scatter over the green parts of the spring onion."
    }
  ],
