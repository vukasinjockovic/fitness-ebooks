  "method": [
    {
      "heading": null,
      "description": "Get your pearl barley on. Follow pack instructions. Add a veggie stock cube to the water."
    },
    {
      "heading": null,
      "description": "Veg prepping time. Halve your cherry tomatoes. Cube your red peppers, avocado and cucumber (peel and de-seed the cucumber)."
    },
    {
      "heading": null,
      "description": "Add the veggies to a bowl along with your cooked pearl barley. Add the mango and pomegranate seeds."
    },
    {
      "heading": null,
      "description": "Finely chop a handful of basil, coriander and mint. Add to the bowl along with a finely chopped chilli."
    },
    {
      "heading": null,
      "description": "Add your vinegar, soy sauce, the juice of a lime and your olive oil. Season with salt and pepper. Mix everything together. Serve in bowls or add to your tupperware and take to uni or work the next day!"
    }
  ],
