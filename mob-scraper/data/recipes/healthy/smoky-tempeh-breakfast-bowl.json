  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Rinse the quinoa under cold water, then cook in a pan of salted boiling water for 12–15 mins until fluffy. Drain and set aside."
    },
    {
      "heading": null,
      "description": "Slice the tempeh and chuck it into a bowl with the smoked paprika, soy sauce, maple syrup, half the olive oil and a pinch of black pepper. Toss to coat, then spread out on one side of a baking tray."
    },
    {
      "heading": null,
      "description": "Toss the cherry tomatoes with the rest of the olive oil and some salt and pepper. Add to the other side of the tray, then slide it into the oven for 15 mins until the tomatoes are soft and blistered and the tempeh is golden."
    },
    {
      "heading": null,
      "description": "Finely chop most of the parsley, saving a few leaves for garnish. Stir the chopped parsley through the cooked quinoa."
    },
    {
      "heading": null,
      "description": "Grate the garlic and squeeze the lime. Add both to a blender with the edamame and a pinch of salt and pepper. Blitz until smooth, adding a splash of water if needed to loosen it to a hummus-like consistency."
    },
    {
      "heading": null,
      "description": "Spoon the quinoa into a bowl and top with the roasted tomatoes and crispy tempeh. Add a big dollop of the edamame guac and finish with the rest of the parsley. Serve with a wedge of lime on the side, if you like."
    }
  ],
