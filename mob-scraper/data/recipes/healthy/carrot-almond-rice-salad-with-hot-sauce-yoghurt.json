  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Halve the carrots lengthways and add to a large roasting tray. Drizzle with olive oil and season well, then slide into the oven for 30 mins, until softened."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the rice. Cook the rice according to packet instructions, then add to a bowl. Roughly chop the parsley and mint and add to the bowl. Roughly chop the almonds and add most of them to rice."
    },
    {
      "heading": null,
      "description": "Tip the raisins into a small saucepan, add the lemon juice, ras el hanout and 2 tbsp olive oil, place over a low heat and gently warm for 5 mins, until the raisins are plump, then tip the mix into the rice. Season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Mix the yoghurt and the hot sauce, season well."
    },
    {
      "heading": null,
      "description": "Tip the rice into bowls or onto a platter, top with the carrots, drizzle in the hot sauce yoghurt and scatter with the remaining toasted almonds. Finish with a crack of black pepper."
    }
  ],
