  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Cut your squashes in half and scoop out the seeds. Cut the flesh into large wedges 3cm thick."
    },
    {
      "heading": null,
      "description": "Pop onto a baking tray and drizzle your squash with olive oil, salt and pepper. Bake for 30 mins until beginning to soften."
    },
    {
      "heading": null,
      "description": "Meanwhile, wrap your bulb of garlic in foil and pop this on the lowest shelf of your oven to roast for 40 mins."
    },
    {
      "heading": null,
      "description": "Chop your spring onions and ginger into large chunks. Scoop out the seeds of the scotch bonnet."
    },
    {
      "heading": null,
      "description": "After the 30 mins has elapsed, remove your tray from the oven and add your spring onions, your scotch bonnet and ginger. Return to the oven for another 20 mins, by which time your veg should be nice and caramelised."
    },
    {
      "heading": null,
      "description": "When your garlic is cool enough to handle, squeeze the flesh out of its skin by pressing a knife on top. Discard the skin."
    },
    {
      "heading": null,
      "description": "Tip all your veg into a large saucepan and add your vegetable stock, roasted garlic pulp, peanut butter and 4 tbsp of your coconut yoghurt. Whizz to a smooth consistency with a stick blender."
    },
    {
      "heading": null,
      "description": "Season your soup to taste - it might need a little salt and pepper."
    },
    {
      "heading": null,
      "description": "Garnish with a drizzle of coconut yoghurt, chopped peanuts and coriander. Serve and enjoy!"
    }
  ],
