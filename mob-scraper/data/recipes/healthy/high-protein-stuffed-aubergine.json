  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Add the boiling water in a jug and mix through the stock cube until dissolved. Mix the stock through the soy protein and cover with a plate to steam. Set aside for at least 15 mins."
    },
    {
      "heading": null,
      "description": "Cut the aubergine in half and score in a criss cross pattern all along the flesh. Place it cut side down on a lined baking sheet. \nBake for 35-45 mins, until very soft inside (this will depend on the size of your aubergine)."
    },
    {
      "heading": null,
      "description": "Drain the soy protein in a colander and squeeze out the excess water with the back of a spoon."
    },
    {
      "heading": null,
      "description": "Finely chop the onion and garlic. Sauté the onion in a large frying pan on medium heat for 3-4 mins with a drizzle of olive oil. Add the garlic and stir for another minute before adding your spices (ras el hanout or a mix of cumin, paprika and chilli) tomato paste and balsamic vinegar."
    },
    {
      "heading": null,
      "description": "Add the soy protein and the mashed aubergine flesh to the pan with a drizzle of olive oil and season well. Fry the mix for 7-8 mins until starting to crisp up. Taste and add more seasonings as you like. Mix in the pine nuts."
    },
    {
      "heading": null,
      "description": "Spoon the mixture back into the aubergine skins. Drizzle with a little olive oil and grill for 3-5 mins until crispy on top."
    },
    {
      "heading": null,
      "description": "Cook your rice or couscous. Finely chop the parsley."
    },
    {
      "heading": null,
      "description": "Serve the aubergines with your chosen grain and top with plenty of parsley, some extra pine nuts, and pomegranate and tahini if using. Finish with a good squeeze of lemon and enjoy."
    }
  ],
