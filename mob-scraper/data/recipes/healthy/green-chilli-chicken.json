  "method": [
    {
      "heading": null,
      "description": "Dice the chicken breast. Add the chicken, tomatillo salsa and chicken stock to a large saucepan. Finely grate in the garlic, season with salt and place over a medium heat. Let it simmer for 8–10 mins until the chicken is cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the jalapeño, avocado and radishes. Finely mince the coriander."
    },
    {
      "heading": null,
      "description": "Once the chicken is cooked, stir in the cannellini beans (with their liquid) and the coriander. Let it warm through for another minute or two. Taste and season with more salt, black pepper and a good squeeze of lime juice."
    },
    {
      "heading": null,
      "description": "Ladle the soup into bowls. Top with a handful of grated cheddar, sliced radishes, avocado and jalapeño. Serve with tortilla crisps on the side."
    }
  ],
