  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Add the kale and parsley to a food processor removing any stalks as you go."
    },
    {
      "heading": null,
      "description": "Add the cheese, nuts (we used walnuts), garlic and olive oil and blend until you have a smooth texture. Season with salt and black pepper and taste."
    },
    {
      "heading": null,
      "description": "Next, brown the sausages in a pan over a medium heat, season with salt then transfer to the oven to cook for 20-25 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, crack on with the beans. Finely dice the shallot and thinly slice the garlic. Set a pan over a medium heat with a good glug of olive oil, add the shallots and begin to gently sauté."
    },
    {
      "heading": null,
      "description": "After 5 mins, add the garlic and fennel seeds and cook for a few mins before draining and adding the beans."
    },
    {
      "heading": null,
      "description": "Season with salt then turn up the heat and add the wine if using and reduce. Add the stock and reduce by half before adding the butter and tossing through. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Spread the beans over the bottom of a plate then top with the sausage and dots of the pesto."
    },
    {
      "heading": null,
      "description": "Drizzle with olive oil and serve."
    }
  ],
