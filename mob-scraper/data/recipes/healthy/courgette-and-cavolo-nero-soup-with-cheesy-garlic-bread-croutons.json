  "method": [
    {
      "heading": null,
      "description": "Add 3 tbsp of olive oil to a large pan and place over a medium heat. Dice the onion and fry gently for a few minutes along with the bay leaves."
    },
    {
      "heading": null,
      "description": "Add the courgette and a good pinch of salt, cook for another few minutes."
    },
    {
      "heading": null,
      "description": "Roughly chop and add the cavolo nero or kale and cook for about 5 mins until softened."
    },
    {
      "heading": null,
      "description": "Dice the potato and add to the pan along with the chilli flakes (if using). Then add the stock and 3 of the peeled whole garlic cloves."
    },
    {
      "heading": null,
      "description": "Stir well and bring to a simmer, cook until the potatoes are completely soft (about 20 mins)."
    },
    {
      "heading": null,
      "description": "While the soup cooks, make the croutons. Tear up the ciabatta into roughly 1 inch cubes."
    },
    {
      "heading": null,
      "description": "Put the softened butter into a bowl (you can microwave it for a few seconds) then mince the remaining garlic and finely chop the parsley, add both to the butter with a pinch of salt and mix."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium heat, add the butter and then the bread. Fry well, tossing until golden brown and crunchy. Tip onto a plate and grate over the parmesan which will melt a little bit."
    },
    {
      "heading": null,
      "description": "When the soup is ready, blitz with a stick blender until smooth. Then season with salt and lemon juice to taste. Finely chop the tarragon, add and stir."
    },
    {
      "heading": null,
      "description": "Add the soup to bowls and top with the cheesy garlic bread croutons."
    }
  ],
