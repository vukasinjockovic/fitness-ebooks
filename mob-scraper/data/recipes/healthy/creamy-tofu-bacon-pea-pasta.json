  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C fan."
    },
    {
      "heading": null,
      "description": "Dice the tofu into small 1cm cubes and chuck into a bowl with the smoked paprika, soy sauce and maple syrup. Mix well, then spread out on a lined baking tray. Roast for 20 mins, giving it a mix halfway through, until crispy and golden."
    },
    {
      "heading": null,
      "description": "Get a large saucepan of salted water on to boil. Once boiling, cook the pasta following pack instructions."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the onion and garlic. Heat the olive oil in a second saucepan over a medium heat. Add the onion and cook for 10 mins until soft and golden. Stir in the garlic and cook for 2-3 mins more until fragrant. Tip in the frozen petit pois and cook for another couple of mins until vibrant and tender."
    },
    {
      "heading": null,
      "description": "Zest the lemon, then cut it in half. Finely chop the chives."
    },
    {
      "heading": null,
      "description": "Add the drained pasta straight into the pea mixture, followed by the Greek yoghurt, lemon zest and a squeeze of lemon juice. Stir well to combine. Taste and season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Serve topped with the crispy tofu ‘bacon’ and a scattering of chives."
    }
  ],
