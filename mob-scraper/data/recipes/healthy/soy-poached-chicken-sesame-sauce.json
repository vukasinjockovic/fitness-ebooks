  "method": [
    {
      "heading": null,
      "description": "Pop the chicken into a large pot and cover with cold water or if you’ve got it, chicken stock. Chunk up the spring onions and drop those in along with the roughly chopped ginger, smashed garlic cloves and the soy sauce."
    },
    {
      "heading": null,
      "description": "Set over a high heat and bring to a rolling boil. Remove from the heat, add a lid and set aside for 90 mins. The residual heat will fully poach the chicken."
    },
    {
      "heading": null,
      "description": "For the sesame sauce, pop the sugar, vinegar, tahini and soy sauce into a blender or bowl and whizz together until smooth. Add icy cold water as needed to loosen, until you have a creamy sauce. Finish with the sesame seeds and set aside."
    },
    {
      "heading": null,
      "description": "To cook the rice, rinse it well with cold water until most of the starch has been washed away. Drain and pop into a saucepan with the salt, sugar and vinegar. Cover with 480ml of the chicken cooking liquid, add a lid and bring to a boil. Once boiling, reduce the heat to the lowest setting and cook for 8-10 mins, or until the rice is full cooked and the liquid has been absorbed. Remove from the heat and allow to rest for 10 mins."
    },
    {
      "heading": null,
      "description": "Cut the cucumber into thin slices and finely chop the spring onions. Remove the meat from the chicken, you can carve or shred, up to you!"
    },
    {
      "heading": null,
      "description": "Return the shredded/carved chicken to the broth. Set the pan over a medium heat for 5-10 mins until warmed through."
    },
    {
      "heading": null,
      "description": "Divide the rice between bowls, top with some chicken, a handful each of cucumber and spring onion and a good few ladles of the warm chicken cooking liquid. Add a spoon of soy and a generous spoonful of the sesame sauce."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
  ],
