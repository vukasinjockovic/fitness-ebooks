  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Roughly dice 1kg of the tomatoes."
    },
    {
      "heading": null,
      "description": "Peel and chunk up one of the cucumbers."
    },
    {
      "heading": null,
      "description": "Roughly chop one of the peppers and the onion."
    },
    {
      "heading": null,
      "description": "Smush the garlic cloves and de-seed and roughly chop the chilli."
    },
    {
      "heading": null,
      "description": "Chuck the lot into your biggest mixing bowl with a handful of basil leaves."
    },
    {
      "heading": null,
      "description": "Remove the crusts from the sourdough. Cut into croutons and add half to the gazpacho veggies."
    },
    {
      "heading": null,
      "description": "Season the veggies generously with salt and pepper and add 60ml of olive oil and the sherry vinegar."
    },
    {
      "heading": null,
      "description": "Toss the remaining bread with a glug of oil and a pinch of salt. Bake until golden and crisp, around 10 mins. Remove from the oven and leave to cool."
    },
    {
      "heading": null,
      "description": "Leave the veggies to marinate for at least an hour, overnight in the fridge is ideal!"
    },
    {
      "heading": null,
      "description": "Meanwhile, dice the remaining veggies and melon into equal-sized pieces. I shoot for 2cm dice. Toss with olive oil, salt, and pepper to make a lovely mixed salad to garnish your soup."
    },
    {
      "heading": null,
      "description": "Now, time to blend. Grab the gazpacho mix and blend until super smooth, you might have to do this in batches."
    },
    {
      "heading": null,
      "description": "Season to taste and refrigerate until icy cold."
    },
    {
      "heading": null,
      "description": "Give the soup a brief whisk to loosen, divide between chilled bowls and top with your salad and crunchy croutons. Finish with a few extra basil leaves, a drizzle of olive oil and get stuck in."
    }
  ],
