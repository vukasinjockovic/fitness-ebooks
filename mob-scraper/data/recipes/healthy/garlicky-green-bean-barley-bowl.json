  "method": [
    {
      "heading": null,
      "description": "Bring the stock to the boil in a large saucepan. Rinse the barley well, then add it to the stock pan. Cook for 25 mins or until tender."
    },
    {
      "heading": null,
      "description": "Trim the green beans. Bring a pan of water to the boil and blanch the beans for 1 min. Drain and rinse in cold water, then dry well and set aside."
    },
    {
      "heading": null,
      "description": "Finely chop the garlic, then add to a pan with a shot of oil over a medium-high heat. Cook for 2 mins, then add the green beans and cook for another 1-2 mins. Remove from the heat and squeeze in the juice of 1/2 your lemons, then season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Finely dice the shallot and mix with the vinegar, mustard, honey, salt and pepper. Set aside. Mix the goat’s cheese with the yoghurt until smooth. Set aside. Finely chop the parsley and mix it through the barley."
    },
    {
      "heading": null,
      "description": "Swoosh some of the goat’s cheese yoghurt into a bowl, then top with barley, green beans, shallot vinaigrette and toasted almonds, and the remaining lemon cut into wedges."
    }
  ],
