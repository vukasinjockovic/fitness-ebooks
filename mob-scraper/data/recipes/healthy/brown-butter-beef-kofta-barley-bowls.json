  "method": [
    {
      "heading": null,
      "description": "Rinse the pearl barley. Place a saucepan on medium-high heat. Tip the barley and water in, let it come to the boil. Place a lid on, decrease the heat to low and cook for 40 mins, adding more water if needed."
    },
    {
      "heading": null,
      "description": "Pick the parsley leaves, thinly slice the stalks."
    },
    {
      "heading": null,
      "description": "Add the beef mince into a bowl. Trim and finely grate half the onions, three-quarters of the cloves of garlic onto it, and stir the parsley stalks, oregano, pul biber, and half the sumac through, season generously with salt, and mix. Portion the mince out evenly and shape into thick sausages. Gently press down to flatten them slightly."
    },
    {
      "heading": null,
      "description": "Thinly slice the onion, toss with the sumac and season with salt. Set aside. Before serving, toss the parsley leaves through."
    },
    {
      "heading": null,
      "description": "Finely grate the remaining garlic into a bowl and stir through the yoghurt. Season with salt."
    },
    {
      "heading": null,
      "description": "Place a frying pan over medium-high heat with a drizzle of olive oil. Once hot, add the koftas and cook until golden brown, 5-8 mins. Add the butter and cook until browned and nutty, then add the tomatoes and stir through until just starting to soften."
    },
    {
      "heading": null,
      "description": "Share the barley between bowls, top with the koftas and onion salad. Finish with a drizzle of garlic yoghurt."
    }
  ],
