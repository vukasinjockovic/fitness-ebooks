  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Cut up your ciabatta into crouton sized pieces. Place in an oven dish and cover in olive oil. Grate the garlic cloves over the bread. Salt generously. Mix together and place in the oven for 45 minutes."
    },
    {
      "heading": null,
      "description": "Peel and de-seed your cucumber. Chop the cucumber, lettuce, avocados and tomatoes."
    },
    {
      "heading": null,
      "description": "Pan fry your bacon lardons, starting on a low heat and gradually bringing it up to a high heat. Remove when crispy. Save the bacon fat and pour over the croutons."
    },
    {
      "heading": null,
      "description": "Dressing time. Chop your anchovies. Then pour 4 tbsp of olive oil, the juice of a lemon, dijon mustard, a sprinkling of salt, a grinding of pepper and the anchovies into a jar. Put on the lid and shake well."
    },
    {
      "heading": null,
      "description": "Assemble the salad and enjoy!"
    }
