  "method": [
    {
      "heading": null,
      "description": "Use a vegetable peeler to shave the tofu into ribbons. In a bowl, mix together the olive oil, smoked paprika, oregano, garlic powder, cumin, and a good pinch of salt and pepper. Add the tofu and toss to coat. Leave to marinate for at least 15 mins."
    },
    {
      "heading": null,
      "description": "Air-fry the tofu at 190°C for 10 mins, or bake at 200°C for 10-15 mins, until golden and slightly crisp."
    },
    {
      "heading": null,
      "description": "Meanwhile, dice the cucumber, halve the cherry tomatoes, and finely slice the red onion. Cut the lemon into wedges. Add the veg to a bowl and squeeze over ½ the lemon, saving the rest for serving. Cook the quinoa according to the packet instructions, then fluff it up with a fork and season lightly with salt and pepper."
    },
    {
      "heading": null,
      "description": "Swoosh the Greek yoghurt into a serving bowl. Pile on the quinoa, crispy tofu, cucumber, tomatoes, and red onion. Crumble over the feta and scatter with mint leaves. Serve with lemon wedges on the side for squeezing."
    }
  ],
