  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 210°C. Prick the sweet potatoes all over and place them on a foil-lined baking tray. Bake for 40–45 mins until tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the mushrooms. Chuck them into a nonstick frying pan with the pork mince. Set over a medium-high heat and cook for about 10 mins, stirring occasionally, until golden brown and cooked through."
    },
    {
      "heading": null,
      "description": "Add the black beans (including their liquid) to the pan along with most of the chipotle paste – keep a little back for the yoghurt. Add a splash of water and let everything simmer for 15 mins, topping up with more water if it starts looking dry."
    },
    {
      "heading": null,
      "description": "Zest the lime over the yoghurt, then squeeze in the juice from half. Stir through the reserved chipotle paste. Pick the coriander leaves and finely chop most of them, then fold those through the yoghurt too. Season to taste. Cut the remaining lime into wedges."
    },
    {
      "heading": null,
      "description": "Cut open the sweet potatoes and lightly fluff the insides with a fork. Pile on the chipotle pork and bean mixture, then dollop over the yoghurt. Scatter with the reserved coriander leaves and serve with lime wedges on the side."
    }
  ],
