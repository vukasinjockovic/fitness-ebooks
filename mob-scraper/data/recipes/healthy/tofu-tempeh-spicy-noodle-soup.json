  "method": [
    {
      "heading": null,
      "description": "Crumble the tempeh into a bowl and toss it with one-third of the soy sauce. Set a non-stick frying pan over a medium heat with a drizzle of olive oil. Fry the tempeh for 5–7 mins until golden and crispy around the edges. Set aside."
    },
    {
      "heading": null,
      "description": "Tip the silken tofu and water into a blender and blitz until smooth. Pour the mixture into a saucepan set over a medium heat."
    },
    {
      "heading": null,
      "description": "Place the miso paste in a small sieve, dip it into the hot tofu broth, and use the back of a spoon to press it through until dissolved. Stir in the gochujang, remaining soy sauce and rice vinegar. Let it simmer gently for 3 mins, stirring to combine."
    },
    {
      "heading": null,
      "description": "Meanwhile, bring a pan of salted water to the boil. Add the noodles and cook following pack instructions. Drain and set aside."
    },
    {
      "heading": null,
      "description": "Finely slice the pak choi and spring onion. Toast the sesame seeds in a dry frying pan for 1–2 mins until fragrant, if using."
    },
    {
      "heading": null,
      "description": "Add the chickpeas and pak choi to the broth and simmer for another 2 mins until heated through. Season with salt and black pepper to taste."
    },
    {
      "heading": null,
      "description": "To serve, divide the noodles between bowls. Ladle over the spicy broth, then top with the crispy tempeh. Finish with sliced spring onion, sesame seeds, chilli flakes (if using) and a drizzle of sesame oil."
    }
  ],
