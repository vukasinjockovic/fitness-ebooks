  "method": [
    {
      "heading": null,
      "description": "Peel and dice the sweet potato into small chunks. Spray with oil and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Cook in the air fryer at 200°C for 16–18 mins until golden and soft. Alternatively, roast in the oven at 180°C for 30 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, set a non-stick frying pan over a medium-high heat. Add the minced beef and cook for 6–7 mins until browned and cooked through. Stir in the taco seasoning and a pinch of salt."
    },
    {
      "heading": null,
      "description": "While that’s cooking, halve the cherry tomatoes and shred the iceberg lettuce."
    },
    {
      "heading": null,
      "description": "To plate up, spoon the roasted sweet potatoes into bowls, followed by the cottage cheese and taco beef. Add the lettuce, tomatoes and pickled onions."
    },
    {
      "heading": null,
      "description": "Drizzle over the hot honey and finish with a pinch of chilli flakes if you like it spicy."
    }
  ],
