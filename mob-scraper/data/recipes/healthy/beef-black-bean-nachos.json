  "method": [
    {
      "heading": null,
      "description": "Brush any dirt off the mushrooms and finely chop."
    },
    {
      "heading": null,
      "description": "Set a large nonstick oven-safe frying pan over a medium heat. Add the mushrooms and cook dry for 8-10 mins, stirring now and then, until golden and softened."
    },
    {
      "heading": null,
      "description": "Add the beef mince, breaking it up with a wooden spoon. Cook for 1-2 mins until browned all over. Stir through the taco seasoning, then tip in the black beans — juice and all. Add half a jar of water and let the mixture simmer, stirring occasionally for 15 to mins until the beef is tender, adding a splash more water if it starts to look dry."
    },
    {
      "heading": null,
      "description": "Meanwhile, peel the onion, thinly slice and add to a bowl. Pour over a little juice from the pickled jalapeños, add a pinch of salt and scrunch it all together to soften. Set aside."
    },
    {
      "heading": null,
      "description": "Shred the lettuce and fill bowls. Add the nachos then spoon over the beef. Top with the cheddar, pickled onions, jalapeños, dollops of yoghurt and coriander leaves. Serve straight from the pan with green Tabasco on the side."
    }
  ],
