  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C. Pat the chickpeas dry with kitchen paper and toss them with half of the olive oil, chilli flakes, salt, and pepper. Spread them out on a baking tray and roast for 15 mins, or until golden and crisp."
    },
    {
      "heading": null,
      "description": "While the chickpeas roast, slice the onion and slice the garlic. Heat the remaining olive oil in a large pot over medium heat. Add the onion and cook for 5 mins, until soft and translucent. Add the garlic and cook for 1 minute more."
    },
    {
      "heading": null,
      "description": "Tip in the edamame, spinach, and vegetable stock. Simmer for 5 mins, until everything is tender and the spinach is wilted."
    },
    {
      "heading": null,
      "description": "Add the silken tofu and basil to the pot, then blitz everything with a stick blender until smooth and vibrant green. Season generously with salt and pepper to taste. Alternatively, blend in a food processor."
    },
    {
      "heading": null,
      "description": "Ladle the soup into bowls and top with the crispy chickpeas. Finish with an extra pinch of chilli flakes if you like it hot and some basil, if you like."
    }
  ],
