  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Cut the mushrooms into thin, uniform slices. Transfer to a bowl, then add the chipotle paste, 3 tbsp olive oil and a pinch of salt. Toss to combine until the mushrooms are evenly coated in chipotle marinade."
    },
    {
      "heading": null,
      "description": "Lay the mushrooms in a single layer on a baking tray (you might need to use two trays), then place the jalapeños, garlic and onion for the coriander salsa on the side of one tray. Roast for 30 mins, checking halfway."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the strawberry tomato salsa by cutting the strawberries and tomatoes into small cubes. Transfer to a bowl, squeeze in the lime juice, then add the olive oil and salt to taste. Toss to combine."
    },
    {
      "heading": null,
      "description": "Heat a medium-sized shallow frying pan over a medium-high heat. Remove the pistachio skins, then put the pistachios in the pan and gently stir. Cook for 3-5 mins until fragrant. Remove from the pan, place on a chopping board and roughly chop. Set aside."
    },
    {
      "heading": null,
      "description": "For the coriander salsa, put the coriander, tomato, olive oil, red wine vinegar, lime juice, roasted jalapeños and roasted onion into a food processor. Lastly, squeeze the roasted garlic into the food processor and blitz to combine. If needed, add a small splash of water to loosen."
    },
    {
      "heading": null,
      "description": "Load your tacos up with roasted chipotle mushrooms, a drizzle of coriander salsa, a spoon of strawberry tomato salsa, avocado slices, a squeeze of fresh lime juice and a sprinkle of pistachio nuts."
    }
  ],
