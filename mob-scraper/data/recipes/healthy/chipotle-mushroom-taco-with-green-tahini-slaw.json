  "method": [
    {
      "heading": null,
      "description": "Toast the coriander seeds and cumin seeds in a dry frying pan, then coarsely grind in a pestle and mortar. Add the chipotle paste and a glug of oil and mix to a loose-ish paste."
    },
    {
      "heading": null,
      "description": "Grab the mushrooms and rub with plenty of salt and the spice mix, then set aside."
    },
    {
      "heading": null,
      "description": "Thinly slice three of the onions and the garlic. Preheat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Set an ovenproof, flameproof casserole or roasting tray over a high heat. Add a glug of olive oil and the sliced onions with a big pinch of salt. Cook for 5 mins until starting to caramelise."
    },
    {
      "heading": null,
      "description": "Add the garlic, stir through and sit the mushrooms on top along with all the marinade. Chuck the whole lot in the oven for 35-40 mins or until the onions are jammy and the mushrooms are tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, blend the tahini with a handful of the jalapeños, one bunch of coriander, a splash of jalapeño liquor and a splash of water. Season with salt and a squeeze of lime if needed."
    },
    {
      "heading": null,
      "description": "Now, thinly slice the cabbage and remaining onion, then add to a large mixing bowl. Pour over the tahini mixture and chuck in the remaining jalapeños. Roughly chop the remaining coriander and add to the bowl."
    },
    {
      "heading": null,
      "description": "Toss everything together and add a squeeze of lime if necessary."
    },
    {
      "heading": null,
      "description": "Heat your tortillas according to the pack instructions."
    },
    {
      "heading": null,
      "description": "Pull your mushrooms out of the oven and rest for a couple of minutes. Shred with a couple of forks."
    },
    {
      "heading": null,
      "description": "Build your tacos up with plenty of caramelised onions, pulled ’shrooms, slaw and a squeeze of lime. Get stuck in."
    }
  ],
