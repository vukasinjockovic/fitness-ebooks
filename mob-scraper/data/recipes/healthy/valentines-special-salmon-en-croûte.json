  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Splash some olive oil into a frying pan. Add sliced garlic cloves. After 20 seconds, add your spinach. Once wilted, remove from the heat and squeeze through a sieve to drain."
    },
    {
      "heading": null,
      "description": "Add the spinach to a bowl with a horseradish and sour cream. Add a handful of chopped dill, a handful of chopped parsley, salt and pepper. Mix together."
    },
    {
      "heading": null,
      "description": "Roll out your sheet of puff pastry. Cut it in half."
    },
    {
      "heading": null,
      "description": "Line a baking tray with baking paper. Add 1 of the pastry halves to the paper. Add some spinach mix and then add your salmon fillet. Top with spinach. Fold the pastry over, crimp it, brush with egg yolk and sprinkle with some sea salt. Repeat with the other pastry half."
    },
    {
      "heading": null,
      "description": "Place the tray in the oven for 30 minutes or until the pastry is golden and crisp. Serve and enjoy!"
    }
