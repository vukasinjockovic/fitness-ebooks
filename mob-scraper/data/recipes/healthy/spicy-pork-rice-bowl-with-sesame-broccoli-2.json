  "method": [
    {
      "heading": null,
      "description": "Finely grate the garlic and mix it with the gochujang, oyster sauce, dark soy sauce and sugar in a small bowl. Set aside."
    },
    {
      "heading": null,
      "description": "Place a large frying pan over a high heat with the vegetable oil. Once hot, add the pork mince and cook for 5–7 mins, breaking it up with a spoon as you go, until golden and caramelised."
    },
    {
      "heading": null,
      "description": "Pour in the sauce and stir through. Cook for another 2–3 mins until thick, glossy and sticky."
    },
    {
      "heading": null,
      "description": "Meanwhile, microwave the tenderstem broccoli for 2 mins until just tender. Toss with a pinch of salt, the sesame oil and the sesame seeds. Alternatively, steam or pan-fry if you prefer."
    },
    {
      "heading": null,
      "description": "Trim and thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "Spoon the rice into containers. Top with the pork, sesame broccoli and a scattering of spring onions and extra sesame seeds. Leave to cool and pop in the fridge until needed."
    }
