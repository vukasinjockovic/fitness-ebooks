  "method": [
    {
      "heading": null,
      "description": "Slice your block of tofu into two evenly-sized slices. Mince your garlic."
    },
    {
      "heading": null,
      "description": "Mix all ingredients (apart from the tofu) together to make a marinade."
    },
    {
      "heading": null,
      "description": "Lightly score each side of the tofu slices (this will help them soak up more flavour) then pour over about two-thirds of the marinade. Set aside to marinate for at least 30 mins."
    },
    {
      "heading": null,
      "description": "Once the tofu slices are marinated, heat up a tbsp of olive oil in a hot pan. Once the pan is hot, add your slices and cook for 4-5 mins, flipping halfway through and basting with the extra marinade as you go, until they're looking crisp on the outside. If your tofu looks like it's starting to stick or burn, add a splash of water to deglaze the pan."
    },
    {
      "heading": null,
      "description": "When you remove the tofu, pour the sauce over each slice and spread the glaze evenly."
    },
    {
      "heading": null,
      "description": "Serve over rice topped with sesame seeds and sliced spring onion."
    }
  ],
