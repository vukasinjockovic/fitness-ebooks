  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Sticky Soy, Ginger &amp; Garlic Chicken Traybake batch recipe."
    },
    {
      "heading": null,
      "description": "Slice the cucumber in half lengthways and scoop out the seeds and discard. Then finely dice the cucumber."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onions and green chilli."
    },
    {
      "heading": null,
      "description": "Mix the cucumber, spring onions and chilli with the rice vinegar, sesame oil and a pinch of salt. Set aside to pickle for 10 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, reheat the Soy, Ginger &amp; Garlic Chicken Traybake leftovers in a pan, oven or microwave until hot and glazed. Slice the chicken into strips."
    },
    {
      "heading": null,
      "description": "Toast the tortillas in a dry frying pan until soft and warmed through. To build your tacos, spread a little sour cream over each tortilla, then pile on the sticky chicken and spoon over the salsa. Finish with coriander, sesame seeds and sambal, if using."
    }
