  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Sumac Chicken &amp; Roasted Veg Traybake."
    },
    {
      "heading": null,
      "description": "Shred the chicken from the sumac chicken traybake. Drain the chickpeas, reserving the liquid. Pick the coriander leaves and thinly slice the stalks."
    },
    {
      "heading": null,
      "description": "Add the chicken, roasted veggies from the traybake, chickpeas and coriander stalks to a large frying pan set over a medium heat. Add a splash of the reserved chickpea liquid and reheat until piping hot, adding more liquid if you prefer it saucier. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely grate the garlic into a bowl and squeeze over some lemon juice. Season with salt, then stir in the tahini and natural yoghurt. Loosen with a splash of cold water if needed, and taste, adjust with more salt, pepper or a little sugar if it’s too bitter."
    },
    {
      "heading": null,
      "description": "Divide the hot chicken mixture between bowls. Spoon over the tahini yoghurt and finish with a sprinkling of sumac, the pitta crisps or croutons, and the coriander leaves. Serve with lemon wedges for squeezing."
    }
  ],
