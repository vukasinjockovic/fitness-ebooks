  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the No-Fuss Roast Chicken."
    },
    {
      "heading": null,
      "description": "Cut the leek, celery and fennel bulb into a small-ish dice. Crush the garlic. Set a large saucepan over a medium-high heat and add a good glug of olive oil. Tip in the diced veggies with a pinch of salt and cook for 7-8 mins until just starting to soften. Tip in the garlic for another 1-2 mins."
    },
    {
      "heading": null,
      "description": "Add in the chicken stock and bring to a boil. Season with a little salt and then add the pasta. Cook for 8 mins until just cooked. While the pasta cooks, cut the courgette into a small dice and quarter the tomatoes. Once the pasta is al dente, add the courgette and tomatoes for 2 mins."
    },
    {
      "heading": null,
      "description": "Shred the leftover chicken and add to the pan for the final minute to warm through. Season to taste and add chopped dill and lemon juice to finish. Divide the soup between warm bowls and top with plenty of pesto."
    }
  ],
