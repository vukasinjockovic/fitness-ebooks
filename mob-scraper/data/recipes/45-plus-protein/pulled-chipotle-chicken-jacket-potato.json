  "method": [
    {
      "heading": null,
      "description": "Make the Juicy Pulled Chipotle Chicken"
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Scrub the potatoes, prick them all over with a fork, then rub with olive oil and salt. Bake directly on the oven shelf for 1 hr until crisp on the outside and fluffy inside."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the red onion and squeeze over the juice half the limes. Season with a pinch of salt and set aside to pickle. Pick the coriander leaves from their stems and set aside."
    },
    {
      "heading": null,
      "description": "Warm the leftover pulled chipotle chicken in a saucepan set over a low heat until piping hot throughout. Add a splash of water if needed to loosen the sauce. Crumble the feta."
    },
    {
      "heading": null,
      "description": "Once the potatoes are cooked, cut a deep cross into each one and squeeze from the base to open. Fluff up the inside with a fork, then pile in the hot chipotle chicken."
    },
    {
      "heading": null,
      "description": "Top each jacket with a spoonful of salsa, crumbled feta, the quick-pickled onions and fresh coriander. Serve with lime wedges and hot sauce on the side."
    }
  ],
