  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Sumac Chicken &amp; Roasted Veg Traybake."
    },
    {
      "heading": null,
      "description": "Wash the rice in cold water until it runs clear. Pick the parsley leaves and thinly slice the stems. Lightly crush the cardamom pods."
    },
    {
      "heading": null,
      "description": "Melt the butter in a large frying pan with high sides over a medium heat. Stir in the cardamom pods, parsley stems, rice and chickpeas. Pour in the water and bring to the boil. Cover with a lid, reduce the heat to low and cook for 12 mins."
    },
    {
      "heading": null,
      "description": "Halfway through cooking, place the sumac chicken and roasted vegetables from the traybake on top of the rice. Replace the lid and continue cooking for the remaining time."
    },
    {
      "heading": null,
      "description": "Remove the pan from the heat and leave covered for another 10 mins to finish cooking the rice."
    },
    {
      "heading": null,
      "description": "Fluff the rice with a fork, then share between plates. Top with the parsley leaves and a dollop of Greek yoghurt. Season with salt and pepper to taste."
    }
  ],
