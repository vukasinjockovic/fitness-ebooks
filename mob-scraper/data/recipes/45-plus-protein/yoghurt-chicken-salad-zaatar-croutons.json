  "method": [
    {
      "heading": null,
      "description": "Make the Poached Chicken &amp; Ginger Broth."
    },
    {
      "heading": null,
      "description": "Shred the leftover poached chicken and set aside."
    },
    {
      "heading": null,
      "description": "Make the Yoghurt Tahini. Grate the garlic. Whisk the skyr, tahini, lemon juice and a pinch of salt in a bowl until smooth, then stir through the garlic. Set aside."
    },
    {
      "heading": null,
      "description": "Tear the pitta into bite-sized chunks. Toss with the olive oil, za’atar and a good pinch of salt and pepper."
    },
    {
      "heading": null,
      "description": "Place a frying pan over a medium heat and toast the pitta pieces for 5–7 mins, turning often, until golden and crisp. Set aside."
    },
    {
      "heading": null,
      "description": "Thinly slice the courgette. Roughly chop the tomatoes. Tear up the dill and parsley. Pit and roughly chop the olives."
    },
    {
      "heading": null,
      "description": "Optional \nTo make crispy shallots and garlic (if using), thinly slice both and fry in a good glug of oil over a medium heat until deep golden. Drain on kitchen paper."
    },
    {
      "heading": null,
      "description": "Whisk together the olive oil, lemon juice, sumac and a good pinch of salt in a small bowl until emulsified."
    },
    {
      "heading": null,
      "description": "Spoon the yoghurt tahini onto plates. Top with the shredded chicken, courgette, tomatoes, olives and herbs. Drizzle over the dressing, then scatter with the za’atar croutons and crispy shallots and garlic, if using. Now get stuck in!"
    }
  ],
