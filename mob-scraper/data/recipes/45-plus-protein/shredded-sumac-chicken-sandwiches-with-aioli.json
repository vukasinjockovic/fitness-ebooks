  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Sumac Chicken &amp; Roasted Veg Traybake batch recipe."
    },
    {
      "heading": null,
      "description": "In a large bowl, finely grate the garlic, zest half of the lemon and squeeze the juice in. Season with salt and set aside."
    },
    {
      "heading": null,
      "description": "Shred the chicken from the sumac chicken traybake and roughly chop the roasted onions from the traybake into 1cm chunks. Pick the parsley and coriander leaves, thinly slicing the stalks. Trim and thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "Stir the Dijon mustard and mayonnaise into the garlic mixture, then add the chicken, roasted onions, spring onions and herb stalks. Toss together until well coated. Taste and adjust seasoning with salt and pepper if needed."
    },
    {
      "heading": null,
      "description": "Toast the bread, then spread the chicken salad over one slice of each sandwich. Toss the parsley and coriander leaves together, place on top of the chicken salad and drizzle with olive oil. Sandwich together and eat straight away."
    }
