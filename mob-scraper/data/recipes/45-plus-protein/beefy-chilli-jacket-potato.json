  "method": [
    {
      "heading": null,
      "description": "Make the Beef Chilli Con Carne."
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Scrub the potatoes, prick them all over with a fork, then rub with a little olive oil and salt. Place directly onto the oven rack and bake for 1 hr until crisp on the outside and fluffy in the middle."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the red onion and place it into a bowl. Squeeze over the lime juice and season with salt. Set aside to pickle."
    },
    {
      "heading": null,
      "description": "Warm the leftover beef chilli in a saucepan set over a low heat, stirring occasionally until piping hot. Add a splash of water if it’s thickened in the fridge."
    },
    {
      "heading": null,
      "description": "Grate the cheddar."
    },
    {
      "heading": null,
      "description": "Once the potatoes are cooked, cut a deep cross into the tops and squeeze them open. Fluff the insides with a fork, then spoon over the hot beef chilli. Top with soured cream, grated cheddar and a big spoonful of pickled red onions."
    },
    {
      "heading": null,
      "description": "Bake for 20 mins until the cheese is melted, golden and everything is bubbling."
    },
    {
      "heading": null,
      "description": "Spoon onto plates and serve with the pickled red onions and a wedge of lime."
    }
  ],
