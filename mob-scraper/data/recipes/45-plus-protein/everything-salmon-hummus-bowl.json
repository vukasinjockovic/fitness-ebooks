  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Everything Salmon &amp; Green Pesto Chickpeas batch recipe."
    },
    {
      "heading": null,
      "description": "Reheat the salmon in the oven, microwave or a frying pan until piping hot."
    },
    {
      "heading": null,
      "description": "To make the hummus, add your leftover chickpeas to a blender or food processor along with the tahini, ice cubes, water, olive oil and juice of half the lemon. Blend until smooth, adding more water if needed to loosen. Taste and season with salt."
    },
    {
      "heading": null,
      "description": "Finely grate the garlic into a large bowl. Squeeze over the remaining half of the lemon and season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Chop the cucumber and tomatoes into 2cm chunks and thinly slice the spring onions. Add them all to the bowl with the garlic and lemon, drizzle over a little olive oil and toss to coat."
    },
    {
      "heading": null,
      "description": "Toast the flatbreads until warm and golden. Spread the hummus over the base of your plate or bowl. Top with the hot salmon and the salad. Serve with the flatbreads on the side."
    }
