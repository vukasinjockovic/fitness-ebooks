  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the No-Fuss Roast Chicken."
    },
    {
      "heading": null,
      "description": "Finely chop the chillies, ginger and garlic clove and pop into a small saucepan. Add the honey, soy and vinegar. Set over a medium-high heat and bring to a boil. Once boiling, remove from the heat and allow to infuse."
    },
    {
      "heading": null,
      "description": "Cut the asparagus into chunky diamonds and shred the chicken into bite-sized pieces. Set a large frying pan over a high heat and add a glug of oil. Toss in the chicken and cook for 5-6 mins, tossing regularly until the skin is crispy and the meat is reheated. Add the asparagus and cook for 2 mins before tipping in the honey mixture."
    },
    {
      "heading": null,
      "description": "Toss the mixture through the asparagus and chicken and keep cooking, reducing the marinade and letting it glaze the contents of the pan."
    },
    {
      "heading": null,
      "description": "Heat the rice according to the package instructions. Season with salt."
    },
    {
      "heading": null,
      "description": "Divide the rice between warm bowls, top with a pile of sticky chicken and asparagus and finish with torn coriander. Serve."
    }
