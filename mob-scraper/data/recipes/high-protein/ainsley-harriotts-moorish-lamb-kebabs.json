  "method": [
    {
      "heading": null,
      "description": "Grate the garlic, crush the cumin seeds and trim the excess fat off the lamb, cutting into 3cm cubes."
    },
    {
      "heading": null,
      "description": "Combine 3 tbsp of oil, vinegar, garlic, oregano, cumin seeds, paprika, cayenne pepper, turmeric with a generous pinch of salt and pepper in a large bowl."
    },
    {
      "heading": null,
      "description": "Add your lamb to the bowl and toss together with your hands so that the marinade coats the meat. Cover with cling film and marinate in the fridge for at least an hour, or overnight if you have the time."
    },
    {
      "heading": null,
      "description": "Whilst the lamb is marinating, make the dukkah. Toast the nuts in a dry pan until lightly browned and fragrant. Transfer into a food processor. In the same hot pan, toast the remaining spices for 1 minute until fragrant. Blitz everything in the food processor until it resembles coarse sand."
    },
    {
      "heading": null,
      "description": "Get your veg ready. Slice the tomatoes and red onion, and finely chop the coriander leaves."
    },
    {
      "heading": null,
      "description": "Preheat a griddle pan to medium-high heat."
    },
    {
      "heading": null,
      "description": "Divide the marinated lamb onto eight skewers. Place onto the hot griddle pan and cook for 8 - 10 minutes until they are tender with some nice charring, turning occasionally so that they cook evenly."
    },
    {
      "heading": null,
      "description": "Mix the yoghurt with another squeeze of lemon and a pinch of cayenne pepper to taste. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Arrange the tomatoes and onion on a serving platter, sprinkle with salt, zest of the lemon and drizzle with olive oil. Scatter with 2 tablespoons of dukkah, your chopped coriander and a squeeze of the lemon."
    },
    {
      "heading": null,
      "description": "Drizzle the kebabs with the yoghurt dressing and serve up with the tomato salad and some toasted flatbreads."
    }
  ],
