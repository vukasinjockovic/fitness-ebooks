  "method": [
    {
      "heading": null,
      "description": "Place the duck legs skin side down into a large, cold pan, then place the pan over a medium heat (this will let the fat render as the legs come up to temperature) and cook for about 5 mins each side until golden and crispy."
    },
    {
      "heading": null,
      "description": "Remove the duck from the pan and set aside."
    },
    {
      "heading": null,
      "description": "Finely chop the onion and celery and add to the pan. Cook for about 10 mins until softened."
    },
    {
      "heading": null,
      "description": "Peel the garlic and add along with the sage, bay leaves and cinnamon and cook for another 2 mins."
    },
    {
      "heading": null,
      "description": "Pour in the wine and let it bubble away and reduce by three quarters."
    },
    {
      "heading": null,
      "description": "Add the chopped tomatoes, the stock, and a big pinch of salt and pepper. Bring up to a simmer, return the duck to the pan (make sure it’s submerged) and cover with foil or parchment and a lid."
    },
    {
      "heading": null,
      "description": "Simmer gently for about 2 hours until the duck is tender."
    },
    {
      "heading": null,
      "description": "Remove the duck from the pan and discard the skin and bones. Shred the duck and return to the sauce."
    },
    {
      "heading": null,
      "description": "Put the pasta onto cook in plenty of boiling salted water."
    },
    {
      "heading": null,
      "description": "Meanwhile, heat a frying pan over a medium heat and add a splash of olive oil. Add the breadcrumbs and cook until golden brown. Remove from the heat, grate in the orange zest, mix well and set aside."
    },
    {
      "heading": null,
      "description": "Once the pasta is cooked, combine with the sauce and a splash of pasta water, mixing well to emulsify."
    },
    {
      "heading": null,
      "description": "Plate up and top with the zesty breadcrumbs."
    }
  ],
