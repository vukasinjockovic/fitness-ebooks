  "method": [
    {
      "heading": null,
      "description": "Heat the Weber Crafted Griddle over high heat."
    },
    {
      "heading": null,
      "description": "Toss the tomatoes, red onion and chillies in vegetable oil and grill until very charred."
    },
    {
      "heading": null,
      "description": "Transfer to a cutting board and chop together with the juice of one lime, fresh coriander and a generous pinch of salt until a chunky salsa forms. Alternatively, you can do this with a mortar and pestle. Refrigerate until ready to use."
    },
    {
      "heading": null,
      "description": "Slice the chicken and the large onion, and place in a mixing bowl."
    },
    {
      "heading": null,
      "description": "Combine the chipotle chilli flakes, ground cumin, smoked paprika, garlic granules, chipotle paste and ½ teaspoon salt in a small bowl. Add the spice mix to the chicken with a splash of vegetable oil and toss to coat."
    },
    {
      "heading": null,
      "description": "Heat the Weber Crafted Griddle on a medium-high heat. Cook the chicken, stirring often, until cooked through and charred in places."
    },
    {
      "heading": null,
      "description": "Combine the cheeses in a bowl."
    },
    {
      "heading": null,
      "description": "Place a small handful of cheese on half of a flour tortilla. Add a good dollop of the chipotle chicken mix and top with another small handful of cheese. Fold the tortilla half over the filling, pressing to smoosh it down, then brush with oil. Repeat with the remaining tortillas."
    },
    {
      "heading": null,
      "description": "Heat the Weber Crafted Griddle over medium heat. Cook the quesadillas until browned on the outside and gooey in the middle, around 2 to 3 mins per side. Cut the lime into 4 wedges."
    },
    {
      "heading": null,
      "description": "Serve topped with the charred salsa and lime wedges."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
  ],
