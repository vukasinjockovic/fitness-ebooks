  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "For the salmoriglio: zest half of the lemon into a bowl. Pick the oregano leaves, discarding the stems. Finely mince the parsley stems as well. Add both to the lemon zest and mix together. Pour 60ml of olive oil into the herbs and squeeze in the lemon juice. Season with salt and pepper, mix and set aside."
    },
    {
      "heading": null,
      "description": "Peel and thinly slice the shallot. Peel and thinly slice all the garlic."
    },
    {
      "heading": null,
      "description": "Place the vegetarian sausages onto a baking tray with a drizzle of oil, toss to evenly coat. Roast in the oven for 18-20 mins, until the vegetarian sausages are golden."
    },
    {
      "heading": null,
      "description": "Add 4 tbsp of olive oil into a frying pan with the shallot and garlic. Place on medium heat and cook until lightly golden, 3-5 mins. Stir the beans and spinach through until thickened and wilted, 3-4 mins. Remove from the heat. Taste and season with salt, pepper and lemon juice."
    },
    {
      "heading": null,
      "description": "Serve the creamy beans into bowls, top with the vegetarian sausages, some salmoriglio, crushed croutons and chilli flakes."
    }
  ],
