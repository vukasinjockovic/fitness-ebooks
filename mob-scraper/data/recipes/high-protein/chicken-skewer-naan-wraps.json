  "method": [
    {
      "heading": null,
      "description": "Dice up your thighs. Add to a bowl with ground ginger, ground coriander, cumin and cayenne pepper. Add a crushed garlic clove, 4 tbsp of plain yoghurt, salt and pepper. Add a drizzle of olive oil and mix everything together. Cover and leave to marinate for 40 minutes."
    },
    {
      "heading": null,
      "description": "Raita time. Into a blender, add a handful of coriander, a handful of mint, 300g of yogurt, salt, pepper and olive oil. Add the zest and juice of a lime and blitz until smooth."
    },
    {
      "heading": null,
      "description": "Place 8 wooden skewers in a bowl of water to soak."
    },
    {
      "heading": null,
      "description": "Roughly cut your onion into chunks."
    },
    {
      "heading": null,
      "description": "Take a skewer, add a piece of onion, chicken, more onion, more chicken and finish with a piece of onion. Use up the chicken and onions on all the skewers and place them on a baking tray. Place under the grill for 30 minutes, turning every 10 minutes."
    },
    {
      "heading": null,
      "description": "Warm your naans."
    },
    {
      "heading": null,
      "description": "Once the chicken is charred and cooked through, remove from the oven."
    },
    {
      "heading": null,
      "description": "Chop up some iceberg lettuce."
    },
    {
      "heading": null,
      "description": "Serving time. Add your chicken (removing the wooden skewer), some lettuce and a big dollop of raita onto a naan. Wrap it up and tuck in!"
    }
  ],
