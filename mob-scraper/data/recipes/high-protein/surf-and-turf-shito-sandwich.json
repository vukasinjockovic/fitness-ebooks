  "method": [
    {
      "heading": null,
      "description": "Thinly slice your onions and add to a pan with a good glug of oil and let it cook for 15 to 20 mins until translucent."
    },
    {
      "heading": null,
      "description": "Meanwhile, thickly slice your sweet bread in a separate pan and fry until golden then set aside."
    },
    {
      "heading": null,
      "description": "Preheat your oven to 180°c."
    },
    {
      "heading": null,
      "description": "Heat your pan with the butter until very hot then add your patties. Season with salt and pepper and sear them on both sides."
    },
    {
      "heading": null,
      "description": "Add the shito chilli sauce to your onions and let them cook for just a few more mins on low heat until it’s all nice and caramelised."
    },
    {
      "heading": null,
      "description": "Now we’re ready to layer it all up. First, grab your toasted bread then add 3 slices of Swiss cheese, a slice of American cheese on top, your cooked patty, some more cheese, then a dollop of shito onions and another slice of toasted bread."
    },
    {
      "heading": null,
      "description": "Pop your surf and turf sandwich into the oven for just 5 mins to heat it through, then enjoy!"
    }
