  "method": [
    {
      "heading": null,
      "description": "Place a large pan over a medium heat and add the pancetta and butter. Fry for about 5 mins until golden."
    },
    {
      "heading": null,
      "description": "Meanwhile, dice the onion, carrot, and celery. Add to the pan with the pancetta and cook for about 5 mins until softened."
    },
    {
      "heading": null,
      "description": "Remove the contents of the pan into a bowl and return to a hight heat. Add the beef and a big pinch of salt and cook until browned all over, breaking it up with a spoon as you go."
    },
    {
      "heading": null,
      "description": "Pour in the red wine and let it evaporate. Lower the heat, return the onion and pancetta mix to the pan and stir well."
    },
    {
      "heading": null,
      "description": "Add the milk and stock followed by the tomatoes and bring up to a very gentle simmer. Cover and leave to cook for an hour and 30 mins, stirring occasionally."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the basil and add to a bowl with the ricotta and a pinch of salt. Mix well and set aside."
    },
    {
      "heading": null,
      "description": "Cook the pasta in plenty of salted water until al dente, then drain and allow to cool. Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Once the ragù is ready, season to taste and pour it into a large baking dish."
    },
    {
      "heading": null,
      "description": "Take the cooled pasta and use a teaspoon to fill each shell withricotta, then nestle it down into the ragù."
    },
    {
      "heading": null,
      "description": "Grate the Parmesan over the top and place into the oven for 20 mins until golden."
    },
    {
      "heading": null,
      "description": "Sprinkle with basil leaves and allow to rest for 5 mins before serving."
    }
  ],
