  "method": [
    {
      "heading": null,
      "description": "Marinate the steak in 1 tbsp soy sauce, 1 clove grated garlic, and 1 tbsp rice wine vinegar and allow to marinate until you are ready to cook."
    },
    {
      "heading": null,
      "description": "Mince the remaining garlic, ginger and red chilli. Chop up the spring onions. Slice the onion and chop up the tenderstem broccoli."
    },
    {
      "heading": null,
      "description": "Mix together the black bean sauce, 3 tbsp soy sauce, 1 tbsp rice wine vinegar and 200ml water. In a small cup, combine the cornflour with 2 tbsp of water."
    },
    {
      "heading": null,
      "description": "Bring a pan of water to a boil. Add your pappardelle and bicarbonate of soda, then cook for a couple of mins less than the packet instructions"
    },
    {
      "heading": null,
      "description": "Add a large glug of cold oil to a hot wok and fry the beef for 2-3 mins until golden on the outside but still pink on the inside. Remove and set aside."
    },
    {
      "heading": null,
      "description": "Add another glug of oil and fry the spring onion whites until charred for 3 mins. Then add in the ginger, garlic, red chilli and onions and cook for 4 mins until darkened. Then toss in the broccoli and cook for 3 mins."
    },
    {
      "heading": null,
      "description": "Pour in the sauce and bring it to a bubble. Add the cornflour slurry and allow the sauce to bubble and thicken for 2 mins."
    },
    {
      "heading": null,
      "description": "Add in the cooked pappardelle and toss together until the pasta is well-coated and glossy."
    },
    {
      "heading": null,
      "description": "Finally, add in the beef, black pepper cashews, and spring onion greens. Toss it all together and serve."
    }
  ],
