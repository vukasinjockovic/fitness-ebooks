  "method": [
    {
      "heading": null,
      "description": "For the marinade, combine the Greek yoghurt, smoked paprika, 2 tsp garlic powder, 2 tsp chilli powder, 2 tsps Italian herb mix, mustard, 1 tbsp sriracha, 1 tsp salt and the eggs in a bowl. Mix well until smooth then add in your chicken thighs and allow to marinate for at least 30 mins in the fridge."
    },
    {
      "heading": null,
      "description": "Combine the plain flour, 2 tsp chilli powder, 2 tsp Italian herb mix, 2 tsp garlic powder and 3 tsp salt in a large bowl."
    },
    {
      "heading": null,
      "description": "Combine the mayonnaise, apple cider vinegar and 2 tbsp sriracha in a small bowl."
    },
    {
      "heading": null,
      "description": "Shred the lettuce and slice the tomatoes."
    },
    {
      "heading": null,
      "description": "Heat up a big pot with enough vegetable oil to deep fry the chicken thighs."
    },
    {
      "heading": null,
      "description": "Lift the chicken out of the marinade and shake off the excess mixture. Put it into the flour mix and press it to coat it. Press and scrunch the chicken into the flour at least 4 times so it will be well coated and has lots of craggy bits; this is what makes it extra crispy."
    },
    {
      "heading": null,
      "description": "Deep fry the chicken for 5-6 mins until golden brown and cooked through. You can check it is cooked by checking with a meat thermometer - it should be 75°C."
    },
    {
      "heading": null,
      "description": "Allow the chicken to drain in a metal sieve or colander. This will prevent the bottom from becoming soggy."
    },
    {
      "heading": null,
      "description": "Toast the buns on a hot dry pan. Spread 1 tbsp of the spicy mayo on the bun before adding a layer of lettuce, tomatoes, the fried chicken and finally a slice of cheese. Close the burger and enjoy."
    }
  ],
