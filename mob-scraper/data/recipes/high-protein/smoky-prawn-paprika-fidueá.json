  "method": [
    {
      "heading": null,
      "description": "Grate the tomato. Finely chop the onion and garlic.Tip the prawns into a bowl with a glug of olive oil, a pinch of smoked paprika and some salt. Give them a good mix."
    },
    {
      "heading": null,
      "description": "Heat a large frying pan over a high heat with a little olive oil. Add the prawns and fry for about 30 seconds on each side until browned, then remove and set aside."
    },
    {
      "heading": null,
      "description": "Wrap the spaghetti in kitchen paper and bash it with a rolling pin until it breaks into short pieces. Add more olive oil to the pan and toast the spaghetti for a few minutes until golden brown. Remove and set aside."
    },
    {
      "heading": null,
      "description": "Add another drizzle of oil to the pan, then fry the onion and garlic for about 5 mins until softened and just starting to colour."
    },
    {
      "heading": null,
      "description": "Stir in the grated tomato, the rest of the smoked paprika and the chilli flakes. Let it cook on high for 5 mins until it thickens and most of the liquid has evaporated."
    },
    {
      "heading": null,
      "description": "Return the toasted spaghetti to the pan and stir to coat. Pour in the fish stock and bring to the boil. Turn the heat down and simmer for about 8 mins without stirring. Top with prawns and turn up the heat for 5 mins, until the pasta’s cooked through and the bottom’s crisp."
    },
    {
      "heading": null,
      "description": "Chop the parsley and scatter over the Fidueá and serve with a wedge of lemon."
    }
  ],
  "tips": [
    "You can swap the fish stock for veg stock and a splash of Thai Fish Sauce.",
    "Use a paella pan if you’ve got one, but a big frying pan works fine.",
    "Toasting the pasta gives it that proper crispy bite – don’t skip it."
  ],
