  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Start with the tomato sauce. Chop the cloves of garlic. Fry in a pan with a glug of olive oil until soft."
    },
    {
      "heading": null,
      "description": "Pour in your tins of tomatoes. Add a splash of water to the tins to get all the leftover tomato off the sides, and pour that in."
    },
    {
      "heading": null,
      "description": "Pour in your balsamic vinegar, and let that simmer until it resembles a thick sauce. Add a handful of chopped basil, season with salt and pepper, remove from the heat and set aside."
    },
    {
      "heading": null,
      "description": "Filling time. Wilt all your spinach in a pan. Squeeze it so you get rid of any excess water, and then chop it up. Put in a bowl, and add your ricotta, half your Italian style hard cheese (grated), the zest of a lemon, some salt, pepper and olive oil. Mix everything together."
    },
    {
      "heading": null,
      "description": "Stuffing time. Spoon the filling into any bag with a corner. Cut a little hole in the corner, and then squeeze the filling into the cannelloni tubes. Line the tubes up in a baking dish."
    },
    {
      "heading": null,
      "description": "Cover the stuffed tubes with tomato sauce. Top everything with slices of mozzarella. Grate the rest of the Italian style hard cheese over the top."
    },
    {
      "heading": null,
      "description": "Place in an oven for 30 minutes or until the cheese is golden. Bish bash bosh. Done. Enjoy!"
    }
  ],
