  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 150°C."
    },
    {
      "heading": null,
      "description": "Finely chop your onion and carrots."
    },
    {
      "heading": null,
      "description": "Heat a casserole dish over a low heat. Add a little olive oil, then tip in your bacon lardons. Fry for a few mins until the fat has rendered out and they are starting to crisp up."
    },
    {
      "heading": null,
      "description": "Add your diced onion and carrot to the pan and cook for 15 mins until softened."
    },
    {
      "heading": null,
      "description": "Meanwhile, brown your beef. Start by placing your flour in a large bowl and seasoning generously with salt and pepper. Add your beef and mix so that the flour totally coats all the pieces."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium-high heat and add a little olive oil. Brown your beef in batches for a minute or two on all sides until there is lots of caramelisation. Remove from the pan, and repeat with your remaining beef."
    },
    {
      "heading": null,
      "description": "Pick your thyme leaves off their stalks and add these to the pan along with your tomato purée. Cook out for 5 mins until your puree has darkened."
    },
    {
      "heading": null,
      "description": "Add your beef to the veg pan along with your stock and ale. Bring the whole mixture to a simmer, then pop on a lid and place in the oven to cook for 2 and a half hours."
    },
    {
      "heading": null,
      "description": "Halve your button mushrooms."
    },
    {
      "heading": null,
      "description": "Remove your pan from the oven. Add your button mushrooms, then pop the lid back on. Cook for another hour."
    },
    {
      "heading": null,
      "description": "At this point, your beef should be tender and your sauce lovely and thick. Add your Worcestershire sauce, then season to taste with salt and pepper. Allow your pie filling to cool."
    },
    {
      "heading": null,
      "description": "Heat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Roll out your pastry to 2mm thickness."
    },
    {
      "heading": null,
      "description": "Spoon your beef into a pie dish, then add your pastry on top. Crimp the edges, then brush the surface with beaten egg."
    },
    {
      "heading": null,
      "description": "Bake for 25 mins until well risen and golden."
    },
    {
      "heading": null,
      "description": "Serve with mash and greens."
    }
  ],
