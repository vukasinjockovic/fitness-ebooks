  "method": [
    {
      "heading": null,
      "description": "Thickly slice the mushrooms then scrape into a bowl. Halve and finely chop the onion, then peel and finely chop the garlic."
    },
    {
      "heading": null,
      "description": "Season the chicken breasts really well with salt and pepper all over. Pour a splash of olive oil into a large, deep frying pan and set over a medium-high heat."
    },
    {
      "heading": null,
      "description": "Once hot, lay the chicken into the pan, skin-side down. Fry for 3-4 mins until golden and crisp, then remove from the pan onto a plate."
    },
    {
      "heading": null,
      "description": "Pour a glug of oil into the pan and add the mushroom slices. Fry for 5-6 mins until all of the water has evaporated and the mushrooms are caramelising."
    },
    {
      "heading": null,
      "description": "Reduce the heat to medium and scrape in the onion along with a pinch of salt. Strip all of the leaves from the thyme sprigs and add to the pan, too. Cook, stirring, for 7-8 mins until the onion has softened."
    },
    {
      "heading": null,
      "description": "Add in the garlic and cook for a couple of minutes, stirring every now and again. Pour in the white wine and bubble for a few minutes before pouring in the chopped tomatoes and chicken stock."
    },
    {
      "heading": null,
      "description": "Bring up to the boil, reduce to a simmer and cook gently for 20 mins."
    },
    {
      "heading": null,
      "description": "Put the chicken into the pan, skin-side up, and simmer for 12 mins until the sauce has thickened and the chicken is cooked through."
    },
    {
      "heading": null,
      "description": "Scatter with the parsley leaves and serve with mash."
    }
  ],
