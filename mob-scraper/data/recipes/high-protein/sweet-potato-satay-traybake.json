  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 190°C."
    },
    {
      "heading": null,
      "description": "Wash the sweet potatoes and cut them into wedges. Drain the chickpeas and dry them with a kitchen towel. Add the sweet potatoes and chickpeas to a large baking tray and drizzle with olive oil and season with salt and pepper. Roast for 15 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, deseed and slice the peppers thickly."
    },
    {
      "heading": null,
      "description": "After the 15 mins are up, remove the tray and add the peppers and broccoli to the tray and add a little more olive oil and seasoning. Roast for another 10-12 mins or until all of the vegetables are cooked through and the chickpeas are getting crispy."
    },
    {
      "heading": null,
      "description": "While the vegetables roast, make the satay sauce. Whisk together the peanut butter, rice wine vinegar, soy sauce, coconut milk and chili flakes until smooth. Taste and adjust if needed."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onion and roughly chop the peanuts."
    },
    {
      "heading": null,
      "description": "When the traybake is ready, drizzle over the sauce, sprinkle over the coriander, spring onions and peanuts and the zest and juice of the lime."
    }
  ],
