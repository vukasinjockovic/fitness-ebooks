  "method": [
    {
      "heading": null,
      "description": "Add your breadcrumbs to a bowl. Cover with twice the amount of whole milk. Set aside and wait until the crumbs have soaked up the liquid."
    },
    {
      "heading": null,
      "description": "Add the soaked breadcrumbs to a mixing bowl with 1 crushed garlic clove, lamb mince, a handful of parsley stalks, 3 tsp harissa paste, salt and pepper. Mix everything together. Cover and place in fridge for 15 minutes."
    },
    {
      "heading": null,
      "description": "After 15 minutes, remove mince from fridge. Divide into little meatballs. Add meatballs to a non-stick frying pan with a splash of oil. Cook until browned on the outside. Remove from the pan and set aside."
    },
    {
      "heading": null,
      "description": "Get your rice on (follow pack instructions)."
    },
    {
      "heading": null,
      "description": "Remove excess oil from pan. Add 2 crushed garlic cloves. Before they start browning, add your tomatoes. Break them up with a spoon. Add 2 tsp of harissa and mix everything together."
    },
    {
      "heading": null,
      "description": "Reintroduce your meatballs. Stir them in and cook the sauce until it is nice and thick."
    },
    {
      "heading": null,
      "description": "Once the sauce is thick, add a handful of chopped parsley and basil. Season with salt and pepper, mix everything together and remove the meatballs from the heat."
    },
    {
      "heading": null,
      "description": "Serve on a bed of steaming hot rice and tuck in! Enjoy!"
    }
  ],
