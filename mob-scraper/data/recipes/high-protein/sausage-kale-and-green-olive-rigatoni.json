  "method": [
    {
      "heading": null,
      "description": "Preheat a large frying pan over a medium heat and add a glug of olive oil. Remove the skins from your sausages, and get them in the pan."
    },
    {
      "heading": null,
      "description": "Break them up with your wooden spoon and cook down until browned and crispy. Remove from the pan and set aside, leaving all the rendered fat in the pan."
    },
    {
      "heading": null,
      "description": "Now finely dice the shallots, fennel and garlic and get them into the pan with a big pinch of salt. Cook down for 6-7 mins."
    },
    {
      "heading": null,
      "description": "Add the browned sausage, fennel seeds and chilli flakes to the pan and cook for 2-3 minutes."
    },
    {
      "heading": null,
      "description": "Turn up the heat and add the white wine to deglaze the pan. Cook down until almost completely gone. Add the milk and turn the heat down to low. Cook for 20-25 mins."
    },
    {
      "heading": null,
      "description": "Now bring a big pot of water to a boil, season generously with salt and drop in your rigatoni."
    },
    {
      "heading": null,
      "description": "While your pasta is cooking. Add the kale to the sauce along with a ladle of pasta water and wilt for 1-2 mins."
    },
    {
      "heading": null,
      "description": "Smash your olives with the flat of a knife and pick out the stones. Discard the stones and add the olives to the sauce."
    },
    {
      "heading": null,
      "description": "Once the pasta is cooked, add it to the sauce with another ladle of pasta water, the mascarpone and lemon zest. Toss everything together to create a creamy sauce."
    },
    {
      "heading": null,
      "description": "Finish with a big squeeze of lemon juice, divide between warm plates and get stuck in."
    }
  ],
