  "method": [
    {
      "heading": null,
      "description": "Quarter your mushrooms. Add to a pan with a splash of olive oil. Fry until brown."
    },
    {
      "heading": null,
      "description": "Add sliced garlic cloves and a handful of sliced thyme leaves. Squeeze a few drops of lemon juice in. Mix everything together. Once the garlic begins to go brown, remove everything from the pan and set aside."
    },
    {
      "heading": null,
      "description": "Add 5 tablespoons of olive oil and plain flour to the pan. Whisk it together. Start adding your whole milk, bit by bit, whisking it in. Keep adding milk until you have a smooth white sauce."
    },
    {
      "heading": null,
      "description": "Get your macaroni cooking."
    },
    {
      "heading": null,
      "description": "At this point, crumble in the mozzarella and add taleggio to the pan. Stir it in until it melts and you have a smooth white sauce."
    },
    {
      "heading": null,
      "description": "Re-add your mushrooms and a large handful of parsley. Mix it in."
    },
    {
      "heading": null,
      "description": "Drain your cooked macaroni and add to the sauce. Mix it in. Season with salt and pepper and add a big squeeze of lemon juice. Smooth out the top of the mac and cheese. Add your remaining taleggio."
    },
    {
      "heading": null,
      "description": "Place under the grill until the taleggio is golden and bubbling."
    },
    {
      "heading": null,
      "description": "Remove from the oven, serve it up, scatter over some more chopped parsley and enjoy!"
    }
  ],
