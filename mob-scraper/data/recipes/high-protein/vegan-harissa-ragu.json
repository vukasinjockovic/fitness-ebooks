  "method": [
    {
      "heading": null,
      "description": "Pulse the onion, carrot, celery and garlic in a food processor until roughly chopped up. This is your soffritto."
    },
    {
      "heading": null,
      "description": "Add a big glug of oil to a large pot with a big pinch of salt and add in the soffritto and cook for 15 mins until softened."
    },
    {
      "heading": null,
      "description": "Meanwhile, pulse the mushrooms and puy lentils in your food processor until roughly chopped."
    },
    {
      "heading": null,
      "description": "Add your rose harissa paste to your sofrito pot and cook for 3 mins."
    },
    {
      "heading": null,
      "description": "Then add in the mushrooms and puy lentils and cook for 15 mins until the water has evaporated from the mushrooms."
    },
    {
      "heading": null,
      "description": "Add in the chopped tomatoes and let this simmer on a low-medium heat for 30 mins."
    },
    {
      "heading": null,
      "description": "Cook your pasta and add this to the sauce with 200ml of pasta water, tossing until it is totally coated."
    },
    {
      "heading": null,
      "description": "Serve with parsley."
    }
