  "method": [
    {
      "heading": null,
      "description": "Place all of the marinade ingredients in a food processor with a 1 1/2 tbsp of olive oil &amp; blend. Toss with chicken and marinade overnight, or for at least 30 min."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 220°C. Chuck your marinated chicken onto a tray and roast for 15-16 mins until golden brown, a bit gnarly and cooked through. Allow to rest for 10-12 mins."
    },
    {
      "heading": null,
      "description": "Peel and cut plantain into fries. Add enough oil to a saucepan for shallow frying. Fry the plantain over a medium heat on all sides until golden and tender. This will take roughly 4-5 mins."
    },
    {
      "heading": null,
      "description": "To make the jerk mayo, mix the mayo with 3 tbsp of jerk sauce and season, set aside."
    },
    {
      "heading": null,
      "description": "Roughly chop your chicken thighs and toss with couple of spoons of jerk sauce."
    },
    {
      "heading": null,
      "description": "Warm your wraps, stack up with the jerk chicken, salad, avocado, coleslaw and plenty of extra jerk sauce and jerk mayo. Get them wrapped up and get stuck in!"
    }
  ],
