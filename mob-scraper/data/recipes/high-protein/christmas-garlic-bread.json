  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Cut the bread in a criss cross pattern like a hedgehog."
    },
    {
      "heading": null,
      "description": "Finely chop the rosemary."
    },
    {
      "heading": null,
      "description": "Grate the garlic into a bowl, add in rosemary, 50ml of olive oil and a big pinch of salt."
    },
    {
      "heading": null,
      "description": "Cut the cheese into small thin slices."
    },
    {
      "heading": null,
      "description": "Brush the bread with the garlic oil making sure to get inside all of the crevices and cuts."
    },
    {
      "heading": null,
      "description": "Spread the cranberry sauce into the cuts over the garlic oil and then stuff each slit with the cheese. Brush over with any remaining garlic oil and wrap the whole thing in foil."
    },
    {
      "heading": null,
      "description": "Pop this in the oven for 20 mins or until the cheese is melted and bubbly."
    },
    {
      "heading": null,
      "description": "Pull apart the cheese and enjoy."
    }
