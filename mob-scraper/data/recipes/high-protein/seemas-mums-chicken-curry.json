  "method": [
    {
      "heading": null,
      "description": "Blend the onion in a food processor until it's roughly chopped."
    },
    {
      "heading": null,
      "description": "Heat up 3 large glugs of oil in a large pot. When the oil is hot, add in the cumin seeds. Once the seeds are bubbling, add the cinnamon stick, cloves, black peppercorns, star anise and dried bird's eye chillies. Cook them for 30 secs until they are fragrant."
    },
    {
      "heading": null,
      "description": "Add in the blended onion cook for 10 mins on a low heat until they are caramelised and translucent."
    },
    {
      "heading": null,
      "description": "Blend the tinned chopped tomato, garlic, fresh bird's eye chillies, and half the ginger in the food processor – don’t worry about washing it between uses."
    },
    {
      "heading": null,
      "description": "Once the onions are browned, add the blended tomato mix and chilli powder, cumin powder, coriander powder, ground turmeric and ½ tsp salt. Cook for 10 mins, until the oil starts to separate from the sauce. You can add an extra glug of oil here to help fry the spices."
    },
    {
      "heading": null,
      "description": "Add in the chicken and mix well so it’s coated. Cook for another 5 mins."
    },
    {
      "heading": null,
      "description": "Pour in 250ml water and mix with the chicken. Pop on a lid and cook for 15 mins."
    },
    {
      "heading": null,
      "description": "Finely chop the coriander, julienne the remaining ginger and slice the jalapeños into thick coins."
    },
    {
      "heading": null,
      "description": "After 15 mins, stir in the yoghurt and garam masala along with half of fresh coriander, half the julienned ginger and half the sliced jalapeños."
    },
    {
      "heading": null,
      "description": "Garnish with the remaining coriander, ginger and chilli. Pop a lid on the pot until you’re ready to serve. Enjoy with rice or freshly made rotli."
    }
  ],
