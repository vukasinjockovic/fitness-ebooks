  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C fan."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil in a large pan over a medium-high heat. Add the chicken legs, skin side down, and cook for 5-10 mins on each side until nicely browned. Remove from the pan and set aside."
    },
    {
      "heading": null,
      "description": "Finely dice the onion, carrot and celery stick (this is your soffritto). Get the soffritto in the chicken pan along with the bacon lardons. Cook for about 10-15 mins until softened then deglaze with the wine."
    },
    {
      "heading": null,
      "description": "Add the lentils, chicken stock, fresh thyme and bay leaf to the pan and give it a stir then top with the chicken legs. Cover and bake with the lid on for 50 mins."
    },
    {
      "heading": null,
      "description": "Remove the chicken to a plate. Stir the spinach, mustard, crème fraîche and black pepper through the lentils."
    },
    {
      "heading": null,
      "description": "To serve, divide the lentils between plates and top with the chicken legs. Serve with a simple side salad and a vinaigrette dressing, if you like. \nEnjoy with a glass of Prestige Bordeaux Red by Calvet. Delicious."
    }
  ],
