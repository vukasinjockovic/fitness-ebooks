  "method": [
    {
      "heading": null,
      "description": "Separate the spring onions into white and green parts. Finely slice both and set aside. Slice half of the chilli and split the other half lengthways. Finely chop the ginger and garlic."
    },
    {
      "heading": null,
      "description": "Cut the pork belly into 3cm chunks and pop into a large saucepan. Cover with cold water and bring to a gentle simmer. Cook for 4-5 mins, skimming off any scum that floats to the surface. Drain the pork and rinse out the pan."
    },
    {
      "heading": null,
      "description": "Melt the brown sugar in the clean pan over a medium heat. Add the pork and roll around in the caramel."
    },
    {
      "heading": null,
      "description": "Add the star anise, the whites of the spring onion, the ginger and garlic and the halved chilli. Cook for 2-3 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Now add the soy, wine and Guinness Paste."
    },
    {
      "heading": null,
      "description": "Cover with fresh water (approx 600ml) and braise for 30-40 mins until the pork is just tender."
    },
    {
      "heading": null,
      "description": "Remove the pork and reduce the liquid to a sweet sticky glaze. Add the pork back to the pan and toss to coat in the Guinness glaze."
    },
    {
      "heading": null,
      "description": "Finely slice the cabbage and cucumber."
    },
    {
      "heading": null,
      "description": "Steam your bao buns, split in half and stuff full of cabbage, cucumbers, juicy pork belly and top with spring onion and fresh red chilli."
    },
    {
      "heading": null,
      "description": "Get stuck in."
    }
  ],
