  "method": [
    {
      "heading": null,
      "description": "For the tofu feta, crumble the tofu into a medium bowl and add the remaining ingredients. Stir well to combine. Season to taste and transfer to the fridge while you make the beans."
    },
    {
      "heading": null,
      "description": "Dice the red onion, crush the garlic, halve the tomatoes and finely chop the sun-dried tomatoes."
    },
    {
      "heading": null,
      "description": "Add a splash of olive oil to a large sauté pan. Once the oil is hot, add in the onion and fry over a medium heat with a small pinch of salt for 7-8 mins. Add the garlic and fry for 2-3 mins, then add the smoked paprika and fry for 1 min. Add the sundried tomatoes, stir, then add the cherry tomatoes and a pinch of sea salt. Cook for around 10 mins, stirring regularly, until you can squish them down into the pan to make a jammy sauce."
    },
    {
      "heading": null,
      "description": "Pour two to three tablespoons of liquid out of the beans cans, then tip them into the pan with the remaining canning liquid. Stir and heat through, then add the basil and nutritional yeast. Cook over a medium heat for 5 mins, then season to taste."
    },
    {
      "heading": null,
      "description": "Serve with the tofu feta and optional toppings."
    }
  ],
