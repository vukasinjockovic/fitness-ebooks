  "method": [
    {
      "heading": null,
      "description": "Grab a bowl. Add soy sauce, honey, cider vinegar, grated garlic cloves, Chinese 5 Spice, cayenne, tomato puree and a good grind of black pepper. Mix it all together."
    },
    {
      "heading": null,
      "description": "Place your rack of ribs in a baking tray. Pour ¾ of the marinade over them and rub it in. Cover with tin foil and marinate for 2 hours."
    },
    {
      "heading": null,
      "description": "Preheat oven to 160°C/320°F."
    },
    {
      "heading": null,
      "description": "Once the ribs have marinated, place the tray, with the tin foil still on, in the hot oven for an hour. After an hour, remove the foil and baste with the juices in the tray. Put the tray back in the oven for half an hour."
    },
    {
      "heading": null,
      "description": "After 30 minutes, remove from the oven and pour over the remaining ¼ of marinade. Place the ribs back in the oven."
    },
    {
      "heading": null,
      "description": "Keep on basting them every 20 minutes or so, until the ribs have had 3 hours total in the oven."
    },
    {
      "heading": null,
      "description": "Remove from the oven, hack them up and tuck in! Enjoy!"
    }
  ],
