  "method": [
    {
      "heading": null,
      "description": "Finely slice the garlic cloves and chop the herbs. Mix all the kofta ingredients together and form the koftas (there should be around 12)."
    },
    {
      "heading": null,
      "description": "Fry in a griddle pan over a medium-high heat to get some lovely char marks, cooking on each side, about 8-10 mins in total. Once cooked, keep warm."
    },
    {
      "heading": null,
      "description": "Place the mint, mayo, minced garlic and lemon juice in a bowl and mix well. Season with salt and pepper, adding more lemon juice if needed."
    },
    {
      "heading": null,
      "description": "Thinly slice the tomatoes, red onions and iceberg lettuce. Set aside."
    },
    {
      "heading": null,
      "description": "Lightly toast the flatbread before adding a thin layer of the garlic mayonnaise, the koftas and topping off with the veggies. Finish with some more garlic mayo. Enjoy."
    }
  ],
