    },
    {
      "heading": null,
      "description": "Heat a large saucepan, add oil. When the oil has heated up, add cloves, mustard seeds, and cumin seeds."
    },
    {
      "heading": null,
      "description": "Add the diced onion, ginger and garlic and mix well. Cook until it all softens and the base is golden brown."
    },
    {
      "heading": null,
      "description": "Add the tomatoes and heat through for 1 minute. Lid on."
    },
    {
      "heading": null,
      "description": "Add the chilli powder, ground turmeric, garam masala, ground cumin, ground coriander and a pinch of salt. Mix and heat through on a low heat with the lid on for 10 mins."
    },
    {
      "heading": null,
      "description": "Add the chicken. Mix well and leave on a low heat with the lid on for around 15 mins, until the chicken is tender."
    },
    {
      "heading": null,
      "description": "Remove from heat, garnish with the chopped coriander. Serve with rice or chapatis."
    }
