  "method": [
    {
      "heading": null,
      "description": "Add the buttermilk and all the spices for marinating to a large bowl, mix and add the chicken wings. Cover and pop into the fridge. Leave for at least an hour, ideally overnight."
    },
    {
      "heading": null,
      "description": "To make the dry coating, add the plain flour, cornflour and spices to a large bowl."
    },
    {
      "heading": null,
      "description": "To make the garlic butter, melt the butter in a small saucepan and grate in the garlic. Cook over a medium heat for 2-3 mins. Then, tip in the lemon juice and season to taste. Finely chop the herbs and add those at the last min. Set aside and keep warm."
    },
    {
      "heading": null,
      "description": "Preheat a pot of oil to 170°C."
    },
    {
      "heading": null,
      "description": "Pull the chicken out of the fridge. Grab a wing and shake off the excess buttermilk. Coat each chicken wing in the dry mixture, scrunching the dry coat in to make a craggy texture. Deep fry in vegetable oil for 6-8 mins until golden and crispy all over."
    },
    {
      "heading": null,
      "description": "Toss the fried chicken wings in the garlic butter and grate over Parmesan."
    }
  ],
