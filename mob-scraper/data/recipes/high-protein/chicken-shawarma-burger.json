  "method": [
    {
      "heading": null,
      "description": "Combine the first six ingredients in a small bowl and mix."
    },
    {
      "heading": null,
      "description": "Slice the onion and add to a large bowl. Dice up the chicken thighs into roughly 1 inch pieces and add to the same bowl with the onions."
    },
    {
      "heading": null,
      "description": "Pour over the spice mix and squeeze over the juice of a lemon. Add the salt and olive oil and mix really well to coat the chicken."
    },
    {
      "heading": null,
      "description": "Cover and transfer to the fridge, ideally overnight but an hour or so is fine, too."
    },
    {
      "heading": null,
      "description": "Once you’re ready to cook the chicken, preheat your grill to max. Spread the chicken and onions out in a single layer on a large baking tray and place into the oven for 15 mins."
    },
    {
      "heading": null,
      "description": "While the chicken cooks, make the chopped salad relish. Take the core and seeds out of the tomato and add to a food processor along with the red onion, gherkin and coriander. Pulse until finely chopped."
    },
    {
      "heading": null,
      "description": "Transfer the mix to a sieve and squeeze out as much liquid as you can, then transfer to small bowl. Add the red wine vinegar, sugar and a pinch of salt, stir and set aside."
    },
    {
      "heading": null,
      "description": "Finely chop the mint and mix through the Greek yoghurt with a pinch of salt."
    },
    {
      "heading": null,
      "description": "Check that the chicken is cooked through and remove from the oven. It should be well browned and crispy on one side and soft and juicy on the other."
    },
    {
      "heading": null,
      "description": "Toast the buns, then spread the bottom half with a layer of the minty yoghurt. Top with a big spoonful of the chicken and onions."
    },
    {
      "heading": null,
      "description": "Spread the top layer of the bun with a spoon of the relish, then sandwich the burger together and enjoy."
    }
  ],
