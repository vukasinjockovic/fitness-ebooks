  "method": [
    {
      "heading": null,
      "description": "Heat a small knob of butter and oil in a frying pan, slice half of your garlic and onions, and start to sweat."
    },
    {
      "heading": null,
      "description": "Add the tomato purée and cook for 5 minutes."
    },
    {
      "heading": null,
      "description": "Add a tin of plum tomatoes and crush it by hand straight into the pan. Mix that in then add in your salt, pepper, garlic powder and Italian seasoning mix. Pop a lid on, let that cook down and reduce for 30 mins"
    },
    {
      "heading": null,
      "description": "Slice the rest of your onion, garlic, parsley, salt and chilli and add that into a bowl followed by your beef mince. Get your hands in there and mix that all together."
    },
    {
      "heading": null,
      "description": "Form the mixture into 6 even-sized meatballs, and place them onto a tray with baking paper and into the oven at 180°C for 25 mins or until cooked through."
    },
    {
      "heading": null,
      "description": "Cut a circle into all your bread rolls, the same size as your meatballs, and push it down."
    },
    {
      "heading": null,
      "description": "Make a garlic butter by mixing together the rest of your butter with parsley and garlic. Spread it in and around the bread rolls then get those in the oven for 5 mins. Remove from the oven when crispy."
    },
    {
      "heading": null,
      "description": "Take the meatballs out and add them to the tomato sauce, get them coated then transfer each meatball into a bread roll and put a spoonful of sauce onto each one. Sprinkle with mozzarella and parmesan."
    },
    {
      "heading": null,
      "description": "Bake until the cheese is golden and melted, then top with fresh parsley. Get stuck in and enjoy!"
    }
  ],
