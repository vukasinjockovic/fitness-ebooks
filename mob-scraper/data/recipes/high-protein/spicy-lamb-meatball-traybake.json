  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Tip the lamb mince into a bowl."
    },
    {
      "heading": null,
      "description": "Finely chop a third of the red onions and add to the lamb mince with the pine nuts and raisins. Finely chop half of the parsley along with the red peppers and tip them into the bowl, too. Add the ras el hanout and season well with salt and pepper. Mix vigorously until the mixture starts to get a little sticky."
    },
    {
      "heading": null,
      "description": "Grab a large roasting tray and dump in the drained chickpeas. Split the chilli in half and chuck it into the tray, too. Cut the remaining onions into a super chunky dice and get those into the tray with the harissa. Toss everything together with a healthy pinch of salt."
    },
    {
      "heading": null,
      "description": "Using wet hands, form the lamb mixture into little meatballs, about the size of golf balls, and lay over the chickpeas. Slide into the oven for 45-50 mins, turning the meatballs halfway."
    },
    {
      "heading": null,
      "description": "Once cooked, finish with the rest of the parsley and the zest and juice of the lemon."
    },
    {
      "heading": null,
      "description": "Divide between plates and dig in.\n Enjoy with a delicious glass of Prestige Bordeaux Red by Calvet. Yum."
    }
  ],
