  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Add your peppers to a roasting tray and cook for 45 mins, until charred and soft."
    },
    {
      "heading": null,
      "description": "Remove peppers from oven. Allow to cool. Peel off skins and remove seeds."
    },
    {
      "heading": null,
      "description": "Add ⅔ of the peppers to a blender with the milk and a good grinding of pepper. Blitz until smooth."
    },
    {
      "heading": null,
      "description": "Crumble your chorizo into a pan with a splash of olive oil. Cook until crispy, adding a small handful of rosemary after 5 mins. Once crispy, remove rosemary and chorizo from the pan and set aside."
    },
    {
      "heading": null,
      "description": "Get your macaroni on (cook for 10 mins in salted boiling water)."
    },
    {
      "heading": null,
      "description": "Add the plain flour to the chorizo fat and whisk it in to make a paste. Start slowly adding the blended pepper mix, whisking as you go. You should end up with a nice thick red sauce."
    },
    {
      "heading": null,
      "description": "Add grated cheddar and grated manchego. Mix it in until smooth."
    },
    {
      "heading": null,
      "description": "Once the cheese is melted, add your macaroni and stir to combine. Add the crispy chorizo. Slice up your remaining roasted pepper and add that too."
    },
    {
      "heading": null,
      "description": "Stir everything together, and then top it with any leftover cheddar and manchego. Whack the mac and cheese under the grill for 10 mins until golden and bubbling. Remove from the oven, spoon into bowls and enjoy!"
    }
  ],
