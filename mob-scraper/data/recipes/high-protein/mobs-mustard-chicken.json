  "method": [
    {
      "heading": null,
      "description": "Place the thighs on a large frying pan and cook both sides until golden brown. Remove the thighs from the pan and set aside, leaving the chicken fat in the pan."
    },
    {
      "heading": null,
      "description": "Chop your onion and fry in the reserved chicken fat for about 5 minutes."
    },
    {
      "heading": null,
      "description": "Add your bacon lardon pieces, stirring until cooked through."
    },
    {
      "heading": null,
      "description": "Mince your garlic and add to the pan with your rosemary sprigs. Pour the white wine into the pan and allow your ingredients to simmer away."
    },
    {
      "heading": null,
      "description": "Stir in the Dijon mustard and double cream along with the white wine vinegar, a pinch of salt and pepper. Give it a good stir."
    },
    {
      "heading": null,
      "description": "Prepare your bulgur wheat."
    },
    {
      "heading": null,
      "description": "Time to bring it all together. Roughly chop your tarragon and add it to the pan with the cooked chicken thighs. Make sure to flip the thighs over every few minutes to allow them to be fully covered in the sauce."
    },
    {
      "heading": null,
      "description": "You’re now ready to serve up the delicious MOB Mustard Chicken on a bed of bulgur wheat. Enjoy!"
    }
