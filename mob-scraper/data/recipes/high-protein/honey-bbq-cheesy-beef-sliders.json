  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "For the seasoned beef, slice the onions lengthways. Heat a glug of olive oil in a large frying pan set over a medium heat, and cook the onions with the balsamic vinegar until softened. Add the beef to the pan and cook until browned and cooked through."
    },
    {
      "heading": null,
      "description": "Add the BBQ seasoning, passata, tomato purée, Worcestershire sauce and honey to the pan with the beef. Season with salt and pepper and mix together. Leave to simmer for a couple of minutes."
    },
    {
      "heading": null,
      "description": "Halve the burger buns and lay out the bottoms in a large baking dish. Drizzle over the BBQ sauce, followed by the seasoned beef and grated mozzarella and cheddar cheese."
    },
    {
      "heading": null,
      "description": "Meanwhile, melt the butter and mince the garlic and parsley then combine in a ramekin. Add the tops of the buns to the filled bottoms, then brush over the garlic and herb mix. Sprinkle over the sesame seeds."
    },
    {
      "heading": null,
      "description": "Loosely cover the dish with foil and bake in the oven for 10 mins, removing the foil halfway through."
    }
  ],
