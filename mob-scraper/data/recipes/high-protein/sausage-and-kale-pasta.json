  "method": [
    {
      "heading": null,
      "description": "Squeeze the meat out of each sausage. Break up each sausage into four balls and add to a frying pan. Stir them until they begin to brown. Once browned, add the curly kale."
    },
    {
      "heading": null,
      "description": "Start boiling your pasta."
    },
    {
      "heading": null,
      "description": "Chop up your garlic and add to the sausage balls. Add the chilli flakes and a glass of wine. Mix in the single cream along with a ladle of pasta water and mix everything together."
    },
    {
      "heading": null,
      "description": "Slice up the Taleggio, add to the pan and allow it to melt. Chop your parsley finely and add this to the pan with a good grinding of black pepper and the juice of a whole lemon."
    },
    {
      "heading": null,
      "description": "Once the pasta is cooked, add this to the pan and fold the sauce into the pasta. And that’s it, tuck in and enjoy this warming pasta dish!"
    }
