  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Rub the chicken thighs all over with olive oil and plenty of flaky sea salt."
    },
    {
      "heading": null,
      "description": "Place a heavy pan over a medium heat and cook the chicken thighs skin side down for about 7 or 8 mins until the skin is golden and crispy. Take off the heat and season with 2 tbsp of za’atar."
    },
    {
      "heading": null,
      "description": "Parboil the potatoes for 7 mins in heavily salted water. Drain and shake hard in the colander to rough up the outer surface."
    },
    {
      "heading": null,
      "description": "Add 4 tbsp olive oil to a roasting tray and place into the oven. Let it heat up for 5 mins, then add the potatoes and shake well."
    },
    {
      "heading": null,
      "description": "Place the chicken thighs skin side up on top of the potatoes and season the skin side with the remaining za’atar. Place the tray into the oven for about 20 mins or until the chicken is cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the romesco sauce."
    },
    {
      "heading": null,
      "description": "Toast the blanched almonds for a few minutes in a dry pan over a medium heat. Add to the food processor along with the peppers, tomatoes, garlic, chilli flakes, smoked paprika and a tsp of salt. Blend until emulsified, then drizzle in the oil with the processor running."
    },
    {
      "heading": null,
      "description": "On a large serving platter, spread the romesco evenly, top with the roast potatoes and then the chicken. Sprinkle with chopped parsley and a drizzle of olive oil. Best served with a simple green salad."
    }
  ],
