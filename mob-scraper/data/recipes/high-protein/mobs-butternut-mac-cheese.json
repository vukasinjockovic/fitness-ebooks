  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Peel your butternut squash and cut it into cubes. Place on a baking tray. Drizzle with olive oil, season with salt and pepper and roast for 25 minutes (until soft, not browning though)."
    },
    {
      "heading": null,
      "description": "When the squash is ready, take 2/3 of it and add to a blender. Pour the milk into the blender and blitz until smooth."
    },
    {
      "heading": null,
      "description": "Place a large saucepan on the heat. Add 4 tbsp of olive oil and flour. Whisk it together until the flour is absorbed by the oil."
    },
    {
      "heading": null,
      "description": "Start gradually adding your blended butternut mix, whisking constantly. Once mixed in, add dijon mustard."
    },
    {
      "heading": null,
      "description": "Get your macaroni cooking in a separate pan."
    },
    {
      "heading": null,
      "description": "Finely grate cheddar and Parmesan."
    },
    {
      "heading": null,
      "description": "Add chopped sage leaves and a small handful of chopped rosemary to the butternut squash sauce. Mix them in. Add the remaining 1/3 of the roasted cubed butternut."
    },
    {
      "heading": null,
      "description": "Drain your macaroni and add it to the butternut squash pan. Mix it all together. Add the cheese, saving enough to sprinkle over the macaroni before putting it in the oven."
    },
    {
      "heading": null,
      "description": "Fold the cheese in. Once it has melted, remove the pan from the heat. Pour the macaroni into a baking dish. Sprinkle your leftover cheese on top. Add some sage and rosemary leaves and a drizzle of olive oil."
    },
    {
      "heading": null,
      "description": "Place under the grill for 3 minutes. Keep an eye on it, you don’t want the cheese to burn."
    },
    {
      "heading": null,
      "description": "When the cheese is nicely browned, remove the dish from the oven. Dole out and tuck in! Enjoy mob!"
    }
  ],
