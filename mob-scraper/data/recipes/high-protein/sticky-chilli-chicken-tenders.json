  "method": [
    {
      "heading": null,
      "description": "Add all the brine ingredients to a large bowl. Add the chicken fillets, cover and set aside for an hour in the fridge."
    },
    {
      "heading": null,
      "description": "Make the batter by whisking together the egg and water, then add the flour slowly, whisking with each addition until you make a smooth batter. Season with salt. Set aside."
    },
    {
      "heading": null,
      "description": "To create the seasoned flour, tip the flour into a bowl, add in the dry spices, and toss to combine. Set aside."
    },
    {
      "heading": null,
      "description": "To make the sticky chilli sauce, peel and finely grate the ginger and garlic. Melt the butter in a small saucepan over a medium heat, add the grated ginger and garlic, cook for 2 mins then add the chilli powder and cook for a 2 mins further, to toast the spice. Add the gochujang, honey and soy sauce, whisk together to combine, cook for a minute further until the sauce is a sticky consistency then remove from the heat and set aside."
    },
    {
      "heading": null,
      "description": "Tip enough vegetable oil into a large sauce pan to come halfway up the sides. Place over a high heat and heat to 150°C, then turn to a medium heat to keep the heat constant."
    },
    {
      "heading": null,
      "description": "Remove the chicken from the brine and dry on a paper towel. Working in batches, put a handful of the chicken fillets into the plain flour, then dust off a little. Transfer into the batter, then use your hands to remove from the batter and toss into the seasoned flour. Toss to coat. Use a slotted spoon to lower the chicken into the oil and fry for 2-3 mins, until pale golden. Remove with the slotted spoon and set aside on a wire rack. Repeat with the rest of the chicken."
    },
    {
      "heading": null,
      "description": "Turn up the heat under the saucepan to heat the oil to 180°C. Lower the chicken back into the pan, and fry for a few more mins until golden and crispy. Drain on the wire rack."
    },
    {
      "heading": null,
      "description": "Reheat the sticky chilli sauce until glossy, then spread the sauce on all of the tenders and enjoy."
    }
  ],
