  "method": [
    {
      "heading": null,
      "description": "Add the ribs to the SatisFry Air &amp; Grill cooking basket and select the slow cook function. Tip in the cola, onion, and half the soy. Add enough water to barely cover the ribs and slow cook for 2 hours or until the meat is tender, but not falling to bits."
    },
    {
      "heading": null,
      "description": "Meanwhile make the glaze. Combine the remaining soy, ketchup, gochujang, maple syrup, vinegar and five-spice in a pan. Bring to the boil and reduce by a third."
    },
    {
      "heading": null,
      "description": "Once the ribs are cooked, remove from the slow cooker and set up the SatisFry for air fry. Place the grill plate in the cooking pot and then add the ribs and brush on the BBQ sauce. Air fry for 2 mins then brush on more BBQ sauce. Repeat until the ribs are sticky, gnarly and coated. Leave on keep warm while you make the slaw."
    },
    {
      "heading": null,
      "description": "To make the slaw, thinly slice the cabbage and fennel. Toss with salt and the juice of two limes. Add smashed cashew nuts and chopped dill."
    },
    {
      "heading": null,
      "description": "Serve the ribs with a heaping pile of slaw and extra lime."
    }
  ],
