  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Ancho Chilli Chicken Traybake batch recipe."
    },
    {
      "heading": null,
      "description": "Separate the chicken and peppers from the beans in the traybake. Shred the chicken, thinly slice the garlic, and pick the coriander leaves, thinly slicing the stems."
    },
    {
      "heading": null,
      "description": "Set a saucepan over a medium heat with a drizzle of olive oil. Once hot, add the tomato purée, garlic, and coriander stems. Cook for a couple of minutes until softened and the purée has darkened."
    },
    {
      "heading": null,
      "description": "Stir in the chipotle paste, chicken stock, shredded chicken, and peppers. Leave on the heat until piping hot, then reduce to low. Season to taste with salt, black pepper, and a squeeze of lime juice."
    },
    {
      "heading": null,
      "description": "Stir the beans through the cooked rice and reheat until steaming."
    },
    {
      "heading": null,
      "description": "Share the rice between bowls, ladle over the broth, and top with the shredded chicken and peppers. Finish with the coriander leaves and serve with any remaining lime wedges."
    }
  ],
