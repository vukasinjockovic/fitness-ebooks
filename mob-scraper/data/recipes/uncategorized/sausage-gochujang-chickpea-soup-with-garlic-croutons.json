  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Sausage Gochujang Ragù batch recipe."
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Tip the ragù into a saucepan and set over a medium heat. Stir in the drained chickpeas and stock, then bring to a simmer. Cook for 10–15 mins until slightly thickened."
    },
    {
      "heading": null,
      "description": "Scoop out roughly a quarter of the soup and blitz until smooth using a blender or stick blender. Pour it back into the pan and stir through. This makes the soup extra creamy while keeping some chunky texture."
    },
    {
      "heading": null,
      "description": "While the soup simmers, tear the sourdough into bite-sized chunks. Toss with a drizzle of olive oil, garlic granules, salt and black pepper. Spread out on a tray and bake for 12–15 mins until golden and crisp."
    },
    {
      "heading": null,
      "description": "Finely chop the chives, and then ladle the soup into bowls. Top with the crunchy garlic croutons and a scattering of chives to finish."
    }
  ],
