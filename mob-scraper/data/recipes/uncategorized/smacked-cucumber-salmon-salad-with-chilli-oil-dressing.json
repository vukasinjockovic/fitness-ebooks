  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Zingy Greens &amp; Miso Salmon Traybake batch recipe."
    },
    {
      "heading": null,
      "description": "Stir all the chilli oil dressing ingredients together in a large mixing bowl."
    },
    {
      "heading": null,
      "description": "In a separate small bowl, mix the tahini dressing ingredients together with a splash of cold water until you’ve got a smooth, spoonable consistency."
    },
    {
      "heading": null,
      "description": "Flake the cooked miso salmon. Trim and thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "Trim the cucumber and cut into quarters width ways. Using something heavy (like a rolling pin or meat mallet), smack the cucumber until it splits and cracks. Chop into rough 2cm chunks."
    },
    {
      "heading": null,
      "description": "Chuck the smashed cucumber, spring onions, miso salmon and green veg from the batch, sesame seeds into the chilli oil dressing and toss well to coat."
    },
    {
      "heading": null,
      "description": "Spoon the tahini dressing across the base of your plates. Pile the cucumber salad over the top and spoon over any leftover chilli oil dressing."
    }
