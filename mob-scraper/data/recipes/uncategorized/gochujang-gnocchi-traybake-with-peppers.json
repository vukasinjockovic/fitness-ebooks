  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Sausage Gochujang Ragú batch recipe."
    },
    {
      "heading": null,
      "description": "Heat the oven to 220°C. Slice the peppers into strips and the red onion into wedges."
    },
    {
      "heading": null,
      "description": "Toss the gnocchi, peppers and onion with olive oil, salt and pepper on a large baking tray. Roast for 20 mins, giving it all a good toss halfway through until the gnocchi is golden and the veg is soft and charred in spots."
    },
    {
      "heading": null,
      "description": "While that’s roasting, warm the Sausage Gochujang Ragù in a saucepan or microwave-safe bowl until piping hot. Add a splash of water if needed to loosen."
    },
    {
      "heading": null,
      "description": "Mix the ragú through the gnocchi traybake, loosening with water, if needed. Serve the traybake drizzled with chilli oil and some single cream (if you like), then scatter with coriander."
    }
