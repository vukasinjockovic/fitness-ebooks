  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Aubergine Alla Norma batch recipe."
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of salted water to the boil. Blanch the lasagne sheets for 1 min, then remove with tongs and set aside on a plate, make sure they’re not touching or they’ll stick. Save the water."
    },
    {
      "heading": null,
      "description": "Tip the Aubergine Alla Norma leftovers into a deep ovenproof frying pan along with the tinned cherry tomatoes. Place over a medium heat and bring to a bubble."
    },
    {
      "heading": null,
      "description": "Tear the lasagne sheets in half and stir through the sauce with a splash of the blanching water to loosen. The sauce should be a bit thinner than usual, the pasta will soak a lot of it up. Taste and season well with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Dice the mozzarella. Dot the ricotta and mozzarella evenly over the top, then grate over the parmesan. Drizzle with a little olive oil."
    },
    {
      "heading": null,
      "description": "Transfer to the oven and bake for 35–40 mins until golden and bubbling. Garnish with basil, if using."
    }
  ],
