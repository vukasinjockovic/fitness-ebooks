  "method": [
    {
      "heading": null,
      "description": "Make the Air Fryer Smoky Chicken &amp; Chorizo."
    },
    {
      "heading": null,
      "description": "Start by cooking the couscous in boiling, salted water for 6 mins. Drain and rinse in cold water. Warm the batch through until piping hot if you like, or you can serve this one cold."
    },
    {
      "heading": null,
      "description": "Whichever you decide, mix the Air Fryer Smoky Chicken &amp; Chorizo (saving the chicken either for the top or shredding it up) through the drained couscous along with the spinach. Taste and adjust the seasoning with salt, pepper and a squeeze of lemon juice."
    },
    {
      "heading": null,
      "description": "Pick the herbs and finely slice the red onion. Mix together in a bowl."
    },
    {
      "heading": null,
      "description": "Serve the couscous topped with the chicken (if eating whole) and the herb salad. Finish with a drizzle of oil and a sprinkling of sumac."
    }
