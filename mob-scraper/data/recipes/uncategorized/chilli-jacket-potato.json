  "method": [
    {
      "heading": null,
      "description": "Make the Veggie Chilli Sin Carne."
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Prick the potatoes with a fork and rub with olive oil, salt and pepper. Pop onto a baking tray and get into the oven for 1 hr - 1 hr 30 mins, until a knife goes through."
    },
    {
      "heading": null,
      "description": "Finely slice the red onion and transfer to a bowl with a pinch of salt and the juice of the lime. Scrunch the onion a little with your hands and set aside."
    },
    {
      "heading": null,
      "description": "Get the leftover Veggie Chilli Sin Carne into a saucepan and heat through until piping hot. Dice the avocado. Get the potatoes out of the oven, cut with a cross and squish to open. Add the butter and mash it in before topping with the chilli, feta, avocado and limey onions."
    }
