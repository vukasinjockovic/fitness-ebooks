  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Everything Salmon &amp; Green Pesto Chickpeas batch recipe."
    },
    {
      "heading": null,
      "description": "Wash the rice two or three times until the water runs clear, then drain well."
    },
    {
      "heading": null,
      "description": "Add the spinach, water, garlic and butter to a blender and blitz until smooth."
    },
    {
      "heading": null,
      "description": "Tip the rice into a medium-sized saucepan and pour over the green mixture. Bring to the boil, then cover with a lid and turn the heat down as low as it goes. Cook for 12 mins."
    },
    {
      "heading": null,
      "description": "Turn off the heat and leave to stand, covered for 10 mins. Remove the lid and fluff up the rice with a fork, some of the spinach may sit on top, so just stir it back through. Cover again and leave for another 5 mins. Season to taste with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, pour the balsamic vinegar into a bowl and slowly whisk in the olive oil to make a dressing. Season with salt and pepper. Chop the tomatoes into 2cm chunks, then toss them through the dressing along with the pesto chickpeas."
    }
  ],
