  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Aubergine Alla Norma batch recipe."
    },
    {
      "heading": null,
      "description": "Heat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Rub the potatoes all over with olive oil, then season with salt and black pepper. Wrap each one in foil and place onto a baking tray. Roast for 1 hr, then remove the foil and bake for another 15–20 mins until crisp on the outside and fluffy in the middle."
    },
    {
      "heading": null,
      "description": "Meanwhile, reheat the Aubergine Alla Norma in a saucepan over a medium heat until piping hot."
    },
    {
      "heading": null,
      "description": "Cut a cross in the top of each potato and push the sides out to open them up. Drizzle the insides with a little olive oil, then sprinkle in the grated mozzarella and cheddar."
    },
    {
      "heading": null,
      "description": "Spoon over the hot Aubergine Alla Norma, grate over the Parmesan and finish with a scattering of basil leaves."
    }
