  "method": [
    {
      "heading": null,
      "description": "Start by prepping your veg. Dice your onion and your red, yellow and green peppers. Slice your spring onions. Finely chop your garlic and scotch bonnet."
    },
    {
      "heading": null,
      "description": "Tip your mushrooms into a large bowl and add your browning (or soy sauce if using) along with your allspice. Season generously with salt and pepper. Tip in all of your chopped veg and a few sprigs of thyme, then stir to combine. Pop in the fridge to marinate overnight, or for a couple of hours."
    },
    {
      "heading": null,
      "description": "Heat a glug of oil in a large saute pan. Tip your veg mixture in and fry for 10 mins until all the veg has softened and is starting to reduce and caramelise slightly."
    },
    {
      "heading": null,
      "description": "Pour in your veg stock gradually and bring to a simmer. Sprinkle on your cornflour and stir to mix in - this should make your sauce thick and glossy."
    },
    {
      "heading": null,
      "description": "Time to pour your Guinness into the pan. Let it simmer for 5 mins until you have a glossy sauce."
    },
    {
      "heading": null,
      "description": "Serve over rice and peas alongside fried plantain. Enjoy!"
    }
  ],
