  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 190°C."
    },
    {
      "heading": null,
      "description": "Pour the soup and the coconut milk into a deep roasting pan or baking tray and mix well."
    },
    {
      "heading": null,
      "description": "Mix the butter beans and gnocchi into the baking tray with the soup."
    },
    {
      "heading": null,
      "description": "Slice the pumpkin in half, scoop out the seeds, then slice into thin crescent slices."
    },
    {
      "heading": null,
      "description": "Place the pumpkin on top of the gnocchi mix. Season with salt and pepper and a drizzle of olive oil."
    },
    {
      "heading": null,
      "description": "Bake for 35-40 mins or until the pumpkin is cooked and starting to brown on top."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the herbs, zest the orange and grate the garlic. Add these to a bowl with 2 tbsp of orange juice and 3 tbsp of olive oil and season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Add the herb sauce on top of the gnocchi bake and serve."
