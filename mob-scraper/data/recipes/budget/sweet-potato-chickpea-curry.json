  "method": [
    {
      "heading": null,
      "description": "Peel and dice the sweet potatoes into 2cm chunks. Peel and thinly slice the onion. Peel and finely slice the garlic. Cut the ginger into thin matchsticks. Roughly chop the coriander."
    },
    {
      "heading": null,
      "description": "Place a large saucepan over a medium heat with a drizzle of oil. Once hot, add the onion, ginger and garlic. Season with salt and cook, stirring, until the onion has softened. Stir in the garam masala, chilli flakes, ground cumin and ground turmeric. Cook for 1 min until fragrant."
    },
    {
      "heading": null,
      "description": "Add the sweet potatoes, chopped tomatoes, drained chickpeas, coconut cream and cherry tomatoes to the pan. Stir well, bring to a boil, then cover with a lid. Reduce the heat to low-medium and simmer for 20-25 mins until the sweet potatoes are tender. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Once the sweet potatoes are cooked, stir through the spinach and ½ the chopped coriander. Taste and adjust the seasoning if needed."
    },
    {
      "heading": null,
      "description": "Ladle the curry into bowls. Top with a dollop of coconut yoghurt and the remaining coriander. Enjoy!"
    }
  ],
