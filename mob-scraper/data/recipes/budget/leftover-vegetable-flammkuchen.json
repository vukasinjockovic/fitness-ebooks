  "method": [
    {
      "heading": null,
      "description": "Combine the flour, 150ml water, ½ tsp salt and 2 tbsp of olive oil in a large mixing bowl. Mix to form a dough and knead for 3-5 mins until it's smooth and elastic. Cover and allow to rest whilst you prepare the rest of the ingredients."
    },
    {
      "heading": null,
      "description": "Slice up your onions and chop the peppers into large chunks. Chop up the bacon into small cubes."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium-high heat. Add your bacon and fry until mostly cooked. Add in the onions and peppers and cook for 5 mins until translucent and softened. Grate in the garlic, add in the spinach, and cook for a further minute or so until the spinach has wilted."
    },
    {
      "heading": null,
      "description": "Combine the crème fraîche and nutmeg in a small bowl and season with salt."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 200°C/390°F."
    },
    {
      "heading": null,
      "description": "Roll out the dough as thinly as you can (roughly the thickness of a pound coin) and place it on a lined baking tray. Fold the corners to make a crust and spread on the crème fraîche."
    },
    {
      "heading": null,
      "description": "Sprinkle on your onion topping and leftover spinach and bake in the oven for 20-25 mins until the crust is golden."
    },
    {
      "heading": null,
      "description": "Slice it up and eat immediately."
    }
  ],
