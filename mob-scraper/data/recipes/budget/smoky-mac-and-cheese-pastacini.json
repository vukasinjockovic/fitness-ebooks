  "method": [
    {
      "heading": null,
      "description": "If not using leftover pasta, cook 300g tubetti or other small pasta shape in plenty of boiling salted water until al dente, then drain."
    },
    {
      "heading": null,
      "description": "Meanwhile, melt the butter in a saucepan over a medium heat. Once it foams, add the flour bit by bit, whisking as you go, until you have a smooth paste."
    },
    {
      "heading": null,
      "description": "Cook for a min, then slowly pour in the milk, whisking constantly. Add the paprika and chilli and whisk again to incorporate. Cook for about 3 mins until the sauce starts to thicken."
    },
    {
      "heading": null,
      "description": "Grate in the cheese, stir and continue to cook until you have a smooth, thick and creamy sauce."
    },
    {
      "heading": null,
      "description": "Add the pasta to the sauce and mix well to combine, then allow to cool to room temperature."
    },
    {
      "heading": null,
      "description": "Into 3 separate bowls add the flour, eggs and panko breadcrumbs. Form the pasta mix into golfball size rounds and then dredge in the flour, then dip into the egg and finally the breadcrumbs."
    },
    {
      "heading": null,
      "description": "Transfer to a clean tray and place into the fridge for 20 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the slaw by grating the apples, carrot and fennel into a bowl. Squeeze out any excess moisture and then season with the mustard, vinegar, a third of the mayo, salt and pepper."
    },
    {
      "heading": null,
      "description": "Mince up the basil and mix with the remaining mayo and set aside."
    },
    {
      "heading": null,
      "description": "Fill a large pan half full with vegetable oil, you want it about 2 inches deep. Heat the oil to 180c and then add the pastacini in batches and fry for about 3 mins until golden brown."
    },
    {
      "heading": null,
      "description": "Use a slotted spoon to transfer to a plate lined with a paper towel and fry the rest."
    },
    {
      "heading": null,
      "description": "Plate up 3 of the pastacini, a couple of spoons of the slaw and a good dollop of the basil mayo."
    }
  ],
