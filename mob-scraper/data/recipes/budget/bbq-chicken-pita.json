  "method": [
    {
      "heading": null,
      "description": "Debone the chicken thigh, leaving the skin on. Cut a slit near the bone, and scrape the meat down to remove the bone."
    },
    {
      "heading": null,
      "description": "Place the chicken into a bowl and sprinkle on the smoked paprika, ½ tsp salt, a good grinding of black pepper and a big glug of olive oil. Mix well so it's evenly coated and stained red."
    },
    {
      "heading": null,
      "description": "Cook on your BBQ or a very hot grill skin side down for 15 - 20 mins until cooked through and the skin is crispy."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely slice the red onions and place them in a bowl with the juice of a lemon and salt. Scrunch the onions with your hands to quick pickle."
    },
    {
      "heading": null,
      "description": "Finely slice your white cabbage and combine in a bowl with 100g of sour cream, the juice of 1 lemon, salt and pepper."
    },
    {
      "heading": null,
      "description": "For the sauce, combine the remaining sour cream with the hot sauce. Mix well and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Roughly chop the chicken and pick the leaves of the parsley. Combine the parsley with the pickled onions."
    },
    {
      "heading": null,
      "description": "Toast the pitta and stuff with the cabbage, chicken, pickled red onion mix and the sour cream sauce and enjoy!"
    }
  ],
