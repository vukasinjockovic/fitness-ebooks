  "method": [
    {
      "heading": null,
      "description": "Preheat the oven 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Chop thigh meat into strips. Add it to a pan with some oil and brown it off."
    },
    {
      "heading": null,
      "description": "Add a finely chopped onion, a sliced knob of ginger and sliced garlic cloves. Add garam masala, curry powder and cinnamon. Mix it all in."
    },
    {
      "heading": null,
      "description": "Add mango chutney and mix it in. Add passata, stir it in and reduce the curry down. Once it is thick, plain yogurt."
    },
    {
      "heading": null,
      "description": "Season the Balti with salt and pepper and remove from the heat."
    },
    {
      "heading": null,
      "description": "Roll out some puff pastry and lay it into a baking tray, Make sure it comes up and hangs over the sides. Lay some baking paper on top of it and pour in a bag of rice to weigh the pastry down. Add the tray to the oven for 12 minutes. Remove the baking paper and bake for another 3 minutes."
    },
    {
      "heading": null,
      "description": "Remove the tray from the oven. The pastry should be dry and partially baked. Spoon in your Balti."
    },
    {
      "heading": null,
      "description": "Roll out the second layer of puff pastry. Layer it on top of the pie. Squeeze it along the pie edges. Brush the pie with egg yolk, sprinkle on some salt and then bake for 30 minutes until golden."
    },
    {
      "heading": null,
      "description": "Cut up the pie and tuck in! Enjoy!"
    }
  ],
