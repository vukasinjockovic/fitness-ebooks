  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Place the sweet potatoes on a baking tray. Drizzle over some olive oil and season with salt. Place in the oven for 1 hour until soft."
    },
    {
      "heading": null,
      "description": "When the potatoes are ready, halve them and scoop out the flesh."
    },
    {
      "heading": null,
      "description": "Add the flesh to a bowl with ginger, crushed lemongrass, a grated red chilli, chopped coriander, soy sauce, 3 chopped spring onions and the juice of a lime."
    },
    {
      "heading": null,
      "description": "Finely chop your fish fillets into little bits and add to the mix. Squish everything together and mould it into a big lump. Cover with tin foil and place in the fridge for 20 minutes or so to firm up."
    },
    {
      "heading": null,
      "description": "Once firm, mould the mixture into cakes. Dip the cakes in plain flour followed by beaten egg and then breadcrumbs. Arrange the cakes on a baking tray. Drizzle olive oil on top and sprinkle on some salt. Place in the oven for 35 minutes until golden."
    },
    {
      "heading": null,
      "description": "Boil your peas and drain. Add a handful of chopped mint, the juice of a lemon, olive oil, salt and pepper. Mash together."
    },
    {
      "heading": null,
      "description": "Serve the fish cakes on top of the crushed peas, sprinkle over some lemon juice and enjoy!"
    }
  ],
