  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion, pepper and celery. Scrape into a saucepan along with a pinch of salt and a good drizzle of oil. Cook over a medium to high heat for 6-8 mins, stirring regularly until soft and a little caramelised."
    },
    {
      "heading": null,
      "description": "Add the Cajun seasoning and rice, stir so that each grain gets coated then pour in the hot stock. Bring to the boil then reduce the heat to medium, simmer away, stirring regularly for 20 mins until the rice is cooked through, adding a splash more water if needed. Season to taste."
    },
    {
      "heading": null,
      "description": "Once the rice is nearly done, drain the sweetcorn. Melt the butter in a frying pan over a medium high heat. Add the raw prawns, cook for 2 mins until they have turned from grey to pink."
    },
    {
      "heading": null,
      "description": "Tip in the sweetcorn, add the Sriracha and toss everything to coat so that the prawns get nicely coated."
    },
    {
      "heading": null,
      "description": "Divide the rice between two bowls, top with the sriracha butter prawns, sweetcorn and their sauce then scatter over a few parsley leaves and a good squeeze of lemon, to serve."
    }
  ],
