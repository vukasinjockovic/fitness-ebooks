  "method": [
    {
      "heading": null,
      "description": "Heat the oven to fan 200°C"
    },
    {
      "heading": null,
      "description": "Peel (optional) and chop the carrots &amp; sweet potatoes into 2cm chunks. Toss with a drizzle of olive oil, season with salt &amp; pepper, then spread out on a baking tray. Roast for 25–30 mins, until softened."
    },
    {
      "heading": null,
      "description": "Meanwhile stir the ground cumin, tamarind purée &amp; maple to make the sweet and tangy glaze. Taste &amp; tweak the balance if needed, more tamarind for tang, more maple for sweetness. Set aside."
    },
    {
      "heading": null,
      "description": "Trim and thinly slice the onion and green chilli. Pick the coriander leaves, set the coriander stems aside. Place the onion into a sieve and wash under cold running water. Then soak in a bowl full of ice water, this takes away the harsh bite and makes them last longer."
    },
    {
      "heading": null,
      "description": "Chuck the coriander stems, yoghurt, green chillies, ground cumin &amp; olive oil into a blender. Blitz until smooth, then season with salt, pepper &amp; lemon juice to taste. Divide between boxes."
    },
    {
      "heading": null,
      "description": "Once the veggies are cooked, pour the tamarind glaze over the top, toss together and return to the oven for 5-7 mins until sticky. Leave to cool before boxing up."
    },
    {
      "heading": null,
      "description": "Drain the onions and toss with the sliced green chilli, coriander leaves and roasted veg."
    },
    {
      "heading": null,
      "description": "Top the dressing with the grains and roasted veg mixture. Refrigerate until needed. Shake before serving."
    }
  ],
  "tips": [
    "Works with any grain – freekeh, bulgur or brown rice will be great here.",
    "Make it vegan with dairy-free yoghurt.",
    "Great cold, but also delish served warm."
  ],
