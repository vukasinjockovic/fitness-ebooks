  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Chop the aubergine and peppers into 2-3cm chunks, slice the red onions in 1cm slices. Pile into the largest roasting tray you have and season well with salt and black pepper. Drizzle over a good glug of olive oil, toss everything together then spread into a single layer. Roast in the oven for 20 minutes."
    },
    {
      "heading": null,
      "description": "After 20 minutes, chuck the cherry tomatoes into the pan. Return to the oven for 5 minutes. Meanwhile, tear the bread into large croutons, toss with some olive oil and sea salt."
    },
    {
      "heading": null,
      "description": "Scatter the croutons on top and return to the oven for 10-15 minutes, until the vegetables are cooked through and the croutons are crisp."
    },
    {
      "heading": null,
      "description": "Toss the basil, balsamic vinegar and some olive oil through the salad and share between plates. Tear the mozzarella and top the salads with."
    }
  ],
