  "method": [
    {
      "heading": null,
      "description": "Mince the garlic and ginger and place in a small saucepan with the chilli flakes."
    },
    {
      "heading": null,
      "description": "Add a glug of vegetable oil and heat over medium heat. Cook until toasted and fragrant."
    },
    {
      "heading": null,
      "description": "Remove the saucepan from the heat and whisk in the balsamic vinegar, soy sauce, and sugar. Leave to cool."
    },
    {
      "heading": null,
      "description": "Trim the green beans. Boil in salted water until tender-crisp, around 3 mins, then drain."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the celery on a diagonal, peel the cucumber into ribbons, crush the peanuts, and roughly chop the coriander."
    },
    {
      "heading": null,
      "description": "Season the chicken thigh fillets with salt and pepper on both sides. Place in a cold non-stick frying pan."
    },
    {
      "heading": null,
      "description": "Heat the frying pan over medium heat and cook the chicken undisturbed for 6 mins, or until deep golden brown. Flip and cook for a further 4 mins, or until cooked through, then transfer to a chopping board to rest."
    },
    {
      "heading": null,
      "description": "Place the green beans, celery, and cucumber in a mixing bowl. Add half of the dressing and toss to coat. Transfer to a platter."
    },
    {
      "heading": null,
      "description": "Chop the chicken and place on top of the salad with the crushed peanuts and chopped coriander. Top with the remaining dressing then tuck in and enjoy!"
    }
  ],
