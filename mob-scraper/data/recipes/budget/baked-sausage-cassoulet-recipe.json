  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 220°C. Put a large, deep roasting tin into the oven to heat for 5 mins. Chuck the sausages and lardons into the tin, pour in 1 tbsp oil and roast for 10 mins, tossing halfway until starting to brown."
    },
    {
      "heading": null,
      "description": "Turn the heat down to 180°C. Peel and finely chop the onion, carrots and celery. Scrape into the roasting tin with the garlic cloves in their skins, three-quarters of the thyme sprigs and the bay leaves. Drizzle with 1 tbsp oil, season with salt and pepper and roast in the oven for 10 mins."
    },
    {
      "heading": null,
      "description": "Pour in the white wine, both tins of beans and their liquid and the can of chopped tomatoes. Put back into the oven for 20 mins until reduced and thickened slightly. Remove from the oven, squeeze out the flesh from the roasted garlic skins and pop them back in the sauce."
    },
    {
      "heading": null,
      "description": "Meanwhile, combine the mozzarella and breadcrumbs in a bowl. Strip the remaining thyme leaves from their stalks and add them to the bowl, too."
    },
    {
      "heading": null,
      "description": "Scatter the cheesy breadcrumbs over the top of the dish, drizzle with a little oil and bake for a final 15 mins until golden and bubbling."
    },
    {
      "heading": null,
      "description": "Serve with a baguette for scooping-up and a bright, fresh green salad to compliment."
    }
  ],
