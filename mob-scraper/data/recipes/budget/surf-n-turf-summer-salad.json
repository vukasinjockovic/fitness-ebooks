  "method": [
    {
      "heading": null,
      "description": "Peel, pit and mash all three of the avocados."
    },
    {
      "heading": null,
      "description": "Thinly slice the spring onions and coriander and add to the avocado mash. Squeeze a lime into the mixture and add salt, pepper and olive oil. Mix well."
    },
    {
      "heading": null,
      "description": "Slice your new potatoes in halves and boil for 15 minutes or until cooked all the way through."
    },
    {
      "heading": null,
      "description": "Slice the chorizo into chunks and the squid into rings. Cook the chorizo in a pan with some olive oil and then add the squid when the chorizo begins to cook."
    },
    {
      "heading": null,
      "description": "Add pepper and lemon juice and continue to cook. Avoid the squid from turning rubbery by not over cooking it."
    },
    {
      "heading": null,
      "description": "Once the potatoes are cooked, unevenly mash them with their skins still on."
    },
    {
      "heading": null,
      "description": "Serve in a bowl with the guac and the cooked surf ‘n’ turf. Grab a fork and dig in."
    }
  ],
