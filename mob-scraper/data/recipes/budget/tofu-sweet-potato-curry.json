  "method": [
    {
      "heading": null,
      "description": "Heat a non-stick pan. Add the sliced brown onions and sliced garlic cloves. Fry until soft. Add the tofu cubes and curry paste, stir fry for 1 minute and then add the sweet potato."
    },
    {
      "heading": null,
      "description": "Stir well. Dissolve stock cube into 300ml of water and pour the coconut milk and stock over. Bring to the boil, reduce the heat, cover and simmer for 20 minutes"
    },
    {
      "heading": null,
      "description": "After 20 minutes, remove the lid and let the curry bubble away and reduce until it has thickened. Cover and set aside."
    },
    {
      "heading": null,
      "description": "Couscous time. Pour some olive oil into a frying pan and add your cauliflower couscous. Add a large handful of frozen peas. Cook until the peas are hot and then add a large handful of chopped coriander. Season with salt and pepper. Remove from the heat."
    },
    {
      "heading": null,
      "description": "Time to serve up. Divide the cauliflower couscous between four plates, top with the curry and garnish with any leftover coriander leaves. Enjoy!"
    }
  ],
