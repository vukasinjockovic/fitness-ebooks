  "method": [
    {
      "heading": null,
      "description": "Slice the potatoes about 3mm thick and place in a large bowl. Rinse in cold water until the water runs clear, then soak for 30 mins in water with your vinegar."
    },
    {
      "heading": null,
      "description": "Heat a large, deep pan about ⅓ full with oil to 160ºC. Meanwhile, drain the potatoes and dry them very well with kitchen towels."
    },
    {
      "heading": null,
      "description": "Fry in batches (they will take longer if you overcrowd the pan), stirring as you first add them, until golden and crisp. Drain on kitchen paper and season lightly with salt or spice mix."
    },
    {
      "heading": null,
      "description": "Eat immediately, or allow to cool, then store in an airtight container (they should be good for 24 hours or so)."
    },
    {
      "heading": null,
      "description": "Add the first 7 of the spices to a spice grinder or a pestle along with ½ tbsp of parsley and 1 tbsp of sugar, then blitz or pound until dusty. Stir through the remaining ½ tbsp of parsley and ½ tbsp of sugar until combined. When the crisps have come out of the oil, tip into a bowl and toss with the seasoning in batches. Simple."
    }
  ],
