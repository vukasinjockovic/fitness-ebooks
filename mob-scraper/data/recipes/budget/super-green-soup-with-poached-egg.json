  "method": [
    {
      "heading": null,
      "description": "Finely slice the red chilli, pick the sage and finely dice the sourdough. Strip the leaves off the kale and finely slice the garlic."
    },
    {
      "heading": null,
      "description": "Heat half the oil in a large pot and add the garlic. Cook over a medium heat for 3 mins. Add the fennel seeds and continue to cook for 1 min. Pour in the stock, bring to the boil, pop on a lid and reduce to a simmer. Cook for 15-20 mins. Allow to cool slightly (you could start the croutons) before adding the kale and cooking for 4 mins. Add the beans, then set aside."
    },
    {
      "heading": null,
      "description": "Heat the remaining oil in a frying pan set over a medium heat, then add the sage, chilli and diced sourdough. Cook until golden and crisp, then remove from the pan and set aside."
    },
    {
      "heading": null,
      "description": "Bring a small pan of water to the boil. Crack an egg into a bowl, then carefully drop the egg into the water, turning the heat down as low as it can go. Cook for 3 mins, then remove from the pan and drain. Repeat with the remaining eggs and set aside."
    },
    {
      "heading": null,
      "description": "Blend the soup until smooth, then season with a squeeze of lemon, adjusting to suit your taste. Ladle into bowls. Top with the poached egg, crispy croutons and lemon zest."
    }
  ],
