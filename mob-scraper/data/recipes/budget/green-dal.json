  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Cut the cauliflower into florets and put on a baking tray. Drizzle with oil, salt and pepper, then transfer to the oven and cook for 15 min."
    },
    {
      "heading": null,
      "description": "Pour the stock into a large pan and bring to the boil. Rinse the red lentils well and add to the stock, then grate in the ginger and the garlic. Add the curry powder and simmer for 15 mins until the lentils are soft."
    },
    {
      "heading": null,
      "description": "Put the coconut milk into a blender with the coriander and blitz until smooth, then add to the lentil pan. Mix and season with salt and pepper. When the cauliflower is cooked, mix through the mango chutney."
    },
    {
      "heading": null,
      "description": "Finely slice the chilli. Stir the spinach through the dal and top with the cauliflower. Garnish with coriander, chillies and a drizzle of coconut milk."
    }
  ],
