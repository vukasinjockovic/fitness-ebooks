  "method": [
    {
      "heading": null,
      "description": "Peel and core the apples. Chop up the apples into small 2cm cubes."
    },
    {
      "heading": null,
      "description": "Mix the apples with brown sugar, cornflour, cinnamon and ½ tsp salt."
    },
    {
      "heading": null,
      "description": "Put the apples in a small pan with the water and cook for 10 mins until the apples have slightly softened and the sauce has thickened."
    },
    {
      "heading": null,
      "description": "Transfer to a plate or a baking dish and spread out thinly to cool down completely."
    },
    {
      "heading": null,
      "description": "Roll out the shortcrust pastry until it’s roughly half the thickness and cut it into 10 small rectangles to make 5 pies."
    },
    {
      "heading": null,
      "description": "Add a tbsp of the apple filling to the centre and brush the edges with egg wash."
    },
    {
      "heading": null,
      "description": "Add another piece of pastry on top and close the seam with a fork. Trim the edges and pop the pies on a baking sheet."
    },
    {
      "heading": null,
      "description": "Freeze the pies for 30 mins."
    },
    {
      "heading": null,
      "description": "Get a big pot of oil ready for frying. Heat the oil to a medium-high temperature (roughly 180°C)."
    },
    {
      "heading": null,
      "description": "Once the oil is hot, deep fry the pies for 5 mins or until golden brown and crispy."
    },
    {
      "heading": null,
      "description": "Drain on a paper towel and enjoy piping hot."
    }
  ],
