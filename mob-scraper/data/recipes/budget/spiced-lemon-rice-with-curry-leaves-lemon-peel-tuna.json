  "method": [
    {
      "heading": null,
      "description": "Rinse the rice in cold water until it runs clear, then drain well. Finely dice the onion."
    },
    {
      "heading": null,
      "description": "Tip the butter into a medium saucepan set over a medium heat, then add the curry leaves, whole green chillies, fennel seeds, black mustard seeds and nigella seeds. Cook for 30 seconds until the seeds pop and sizzle, then add the onion and cook over a slightly lower heat for around 10 mins until soft."
    },
    {
      "heading": null,
      "description": "Add the rice, water, the zest of the lemon in thin strips, a pinch of salt and plenty of black pepper, then cover the pan and cook for about 20 mins, or until all the water has been absorbed and the rice is cooked through."
    },
    {
      "heading": null,
      "description": "When the rice is cooked, add the juice of the lemon and fluff up the rice with a fork to serve. Check the seasoning, adjusting with more salt and pepper as necessary, then flake in the tuna. Finish by drizzling the reserved tuna can oil over the dish."
    }
