  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Slice up your onions, celery, aubergine, courgettes and red peppers."
    },
    {
      "heading": null,
      "description": "Place your pan on a medium heat, add a splash of olive oil and add your veggies. Mix well."
    },
    {
      "heading": null,
      "description": "Slice up your garlic cloves and add to the pan followed by your oregano and chilli flakes. Mix well."
    },
    {
      "heading": null,
      "description": "Add two tins of tomatoes, refill the tins with water and pour into the pan. Add one stock cube and another tin of water, mixing everything in. Cover and simmer for 30 minutes."
    },
    {
      "heading": null,
      "description": "Grab a mixing bowl. Add the self-raising flour, a knob of butter, a pinch of salt and baking soda. Knead everything together to form a dough. Add 150g of grated cheddar, a teaspoon of oregano and continue to mix. Add the milk and mix together using a spoon."
    },
    {
      "heading": null,
      "description": "Create a baguette shape with the dough and slice into 8 pieces. Form balls out of these pieces and place around the ratatouille pan. Grate the remaining 50g of cheese over the dumplings."
    },
    {
      "heading": null,
      "description": "Place the pan in the oven for 35 minutes to bake."
    },
    {
      "heading": null,
      "description": "Garnish with some chopped basil and enjoy."
    }
  ],
