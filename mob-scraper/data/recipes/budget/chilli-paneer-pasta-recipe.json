  "method": [
    {
      "heading": null,
      "description": "Dice the paneer into bite-sized cubes, then transfer to a bowl. Add the oil, turmeric, curry powder and a pinch of salt, then toss well."
    },
    {
      "heading": null,
      "description": "Heat a large frying pan over a medium-high heat, add a splash of vegetable oil. Once the oil is shimmering, add the paneer cubes and fry on all sides for a total of 5 mins. Meanwhile, dice the onion, green chillies and peppers. Finely dice the garlic and coriander."
    },
    {
      "heading": null,
      "description": "Remove the cooked paneer from the pan and set aside. Add the onion and garlic to the same pan, turn the heat to medium and cook for 10 mins until translucent."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the pasta following pack instructions. Combine all the chilli sauce ingredients in a bowl and set aside."
    },
    {
      "heading": null,
      "description": "Add the peppers to the pan, then pour in the chilli sauce. Reduce the sauce to your preferred thickness, over a medium heat for 10 mins. Add the paneer back to the pan, tip in the cooked pasta and give everything a good mix."
    },
    {
      "heading": null,
      "description": "Serve with chillies and coriander on top."
    }
  ],
