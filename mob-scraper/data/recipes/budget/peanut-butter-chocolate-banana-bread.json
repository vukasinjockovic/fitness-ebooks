  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C/354°F."
    },
    {
      "heading": null,
      "description": "Line and grease a loaf tin."
    },
    {
      "heading": null,
      "description": "Mash the banana with the vegetable oil, light brown sugar, Dr. Oetker Vanilla Extract, and all but 1 tbsp of your peanut butter."
    },
    {
      "heading": null,
      "description": "Roughly chop up 150g of your Dr. Oetker Very Dark Chocolate and peanuts."
    },
    {
      "heading": null,
      "description": "Whisk the flour and Dr. Oetker Baking Powder in a bowl together. Add in the dark chocolate and peanuts (save a tablespoon of peanuts for later)."
    },
    {
      "heading": null,
      "description": "Add the dry ingredients to the wet mixture and mix well."
    },
    {
      "heading": null,
      "description": "Pour your batter into the loaf tin and sprinkle with the tablespoon of peanuts."
    },
    {
      "heading": null,
      "description": "Bake for 45-50 mins. If your banana bread looks like it’s browning too much, top with foil after 30 mins."
    },
    {
      "heading": null,
      "description": "Melt the saved peanut butter and chocolate to drizzle over the top. Cool to room temperature, then serve."
    }
