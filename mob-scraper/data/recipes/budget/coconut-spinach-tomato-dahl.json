  "method": [
    {
      "heading": null,
      "description": "Add lentils to a large saucepan along with the veg stock (dissolved in 1 litre boiling water), coconut milk and ground spices (cumin and tumeric). Season generously. Bring to the boil then simmer gently for 10 minutes."
    },
    {
      "heading": null,
      "description": "Next, peel and finely chop the ginger and roughly chop the nuts. Scrape into a bowl along with the chilli flakes and sugar. Finely slice the onion and garlic cloves - set aside separately."
    },
    {
      "heading": null,
      "description": "Back to the dahl, chuck in the tomatoes. Cook for a further 15 minutes, stirring regularly as the dahl thickens until the lentils are cooked through and have absorbed most of their liquid."
    },
    {
      "heading": null,
      "description": "Meanwhile, get a frying pan over a medium heat. Pour in enough vegetable oil to cover the base of the pan. Heat until simmering then add the sliced onion. Cook for 8 minutes, stirring until crisp then remove with a slotted spoon into the bowl with the ginger, nuts, chilli and sugar. Add the sliced garlic to the oil. Cook until the garlic is just turning golden then take the pan off the heat. Pour the garlic along with the oil into the bowl with the other chilli bits. Give everything a good mix."
    },
    {
      "heading": null,
      "description": "Time to boil your eggs. Boil for 6 and a half minutes, then place them into an ice-cold bowl of water and allow the eggs to chill for 5 minutes. Peel away the shell and slice in half."
    },
    {
      "heading": null,
      "description": "Stir the spinach through the dahl and squeeze in the lime or lemon juice. Once wilted, season then divide between bowls. Top each with half a soft boiled egg, then drizzle over the crispy chilli oil. Tear over some coriander to serve."
    }
  ],
