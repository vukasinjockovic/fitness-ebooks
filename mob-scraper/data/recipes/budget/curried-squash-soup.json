  "method": [
    {
      "heading": null,
      "description": "Finely slice your onions. Finely chop your garlic and ginger."
    },
    {
      "heading": null,
      "description": "Peel and chop your squash into 3cm chunks."
    },
    {
      "heading": null,
      "description": "Add a good glug of vegetable oil to your sauté pan. Add your onions and squash and cook for 15 mins over\na medium heat, until they are fully softened and have just begun to caramelise. Add your garlic\nand ginger, then cook for 2 mins."
    },
    {
      "heading": null,
      "description": "Tip in your bay leaf, chilli powder and garam masala, then add your tinned tomatoes and stock.\nBring to a gentle simmer and simmer for 25 mins."
    },
    {
      "heading": null,
      "description": "Heat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Cut your bread into 1 inch cubes. Add these to a baking dish with a drizzle of olive oil, then bake\nfor 9 mins."
    },
    {
      "heading": null,
      "description": "Finely chop your green chillies and grate your cheddar."
    },
    {
      "heading": null,
      "description": "Sprinkle your cheddar over your croutons along with your green chillies. Return to the oven for 3\nmins until melted."
    },
    {
      "heading": null,
      "description": "Pour your soup into a blender, then blitz until you have a smooth consistency."
    },
    {
      "heading": null,
      "description": "Pour the soup back into the pan, then pour in your cream. Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Spoon your soup into bowls. Top with an extra drizzle of cream, your croutons and a little\nsprinkle of curry powder. Enjoy!"
    }
  ],
