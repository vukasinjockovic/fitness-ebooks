  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F"
    },
    {
      "heading": null,
      "description": "Put tomatoes into a baking tray. Tear up your ciabatta into bitesize chunks and put in the tray."
    },
    {
      "heading": null,
      "description": "Into a jar, put 3 tbsp of olive oil, your balsamic vinegar and cloves of garlic (crushed or finely chopped). Shake it, and then pour over the bread and tomatoes."
    },
    {
      "heading": null,
      "description": "Add salt, pepper and crushed chillies, and put the tray in the oven for 45 minutes."
    },
    {
      "heading": null,
      "description": "After 45 minutes, remove the tray. Mix everything around, coating the crispy bits in the juices. Add salami, and then place tray back in oven for 10 more minutes."
    },
    {
      "heading": null,
      "description": "Dressing time. Take your basil. Chop it all up, finely, and put into a jar. Add a tbsp and a half of olive oil and shake it all together."
    },
    {
      "heading": null,
      "description": "Take the tray out the oven, and tear your mozzarella on top. Drizzle your dressing over everything, and sprinkle over some crushed chillies, salt and pepper. Enjoy!"
    }
  ],
