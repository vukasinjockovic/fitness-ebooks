  "method": [
    {
      "heading": null,
      "description": "Dice chicken into small chunks and add to a bowl. Grate the cloves of garlic and red chilli into the bowl. Add 3 tsps of oregano. Add the zest of your lemon. Add 4 tsps of your yoghurt, salt and pepper."
    },
    {
      "heading": null,
      "description": "Rub together and cover with cling film. Leave in fridge for 15 minutes."
    },
    {
      "heading": null,
      "description": "Tzatziki time. Pour the rest of the yoghurt into another bowl. Add a small bunch of finely chopped mint, the juice of the lemon, and grated cucumber. Season well and mix it all together."
    },
    {
      "heading": null,
      "description": "Tomato salsa. Finely chop your tomatoes. Add to a bowl with 2 tsps of oregano, salt, pepper and olive oil."
    },
    {
      "heading": null,
      "description": "Finely chop your lettuce."
    },
    {
      "heading": null,
      "description": "Put a griddle pan on a medium to high heat. Once it is hot, add your chicken. It needs 3 minutes on each side."
    },
    {
      "heading": null,
      "description": "Warm some pittas. Assemble to gyros and tuck in. Enjoy!"
    }
