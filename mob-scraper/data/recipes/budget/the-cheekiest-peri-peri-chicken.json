  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F"
    },
    {
      "heading": null,
      "description": "Place chicken in a baking tray. Cover with olive oil. Add two tsp paprika and a tsp of dried oregano. Rub it in. Place chicken in the oven for 30 minutes."
    },
    {
      "heading": null,
      "description": "Meanwhile, prep the sauce. Cut peppers and red onion into chunks and add to a baking tray. Cut a lemon in half. Add the lemon halves, face side down. Add your chillies to the tray. Drizzle olive oil over everything. Place the tray in the oven for 40 minutes."
    },
    {
      "heading": null,
      "description": "After 30 minutes, remove the chicken and baste it in the juices. Place it back in the oven for another 30 minutes."
    },
    {
      "heading": null,
      "description": "When the vegetables and lemon are charred and soft, remove from the oven."
    },
    {
      "heading": null,
      "description": "Place the onion and peppers into a blender. Add the juice of the roasted lemons. Add cloves of grated garlic, the zest and juice of a fresh lemon, 2 tsp of smoked paprika, two tsp of dried oregano, a tsp and a half of red wine vinegar, a tsp of olive oil and a good pinch of salt and pepper. Blitz until you have a smooth orange sauce."
    },
    {
      "heading": null,
      "description": "Pour the sauce into a frying pan and add two bay leaves. Allow the sauce to gently bubble away for a couple of minutes so the bay leaves can infuse."
    },
    {
      "heading": null,
      "description": "While the sauce is getting on, take your chicken out of the oven. Baste it in the juices and remove from the tray. Hack it up roughly."
    },
    {
      "heading": null,
      "description": "Serve the chicken on a bed of basmati rice and black beans. Pour your sauce over the top. Enjoy mob, this one is a winner."
    }
  ],
