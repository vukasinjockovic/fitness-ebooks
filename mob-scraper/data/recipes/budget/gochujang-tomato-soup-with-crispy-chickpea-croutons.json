  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C fan."
    },
    {
      "heading": null,
      "description": "Peel and cube the sweet potato. Peel and chop the onion and roughly chop the red pepper. Drain the chickpeas."
    },
    {
      "heading": null,
      "description": "Add the sweet potato, onion, red pepper and tomatoes to a large, lined baking tray. Add the chickpeas to a separate tray (or use the same tray but keep them separate). Drizzle with olive oil and roast for 20-25 mins until everything is soft and starting to caramelise. Remove from the oven and set aside."
    },
    {
      "heading": null,
      "description": "Heat a little olive oil in a medium sized pot over a medium heat then add the smoked paprika and gochujang. Fry for a minute or two until the spices start to brown, then add the roasted vegetables, keeping the chickpeas to the side for topping."
    },
    {
      "heading": null,
      "description": "Pour in the coconut milk (reserve a tiny drizzle for the end), water, soy sauce, rice vinegar and stock cube and summer for 10 mins. Use a hand or stand blender to blitz until smooth."
    },
    {
      "heading": null,
      "description": "Roughly chop the peanuts and slice the green parts of the spring onion."
    },
    {
      "heading": null,
      "description": "To serve, ladle the soup into bowls and top with the crispy chickpeas, sliced spring onion and chopped peanuts. Finish with a drizzle of crispy chilli oil and reserved coconut milk."
    }
  ],
