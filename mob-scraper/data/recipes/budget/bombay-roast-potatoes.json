  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Add a large glug of oil to a baking dish and pop it into the oven to warm up."
    },
    {
      "heading": null,
      "description": "Peel and chop up your potatoes and pop them into a large pan. Pour over cold water enough to cover and heavily season with salt and the turmeric. Bring to a boil and cook until just fork-tender, 10 minutes."
    },
    {
      "heading": null,
      "description": "Meanwhile, peel the garlic and ginger, and slice the chillis."
    },
    {
      "heading": null,
      "description": "Drain the potatoes and coat with flour, chilli powder, garam masala, coriander powder, cumin powder and a teaspoon of salt. Grate in the garlic and ginger, then add in the chilli. Shake to rustle them up to make them fluffy."
    },
    {
      "heading": null,
      "description": "Add the cumin and black mustard seeds to the hot oil. Stir to mix evenly then pour in the potatoes."
    },
    {
      "heading": null,
      "description": "Roast in the oven for 40 minutes, tossing occasionally to evenly roast."
    },
    {
      "heading": null,
      "description": "Meanwhile, roughly chop the coriander and half the lemon/s."
    },
    {
      "heading": null,
      "description": "When crispy and roasted, pull out the potatoes and squeeze on the juice from your lemon/s and sprinkle the coriander."
    }
  ],
