  "method": [
    {
      "heading": null,
      "description": "Heat the grill to medium-high and dice the aubergine into 2cm pieces. Put the aubergine onto a tray and whack under the grill for 10 mins, then flip and grill for another 5-10 mins until charred and soft. Remove from the grill and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Slice the garlic and finely chop the basil stalks. Heat a shot of oil in a large pan over a low-medium heat and add the garlic, chilli flakes and basil stalks, frying gently for 3 mins until just golden. Tip in the roasted aubergine and canned tomatoes, squashing the tomatoes down a bit. Simmer for 20-25 mins."
    },
    {
      "heading": null,
      "description": "Tear the basil leaves and mix through the sauce along with the red wine vinegar, seasoning with salt and pepper. Cool and decant into an airtight container and store in the fridge or freezer."
    }
  ],
