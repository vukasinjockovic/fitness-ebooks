  "method": [
    {
      "heading": null,
      "description": "Start by adding chapati flour, salt, vegetable oil to a large bowl. Gradually pour in 120ml of warm water and use a wooden spoon to mix everything together."
    },
    {
      "heading": null,
      "description": "Once the mixture comes together, use your hands to knead the dough for a few minutes, it will be sticky at first but keep kneading till it’s soft, pliable and you can easily form a ball."
    },
    {
      "heading": null,
      "description": "Cover and refrigerate for at least 30 mins or overnight."
    },
    {
      "heading": null,
      "description": "Peel and boil the potatoes in salted water until very tender. Mash them and add chopped green chilli (you can deseed if you like!), fresh coriander and all the ground spices, mix well and season to taste."
    },
    {
      "heading": null,
      "description": "Grate the cauliflower and add to a bowl along with the spices and mix well."
    },
    {
      "heading": null,
      "description": "Divide the dough into 8 equal-sized balls."
    },
    {
      "heading": null,
      "description": "On a lightly floured surface, use a floured rolling pin to roll out 2 dough balls into roughly equal-sized circles."
    },
    {
      "heading": null,
      "description": "To one of the circles, add 1-2 tbsp of the potato or cauliflower filling and spread it around, leaving a small border."
    },
    {
      "heading": null,
      "description": "Place the other circle on top and use water to seal the edges."
    },
    {
      "heading": null,
      "description": "Fry in 2 tbsp of vegetable oil until golden and crispy on both sides, 2-3 mins per side. Get stuck in!"
    }
  ],
