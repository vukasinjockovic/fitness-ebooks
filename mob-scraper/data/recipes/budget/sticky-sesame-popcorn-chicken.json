  "method": [
    {
      "heading": null,
      "description": "Cut chicken into bite-size chunks."
    },
    {
      "heading": null,
      "description": "Get two bowls. Fill one with cornflour and crack two eggs into the other. Whisk eggs. Dip a piece of chicken in flour, then egg, then flour. Make sure it is coated. Do this with all your chicken."
    },
    {
      "heading": null,
      "description": "Heat a large glug of vegetable oil in a wok (enough for the chicken to shallow fry). Add your chicken bits in batches. Fry until crispy. Remove from the wok and set aside."
    },
    {
      "heading": null,
      "description": "Get your rice on – cook according to pack instructions."
    },
    {
      "heading": null,
      "description": "Wipe the excess oil out of the wok. Add a tablespoon of sesame oil. Add a large grated knob of ginger and grated garlic cloves. Fry for 30 seconds."
    },
    {
      "heading": null,
      "description": "Add sweet chilli sauce, soy sauce, ketchup and rice wine vinegar. Mix everything together."
    },
    {
      "heading": null,
      "description": "Add 100ml of cornflour slurry. To make the slurry, add a heaped teaspoon of cornflour to a glass and pour in 100ml of warm water. Mix until the cornflour is dissolved."
    },
    {
      "heading": null,
      "description": "Mix everything together. Once it starts thickening, re-add your chicken. Coat it in the sticky sauce."
    },
    {
      "heading": null,
      "description": "Serve the chicken on top of the hot rice, with chopped spring onions and sesame seeds scattered on top. Enjoy!"
    }
  ],
