  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Peel the butternut squash, cut it in half, then remove and discard the seeds. Cut the squash into 5cm pieces."
    },
    {
      "heading": null,
      "description": "Drain and rinse the chickpeas. Dice the onion into 2.5cm cubes. Finely chop the green chilli. Set everything aside."
    },
    {
      "heading": null,
      "description": "Combine the butternut squash, chickpeas, onion, garlic paste, ginger paste, cumin seeds, curry leaves, green chilli, curry powder, ground coriander, turmeric, chilli flakes, 1 tsp salt and coconut oil in a large bowl. Toss well, until the squash and chickpeas are well coated."
    },
    {
      "heading": null,
      "description": "Spread the squash and chickpea mixture in a single layer over a large baking tray lined with baking parchment. Roast in the oven for 25-30 mins, or until the squash is tender and starting to caramelise."
    },
    {
      "heading": null,
      "description": "Remove the tray from the oven and pour the coconut milk over the roasted vegetables. Stir to combine and coat everything evenly. Return to the oven and cook for 10-15 mins, until the coconut milk has thickened slightly."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the coriander."
    },
    {
      "heading": null,
      "description": "Check the finished traybake for seasoning, then squeeze the juice of ½ lime over the top. Garnish with the coriander and serve with rice, rotis or bread."
    }
  ],
