  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Peel the potatoes and cut into medium sized chunks. Add to a large pan of cold salted water and set over a high heat. Bring to a boil and then reduce to a simmer, cook for 10-15 mins until fork tender. Carefully drain and let the potatoes steam dry for 10-15 mins."
    },
    {
      "heading": null,
      "description": "Take a large roasting tray and fill with enough vegetable oil to cover the bottom of the tray. Place in the oven for 5 mins to heat up. Cut the top off the garlic, drizzle with a little oil and wrap in tin foil."
    },
    {
      "heading": null,
      "description": "Take the tray out of the oven and add the potatoes with the wrapped bulb of garlic. Place in the oven for 55 mins, until the potatoes are really crisp and golden."
    },
    {
      "heading": null,
      "description": "Heat honey and lao gan ma (or other chilli oil) in a saucepan over a medium heat then add in the soy and balsamic. Gently simmer for around 5 minutes until thickened."
    },
    {
      "heading": null,
      "description": "Add the mayo to a bowl with sesame oil, before squeezing in the roast garlic and a squeeze of lemon juice. Season with salt and pepper. Drizzle the chilli oil glaze the potatoes and garnish with sesame seeds and spring onions."
    }
  ],
