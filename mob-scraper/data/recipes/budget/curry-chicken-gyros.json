  "method": [
    {
      "heading": null,
      "description": "Place your chicken thighs in a bowl. Add hot chilli powder, ground coriander, garam masala and 1 tablespoon of olive oil. Add yogurt. Season with salt and pepper. Mix in thoroughly. Leave to marinate for 25 minutes."
    },
    {
      "heading": null,
      "description": "Meanwhile, make your green sauce. Get a blender and add a garlic clove, the juice of a lime, a small bunch of fresh mint, a large bunch of fresh coriander and a large green chilli. Whizz it up with a bit of water until smooth."
    },
    {
      "heading": null,
      "description": "Finely chop your red onion and add to a bowl. Squeeze the juice of one lemon over the top. Add a generous pinch of sea salt. This will lightly pickle the onions."
    },
    {
      "heading": null,
      "description": "Roughly chop some tomatoes and half a cucumber. Add to a bowl with salt and some leftover mint and coriander."
    },
    {
      "heading": null,
      "description": "Pan fry the marinated chicken until cooked through."
    },
    {
      "heading": null,
      "description": "Warm your pittas."
    },
    {
      "heading": null,
      "description": "Once the chicken is cooked remove from the heat. Open your pittas and stuff with the chicken, the green sauce, the salad and some extra yogurt on top. Enjoy!"
    }
  ],
