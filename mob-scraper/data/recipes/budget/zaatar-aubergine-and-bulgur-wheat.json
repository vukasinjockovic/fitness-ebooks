  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Slice the aubergines in half and then score the inside in a cross-section."
    },
    {
      "heading": null,
      "description": "Brush the aubergine with olive oil and sprinkle liberally with za'atar and salt. Slice the garlic in half, coat with olive oil then wrap up in foil."
    },
    {
      "heading": null,
      "description": "Pop the garlic and aubergine in the oven with the cherry tomatoes and roast for 30 mins."
    },
    {
      "heading": null,
      "description": "Bring 800ml of water to a boil then add in the bulgur wheat, pop on a lid and cook for 15 mins. Then turn the heat off and allow it to steam for 10 mins."
    },
    {
      "heading": null,
      "description": "Finely chop the red chillies, red onion, parsley and spring onion."
    },
    {
      "heading": null,
      "description": "Whisk together five tablespoons of extra virgin olive oil with the juice of a lemon, your roasted garlic, tomato paste, red chillies, spring onions, cumin, three-quarters of the parsley, salt, and pepper."
    },
    {
      "heading": null,
      "description": "Toss with the cooked bulgur wheat until it's bright red and evenly coated."
    },
    {
      "heading": null,
      "description": "Pour this onto your serving plate and top with the roasted aubergine and cherry tomatoes. Sprinkle with parsley and dollop on the coconut yoghurt. Enjoy!"
    }
  ],
