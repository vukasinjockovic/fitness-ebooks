  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Break the cauliflower into florets, cut into strips and place in a bowl. Add turmeric, chilli powder, ground coriander, cinnamon and about 1/5 of your yoghurt. Season with salt and pepper and mix everything together."
    },
    {
      "heading": null,
      "description": "Heat a griddle pan. Once very hot, add your cauliflower in batches. Cook on a high heat for 3 minutes on each side, until charred."
    },
    {
      "heading": null,
      "description": "Place the char-grilled cauliflower into the oven for 10 minutes so they can cook through."
    },
    {
      "heading": null,
      "description": "Slice up the red onions. Squeeze the juice of a lemon over the top and season with salt. Leave for 10 minutes to pickle."
    },
    {
      "heading": null,
      "description": "For your raita, add your grated cucumber, the rest of your yoghurt, a handful of chopped mint, a handful of chopped coriander, salt, pepper and olive oil. Mix everything together."
    },
    {
      "heading": null,
      "description": "Take your pitta bread, cut it open and place the cauliflower tikka in the pocket and drizzle some raita over the top. Add your pickled onions, some chopped tomatoes, more raita and tuck in."
    }
  ],
