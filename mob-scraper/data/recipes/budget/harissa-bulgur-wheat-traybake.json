  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C/400°F."
    },
    {
      "heading": null,
      "description": "Drain your chickpeas, then tip them into your roasting tray along with your cherry tomatoes, cumin and cinnamon. Drizzle with a glug of olive oil and a sprinkle of salt, then roast for 30 mins."
    },
    {
      "heading": null,
      "description": "Add your bulgur wheat to the roasting tray along with your hot vegetable stock and harissa paste. Give it a good stir, then cover the tray tightly with foil and bake for 15 mins longer."
    },
    {
      "heading": null,
      "description": "Whilst your bulgur wheat cooks, roughly chop your parsley."
    },
    {
      "heading": null,
      "description": "Once cooked, remove the foil and fluff the bulgur wheat with a fork. Season to taste."
    },
    {
