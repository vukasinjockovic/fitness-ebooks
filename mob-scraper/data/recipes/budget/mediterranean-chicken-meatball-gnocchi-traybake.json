  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 210°C. Pick the basil leaves, setting aside the smaller ones for garnish. Finely chop the rest and chuck into a large bowl with the chicken mince. Crumble in one-third of the feta, season with salt and pepper, then mix well with your hands. Shape into 8 meatballs."
    },
    {
      "heading": null,
      "description": "Slice the courgette into half moons. Tip the courgette, gnocchi, cherry tomatoes and olives onto a roasting tray. Drizzle with the olive oil and season with salt and pepper. Toss everything together so it’s well coated."
    },
    {
      "heading": null,
      "description": "Top with the meatballs. Break over the remaining feta into chunky, crouton-sized pieces. Bake for 25 mins, or until everything is golden and the meatballs are cooked through."
    },
    {
      "heading": null,
      "description": "Once the traybake is ready, scatter over the reserved basil leaves and serve up!"
    }
  ],
