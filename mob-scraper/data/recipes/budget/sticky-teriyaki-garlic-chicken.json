  "method": [
    {
      "heading": null,
      "description": "Drizzle some olive oil into a frying pan and add your chicken thighs. Cook until the skin becomes golden and crispy."
    },
    {
      "heading": null,
      "description": "Start cooking your rice (see packet instructions)."
    },
    {
      "heading": null,
      "description": "Once your chicken thighs are crispy, remove from the pan."
    },
    {
      "heading": null,
      "description": "Add butter to a clean pan. Once it has melted, grate your garlic cloves into the pan. Add teriyaki marinade and allow this to simmer for a few minutes. Add Sriracha, honey and allow the sauce to simmer again."
    },
    {
      "heading": null,
      "description": "Add your chicken to the pan and coat it in the sauce. Add 6 tbsps of water and leave the sauce to bubble on a low heat for a few minutes."
    },
    {
      "heading": null,
      "description": "Serve on a bed of rice and sprinkle some sesame seeds over the top. Pour the remaining sauce over the top of the chicken. Slice up some spring onions to use for a garnish and tuck into this delicious dish."
    }
