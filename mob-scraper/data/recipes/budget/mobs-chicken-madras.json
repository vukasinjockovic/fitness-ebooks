  "method": [
    {
      "heading": null,
      "description": "Add garam masala, chilli powder, turmeric and crushed cardamom pods (pod and seeds) to a wide frying pan with a splash of oil. Cook for a minute on a medium heat to toast the spices."
    },
    {
      "heading": null,
      "description": "Add crushed garlic cloves and a large knob of grated ginger. Stir them in. Add finely chopped onions. Coat the onions in the spices."
    },
    {
      "heading": null,
      "description": "Add your chicken thighs and cook for 5 minutes until nicely browned."
    },
    {
      "heading": null,
      "description": "Add a heaped tablespoon of tomato paste. Stir it in and add tins of plum tomatoes. Break them up with a spoon, bring the curry to a boil. Turn down the heat and allow to simmer for 20 minutes."
    },
    {
      "heading": null,
      "description": "Get your rice on – follow pack instructions."
    },
    {
      "heading": null,
      "description": "Once the chicken is cooked through, add a chopped green chilli, salt and pepper."
    },
    {
      "heading": null,
      "description": "When the curry is nice and thick, remove from the heat. Serve over steaming rice and enjoy!"
    }
  ],
