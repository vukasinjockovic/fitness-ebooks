  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Peel and finely grate the garlic and ginger. Finely slice the lime leaves, discarding the tough stems."
    },
    {
      "heading": null,
      "description": "Add the garlic, ginger, lime leaves, curry paste, coconut milk and water to a roasting tin. Whisk everything together to combine."
    },
    {
      "heading": null,
      "description": "Tip in the spinach, edamame and dumplings. Stir gently, then cover the tin tightly with foil. Bake for 25 mins until the dumplings are cooked through and the broth is piping hot."
    },
    {
      "heading": null,
      "description": "Remove from the oven, give everything a stir to mix the spinach through, then drizzle over the soy sauce and fish sauce."
    },
    {
      "heading": null,
      "description": "Serve up with a scattering of coriander and lime wedges for squeezing."
    }
