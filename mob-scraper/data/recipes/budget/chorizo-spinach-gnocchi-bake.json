  "method": [
    {
      "heading": null,
      "description": "Finely chop the cloves of garlic and chop chorizo into bite size bits."
    },
    {
      "heading": null,
      "description": "Place chorizo in frying pan and cook until crispy."
    },
    {
      "heading": null,
      "description": "Add garlic, a teaspoon of chilli flakes and a handful of basil leaves. Cook for 30 seconds, and then add your spinach."
    },
    {
      "heading": null,
      "description": "Wilt the spinach down, and then pour in your tins of chopped tomatoes. Fill the tins halfway with water, and pour that in. Turn down to a medium heat and allow to reduce and thicken."
    },
    {
      "heading": null,
      "description": "While the sauce is thickening, put your gnocchi into a bowl and cover with boiling water."
    },
    {
      "heading": null,
      "description": "Once the sauce has thickened remove from the heat."
    },
    {
      "heading": null,
      "description": "Drain the gnocchi and pour into a baking dish. Cover the gnocchi with your chorizo sauce. Flatten it out, and tear two balls of mozzarella over the top."
    },
    {
      "heading": null,
      "description": "Cover the whole dish with grated Parmesan, and then place under the grill for 15 minutes or until the cheese is golden and bubbling. Enjoy!"
    }
  ],
