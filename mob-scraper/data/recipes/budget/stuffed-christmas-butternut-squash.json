  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Halve your butternut squash. Lay them on a tray and sprinkle with a teaspoon of all spice. Season with salt and pepper, add a drizzle of olive oil and roast for 1 hour until soft."
    },
    {
      "heading": null,
      "description": "Add your chestnuts to a roasting tray and roast for 30 minutes until tender."
    },
    {
      "heading": null,
      "description": "While the squash is roasting, prepare your tzatziki. Pour your coconut yogurt into a bowl. Grate the cucumber, squeeze any excess water out of them and add to the yogurt."
    },
    {
      "heading": null,
      "description": "Add a handful of chopped mint, the zest and juice of a lime. Season with salt and pepper and mix together. Cover with cling film and leave to chill in the fridge."
    },
    {
      "heading": null,
      "description": "Pour couscous into a bowl and cover with boiling water. Leave it to absorb the water, after which it will be ready to eat."
    },
    {
      "heading": null,
      "description": "Finely chop garlic cloves and a red onion. Add it to a large frying pan with a splash of olive oil. Add a heaped teaspoon of all spice and mix everything together. Cook on a low heat for 3-4 minutes."
    },
    {
      "heading": null,
      "description": "Remove your squash from the oven. Scoop out the flesh, being careful to keep the skins intact. Break up the flesh with a spoon and set aside."
    },
    {
      "heading": null,
      "description": "Remove your chestnuts from the oven. Discard the outer shells and add the chestnut insides to the frying pan with the onions. Add the cranberries to the pan and mix everything together."
    },
    {
      "heading": null,
      "description": "Add the couscous, bit by bit. Once it is all mixed in, add the squash. Cook everything for another 4 minutes and remove the pan from the heat."
    },
    {
      "heading": null,
      "description": "Re-stuff your squash skins and place them back in the oven for another 20 minutes."
    },
    {
      "heading": null,
      "description": "Serve the squash with big dollops of the tzatziki and any leftover mint, cranberries and chestnuts. Enjoy!"
    }
  ],
