  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Peel squash and sweet potato. Cut into cubes. Add to a roasting tray."
    },
    {
      "heading": null,
      "description": "Season with salt and pepper and add a drizzle of olive oil. Place in the oven for 50 minutes or until cooked through."
    },
    {
      "heading": null,
      "description": "Finely chop onion and garlic cloves. Add a splash of olive oil to a frying pan and chuck the onion and garlic in. Fry until the onions are soft."
    },
    {
      "heading": null,
      "description": "Add your spinach and wilt it down. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Transfer the spinach mix from the frying pan and into a sieve. Squeeze the spinach with a wooden spoon to get rid of excess moisture. Add the spinach to a mixing bowl."
    },
    {
      "heading": null,
      "description": "Remove your potato and squash from the oven. Mash it up. Add to the mixing bowl. Add your feta, ricotta, 4 eggs and the zest of a lemon. Season with salt, pepper and olive oil. Mix everything together."
    },
    {
      "heading": null,
      "description": "Pie time. Line your pie dish with olive oil. Add a layer of filo pastry. Brush with olive oil. Repeat with 4 more layers of filo. Fill the pie with your filling. Fold the edges of the pastry over the top. Add 3-4 crumpled sheets of filo on the top. Brush with egg yolk."
    },
    {
      "heading": null,
      "description": "Place the pie in the oven for 55 minutes. Remove when golden brown. Serve up the pie and tuck in!"
    }
  ],
