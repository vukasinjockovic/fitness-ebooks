  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C fan."
    },
    {
      "heading": null,
      "description": "Arrange the quartered onions, finely sliced garlic, and drained butter beans on a large baking tray.\nTOP TIP: Make sure to add the mixture into an appropriate sized tray, if the tray is huge, and you don't have much in it, the liquid will evaporate quicker"
    },
    {
      "heading": null,
      "description": "In a bowl, whisk together the melted butter, miso paste, stock cube, and water until combined. Pour over the onions and beans. Cover the tray with foil."
    },
    {
      "heading": null,
      "description": "Roast for 30 mins, then remove the foil and roast for another 30 mins until the onions are charred and tender. Remove the leaves from the stems of the cavolo nero and slice them up."
    },
    {
      "heading": null,
      "description": "Stir in the cavolo nero and return to the oven for another 5 mins until wilted."
    },
    {
      "heading": null,
      "description": "Reheat the rice, remove beans from the oven, and squeeze in the lime juice. Taste and adjust seasoning with salt and black pepper."
    },
    {
      "heading": null,
      "description": "To serve, divide into bowls and drizzle with chilli oil."
    }
  ],
  "tips": [
    "Storage: Store in airtight containers in the fridge for up to 3 days. Reheat before serving.",
    "Substitutions: Swap cavolo nero for kale or spinach. Use white miso for a milder flavour.",
    "Serving Ideas: Enjoy with crusty bread or over rice for a more substantial meal."
  ],
