  "method": [
    {
      "heading": null,
      "description": "Roughly chop your shallots, lemongrass, garlic and ginger."
    },
    {
      "heading": null,
      "description": "Toast your cloves, cardamom pods, coriander seeds and cumin seeds in a pan then set aside."
    },
    {
      "heading": null,
      "description": "Toast your chillies until slightly burnt and deseed."
    },
    {
      "heading": null,
      "description": "Pop everything into a food processor along with the cinnamon, turmeric, 3 tbsp of coconut milk and pulse until you’ve got a smooth paste."
    },
    {
      "heading": null,
      "description": "Peel your potatoes then cut into 3cm-sized chunks."
    },
    {
      "heading": null,
      "description": "Pop your paste in a pot or wok with a good glug of oil then add your potatoes and fry until crispy."
    },
    {
      "heading": null,
      "description": "Add the remaining coconut milk and vegetable stock. Cook for 15 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the carrots, break the cauliflower into florets and drain the chickpeas."
    },
    {
      "heading": null,
      "description": "Add them to the curry and simmer for a further 10 mins, then stir in the tamarind paste and brown sugar."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook your Tilda Jasmine Rice according to packet instructions."
    },
    {
      "heading": null,
      "description": "Plate up, tuck in and enjoy."
    }
  ],
