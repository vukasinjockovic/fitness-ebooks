  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Finely chop the peppers, onion and 1 garlic clove. Add to a frying pan with a splash of oil. Fry until softened."
    },
    {
      "heading": null,
      "description": "Add large handful of finely chopped coriander stalks, cumin and paprika. Mix together."
    },
    {
      "heading": null,
      "description": "Pour in black beans with the tin water. Bubble your bean mix down. Once the beans have softened, season with salt and pepper. Add a handful of fresh coriander and mash everything together."
    },
    {
      "heading": null,
      "description": "Tomato sauce time. Crush 2 garlic cloves into a pan with a splash of olive oil. After 15 seconds, pour in your passata. Bubble it down until it has thickened. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Spoon in half of your tomato sauce to a baking dish."
    },
    {
      "heading": null,
      "description": "Fill each of the 8 tortillas with an equal amount of the bean mixture. Wrap the tortillas up. Lay them side by side in the baking tray. They should be nice and snug when they are all in."
    },
    {
      "heading": null,
      "description": "Pour the remaining tomato sauce over the top, making sure you don’t cover the edges of the tortillas (you want the edges to get nice and crispy)."
    },
    {
      "heading": null,
      "description": "Cheese time. Grate 150g of your cheddar. Scatter it over your enchiladas."
    },
    {
      "heading": null,
      "description": "Place baking dish in the oven for 45 minutes or until the cheddar is golden and bubbling."
    },
    {
      "heading": null,
      "description": "Serve the enchiladas with a handful of fresh coriander and any leftover grated cheese scattered on top. Enjoy!"
    }
  ],
