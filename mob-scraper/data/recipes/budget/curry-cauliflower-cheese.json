  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 190°C."
    },
    {
      "heading": null,
      "description": "Chop your cauliflower into large florets and roughly chop the leaves and stems."
    },
    {
      "heading": null,
      "description": "Bring a pan of salted water to a boil. Add your cauliflower florets and leaves, then cook for 4 mins until just tender."
    },
    {
      "heading": null,
      "description": "Add your butter to a large saucepan and add your cumin seeds. Fry for a minute until fragrant."
    },
    {
      "heading": null,
      "description": "Add in your tomato purée and cook for 3 mins until the colour has darkened."
    },
    {
      "heading": null,
      "description": "Spoon in your ginger and garlic paste, then cook for 30 seconds until fragrant. Add in your chilli powder and turmeric, then cook out for a further 2 mins."
    },
    {
      "heading": null,
      "description": "Add your flour, then mix to a paste and cook for another 2 mins. Gradually pour in your milk in small increments, whisking constantly so you have a smooth paste before pouring in more."
    },
    {
      "heading": null,
      "description": "Once all your milk has been added, bring your mixture to a boil and let it simmer for 2 mins until thickened."
    },
    {
      "heading": null,
      "description": "Remove your sauce from the heat. Add your cheddar and stir until is has totally melted. Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Tip your cauliflower into a baking dish and pour over your cheese sauce. Bake for 25 mins until golden and bubbly."
    },
    {
      "heading": null,
      "description": "Serve and enjoy."
    }
  ],
