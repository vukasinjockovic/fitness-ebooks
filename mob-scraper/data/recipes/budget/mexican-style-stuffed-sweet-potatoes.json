  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Drizzle olive oil over the sweet potatoes. Add salt and a small handful of chilli flakes (optional)."
    },
    {
      "heading": null,
      "description": "Bake sweet potatoes for 50 minutes or until soft."
    },
    {
      "heading": null,
      "description": "Whilst the potatoes are in the oven, sort the guacamole. Scoop the flesh out of your avocados and add to a bowl. Add a handful of chopped coriander leaves, the juice of a lime, a finely chopped red chilli, some salt, pepper and olive oil. Mash."
    },
    {
      "heading": null,
      "description": "Chilli time. Finely chop your onion and peppers."
    },
    {
      "heading": null,
      "description": "In a pan, add a splash of olive oil. Add the chopped garlic, cumin, and paprika."
    },
    {
      "heading": null,
      "description": "Once the garlic has softened (1 minute) add the peppers and onion. Fry until soft, on a medium to low heat. Add a bit of water if it starts catching on the pan. This should take about 15 minutes."
    },
    {
      "heading": null,
      "description": "Once softened, add your black beans. Mash everything together."
    },
    {
      "heading": null,
      "description": "Remove your sweet potatoes from the oven. Scoop out the flesh and save the skins. Add the flesh to the black bean chilli. Mix everything together."
    },
    {
      "heading": null,
      "description": "Assemble time. Stuff the sweet potato skins with the chilli. Add a big dollop of guac. Top with a generous grating of cheddar, and garnish with spring onions, red chillies and coriander. Enjoy!"
    }
  ],
