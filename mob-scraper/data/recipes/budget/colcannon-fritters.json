  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 160°C"
    },
    {
      "heading": null,
      "description": "Peel your potatoes and chop them into chunks."
    },
    {
      "heading": null,
      "description": "Pop your potatoes in a pan and fill it with enough cold water to cover them completely. Salt generously, then bring to a boil. Simmer for 15 mins until the potatoes are tender. Drain and allow to steam dry in the colander for a few minutes."
    },
    {
      "heading": null,
      "description": "Meanwhile, shred your cabbage and slice your spring onions."
    },
    {
      "heading": null,
      "description": "Heat a little oil in a frying pan over a medium heat, then tip in your cabbage. Fry for 7 mins until soft and tender."
    },
    {
      "heading": null,
      "description": "Mash your potatoes with your butter and milk."
    },
    {
      "heading": null,
      "description": "Tip your potatoes and cabbage into a bowl along with your spring onions and plain flour. Grate in some cheddar and season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Shape your mixture into 8 chunky patties."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium heat with a good glug of vegetable oil. Add your patties and fry for about 4 mins on each side until crisp and golden. Pop on a baking tray and slide into the oven to keep warm."
    },
    {
      "heading": null,
      "description": "In the same pan, fry your bacon rashers for a few minutes until crispy."
    },
    {
      "heading": null,
      "description": "Fill a deep saucepan with water. Once boiling, stir the water with a spoon to create a whirlpool. Crack an egg into the centre and cook for 3 mins until the whites are cooked through but your yolk is still soft."
    },
    {
      "heading": null,
      "description": "Serving time. Pop two colcannon fritters on a plate and top with your poached eggs and bacon. Sprinkle with chopped chives and enjoy."
    }
  ],
