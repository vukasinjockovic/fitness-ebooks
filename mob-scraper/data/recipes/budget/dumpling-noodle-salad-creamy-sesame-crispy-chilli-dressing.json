  "method": [
    {
      "heading": null,
      "description": "Cook the noodles according to the packet instructions, then drain and rinse under cold water to cool completely. Set aside."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onions and halve the sugar snap peas. Halve the cucumber lengthways, scoop out the seeds and slice into half-moons. Roughly crush the peanuts with the back of your knife and pick the coriander leaves. Then add everything to a bowl with the noodles."
    },
    {
      "heading": null,
      "description": "Heat the vegetable oil in a large frying pan over a medium-high heat. Add the dumplings and cook for 8–10 minutes, turning regularly, until golden and crispy all over. (You can also do this in an airfryer at 180°C for 15-20 mins)."
    },
    {
      "heading": null,
      "description": "Add the tahini to a bowl. Peel and finely grate in the garlic and ginger, then add the honey, lime juice and water. Whisk until smooth and creamy, loosening with a splash more water if needed. Season with salt, then spoon the crispy chilli oil over the top for a marbled effect, or mix it through for a fully mixed dressing."
    },
    {
      "heading": null,
      "description": "Add the crispy dumpling to your salad. Pour over the dressing and toss well to coat. Serve straight away while the dumplings are still crispy."
    },
    {
      "heading": null,
      "description": "For a marbled finish, pour the crispy chilli oil over the top and leave it untouched. Otherwise, stir it through for a fully mixed sauce."
    }
  ],
