  "method": [
    {
      "heading": null,
      "description": "If you don’t have metal skewers, soak wooden or bamboo ones in water for at least 30 mins."
    },
    {
      "heading": null,
      "description": "Heat the oven to 225°C. Add all the dry spices into a large bowl with the kuli kuli. Stir through the stock powder, sugar and salt. Stir together and set aside ⅙ of it to use as a garnish, later."
    },
    {
      "heading": null,
      "description": "Optional: Wash your chicken with either lemon, salt or vinegar and water. Use a kitchen roll to dry the chicken."
    },
    {
      "heading": null,
      "description": "Dice the chicken into 3cm chunks and tip it into the spice bowl. Pour a drizzle of olive oil on top and mix together. Leave to marinate for 30 mins."
    },
    {
      "heading": null,
      "description": "Thread the marinated chicken onto the skewers and place onto an oiled baking tray. Roast in the oven for 15 mins, turning halfway through."
    },
    {
      "heading": null,
      "description": "Switch the oven to grill and cook the chicken skewers under the grill for 5-10 mins, turning them halfway through, until starting to char on all sides. Each grill works differently, so keep an eye on them."
    },
    {
      "heading": null,
      "description": "Transfer the skewers to plates and sprinkle over the leftover seasoning. Top with some diced tomato, red onion and coriander, if using."
    },
    {
      "heading": null,
      "description": "Plate up the ting and tell your belly it’s time to chow down."
    }
  ],
