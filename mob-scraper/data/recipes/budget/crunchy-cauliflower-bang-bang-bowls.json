  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Break cauliflower into florets and chop up courgettes into bite-size pieces."
    },
    {
      "heading": null,
      "description": "Get three bowls out. Add flour to one, eggs to another (whisk them up) and breadcrumbs to the last."
    },
    {
      "heading": null,
      "description": "Dip veg into the flour, the eggs, the breadcrumbs (in that order). Add baking paper to a baking tray. Add the veg, season with salt and drizzle with olive oil. Put the tray in the oven for 30 minutes until golden and crunchy."
    },
    {
      "heading": null,
      "description": "Get your rice on. Follow pack instructions."
    },
    {
      "heading": null,
      "description": "Finely chop cucumber and radish. Add to a bowl with the juice of half a lime, 3 tbsp of olive oil, a handful of coriander, salt and pepper. Mix together and set aside."
    },
    {
      "heading": null,
      "description": "Into a bowl add mayo, Sriracha and the juice of half a lime. Mix everything together."
    },
    {
      "heading": null,
      "description": "Serving time. Add rice to a bowl. Top with bang bang veg, some avocado slices, the zingy radish salad, a big dollop of Sriracha mayo and some fresh coriander leaves. Enjoy!"
    }
