  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F. Cube your sweet potato and slice up your butternut squashes. Add both to a tray. Drizzle with olive oil, season with salt and pepper. Roast for 45 minutes."
    },
    {
      "heading": null,
      "description": "Finely chop your shallots and garlic. Add to a frying pan with a splash of olive oil and the sage leaves. Cook on a low heat and allow to soften."
    },
    {
      "heading": null,
      "description": "Once the squash is soft, remove from the oven. Place half of the squash and sweet potato in a blender with 300ml of water and a stock cube. Blitz until very smooth."
    },
    {
      "heading": null,
      "description": "Add the puree to the shallots and stir it in. Add your remaining squash and sweet potato."
    },
    {
      "heading": null,
      "description": "Get your pasta on. After 4 minutes, add 5 tbsp of the starchy pasta water to the sauce and mix it in."
    },
    {
      "heading": null,
      "description": "Drain the pasta, add it to the sauce and fold it all together. Season well with salt and pepper and tuck in!"
    }
  ],
