  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Rinse your rice under cold water 2-3 times until the water runs clear, add to a sieve and set aside."
    },
    {
      "heading": null,
      "description": "Thinly slice the red onions and garlic. Set a large lidded pot over a high heat. Add the butter and ¾ of the onions and cook with a pinch of salt until gnarly, caramelised and starting to catch on the pan, this will take roughly 5-6 mins."
    },
    {
      "heading": null,
      "description": "Add the garlic and cook for 1 min. Crush the cardamom pods and add to the pan with the turmeric, cinnamon and curry leaves. Chunk up the leftovers and add to the pot with the rinsed rice. Stir to coat everything in the spicy butter, season with salt and pour in the stock."
    },
    {
      "heading": null,
      "description": "Bring to a simmer, then add a lid and pop into the oven for 20 mins to cook through. The liquid should all be absorbed by the rice, which will be tender and fluffy."
    },
    {
      "heading": null,
      "description": "While the pilaf bakes, add the remaining onions to a bowl with the coriander. Add the juice of one lime and a pinch of salt. Toss together. Cut the remaining lime into wedges."
    },
    {
      "heading": null,
      "description": "Allow the rice to rest for 5 mins before serving with the onion salad, extra lime and a blob of yoghurt."
    }
  ],
