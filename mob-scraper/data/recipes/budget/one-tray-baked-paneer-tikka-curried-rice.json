  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Peel and roughly chop the red onion. Core and chop the peppers. Cut the paneer into 2cm cubes."
    },
    {
      "heading": null,
      "description": "Chuck the chopped onion, peppers, paneer and rice into a large roasting tin. Add the tikka paste and give everything a good mix to coat."
    },
    {
      "heading": null,
      "description": "Pour in the cherry tomatoes, coconut milk, chickpeas (along with their liquid) and the just-boiled water. Stir well, then cover the tray tightly with foil."
    },
    {
      "heading": null,
      "description": "Bake in the oven for 40 mins or until the rice is cooked through and tender."
    },
    {
      "heading": null,
      "description": "Pick the coriander leaves and scatter over the tray to serve."
    }
