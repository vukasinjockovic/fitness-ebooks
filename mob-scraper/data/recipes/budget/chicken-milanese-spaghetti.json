  "method": [
    {
      "heading": null,
      "description": "Chop some garlic. Add a splash of olive oil to a pan. Add the garlic and oregano."
    },
    {
      "heading": null,
      "description": "Add the chopped tomatoes and basil. Let it simmer."
    },
    {
      "heading": null,
      "description": "Place your chicken breasts onto a surface and cover with cling film."
    },
    {
      "heading": null,
      "description": "With a rolling pin, tenderise each breast (by rolling them out/bashing them) until flat."
    },
    {
      "heading": null,
      "description": "Into separate bowls add flour, whisked eggs and crushed croutons."
    },
    {
      "heading": null,
      "description": "Cover your chicken breasts in flour, followed by the whisked eggs, finishing with the croutons."
    },
    {
      "heading": null,
      "description": "Get your spaghetti on."
    },
    {
      "heading": null,
      "description": "Add a generous amount of oil to a frying pan. When the oil is hot, place the breasts into the frying pan for 4 minutes each side or until golden brown."
    },
    {
      "heading": null,
      "description": "Once golden brown, take the chicken out of the frying pan and cut into strips."
    },
    {
      "heading": null,
      "description": "Add the cooked spaghetti to the tomato sauce and mix together."
    },
    {
      "heading": null,
      "description": "Place the chicken strips onto a bed of spaghetti and tuck in!"
