  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Cut aubergines into strips and salt them. Leave for 10 minutes and then pat dry (this removes excess moisture)."
    },
    {
      "heading": null,
      "description": "Place the aubergine strips into a bowl. Add turmeric, chilli powder, coriander and cumin. Season with salt and pepper and mix everything together."
    },
    {
      "heading": null,
      "description": "Heat a griddle pan. Once very hot, add your aubergines in batches. Cook on a high heat for 4 minutes on each side until charred. Place the char-grilled aubergine in the oven for 12 minutes so they can cook through."
    },
    {
      "heading": null,
      "description": "Time to get on with the curry sauce. Slice up your onions. Add to a large pan with a good drizzle of olive oil. Cook on a medium heat until the onions are lovely and caramelised."
    },
    {
      "heading": null,
      "description": "Add a finely chopped garlic clove and a chopped knob of ginger. Mix them in. Add half a tsp of turmeric, and a tsp each of chilli powder, ground coriander and cumin. Mix everything together."
    },
    {
      "heading": null,
      "description": "Add a heaped tbsp of tomato purée. Give it all a good stir and pour in the passata."
    },
    {
      "heading": null,
      "description": "Add your coconut cream into the curry. Stir it through and bring the sauce to the boil. Once it is bubbling, turn it down, and let it simmer and thicken for 2 minutes."
    },
    {
      "heading": null,
      "description": "Add your aubergine and stir. Add 300ml of water and bring to a simmer. Bring it to a medium heat and cover for 15 minutes."
    },
    {
      "heading": null,
      "description": "Get your rice on (follow pack instructions)."
    },
    {
      "heading": null,
      "description": "Serve the aubergine tikka masala over a bed of steaming rice. Garnish with some chopped coriander. Enjoy!"
    }
  ],
