  "method": [
    {
      "heading": null,
      "description": "Preheat oven 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Place the chicken breasts and sweetcorn on a baking tray. Add salt, pepper, olive oil, smoked paprika and cumin."
    },
    {
      "heading": null,
      "description": "Rub the spices in, making sure everything is coated. Put the chicken and corn into the oven for 30 mins."
    },
    {
      "heading": null,
      "description": "De-seed your mixed peppers and chop into cubes."
    },
    {
      "heading": null,
      "description": "Peel the skin off the cucumber, chop in half and scoop out the seeds using a teaspoon. Chop into chunks."
    },
    {
      "heading": null,
      "description": "Chop the onion in half and cube."
    },
    {
      "heading": null,
      "description": "Chop the 2 avocados in half, remove the stones and scoop out the flesh."
    },
    {
      "heading": null,
      "description": "Remove the chicken and corn from the oven. Using a knife, check the chicken is cooked through. With another knife, scrape the sweetcorn kernels off the cobs. Slice up the chicken into chunky strips."
    },
    {
      "heading": null,
      "description": "Add all the ingredients to a serving bowl including the beans."
    },
    {
      "heading": null,
      "description": "Dress with lime juice and olive oil. Toss together. Serve and garnish with coriander leaves. Enjoy!"
    }
  ],
