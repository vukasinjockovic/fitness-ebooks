  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C/392°F."
    },
    {
      "heading": null,
      "description": "Cut the butternut squash into wedges, leaving the skin on. Slice the red onions and finely chop the garlic cloves."
    },
    {
      "heading": null,
      "description": "Put the squash on a roasting tray and drizzle with oil. Rub with 1 tbsp of harissa and 1 tsp of ground cumin. Season with salt and pepper. Roast for 40 minutes until soft."
    },
    {
      "heading": null,
      "description": "Meanwhile, put a pan on a medium heat. Add a splash of oil with the onions. Fry until soft, adding a splash of water (if needed) to stop them from catching."
    },
    {
      "heading": null,
      "description": "Add half the garlic, 1 tbsp of harissa and 1 tsp of ground cumin. Fry for 1 minute."
    },
    {
      "heading": null,
      "description": "Pour in the chopped tomatoes. Fill up one of the tins with water and pour that in too."
    },
    {
      "heading": null,
      "description": "Drain the chickpeas and kidney beans, tip them into the tomato sauce and bring to the boil. Season with salt and pepper. Leave to bubble away. You want to reduce the sauce to a nice, thick consistency."
    },
    {
      "heading": null,
      "description": "Cut the pitta bread into strips using scissors. Toss with the remaining chopped garlic and a good drizzle of oil and some salt. Spread out onto a baking tray. Roast in the oven underneath the squash until crisp. This should take around 10 minutes."
    },
    {
      "heading": null,
      "description": "Stir the cooked squash into the chilli. Top with a spoonful of yoghurt swirled with harissa and chopped coriander. Place the garlic pitta crisps on the side. Enjoy!"
    }
  ],
