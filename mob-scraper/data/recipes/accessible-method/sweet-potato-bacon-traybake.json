  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Start by peeling and chopping your sweet potatoes and butternut squash into cubes. Spread the cubes over 2 baking trays. Chop up your red onion and bacon into quarters and add to the tray followed by your rosemary sprigs (be sure to take them off the stalks). Drizzle a generous glug of olive oil over the trays along with a pinch of salt and a grinding of pepper. Mix everything together with your hands. Place into the oven for 25 minutes."
    },
    {
      "heading": null,
      "description": "Once 25 minutes is up, take the trays out of the oven. Transfer everything into one tray and mix together. Place back into the oven for a further 20 minutes."
    },
    {
      "heading": null,
      "description": "Taleggio time. Slice it up and place the slices on top of your tray once the 20 minutes is up. Bake for a final 15 minutes."
    },
    {
      "heading": null,
      "description": "Chop up your parsley and sprinkle over the top of the traybake. Serve it up and tuck into this warming dish. Enjoy!"
    }
  ],
