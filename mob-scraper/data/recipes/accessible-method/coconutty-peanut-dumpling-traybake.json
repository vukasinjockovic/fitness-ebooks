  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Finely chop the coriander stalks and pick the leaves. Juice one of the limes and cut the other into wedges for serving."
    },
    {
      "heading": null,
      "description": "In a large roasting tin, whisk together the peanut butter, coconut milk, coriander stalks and soy sauce until smooth. Season with salt and pepper. Then drain the chickpeas and add to the tray along with your mixed veg and frozen dumplings or gyoza. Give everything a good mix."
    },
    {
      "heading": null,
      "description": "Cover the tray tightly with foil and bake for 30–35 mins, until the sauce is bubbling and thickened. Cook for another 5–10 mins if the veg needs longer."
    },
    {
      "heading": null,
      "description": "Peel back the foil carefully and add the lime juice. Scatter with coriander leaves, sesame seeds and chilli flakes, if using. Serve with additional lime wedges on the side.."
    }
  ],
