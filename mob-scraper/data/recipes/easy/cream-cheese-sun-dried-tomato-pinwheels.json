  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids Servings\nTip the cream cheese into a bowl. Squeeze in the juice of the lemon, sprinkle in the garlic granules, and season lightly with salt and black pepper. Mix everything together until smooth."
    },
    {
      "heading": null,
      "description": "Drain the sundried tomatoes and finely chop them. Thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "Lay one tortilla on a chopping board and spread over half of the cream cheese mixture. Scatter over half the sundried tomatoes, spring onions and baby spinach in an even layer."
    },
    {
      "heading": null,
      "description": "Roll up the tortilla tightly, like a Swiss roll. Repeat with the second tortilla and remaining filling. Slice each roll into bite-sized pinwheels, about 2–3cm thick."
    },
    {
      "heading": null,
      "description": "Eat straight away or keep in the fridge for up to 3 days in an airtight container."
    }
  ],
  "tips": [
    "Roll them tighter for tidier swirls, looser for a softer wrap vibe.",
    "Works well on seeded or wholegrain wraps too if you want to increase the fibre."
