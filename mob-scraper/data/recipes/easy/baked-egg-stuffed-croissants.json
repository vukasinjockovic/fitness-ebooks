  "method": [
    {
      "heading": null,
      "description": "Cook your croissants according to packet instructions."
    },
    {
      "heading": null,
      "description": "Slice your onion and grate your garlic. Finely chop your parsley."
    },
    {
      "heading": null,
      "description": "Heat a little oil in a large frying pan set over a medium heat. Tip your red onion into the pan and fry for 10 mins until it has gone totally soft and is starting to caramelise."
    },
    {
      "heading": null,
      "description": "Add your grated garlic, cumin and cinnamon, then cook out for 2 mins. Throw in your tbsp of harissa paste and then tip your cans of tomatoes into the pan. Break them up with the back of your spoon. Simmer for 10 mins until they're getting nice and thick and jammy."
    },
    {
      "heading": null,
      "description": "Hollow out your croissants, reserving the middle. Cut the middle parts into rough cubes."
    },
    {
      "heading": null,
      "description": "Heat your oven to 190°C."
    },
    {
      "heading": null,
      "description": "Drizzle the cubes with oil, dried oregano and salt. Bake in the oven for 10 mins."
    },
    {
      "heading": null,
      "description": "Fill your hollowed out croissants with the tomato mix. Make a well in the middle and crack in an egg. Bake for 10-15 mins and keep an eye on them - they're ready when your whites are just set and your yolks still gooey."
    },
    {
      "heading": null,
      "description": "Sprinkle your croissants with your chopped parsley and a crumbling of feta. Serve up with your croissant croutons."
    }
  ],
