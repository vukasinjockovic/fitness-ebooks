  "method": [
    {
      "heading": null,
      "description": "Finely grate the garlic. Trim and finely dice the onion."
    },
    {
      "heading": null,
      "description": "Add a drizzle of oil to a saucepan set over a medium heat. Once hot, add the mustard seeds, chana dal and urid dal, if using. Cook until toasted and the mustard seeds start to pop."
    },
    {
      "heading": null,
      "description": "Add the garlic, onion, 1 dried red chilli and all the curry leaves. Cook, stirring, until fragrant. Pour in the canned tomatoes and stir the Kashmiri chilli powder through. Cook for 3-5 mins until thickened. Let the mixture cool completely, then transfer to a blender and blitz well (add a little water if required, plus salt to taste). Transfer to a serving bowl."
    },
    {
      "heading": null,
      "description": "For the tempering, add the oil to a small saucepan and place over a medium heat. Once hot, add the mustard seeds. Once they start shimmering, add the urid dal, dried red chilli and curry leaves – be careful: the curry leaves will make the oil splatter. Pour the tempering over the tomato chutney before serving."
    }
  ],
