  "method": [
    {
      "heading": null,
      "description": "Finely slice the leeks and set them aside."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil and a knob of butter in a pan until fully melted. Then add your fennel seeds, chilli flakes and mix together."
    },
    {
      "heading": null,
      "description": "Add your chopped leeks to the pan and toss them together with the butter until soft and wilted down."
    },
    {
      "heading": null,
      "description": "Once soft, add your orzo and mix together."
    },
    {
      "heading": null,
      "description": "Add your chicken stock to the pan along with the Parmesan rind. Simmer for 10 minutes stirring every minute."
    },
    {
      "heading": null,
      "description": "Once the stock has been absorbed, grate in your parmesan and mix together with a good season of salt and pepper. Plate up and tuck in!"
    }
