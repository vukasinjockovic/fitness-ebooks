  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C fan. Soak the dates in boiling water for 30 mins, then drain."
    },
    {
      "heading": null,
      "description": "Blitz ½ the soaked dates with the oat milk in a blender until smooth."
    },
    {
      "heading": null,
      "description": "Mash the banana in a large bowl. Add the oats, protein powder, baking powder, bicarbonate of soda, vanilla, cinnamon, cardamom, and a pinch of salt. Pour in the blended date milk and stir well. Transfer to a baking dish and bake for 40-45 mins. If the top browns too quickly, cover with foil and continue baking."
    },
    {
      "heading": null,
      "description": "For the toffee sauce, blend the remaining soaked dates with the oat milk, vanilla, maple syrup, sea salt and coconut oil (if using) until smooth. Add a splash of water to loosen if needed."
    },
    {
      "heading": null,
      "description": "Add the toffee sauce to a saucepan and heat until bubbling. Then take off the heat."
    },
    {
      "heading": null,
      "description": "Let the baked oats cool slightly before slicing. Drizzle with the toffee sauce and serve."
    },
    {
      "heading": null,
      "description": "Portion the baked oats into containers for an easy grab-and-go breakfast. Store in the fridge for up to 3 days then eat cold or reheat before eating."
    }
  ],
