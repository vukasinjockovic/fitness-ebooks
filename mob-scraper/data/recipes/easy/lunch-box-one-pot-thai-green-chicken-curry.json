  "method": [
    {
      "heading": null,
      "description": "Slice the chicken thighs into bite-sized pieces. Trim the baby corn and mange tout. Finely slice the red chilli. Pick some coriander leaves for garnish and cut the lime into wedges."
    },
    {
      "heading": null,
      "description": "Set a large saucepan over a medium heat. Pour in half the coconut milk and cook for 5 mins until the fat starts to split and it smells toasty."
    },
    {
      "heading": null,
      "description": "Add the Thai Green Curry Paste and stir for another 5 mins until darker and super fragrant. Tip in the chicken and cook for 3–4 mins until just sealed."
    },
    {
      "heading": null,
      "description": "Sprinkle in the sugar and let it bubble and caramelise for 2 mins. Pour in half the fish sauce and scrape up any sticky bits."
    },
    {
      "heading": null,
      "description": "Add the rest of the coconut milk and the chicken stock. Bring to a gentle simmer and cook for 15 mins until slightly thickened and the chicken’s cooked through."
    },
    {
      "heading": null,
      "description": "Chuck in the baby corn and mange tout for the final 2 mins. Stir through most of the coriander and the remaining fish sauce. Taste and season."
    },
    {
      "heading": null,
      "description": "Serve over cooked rice and top with fresh chilli, crispy shallots, coriander leaves and a wedge of lime."
    }
  ],
