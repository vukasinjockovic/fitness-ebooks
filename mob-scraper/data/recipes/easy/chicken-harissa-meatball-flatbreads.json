  "method": [
    {
      "heading": null,
      "description": "Finely slice the cucumber and toss it with a good pinch of salt in a colander. Leave to sit for 10 mins to draw out some of the water, then give it a squeeze to remove any excess moisture."
    },
    {
      "heading": null,
      "description": "Chuck the chicken mince into a bowl with half the harissa. Season well with salt and pepper. Shape the mixture into 10 meatballs about the size of walnuts."
    },
    {
      "heading": null,
      "description": "Heat a large nonstick frying pan over a medium heat and give it a spritz of olive oil. Add the meatballs and fry for 8–10 mins, turning regularly, until golden brown and cooked through."
    },
    {
      "heading": null,
      "description": "Transfer the cucumber to a bowl. Zest over the lemon and squeeze in the juice. Pick in the dill leaves, season with black pepper and toss to combine."
    },
    {
      "heading": null,
      "description": "Finely slice the remaining red pepper, discarding any seeds, and toss it through the cucumber salad."
    },
    {
      "heading": null,
      "description": "Dollop the yoghurt onto serving plates and ripple through the remaining harissa. Pile the meatballs on top, then spoon over the cucumber salad."
    },
    {
      "heading": null,
      "description": "Toast the flatbread, cut into triangles and serve on the side for scooping."
    }
  ],
