  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids ServingsThinly slice the onion and red pepper. Finely chop the garlic and ginger."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil in a saucepan set over a medium heat. Add the sliced onion and pepper and cook for 15 mins until soft and sweet."
    },
    {
      "heading": null,
      "description": "Stir in the garlic, ginger and tomato purée. Cook for 2 mins until fragrant and darkened slightly."
    },
    {
      "heading": null,
      "description": "Add the garam masala, water and double cream. Let everything bubble away for 15 mins."
    },
    {
      "heading": null,
      "description": "Use a hand blender to blitz the mixture until completely smooth. Dot in the butter and stir until melted and silky. Drain the chickpeas and stir them into the sauce. Taste and season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the chicken tenders following pack instructions."
    },
    {
      "heading": null,
      "description": "Serve up! Spoon the curry into bowls, top with the crispy tenders, and finish with sliced red chilli, fresh coriander and a wedge of lime for the adults. Serve with rice, if you like."
    }
  ],
