  "method": [
    {
      "heading": null,
      "description": "Boil the broccoli in a pot of salted boiling water for 3-4 mins until it’s just about cooked. Remove the broccoli and allow it to cool."
    },
    {
      "heading": null,
      "description": "Preheat your oven to 180°C. Season your chicken breasts generously with salt and pepper. Place your chicken breasts onto a baking tray and get them in the oven for 25 mins. Allow them to cool once cooked – the salad doesn’t need to be warm."
    },
    {
      "heading": null,
      "description": "Heat up your quinoa according to package instructions."
    },
    {
      "heading": null,
      "description": "Squeeze the juice from your limes and combine with the rest of the dressing ingredients in a bowl."
    },
    {
      "heading": null,
      "description": "Chop up the coriander, the cooked broccoli, and chicken into even-sized pieces. Toss with the quinoa in a large bowl."
    },
    {
      "heading": null,
      "description": "Divide the salad between your Tupperware containers and stick them in the fridge.Keep the dressing separate – either pour it over in the morning or stash it in a little pot inside your box to add just before eating.These will keep for up to 3 days in the fridge."
    }
