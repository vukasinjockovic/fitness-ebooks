  "method": [
    {
      "heading": null,
      "description": "Slice the garlic and chop the chives as finely as possible."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium heat for around 1 min. Add the olive oil and sliced garlic, then sauté for 1 min until soft but not coloured. Add the gochujang, bashing and stirring the paste to infuse into the oil until it gives off a reddish hue. Add the double cream, then stir well to make a smooth paste free from lumps."
    },
    {
      "heading": null,
      "description": "Add the prawns and mascarpone, then cook for 2 mins or until the prawns turn pink. Turn the heat off."
    },
    {
      "heading": null,
      "description": "Heat the water in a saucepan over a high heat until boiling. Once boiling, cook the noodles for 1 min shy of the cooking time stated on the pack. Drain the noodles, reserving 1/5 of the cooking water."
    },
    {
      "heading": null,
      "description": "Turn the heat under the prawns back to medium. Add the cooked noodles, chives and the reserved noodle water. Mix for 1 min to coat the noodles with the sauce. Add more cooking water if it’s too dry – the sauce should be smooth and slightly runny."
    },
    {
      "heading": null,
      "description": "Plate up, shaking the plate slightly to spread the noodles. Grate a generous amount of Parmesan on top. Enjoy!"
    }
  ],
