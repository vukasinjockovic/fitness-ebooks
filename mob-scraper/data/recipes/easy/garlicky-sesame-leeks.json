  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Char the leeks directly on the flame of your gas hob until they are evenly blistered. If you don’t have a gas hob, char them under a very hot grill."
    },
    {
      "heading": null,
      "description": "Cut the ends off the leeks and cut them in half. Nestle them into a baking dish so they are tightly packed."
    },
    {
      "heading": null,
      "description": "Finely chop the red chillies, or blitz them up in a food processor."
    },
    {
      "heading": null,
      "description": "Add the chillies and 50ml vegetable oil to a pan on medium-low heat and cook for 10 mins until the oil is stained red."
    },
    {
      "heading": null,
      "description": "Crush the garlic and roughly chop the garlic and ginger."
    },
    {
      "heading": null,
      "description": "Add in the garlic, ginger and sesame seeds, stir for 1 min and then turn off the heat. Add in the soy sauce, sesame oil, sugar, juice of the orange and 100ml of water."
    },
    {
      "heading": null,
      "description": "Pour this over the leeks and cover with foil. If your leeks are still a bit tough, add more water. Braise in the oven for 30 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, roughly chop the peanuts."
    },
    {
      "heading": null,
      "description": "Sprinkle peanuts over the leeks and grate over orange zest."
    },
    {
      "heading": null,
      "description": "Serve over sticky rice and enjoy."
    }
  ],
