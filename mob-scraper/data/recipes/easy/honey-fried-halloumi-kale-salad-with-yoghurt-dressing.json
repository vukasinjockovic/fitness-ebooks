  "method": [
    {
      "heading": null,
      "description": "Heat the grill to high. Slice the halloumi into 1cm-thick slices. Set a large frying pan over a medium heat, add a splash of olive oil and fry the halloumi until golden on both sides (about 1-2 mins each side)."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the dill and slice the avocado. Set aside."
    },
    {
      "heading": null,
      "description": "While still over the heat, drizzle the halloumi with the honey and sprinkle over the dill and chilli flakes. Fry for a few more minutes."
    },
    {
      "heading": null,
      "description": "Slice the courgette into rounds and lay onto a baking sheet, drizzle with olive oil and slide under the grill for 5 mins, until a little charred. Set aside to cool slightly."
    },
    {
      "heading": null,
      "description": "Coarsely chop the kale and place in a large bowl with the cooked courgette, bulgur and lentils."
    },
    {
      "heading": null,
      "description": "For the dressing, finely grate the garlic clove and juice the lemon. Transfer both to a bowl along with the remaining dressing ingredients. Mix well."
    },
    {
      "heading": null,
      "description": "Stir the dressing through the kale salad and season with salt. Divide the salad between deep plates and top with the fried halloumi and avocado."
    }
  ],
