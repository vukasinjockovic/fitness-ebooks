  "method": [
    {
      "heading": null,
      "description": "Soak your rice noodles in boiling water for 10 mins or according to the packet instructions"
    },
    {
      "heading": null,
      "description": "Mince the garlic, red chillies and onion, then chop the spring onions into 4cm pieces. Pick off the basil leaves and set them aside. Cut the chicken breast into very thin slices."
    },
    {
      "heading": null,
      "description": "In a bowl, combine the fish sauce, oyster sauce, soy sauce and sugar."
    },
    {
      "heading": null,
      "description": "Heat up a large wok until it’s smoking, then add in a big glug of oil. Fry off the garlic, onion and chilli for 1 min until fragrant. Add in the chicken and cook for 3 mins until cooked through."
    },
    {
      "heading": null,
      "description": "Add in your sauce and then immediately add in your soaked noodles. Mix well so that the noodles are evenly coated and then toss through your spring onions and basil leaves."
    },
    {
      "heading": null,
      "description": "Serve immediately."
    }
