  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Start by cracking your eggs into a bowl. Next, grate 100g parmesan and add a good grinding of pepper. Whisk together."
    },
    {
      "heading": null,
      "description": "Slice up your courgettes into discs and roughly chop up your onion. Add a drizzle of oil into a frying pan. Add your courgettes and onion and cook on a medium heat. Stir until they begin to char. Add a pinch of salt, your chilli flakes and a grinding of pepper."
    },
    {
      "heading": null,
      "description": "Take your courgettes off the heat and add them to your eggs and mix together. Chop up your basil (leave some for garnishing) and add to the egg mix. Next, grate in the zest of your lemon. Take your bowl and pour the mixture into a deep frying pan."
    },
    {
      "heading": null,
      "description": "Break up your ricotta and place the pieces over the top. Allow the frittata to fry for a few minutes, so you can see the egg on the side cooking through, and then place into the oven for 10 minutes."
    },
    {
      "heading": null,
      "description": "Flip time. Take your pan out of the oven and flip it using a chopping board, remove the board and it should easily come off the pan. Garnish with a sprinkling of the remaining parmesan and basil and tuck into this delicious frittata."
    }
  ],
