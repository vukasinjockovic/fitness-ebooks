  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Roughly chop all your vegetables and chuck them in a baking tray."
    },
    {
      "heading": null,
      "description": "Add the sausages, rosemary, bay leaves, tinned tomatoes and whole garlic clove to the tray. Mix everything together and get it in the oven for 45 mins."
    },
    {
      "heading": null,
      "description": "While the sausages are cooking, finely chop the almonds and parsley. Add to a bowl, grate in the zest of lemon then squeeze in the juice. Grate in the garlic, add olive oil then whisk to emulsify. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Sprinkle over a bit more fresh rosemary to serve."
    }
