  "method": [
    {
      "heading": null,
      "description": "Heat the oven to fan 150°C. Grease two round 16cm cake tins and line with baking paper. Make sure your butter is at room temperature."
    },
    {
      "heading": null,
      "description": "Get the flour, baking powder and salt in a mixing bowl and whisk until combined."
    },
    {
      "heading": null,
      "description": "In another bowl, use an electric whisk to beat the butter and sugar together for 2-5 mins until light and fluffy. Crack the eggs in, one at a time, and beat until combined each time before adding another."
    },
    {
      "heading": null,
      "description": "Sift the flour mixture into the butter and beat until just combined. Pour in the coconut milk and desiccated coconut and use a spoon or spatula to fold everything together until you have a fully incorporated batter."
    },
    {
      "heading": null,
      "description": "Divide the batter between the prepared cake tins. Bake in the oven for 30-40 mins until golden brown and a toothpick inserted comes out clean. Leave to cool in the tins for 10 mins then transfer to a wire rack to cool completely."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the buttercream. Beat the butter alone for 4–5 mins on high speed. Sift in the icing sugar and add the vanilla and cream then beat on a low speed to bring it together. Beat on high for another 2–3 mins."
    },
    {
      "heading": null,
      "description": "To serve, spread the buttercream over both cooled sponges and pop one on top of the other, sandwiching them together. Sprinkle over the toasted coconut flakes."
    }
  ],
