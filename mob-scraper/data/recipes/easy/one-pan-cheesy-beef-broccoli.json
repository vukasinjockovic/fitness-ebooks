  "method": [
    {
      "heading": null,
      "description": "Cook the mixed rice and grains following pack instructions and set aside. Wash the broccoli stalk and cut into bite-sized pieces. Thinly slice the beef. Grate the cheese."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of olive oil in a large pan over a medium heat. Add the cooked rice to the middle of the pan and put the chopped broccoli stalks around the rice in a circle. Pan fry for 3 mins, without stirring."
    },
    {
      "heading": null,
      "description": "Add the beef to the pan around the rice, with the broccoli. Let that sear for 3 mins on medium heat. Add the soy sauce, chilli oil and sesame oil to the rice in the centre of the pan."
    },
    {
      "heading": null,
      "description": "When the beef is 80% cooked, mix everything in the pan together. Top with the coriander and cheddar cheese. Continue to cook for 2 mins until the cheese is melted and the beef is cooked to the desired tenderness."
    },
    {
      "heading": null,
      "description": "Meanwhile, fry the eggs (if using) sunny side up on a medium heat for 2-3 mins depending on how runny you like them."
    },
    {
      "heading": null,
      "description": "Divide the rice between bowls and top with the eggs and any leftover coriander leaves."
    }
  ],
