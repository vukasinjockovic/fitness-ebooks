  "method": [
    {
      "heading": null,
      "description": "Quick-pickle the chilli. Finely slice the Scotch bonnet and add to a small bowl with the vinegar, sugar and a good pinch of salt. Mix well and set aside to pickle while you cook."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 200°C fan."
    },
    {
      "heading": null,
      "description": "Make the curry sauce. Chuck all the curry sauce ingredients into a blender and blitz until smooth. Pour into a saucepan and bring to the boil. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Dice the halloumi and peppers into bite-sized chunks. Tip into a large roasting tray with a drizzle of olive oil and season well. Roast for 10 mins."
    },
    {
      "heading": null,
      "description": "Take the tray out, add the gnocchi, then pour over the hot curry sauce. Give everything a good mix, then return to the oven for 20–25 mins, until bubbling and golden at the edges."
    },
    {
      "heading": null,
      "description": "Serve it up. Top with dollops of yoghurt, fresh coriander and a scattering of pickled chillies."
    }
  ],
  "tips": [
    "Halloumi → Paneer, firm tofu, or a plant-based halloumi alternative",
    "Gnocchi → Use gluten-free gnocchi if needed",
    "Coconut milk → Swap for oat cream or reduced-fat coconut milk for a lighter version",
    "Scotch bonnet → Use red chillies for less heat, or leave out entirely",
    "Make ahead: Prepare the curry sauce and pickle the chillies up to 3 days in advance.",
    "Lunches: Store in airtight containers and reheat in the microwave or oven until piping hot. Add yoghurt and chillies fresh."
  ],
