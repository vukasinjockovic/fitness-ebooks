  "method": [
    {
      "heading": null,
      "description": "Bring the water to a boil and add the shiitake. Simmer for 5 mins and turn off the heat."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook your noodles according to instructions. Drain, drizzle with a little sesame oil to prevent sticking, set aside."
    },
    {
      "heading": null,
      "description": "Whisk together 2 tbsp soy sauce, miso, tahini, milk and sesame oil in a small bowl. This is your flavour base for the broth which will be added later."
    },
    {
      "heading": null,
      "description": "Grate the garlic and ginger and crumble the tofu into small pieces. Mix together in a small bowl with 2 tbsp of soy sauce and 1-2 tsp of crispy chili oil."
    },
    {
      "heading": null,
      "description": "Heat 2 tbsp of vegetable oil in a frying pan. Fry the tofu on medium- high heat until it starts to crisp up, then add a tablespoon of soy sauce. Fry for a minute longer, then remove from the pan and wipe the pan clean to use again for the mushrooms."
    },
    {
      "heading": null,
      "description": "Drain the mushrooms, keeping the broth to one side. Slice the mushrooms and fry with a drizzle of vegetable oil and 2 tbsp of soy sauce until cooked through. Add the sesame seeds and fry for another minute."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onion and chilli."
    },
    {
      "heading": null,
      "description": "Add the mushroom broth back into the saucepan, bring to the boil. Then, remove from the heat and whisk in the miso and milk mixture."
    },
    {
      "heading": null,
      "description": "To plate, add noodles to a bowl, then add the broth and top with the mushrooms, crumbled tofu, spring onion, sesame seeds and chilli. Finish with a drizzle of sesame oil and chilli oil."
    }
  ],
