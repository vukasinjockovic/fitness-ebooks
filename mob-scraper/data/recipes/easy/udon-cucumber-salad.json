  "method": [
    {
      "heading": null,
      "description": "Place the edamame in a heatproof bowl."
    },
    {
      "heading": null,
      "description": "Boil a pot of water and simmer the noodles for 3 mins. Drain and pour some of the hot water over the edamame to defrost. Then rinse the noodles under cold water and set aside."
    },
    {
      "heading": null,
      "description": "Peel and mince the ginger and garlic and place in a small bowl. Add the soy sauce, sesame oil, rice vinegar, brown sugar and whisk to combine. Set aside."
    },
    {
      "heading": null,
      "description": "Slice the cucumber into half lengthwise and scoop out the watery seeds with a spoon (you can drain the water out of this and drink it!). Slice the cucumber into diagonal slices around .5cm and place in a large bowl."
    },
    {
      "heading": null,
      "description": "Roughly chop the coriander leaves and finely chop the stems. Pick the mint leaves. Cut the chilli in half lengthways, remove the seeds and thinly slice. Roughly chop the peanuts. Finely chop the spring onion."
    },
    {
      "heading": null,
      "description": "Add all of the herbs into the bowl with the cucumbers along with the edamame, spring onion, chilli, soy dressing, noodles and toss well."
    },
    {
      "heading": null,
      "description": "If using tahini, add a drizzle on top and toss again. Drizzle over the crispy chilli oil and a little more sesame oil and the zest and juice of the lime. Toss well before serving."
    }
  ],
