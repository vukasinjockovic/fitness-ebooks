  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 140°C."
    },
    {
      "heading": null,
      "description": "Cut the beef shin into 5cm pieces, or get the butcher to do this for you. Scrape into a bowl."
    },
    {
      "heading": null,
      "description": "Halve the onion and cut into chunky dice, then peel the carrots and cut them into similar-sized pieces. Do the same with the celery."
    },
    {
      "heading": null,
      "description": "Scatter the beef pieces with the flour and plenty of salt and pepper, then toss to coat really well."
    },
    {
      "heading": null,
      "description": "Heat a generous glug of olive oil in a large lidded casserole pan set over a medium-high heat. Lay in some of the beef pieces, leaving a little gap around each so they can fry properly."
    },
    {
      "heading": null,
      "description": "Cook for 2 mins on each side until golden and crisp, then remove into a clean bowl. Repeat with the remaining beef pieces, adding a little more oil as you go, if needed."
    },
    {
      "heading": null,
      "description": "Add in another drizzle of oil and add the onion, carrot, celery, and bay leaves along with a good pinch of salt."
    },
    {
      "heading": null,
      "description": "Put on the lid and cook for 6-8 mins, stirring regularly until the onions have softened slightly."
    },
    {
      "heading": null,
      "description": "Squeeze in the tomato purée, spoon in the Marmite, and cook for a minute before pouring in the beef stock and adding the beef back to the pan along with any resting juices from the bowl."
    },
    {
      "heading": null,
      "description": "Bring to the boil, then put on the lid and pop it into the oven for 2 hrs. After 2 hrs, remove the lid and cook for another 30 mins, until the beef is meltingly tender and the gravy has thickened slightly."
    },
    {
      "heading": null,
      "description": "For the dumplings, tip the flour, baking powder and suet into a bowl with a pinch of salt and pour in the water. Mix briefly to form a dough."
    },
    {
      "heading": null,
      "description": "Tip the dough out onto a well-floured work surface, divide it into 8 pieces and shape into rough scone shapes."
    },
    {
      "heading": null,
      "description": "Coarsely grate the cheddar."
    },
    {
      "heading": null,
      "description": "Once the beef has been cooking for 2 hrs 30 mins as described above, nestle the dumplings into the top of the stew."
    },
    {
      "heading": null,
      "description": "Add a pinch of cheddar on top of each, then pop back into the oven for 30-40 mins, until the cheese and dumplings are lightly golden."
    },
    {
      "heading": null,
      "description": "Scatter with the parsley to serve."
    }
  ],
