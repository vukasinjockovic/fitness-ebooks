  "method": [
    {
      "heading": null,
      "description": "Soak your chickpeas overnight in a bowl of water."
    },
    {
      "heading": null,
      "description": "Thinly slice one of your red onions."
    },
    {
      "heading": null,
      "description": "Place your sliced red onions in a bowl and squeeze over the juice from your lemon. Add a pinch of salt and mix with your hands. Leave it to pickle."
    },
    {
      "heading": null,
      "description": "Time to make some slaw. Finely shred your white cabbage and peel and julienne your carrot. Place in a bowl with 100ml of your Nando’s Vegan PERinaise and give it a good mix. Set aside until later."
    },
    {
      "heading": null,
      "description": "Roughly chop your remaining red onion, red pepper, garlic, and parsley."
    },
    {
      "heading": null,
      "description": "Drain and dry your soaked chickpeas, then put them in the food processor with your red onion, red pepper, garlic, parsley, paprika, ground cumin, ground coriander, cayenne pepper, gram flour, baking powder, Nando’s PERi-PERi Salt and a pinch of regular salt in a food processor. Pulse until you have a smooth mixture that binds together when squeezed."
    },
    {
      "heading": null,
      "description": "Shape your mixture into small patties."
    },
    {
      "heading": null,
      "description": "Heat a generous glug of oil over a medium heat. Add a few of your falafel patties and fry for 3 minutes on each side until they are deeply golden and crisp. Drain on a plate lined with a paper towel and repeat with your remaining patties."
    },
    {
      "heading": null,
      "description": "Toast your pittas and slice your cucumber into thin discs."
    },
    {
      "heading": null,
      "description": "Make an incision in the long side of your pitta to create a pocket. Stuff it with your falafels, slaw, pickled onions and cucumber. Drizzle with some more Nando’s Vegan PERinaise, then enjoy."
    }
  ],
