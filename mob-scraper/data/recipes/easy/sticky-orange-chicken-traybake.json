  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Finely chop two of the red chillies and roughly chop the onions."
    },
    {
      "heading": null,
      "description": "In a large bowl combine the peanut butter, juice and zest two oranges, fish sauce, apple cider vinegar, soy sauce, brown sugar, ground cumin and red chillies. Grate in the ginger and garlic. Add in the chicken and onions and mix well."
    },
    {
      "heading": null,
      "description": "Slice the remaining orange."
    },
    {
      "heading": null,
      "description": "Pour the chicken with the sauce onto a baking tray and push in the slices of orange."
    },
    {
      "heading": null,
      "description": "Bake for 35 mins until the chicken has cooked through, basting with the sauce halfway through."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely slice the last red chilli as well as your coriander and peanuts."
    },
    {
      "heading": null,
      "description": "Finish the chicken with the red chilli, coriander and peanuts. Serve with freshly steamed rice and enjoy."
    }
