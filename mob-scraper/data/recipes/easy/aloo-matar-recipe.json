  "method": [
    {
      "heading": null,
      "description": "Peel and chop the potatoes into 3cm chunks. Transfer to a bowl and wash well to get rid of the excess starch."
    },
    {
      "heading": null,
      "description": "Trim and finely chop the onion. Finely grate or mince the ginger and garlic. Thinly slice half the coriander."
    },
    {
      "heading": null,
      "description": "Add a drizzle of oil to a wok or saucepan and place over a medium heat. Once the oil is hot, add the bay leaves and cumin seeds. Fry until they splutter. Add the onions with a pinch of salt and cook for 3-4 mins until softened. Add the ginger and garlic, fry until fragrant, then stir through the powdered spices and crushed chillies."
    },
    {
      "heading": null,
      "description": "Pour the canned tomatoes in and cook for 8-10 mins until thickened. Add the potatoes and the water and bring to a boil then turn the heat down to medium and cook, uncovered, for 25-30 mins until the potatoes have softened. Once the potatoes are cooked through, add a splash of water to loosen, if needed."
    },
    {
      "heading": null,
      "description": "Add the peas and cook until hot. Stir through the chopped coriander and season with salt and lime juice."
    },
    {
      "heading": null,
      "description": "Serve immediately, garnished with the remaining fresh coriander."
    }
  ],
