  "method": [
    {
      "heading": null,
      "description": "Remove the pork membrane from the ribs."
    },
    {
      "heading": null,
      "description": "Combine the rub ingredients in a bowl, then rub it over both sides of the ribs (most should be on the meaty side). Set aside to marinate for 20 mins."
    },
    {
      "heading": null,
      "description": "When ready to cook, heat the oven to 160°C. Place the ribs in a deep baking tray in a single layer. Pour water underneath the ribs, cover with foil and transfer to the oven. Bake for 1 hr 30 mins or until the meat is pretty tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, pour all the glaze ingredients into a pot and bring to the boil. Reduce to a simmer and cook for 20 mins to reduce the glaze."
    },
    {
      "heading": null,
      "description": "Remove the ribs from the oven and turn the heat up to 180°C. Remove the foil, drizzle with olive oil, then return the ribs to the oven for 15 mins or until the rub has become nice and crusty."
    },
    {
      "heading": null,
      "description": "Meanwhile, line a new baking tray with foil."
    },
    {
      "heading": null,
      "description": "Once cooked, remove the ribs from the oven and transfer to the lined tray. Pour any juices from the tray over the ribs. Flip the ribs so they’re bonier-side up. Slather with the glaze, then bake for 10 mins."
    },
    {
      "heading": null,
      "description": "Remove from the oven, then turn the ribs over so the meaty side is up. Slather with the glaze and bake for 5 mins. Repeat two or three more times until you've got a thick glaze on the ribs."
    },
    {
      "heading": null,
      "description": "Cut the ribs into individual or multiple rib portions and serve with any remaining glaze."
    }
  ],
