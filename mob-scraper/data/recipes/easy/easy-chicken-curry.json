  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids Servings\nCut the chicken thighs into small bite-sized chunks."
    },
    {
      "heading": null,
      "description": "Peel and finely dice the onion. Peel and finely slice the garlic. Peel and grate the ginger."
    },
    {
      "heading": null,
      "description": "Place a large lidded saucepan over a medium heat with a drizzle of olive oil. Add the onion, garlic and ginger and cook for 5–6 mins until soft and fragrant."
    },
    {
      "heading": null,
      "description": "Stir in the curry powder, turmeric and flour. Cook for 1 min, then add the tomato purée and cook for another minute until darkened."
    },
    {
      "heading": null,
      "description": "Add the chicken and cook for 3–4 mins until just turning golden."
    },
    {
      "heading": null,
      "description": "Pour in the stock and bring to the boil. Turn the heat down to low, pop the lid on and let it simmer for 15 mins until the chicken is cooked through and tender."
    },
    {
      "heading": null,
      "description": "Stir through the cream and frozen peas. Cook for 2–3 mins until the sauce is silky and everything's warmed through. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the rice following pack instructions. Slice the green chilli for garnish."
    },
    {
      "heading": null,
      "description": "Serve up!\nKids Plate: Spoon the curry with the fluffy rice.\nParents Plate: Dish out and garnish with the coriander, green chilli and a squeeze of lemon."
    }
  ],
