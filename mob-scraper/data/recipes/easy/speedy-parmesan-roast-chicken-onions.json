  "method": [
    {
      "heading": null,
      "description": "Season the chicken pieces generously with salt. Preheat the oven to 225°C fan."
    },
    {
      "heading": null,
      "description": "Heat the butter and olive oil in a heavy-based oven-safe frying pan set over medium-high heat. Place the chicken skin-side down in the pan for 5-8 mins until the skin is lightly golden and starting to crisp up (it will finish crisping up in the oven)."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the onions."
    },
    {
      "heading": null,
      "description": "Remove the chicken from the pan and add in the onions to fry for a few minutes in the chicken fat until lightly golden."
    },
    {
      "heading": null,
      "description": "Place the chicken back in along with the whole garlic cloves and transfer the pan to the oven for 10 mins."
    },
    {
      "heading": null,
      "description": "Carefully pour in the wine (or water if you prefer) around the chicken and add the Parmesan rind. Reduce the oven to 200°C then return the chicken to the oven for about 15-20 mins or until cooked through (the breasts will cook faster than the legs so you may need to remove them after 15 mins and continue cooking the legs for another 5 mins)."
    },
    {
      "heading": null,
      "description": "Remove the dish from the oven and squeeze over the juice of the lemon. Leave the chicken to rest for at least 5 mins."
    },
    {
      "heading": null,
      "description": "Serve with more grated Parmesan, seasonal greens and crusty bread."
    }
  ],
