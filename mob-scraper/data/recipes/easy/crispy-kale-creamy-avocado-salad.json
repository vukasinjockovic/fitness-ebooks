  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Toss the chickpeas in oil, cayenne pepper and 1⁄2 tsp salt. Pop onto a baking tray and roast for 20 mins."
    },
    {
      "heading": null,
      "description": "Massage the kale with 1 tbsp oil and 1⁄2 tsp salt until it feels moist. Add the kale to the baking tray and continue cooking for another 20 mins until everything is very crispy."
