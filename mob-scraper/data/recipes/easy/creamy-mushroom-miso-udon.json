  "method": [
    {
      "heading": null,
      "description": "Finely mince the garlic cloves, finely dice the shallot, chop the mushrooms into thin slices, and slice the spring onions as finely as possible. Set everything aside."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of water to the boil over a high heat. Once boiling, add the eggs, gently, and set a timer for 6 mins. Get a bowl of ice-cold water ready. Once cooked, remove the eggs and transfer to the bowl of cold water."
    },
    {
      "heading": null,
      "description": "Add the udon to the same saucepan of boiling water, then cook for 3 mins until the noodles have fully separated. Drain and set aside. Peel the eggs and slice in half, then set aside."
    },
    {
      "heading": null,
      "description": "Heat a large frying pan over a medium-high heat for 2 mins. Add 2 tbsp olive oil to the pan, then the mushrooms. Fry for 5 mins, stirring occasionally (they should be golden). Add the garlic, shallots and butter, then fry for 1 min."
    },
    {
      "heading": null,
      "description": "Add the mirin, soy sauce, cream and miso paste. Stir to incorporate. Add the udon and stir for 30 seconds. If the sauce is too dry, add a splash of water."
    },
    {
      "heading": null,
      "description": "Plate up the udon, cover with sesame seeds, top with the sliced spring onion and add the egg. Enjoy!"
    }
  ],
