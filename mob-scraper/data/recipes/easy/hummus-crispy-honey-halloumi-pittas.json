  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids ServingsPeel and finely slice the red onion, then chuck into a bowl with a pinch of salt and the juice of the lemon. Scrunch it together with your hands to soften slightly."
    },
    {
      "heading": null,
      "description": "Halve the cucumber and slice into half-moons. Halve and slice the avocado. Pick the dill fronds, saving a few for garnish."
    },
    {
      "heading": null,
      "description": "Set aside one-third of the cucumber, avocado and pomegranate seeds for the kids’ plates. Toss the rest with the lemony onion, most of the dill and half the olive oil. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Toast the pitta breads, then slice into triangles and set aside."
    },
    {
      "heading": null,
      "description": "Slice the halloumi into 1cm pieces. Heat the remaining olive oil in a frying pan over a medium-high heat. Fry the halloumi for 1–2 mins per side until golden and crispy."
    },
    {
      "heading": null,
      "description": "Serve up!Kids Plate: Spoon a dollop of hummus onto each plate. Add the pitta triangles, a few pieces of crispy halloumi and the reserved cucumber-pomegranate salad.Parents Plate: Spread the hummus onto each plate. Top with the salad mix, golden halloumi and a drizzle of hot honey. Scatter with reserved dill and serve with pitta on the side."
    }
  ],
