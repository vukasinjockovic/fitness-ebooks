  "method": [
    {
      "heading": null,
      "description": "Line a sieve with a piece of kitchen paper or J cloth and set over a bowl. Tip in the yoghurt and chill for 2 hrs."
    },
    {
      "heading": null,
      "description": "When ready to eat, heat the oven to 180°C. Season the cod with salt and pepper. Add to a bowl with the cumin and grate in the garlic. Toss with a little olive oil and add to a lined tray. Slide into the oven for 8-10 mins or until just cooked."
    },
    {
      "heading": null,
      "description": "Tip the chickpeas, liquid and all, into a pan and set over a medium heat. Once warm, drain and toss with the hung yoghurt."
    },
    {
      "heading": null,
      "description": "Finely dice the red onion and cover with lemon juice. Finely dice the cucumber and herbs and get those into the bowl, too. Add a little olive oil and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Spoon the warm labneh chickpeas onto a plate, top with a cod fillet and finish with the cucumber salsa and a wedge of lemon."
    }
