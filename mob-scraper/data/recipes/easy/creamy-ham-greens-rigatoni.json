  "method": [
    {
      "heading": null,
      "description": "Remove the outer layer of the leeks, then slice in half before cutting into half moons. Pop into a colander and wash thoroughly."
    },
    {
      "heading": null,
      "description": "Cut the broccoli into small florets and finely chop the garlic."
    },
    {
      "heading": null,
      "description": "Heat a glug of oil in a pan over a medium heat and add the leeks and broccoli with a big pinch of salt. Sweat them down until softened and then add the garlic, cooking for another 2 mins, until the broccoli is tender and the garlic is fragrant."
    },
    {
      "heading": null,
      "description": "Get the pasta on to boil in a large pot of salted water. Reserve the pasta water and drain."
    },
    {
      "heading": null,
      "description": "Pour in the double cream along with the peas and chopped ham, season with salt and lots of black pepper then bring it to a very gentle simmer. Cook for a couple of minutes until the peas are thawed and the cream has thickened. Transfer the pasta to the sauce directly from the water and mix well, adding another slosh of pasta water if you need to."
    },
    {
      "heading": null,
      "description": "Serve up and grate over the Parmesan and a crack of black pepper."
    }
  ],
