  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion, thinly slice the garlic and halve the fresh cherry tomatoes."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of olive oil in a large frying pan set over a medium heat. Add the onion, garlic and a pinch of salt. Cook for 5-6 mins until soft and translucent."
    },
    {
      "heading": null,
      "description": "Add the halved cherry tomatoes, tinned tomatoes and the water. Let it bubble, then stir in the drained tuna. Bring to a simmer and reduce the heat to low. Let it cook for 15 mins, stirring occasionally, until the sauce is thickened and glossy."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the pasta following pack instructions in a large pan of boiling salted water. Once cooked, drain, reserving a mugful of the cooking water."
    },
    {
      "heading": null,
      "description": "Toss the pasta through the sauce, adding a splash of the reserved pasta water to loosen if needed. Spoon onto plates."
    },
    {
      "heading": null,
      "description": "Serve up! Kids Plate: Dish out the pasta as is.Parents Plate: Top the adult portions with a good pinch of chilli flakes, a scattering of torn basil leaves, grated parmesan and the capers."
    }
  ],
