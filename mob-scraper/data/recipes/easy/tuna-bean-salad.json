  "method": [
    {
      "heading": null,
      "description": "Bring a pan of water to a boil. While you’re waiting for it to boil, finely slice your red onion, chop your tomatoes, and trim your green beans."
    },
    {
      "heading": null,
      "description": "Add the green beans and cook for 1 minute. Drain and rinse under cold water to stop the cooking process."
    },
    {
      "heading": null,
      "description": "In a large bowl, whisk together the olive oil, Dijon mustard, lemon juice, sherry vinegar, salt, and pepper."
    },
    {
      "heading": null,
      "description": "Add the tomatoes, capers, and red onion to the dressing and toss to combine."
    },
    {
      "heading": null,
      "description": "Pat the butter beans and borlotti beans dry, then add them to the bowl along with the torn basil."
    },
    {
      "heading": null,
      "description": "Add the drained tuna, mix everything together, and taste. Adjust seasoning with more salt and pepper if needed."
    },
    {
      "heading": null,
      "description": "Serve immediately or chill for later."
    }
  ],
