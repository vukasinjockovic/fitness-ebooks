  "method": [
    {
      "heading": null,
      "description": "Add the milk, stock, garlic granules, thyme, whole unpeeled garlic cloves and mustard to a blender. Blitz until smooth."
    },
    {
      "heading": null,
      "description": "Add the pasta to a large pan and strain the milk mixture into it. Add the bay leaves and season with salt and plenty of black pepper. Turn the heat up to medium-high, bring to the boil, then reduce to medium. Cook, stirring occasionally, until the pasta is al dente (follow pack instructions) and the sauce has thickened."
    },
    {
      "heading": null,
      "description": "Meanwhile, turn the grill to high. Grate the Cheddar. Tear or cut the baguette into bite-sized chunks."
    },
    {
      "heading": null,
      "description": "Once the pasta is cooked, stir through the Cheddar. Scatter over the mozzarella and baguette chunks."
    },
    {
      "heading": null,
      "description": "Place under the grill until golden and crispy. Serve immediately."
    }
  ],
