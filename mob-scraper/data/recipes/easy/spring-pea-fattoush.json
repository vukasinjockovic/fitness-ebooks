  "method": [
    {
      "heading": null,
      "description": "Preheat your grill."
    },
    {
      "heading": null,
      "description": "Finely slice the red onion and add to a small bowl with the vinegar and a tbsp of water to give it a quick pickle."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onions and put them into a big bowl of ice water."
    },
    {
      "heading": null,
      "description": "Add the peas to a saucepan of well salted boiling water, cook for a minute and then drain. Add the peas to the ice water with the spring onions."
    },
    {
      "heading": null,
      "description": "Half the cucumber and use a teaspoon to scrape out the seeds. Finely slice it and add to a large mixing bowl. Drain and add the peas, spring onions and red onions."
    },
    {
      "heading": null,
      "description": "Finely chop the parsley and mint and add to the bowl. Set that aside while you toast the bread."
    },
    {
      "heading": null,
      "description": "Split the breads into two thin layers and then tear into roughly two-inch pieces and put them on a large roasting tray. Drizzle and toss with olive oil and a big pinch of salt."
    },
    {
      "heading": null,
      "description": "Toast under the grill giving them a shake and stir halfway through until nice and golden and crisp. This will only take a couple of minutes so keep an eye on them! Once ready, remove from the grill and sprinkle over the chilli and ½ the sumac."
    },
    {
      "heading": null,
      "description": "In a small bowl mix the remaining sumac, honey, lemon juice and a splash of olive oil."
    },
    {
      "heading": null,
      "description": "Now, add the bread and dressing to the bowl with the veggies and crumble in most of the feta. Give that a gentle mix and taste for salt and lemon. Plate up, finish with the rest of the feta and a drizzle of olive oil."
    }
  ],
