  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids Serving \nRinse the rice under cold water until it runs clear, then tip into a large lidded frying pan or shallow casserole dish."
    },
    {
      "heading": null,
      "description": "Deseed the peppers and slice into thin strips. Trim the green beans and cut them in half. Trim the spring onions, then cut them into 2cm pieces — set a few aside for serving later."
    },
    {
      "heading": null,
      "description": "Add the peppers, green beans and most of the spring onions to the pan with the rice. Pour over the hot chicken stock, bring to a simmer, then nestle the salmon fillets into the top. Cover with a lid and cook over a low heat for 15 mins."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix together the soy sauce and honey."
    },
    {
      "heading": null,
      "description": "Once the time is up, drizzle the soy-honey mix over the rice and gently fold everything together with a spoon, taking care not to break up the salmon too much."
    },
    {
      "heading": null,
      "description": "Serve up!\nKids Plate: Dish out the rice as is, with some sliced cucumber on the side.\nParents Plate: Dish out the rice and add the remaining spring onions and add a little extra soy sauce if you fancy, a drizzle of chilli oil and a wedge of lime."
    }
  ],
  "tips": [
    "If using frozen salmon, defrost before adding.",
    "You can swap the short grain rice for basmati — just adjust the cooking time according to pack instructions."
