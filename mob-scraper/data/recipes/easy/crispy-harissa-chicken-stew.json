  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 190°C."
    },
    {
      "heading": null,
      "description": "Thinly slice the onions and garlic. Cut the potatoes into 2cm chunks."
    },
    {
      "heading": null,
      "description": "Heat a large oven-proof pan or roasting tin over a medium heat with a glug of oil."
    },
    {
      "heading": null,
      "description": "Season the chicken with salt and brown, skin-side down, until crispy. This should take 7-8 mins."
    },
    {
      "heading": null,
      "description": "Take the chicken out of the pan and add the sliced onions, cinnamon, and a pinch of salt. Cook for 9-10 mins until the onions are starting to caramelise."
    },
    {
      "heading": null,
      "description": "Add the potatoes, harissa and garlic and cook for another couple of mins."
    },
    {
      "heading": null,
      "description": "Add the tinned tomatoes along with a splash of water and bring to a simmer. Once that's all simmering away, nestle the chicken back into the pan."
    },
    {
      "heading": null,
      "description": "Bang it into the oven for 30-35 mins until bubbling. You'll know it's ready when the potatoes and chicken are cooked through and the chicken skin is crispy and golden."
    },
    {
      "heading": null,
      "description": "Stir in the butter and top with the fresh oregano."
    },
    {
      "heading": null,
      "description": "Serve with a blob of yoghurt and get stuck in."
    }
  ],
