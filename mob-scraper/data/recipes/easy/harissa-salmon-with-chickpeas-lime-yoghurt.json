  "method": [
    {
      "heading": null,
      "description": "Cut the salmon into chunky pieces and season with salt and pepper. Heat a drizzle of olive oil in a non-stick frying pan set over a medium-high heat. Add the salmon, skin-side down, and cook for 2-3 mins until crisp. Flip and cook for another 2 mins on the other side."
    },
    {
      "heading": null,
      "description": "Mix the harissa paste, honey and water in a small bowl. Pour the mix into the pan and let it bubble around the salmon for 30 seconds or until cooked through. Baste the fish with the sauce, then lift it out and set aside to rest."
    },
    {
      "heading": null,
      "description": "Finely slice the garlic and the cavolo nero. Add both to the pan and cook for 1 min. Tip in the chickpeas, cumin, paprika and a pinch of salt, then pour in the vegetable stock. Let it simmer for 5 mins until slightly thickened but still brothy."
    },
    {
      "heading": null,
      "description": "While the chickpeas cook, zest the lime and squeeze in the juice of half. Stir it through the Greek yoghurt with a pinch of salt."
    },
    {
      "heading": null,
      "description": "To serve, spoon the chickpeas into bowls and top with the harissa-glazed salmon. Add a generous dollop of the lime yoghurt and finish with fresh coriander, if you’ve got it."
    }
  ],
