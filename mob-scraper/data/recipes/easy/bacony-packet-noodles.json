  "method": [
    {
      "heading": null,
      "description": "Spoon your peanut butter into a bowl and mix together with your soy sauce, chilli oil, rice vinegar and 2 tbsp of water until you get a thick, creamy, rich sauce. Then set aside."
    },
    {
      "heading": null,
      "description": "Chop your bacon into chunks and fry in a non-stick pan until crispy."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop your spring onion (setting aside a handful for garnish) and ginger. Add to the pan along with your five-spice for an aromatic kick, then stir together."
    },
    {
      "heading": null,
      "description": "In another pan bring your noodles to the boil. Simmer for about 3 minutes then add to your bacony pan. Set some of the noodle water aside."
    },
    {
      "heading": null,
      "description": "Next, take your peanut sauce and toss it through the noodles until they are evenly coated - add a splash of the noodle water to loosen it."
    },
    {
      "heading": null,
      "description": "Plate up and garnish with a sprinkle of spring onion and a tsp chilli oil then you’re ready to dig in."
    }
  ],
