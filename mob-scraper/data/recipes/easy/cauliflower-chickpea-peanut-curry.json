  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Pod and roughly crush the cardamom seeds. Cut the cauliflower into florets and tip them onto a baking tray. Drizzle with oil and scatter over the cumin, cardamom seeds, salt and pepper. Put in the oven for 15 mins until charred."
    },
    {
      "heading": null,
      "description": "Peel and finely slice the onion, then peel and grate the garlic and ginger. Heat a shot of oil in a large pan over a low-medium heat and add the onions and a pinch of salt, sweating down for around 15 mins until deeply golden. Grate in the garlic and ginger, then add the spices. Cook for a couple of minutes, then tip in the cauliflower, drained chickpeas, coconut milk, peanut butter and vegetable stock. Gently simmer for 5 mins until thickened, then season with lime juice, salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve with rice and enjoy. \nOptional: if you're batch cooking the curry, portion it out into Tupperware containers."
    }
  ],
