  "method": [
    {
      "heading": null,
      "description": "Get a pan of salted water to the boil. Meanwhile, very finely slice the sugar snaps into long pieces. Toss in a bowl with half the lime juice. Roughly chop the peanuts, if using."
    },
    {
      "heading": null,
      "description": "In a separate large bowl stir together the peanut butter, Sriracha, soy and remaining lime juice or rice wine vinegar to make your sauce."
    },
    {
      "heading": null,
      "description": "Unravel the noodles with your fingers into the pan of salted boiling water and cook for 1 min then, using tongs, transfer the noodles straight into the sauce. Toss together, adding a splash of the cooking water to create a silky, luscious sauce."
    },
    {
      "heading": null,
      "description": "Divide between bowls and top with the shredded sugar snaps, salted peanuts (if using) and more sriracha and soy, if you like. Boom."
    }
  ],
