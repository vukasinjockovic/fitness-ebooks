  "method": [
    {
      "heading": null,
      "description": "Peel and finely grate the garlic and ginger. Thinly slice the jalapeño."
    },
    {
      "heading": null,
      "description": "Add the ghee into a saucepan and lightly crush the cardamom pods. Once hot, simmer the cardamom and caraway seeds until fragrant. Add the ginger, garlic and berbere, then cook until fragrant. Pour in the plum tomatoes and crush to break them down. Bring to the boil, then reduce the heat to medium-low and simmer for 10-15 mins until thickened."
    },
    {
      "heading": null,
      "description": "Meanwhile, bring a saucepan of water to the boil. Once boiling, turn the heat down slightly to a gentle boil, then add the eggs and cook for 6 mins until jammy. Drain and place in an ice bath or keep cold water running over them."
    },
    {
      "heading": null,
      "description": "Toast the bread, discard the cardamom pods from the sauce, then slather the sauce onto the toast. Peel and halve the eggs, then place onto the toasts. Garnish with jalapeño slices and a drizzle of olive oil."
    }
