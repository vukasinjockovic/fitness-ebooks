  "method": [
    {
      "heading": null,
      "description": "Halve the aubergines lengthwise, then cut into 2cm thick pieces on a diagonal. Add the gochujang, honey, soy sauce and rice wine vinegar to a large bowl and grate in the garlic. Toss in the aubergine."
    },
    {
      "heading": null,
      "description": "Halve the cucumber lengthwise and scoop out the seeds before finely slicing. Add to a bowl along with the kimchi and set aside. Finely slice the spring onions."
    },
    {
      "heading": null,
      "description": "Add the aubergines to the air fryer and top with the sausages. Heat to 185C and cook for 5 minutes, then turn the sausages and air fry again for 5 mins. Take the sausages out of the machine and slice on a diagonal, then add them back into the basket and cook for a further 5-15 mins or until everything is cooked through and sticky."
    },
    {
      "heading": null,
      "description": "If using a pouch of rice, heat according to package instructions. If using pre-cooked rice, heat until piping hot."
    },
    {
      "heading": null,
      "description": "Serve up the rice along with the sticky aubergines and sausages. Add the kimchi salad and spring onions before scattering with the sesame seeds."
    }
  ],
