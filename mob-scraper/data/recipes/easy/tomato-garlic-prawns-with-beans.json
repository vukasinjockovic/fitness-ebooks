  "method": [
    {
      "heading": null,
      "description": "Chuck the tomatoes into a large nonstick frying pan and set it over a medium-high heat. Let them cook for 8 to 10 mins, shaking the pan now and then, until they start to burst and char."
    },
    {
      "heading": null,
      "description": "Peel and finely slice the garlic. Push the tomatoes to one side of the pan and add the anchovy oil to the other. Add the anchovy fillets and garlic, and cook for 1 min until the garlic is soft and the anchovies have melted into the oil."
    },
    {
      "heading": null,
      "description": "Tip in the butter beans — juice and all — and stir everything together. Let it simmer for 3 mins until you’ve got a thick, saucy mix. Pick most of the basil leaves and stir them through, saving a few baby ones for garnish. Season to taste."
    },
    {
      "heading": null,
      "description": "Heat a grill pan over a high heat. Spritz the prawns with olive oil, season with salt and pepper, and grill for 2-3 mins on each side until lightly charred and opaque."
    },
    {
      "heading": null,
      "description": "Spritz the sourdough with oil and toast in the grill pan until golden on both sides."
    },
    {
      "heading": null,
      "description": "Spoon the beans into bowls, top with the prawns and scatter over the reserved basil leaves. Finish with chilli flakes if you fancy, and serve with the toast on the side for scooping."
    }
  ],
