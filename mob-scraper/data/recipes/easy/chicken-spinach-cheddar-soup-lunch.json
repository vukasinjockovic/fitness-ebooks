  "method": [
    {
      "heading": null,
      "description": "Finely slice the red onion and add to a bowl with the juice of ¼ the lemon and a pinch of salt. Mix and set aside."
    },
    {
      "heading": null,
      "description": "Finely dice the white onion and celery, and mince the garlic. Melt the butter in a large saucepan set over a medium heat. Add the onion and celery and cook for 6-7 mins until soft and jammy. Add the garlic, coriander and chilli flakes and cook for another 3-4 mins, until the garlic is soft."
    },
    {
      "heading": null,
      "description": "Add the frozen spinach and chicken stock and bring to a gentle simmer. Once the spinach has defrosted and the broth is simmering, add the chicken thighs and gently simmer for 20 mins until cooked through. Then, remove the chicken and use two forks to shred."
    },
    {
      "heading": null,
      "description": "Pour the broth mixture into a blender then add the fresh spinach and grate in the Cheddar. Blend on high until vivid green and smooth. Season to taste with salt, pepper and lemon juice."
    },
    {
      "heading": null,
      "description": "To serve, add the shredded chicken to a bowl and pour over the broth. Top with the pickled onions, a crack of black pepper and some extra grated Cheddar, if you like. Serve with toasted sourdough."
    },
    {
      "heading": null,
      "description": "If batch cooking for the week, transfer the leftover chicken and broth to a container and the pickled onions to another. It will keep in the fridge for 3 days. Reheat the chicken and broth together until piping hot before serving."
    }
  ],
