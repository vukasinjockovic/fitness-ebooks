  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids Servings\nHeat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Cut the chorizo into chunks and the chicken into bite-sized pieces. Finely slice the onions, peppers and garlic."
    },
    {
      "heading": null,
      "description": "Set a large ovenproof frying pan or casserole dish over a medium heat with a drizzle of olive oil. Fry the chorizo for 2-3 mins until it starts to release its oil, then add the chicken and cook for another 5-6 mins until browned."
    },
    {
      "heading": null,
      "description": "Stir in the onions, peppers and garlic. Cook for 8-10 mins until soft and golden. Season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Rinse the rice under cold water until it runs clear. Stir the rice into the pan, then pour in the chicken stock and scatter over the cherry tomatoes. Bring everything to the boil, then cover tightly with a lid or foil and transfer to the oven. Bake for 45 mins until the rice is tender and the stock has been absorbed."
    },
    {
      "heading": null,
      "description": "Meanwhile, zest and juice lemon half the lemons. Mix the yoghurt with the lemon zest, juice, smoked paprika and a pinch of salt."
    },
    {
      "heading": null,
      "description": "Fluff up the rice with a fork and serve up!\nKids Plate: Dish out with a dollop of the paprika yoghurt on the side.\nParents Plate: Dish out with a dollop of the paprika yoghurt and a handful of chopped parsley on top and a lemon wedge."
    }
  ],
  "tips": [
    "If using white basmati just reduce the cooking time slightly.",
    "Add a handful of spinach in the last 5 mins of baking for extra greens."
  ],
