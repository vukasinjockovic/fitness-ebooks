  "method": [
    {
      "heading": null,
      "description": "Bring a large pot of salted water to a boil. Add the rigatoni and cook according to the package instructions. Drain the pasta and rinse it under cold water to stop the cooking process. Set aside to cool completely."
    },
    {
      "heading": null,
      "description": "While the pasta is cooling, halve the cherry tomatoes and slice the roasted red peppers into thin strips. Roughly chop the parsley and roasted almonds."
    },
    {
      "heading": null,
      "description": "Make the dressing. In a small bowl, whisk together the olive oil, harissa paste, lemon juice, lemon zest, and honey (or maple) syrup until well combined. Season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "In a large mixing bowl, combine the cooled rigatoni, cherry tomatoes, roasted red peppers, parsley, and roasted almonds."
    },
    {
      "heading": null,
      "description": "Pour the dressing over the salad and toss everything together until the pasta and vegetables are evenly coated with the dressing."
    },
    {
      "heading": null,
      "description": "Spoon into bowls, top with a few extra parsley leaves and a sprinkle of chopped almonds."
    }
  ],
