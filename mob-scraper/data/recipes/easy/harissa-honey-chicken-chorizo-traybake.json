  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Peel off any casing from the chorizo, then slice into 1cm-thick coins. Tip into a large roasting tray with the sweet potato and drained chickpeas. Drizzle over half the olive oil and season with salt and pepper. Toss to coat."
    },
    {
      "heading": null,
      "description": "Mix the harissa and honey together in a small bowl. Season the chicken breasts with salt and pepper, then brush with half of the harissa-honey glaze. Drizzle over the remaining olive oil."
    },
    {
      "heading": null,
      "description": "Place the chicken on top of the sweet potato and chorizo, then roast for 25 mins, or until the chicken is cooked through and the sweet potato is soft."
    },
    {
      "heading": null,
      "description": "Fold the remaining glaze through the sweet potato and chickpeas. Pick the parsley leaves and scatter over the top before serving, if using. Dig in!"
    }
  ],
