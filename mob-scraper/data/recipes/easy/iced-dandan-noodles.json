  "method": [
    {
      "heading": null,
      "description": "Combine chilli oil, soy sauce, tahini, five-spice, and black vinegar in a bowl or jug. Add the cold water gradually whilst stirring until you have a smooth soup consistency. Chill until very cold, you can either pop in the fridge for at least 2 hours or stick in the freezer for max 30 mins."
    },
    {
      "heading": null,
      "description": "When you’re ready to eat, cook the noodles according to package instructions and then drain and rinse in cold water to stop the cooking process. Toss the noodles in the sesame oil and set aside."
    },
    {
      "heading": null,
      "description": "Cut the cucumber into matchsticks. Finely slice the spring onions. Roughly chop the peanuts."
    },
    {
      "heading": null,
      "description": "Pour the soup broth into a bowl, top with the noodles, a couple of ice cubes, peanuts, cucumber and spring onions. Give it a good mix and get stuck in."
    }
