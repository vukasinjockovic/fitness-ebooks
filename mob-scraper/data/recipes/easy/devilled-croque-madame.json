  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Melt the butter in a pan over a medium low heat, add the flour and whisk until smooth. Add the curry powder, mix again and then slowly add the milk, whisking constantly."
    },
    {
      "heading": null,
      "description": "Add the mustard, Worcestershire sauce and tabasco, then half of the grated Cheddar and whisk until smooth."
    },
    {
      "heading": null,
      "description": "Grab 4 slices of bread and spread each with a little of the béchamel. Top each with 2 slices of ham, a handful of grated Cheddar and a second slice of bread. Transfer to a baking tray and pour over the rest of the béchamel."
    },
    {
      "heading": null,
      "description": "Bake in the oven for about 15 mins until the top is golden brown (you can also grill it for a few minutes at the end)."
    },
    {
      "heading": null,
      "description": "While they bake, fry 4 crispy fried eggs and as soon as the Croque Madame comes out of the oven, top with the eggs and serve."
    }
  ],
