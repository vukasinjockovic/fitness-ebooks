  "method": [
    {
      "heading": null,
      "description": "Set a pot of water over a medium-high heat and bring to the boil. Add the noodles and cook following pack instructions. Drain and rinse with cold water to prevent them from sticking."
    },
    {
      "heading": null,
      "description": "Meanwhile, chop the tomatoes into 3cm pieces. Mince the garlic and slice the spring onion, separating the whites and greens."
    },
    {
      "heading": null,
      "description": "Whisk the eggs in a bowl and season with salt and white pepper."
    },
    {
      "heading": null,
      "description": "Add half of the vegetable oil to a pan or wok set over a medium heat. Once hot, add the eggs. Stir until lightly scrambled, then push the cooked eggs to the side of the pan. Add the rest of the vegetable oil, the tomatoes, garlic and spring onion whites. Fry for a few mins until the tomatoes are softened."
    },
    {
      "heading": null,
      "description": "Combine all the sauce ingredients in a small bowl. Add to the pan with the eggs and tomatoes, turn the heat to low-medium and fry for a few mins. Add the spring onion greens and mix well."
    },
    {
      "heading": null,
      "description": "Serve the stir-fried tomato and eggs on top of the noodles, with a drizzle of chilli oil on top."
    }
  ],
