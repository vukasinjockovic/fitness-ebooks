  "method": [
    {
      "heading": null,
      "description": "Peel and chop the onions and garlic. Heat a few spoons of olive oil in a large pot over medium heat then add the onions and garlic and sauté for about 5 mins, or until fragrant."
    },
    {
      "heading": null,
      "description": "Roughly chop the cabbage into chunks, and peel and dice the potatoes. Add to the pot, season with salt and pepper to taste, then sauté for an additional 5\t mins to allow the flavours to meld."
    },
    {
      "heading": null,
      "description": "Pour in the broth and bring to a gentle boil. Reduce the heat to low, cover, and simmer for about 20 mins, or until the potatoes are fork-tender. Transfer the mixture to a blender and blitz until very smooth, adding the cream as you blend. Taste and adjust seasoning with more salt and pepper, if necessary."
    },
    {
      "heading": null,
      "description": "Ladle the soup into bowls. Roughly chop the chives, pistachios and parsley. Garnish the soups with a drizzle of olive oil, and sprinkle with the chives, pistachios, and fresh parsley."
    }
