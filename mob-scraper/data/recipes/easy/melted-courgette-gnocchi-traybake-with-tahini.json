  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C fan."
    },
    {
      "heading": null,
      "description": "Prep the courgettes. Cut them into irregular 3cm chunks. Spread onto a large roasting tray and toss with half of the olive oil and a sprinkling of salt."
    },
    {
      "heading": null,
      "description": "Roast the courgettes for 10 mins. Remove the tray, give everything a shake, then add the gnocchi and roast for a further 5–8 mins until the courgettes are golden and the gnocchi is crisping at the edges."
    },
    {
      "heading": null,
      "description": "Make the dressing. In a small bowl, whisk together the remaining olive oil, sumac, honey, the zest of the whole lemon, and the juice of half. Season well."
    },
    {
      "heading": null,
      "description": "Once the tray is out of the oven, let it cool slightly, then toss the courgettes and gnocchi through the dressing."
    },
    {
      "heading": null,
      "description": "Make the tahini sauce. Grate the garlic into a separate bowl. Add the tahini and remaining lemon juice. Stir with a splash of water until smooth and pourable. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Drizzle the garlic tahini sauce over the traybake, sprinkle with chilli flakes and sunflower seeds, and scatter over picked mint leaves."
    }
  ],
  "tips": [
    "Gnocchi → Swap for gluten-free gnocchi or roasted baby potatoes",
    "Tahini → Use Greek yoghurt, cashew butter, or plant-based yoghurt for a creamy alternative",
