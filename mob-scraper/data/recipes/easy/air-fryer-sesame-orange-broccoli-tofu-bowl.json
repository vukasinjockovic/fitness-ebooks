  "method": [
    {
      "heading": null,
      "description": "Cook the rice according to package instructions."
    },
    {
      "heading": null,
      "description": "Prepare the broccoli by cutting it into florets. Place in a bowl and cover with boiling water. Let stand for 3 minutes, then drain and allow to steam dry."
    },
    {
      "heading": null,
      "description": "Prepare the tofu by patting it dry and breaking it into 2 cm pieces. Toss with 2 tbsp cornflour, sesame oil, salt, and pepper. Add to the air fryer and cook at 200°C for 10 minutes, turning halfway."
    },
    {
      "heading": null,
      "description": "Toss the broccoli with ½ tbsp olive oil, salt, and pepper."
    },
    {
      "heading": null,
      "description": "Remove the tofu from the air fryer and add the broccoli. Place the tofu back on top and cook for another 5 minutes until golden and tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, mix 1 tbsp cornflour with 4 tbsp water in a small saucepan. Add the juice of the orange, soy sauce, honey, garlic powder, chilli flakes, and rice vinegar. Cook over medium heat, stirring frequently, until bubbling and slightly thickened (about 3 minutes). Remove from the heat."
    },
    {
      "heading": null,
      "description": "Serve the rice or noodles topped with the tofu and broccoli. Garnish with spring onions, the zest of ¼ of the orange, and sesame seeds."
    }
  ],
  "tips": [
    "Make it vegan: Swap honey for maple syrup or agave.",
    "Add more crunch: Top with crushed peanuts or cashews.",
    "Storage: Leftovers keep in the fridge for up to 2 days; reheat in the air fryer for best texture.",
    "Gluten-free option: Use tamari instead of soy sauce."
