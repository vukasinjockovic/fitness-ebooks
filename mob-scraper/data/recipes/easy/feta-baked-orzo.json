  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Finely slice the onions and garlic and roughly chop the roasted peppers."
    },
    {
      "heading": null,
      "description": "Heat a large ovenproof pan over a medium-high heat."
    },
    {
      "heading": null,
      "description": "Cook most of the onion, saving a handful, in a glug of oil with a pinch of salt for 8-10 mins until they start to caramelise."
    },
    {
      "heading": null,
      "description": "Add the oregano, garlic and chilli flakes and cook for a further couple of mins."
    },
    {
      "heading": null,
      "description": "Now add the orzo, chopped tomatoes and peppers. Add the water and a splash of the liquid from the pepper jar."
    },
    {
      "heading": null,
      "description": "Season with salt and pepper, crumble in the feta and scatter your olives over the top of the pan."
    },
    {
      "heading": null,
      "description": "Bring to a simmer and transfer to the oven for 30-35 mins until cooked through and starting to brown on top."
    },
    {
      "heading": null,
      "description": "While the orzo bakes, toss the dill, parsley and remaining sliced onion with a squeeze of lemon."
    },
    {
      "heading": null,
      "description": "Top the orzo with the onion and herbs and a drizzle of olive oil. Serve with extra lemon wedges."
    }
  ],
