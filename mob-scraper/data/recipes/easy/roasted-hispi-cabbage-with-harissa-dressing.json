  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Cut your cabbage into quarters and rub with olive oil and plenty of salt."
    },
    {
      "heading": null,
      "description": "Heat an oven proof pan over a high heat and burn the cut sides of your cabbage. Chuck in the butter, a smashed garlic clove and sherry vinegar. Roll the cabbage around in the butter and stick the whole pan into the oven for 10-15 mins."
    },
    {
      "heading": null,
      "description": "Grab your jar of harissa and add the remaining vinegar. Give it a good shake."
    },
    {
      "heading": null,
      "description": "Meanwhile, toast off the breadcrumbs with a glug of oil in a pan over a medium heat."
    },
    {
      "heading": null,
      "description": "Finely chop the parsley and mix through the toasted breadcrumbs."
    },
    {
      "heading": null,
      "description": "Pull the hispi cabbage out of the oven and pour the butter and vinegar mixture into the jar of harissa. Top with lid and give it a good shake, add a splash more vinegar or water if it needs loosening up."
    },
    {
      "heading": null,
      "description": "Transfer the hispi to a serving platter and cover in the warm dressing. Top with the breadcrumbs."
    }
  ],
