  "method": [
    {
      "heading": null,
      "description": "Slice the chives as finely as possible, cut the spring onions into thirds and slice the shallot in half. Set everything aside."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of water to the boil. Add the beansprouts and cook for 3 mins. Once cooked, transfer to a bowl with the chives, sesame oil, chilli flakes, sesame seeds and soy sauce. Mix well and set aside."
    },
    {
      "heading": null,
      "description": "To the same saucepan, add the udon and cook for around 3 mins until the noodles are separated. Drain and set aside."
    },
    {
      "heading": null,
      "description": "For the sauce, combine all the ingredients in a bowl. Mix well until the sugar is dissolved."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium heat and add the oil. Heat for 1 min, then add the spring onion, shallot and ginger. Cook for 5 mins until the spring onions turn a dark colour. Remove the crispy spring onions to a plate and discard the ginger and shallot."
    },
    {
      "heading": null,
      "description": "Turn the heat up to high for 30 seconds, or until smoking. Turn the heat off. Stir the sauce and pour into the pan of oil. This technique will concentrate and caramelise the sauce. Add the udon to the pan and mix well."
    },
    {
      "heading": null,
      "description": "Plate the udon, add a handful of the dressed beansprouts and finish with crispy spring onions on top. Enjoy!"
    }
  ],
