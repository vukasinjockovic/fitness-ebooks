  "method": [
    {
      "heading": null,
      "description": "Cut your pineapple up and weigh up the desired amount, saving a slice for garnish. Also pull out a couple fronds off the top for garnish."
    },
    {
      "heading": null,
      "description": "Juice your limes and pick five springs of mint leaves off their stalks."
    },
    {
      "heading": null,
      "description": "In a cocktail shaker add your pineapple and mint then using a blunt object squish it down a couple times to juice it."
    },
    {
      "heading": null,
      "description": "Add your tequila, agave, lime juice and ice."
    },
    {
      "heading": null,
      "description": "Shake vigorously for 15 seconds."
    },
    {
      "heading": null,
      "description": "Double strain into your glass over ice."
    },
    {
      "heading": null,
      "description": "Garnish with some mint, your reserved pineapple chunk and your pineapple fronds. Enjoy!"
