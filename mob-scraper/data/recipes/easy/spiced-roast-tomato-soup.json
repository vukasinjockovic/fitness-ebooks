  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Halve the tomatoes and place on a baking tray (chopped sides facing upwards). Drizzle olive oil over the tomatoes. Add the garlic cloves (skins on) to the tray along with the ginger (skin on). Sprinkle a pinch of salt over the tray. Roast in the oven for 20 minutes."
    },
    {
      "heading": null,
      "description": "Remove the baking tray from the oven and move the tomatoes over to one side of the baking tray."
    },
    {
      "heading": null,
      "description": "Slice up your onions, add them to the tray along with whole red chilli. Drizzle olive oil and salt over the top and place back into the oven for 25 minutes."
    },
    {
      "heading": null,
      "description": "Take the tray out of the oven and peel the skin off the ginger and squeeze the garlic out of the skins."
    },
    {
      "heading": null,
      "description": "Add the contents of the baking tray to a saucepan, followed by the coconut milk and vegetable stock. Blend until a smooth orange colour. Add a drizzle of white wine vinegar and a pinch of pepper. Mix together."
    },
    {
      "heading": null,
      "description": "Remove the soup from the heat and ladle into bowls. Top with a drizzle of olive oil, a few drops of coconut cream and a scattering of chopped coriander. Serve with two slices of toasted sourdough and enjoy!"
    }
  ],
