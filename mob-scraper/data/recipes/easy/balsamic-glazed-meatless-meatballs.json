  "method": [
    {
      "heading": null,
      "description": "Break off small pieces of your mince until you have around 18 pieces. Roll them up into small balls. Sprinkle a generous amount of salt and pepper over the top. Move them around with your hands to make sure each ball is coated."
    },
    {
      "heading": null,
      "description": "Get your pasta on."
    },
    {
      "heading": null,
      "description": "Drizzle some olive oil into a pan and add your meatless meatballs. Stir them around until they begin to brown."
    },
    {
      "heading": null,
      "description": "Chop up the garlic cloves and basil."
    },
    {
      "heading": null,
      "description": "Add the garlic to the pan along with the chilli flakes. After 30 seconds, add the balsamic glaze and mix everything together."
    },
    {
      "heading": null,
      "description": "Pour the passata into the pan and grate the zest of 1 lemon over the top. Add your chopped basil to the sauce and give everything a good stir."
    },
    {
      "heading": null,
      "description": "Once your pasta is cooked, take it out of the saucepan and mix it into the tomato sauce and stir everything together. Serve it up and tuck into this delicious meat-free dish."
    }
