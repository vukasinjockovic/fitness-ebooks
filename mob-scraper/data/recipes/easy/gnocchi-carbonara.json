  "method": [
    {
      "heading": null,
      "description": "Dice the pancetta. Add it to a cold frying pan set over a medium heat and cook until it’s rendered and crisp. Take off the heat and set aside."
    },
    {
      "heading": null,
      "description": "Grate the pecorino and Parmesan cheeses. Whisk together the eggs, egg yolks, grated cheeses, black pepper and nutmeg in a bowl."
    },
    {
      "heading": null,
      "description": "Cook the gnocchi following pack instructions then drain, saving the water."
    },
    {
      "heading": null,
      "description": "Add the gnocchi to the pancetta, then add the egg yolk mixture with a splash of the cooking water. Mix vigorously until emulsified."
    },
    {
      "heading": null,
      "description": "To serve, top with some extra grated Parmesan and some more black pepper, if you like."
