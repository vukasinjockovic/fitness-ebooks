  "method": [
    {
      "heading": null,
      "description": "Soak the rice noodles in hot water for 90 seconds, then rinse under cold water. They should be very al dente — they’ll finish cooking in the pan."
    },
    {
      "heading": null,
      "description": "Slice the spring onions into 2cm chunks, separating the whites and greens. Finely shred the cabbage. Dice the tofu into 1cm cubes. Crush the peanuts. Set everything aside."
    },
    {
      "heading": null,
      "description": "Make the sauce by mixing the tamarind purée, brown sugar, fish sauce, dark soy sauce, and grating in the garlic."
    },
    {
      "heading": null,
      "description": "Set a wok or large frying pan over a medium-high heat with the oil. Once hot, add the tofu and prawns. Fry for 2–3 mins, tossing regularly, until the tofu is golden and the prawns are pink. Remove and set aside."
    },
    {
      "heading": null,
      "description": "Add the cabbage to the pan and stir-fry for 2–3 mins until it starts to char and wilt."
    },
    {
      "heading": null,
      "description": "Tip in the noodles and pour over the sauce. Stir-fry for a minute or two until the sauce thickens and coats everything."
    },
    {
      "heading": null,
      "description": "Push the noodles to one side of the pan and crack in the eggs. Leave to set slightly, then scramble until just cooked. Mix through the noodles."
    },
    {
      "heading": null,
      "description": "Return the prawns and tofu to the pan, along with the bean sprouts and spring onion whites. Toss everything together for 1–2 mins until hot and combined."
    },
    {
      "heading": null,
      "description": "Divide between bowls and top with crushed peanuts, coriander and lime wedges. Finish with chilli flakes if you like it spicy."
    }
  ],
