  "method": [
    {
      "heading": null,
      "description": "Bring a large saucepan of water to the boil. Add the spinach and cook for 1-2 mins until wilted. Use a slotted spoon to transfer the spinach to a blender with some water from the pan and blitz until smooth."
    },
    {
      "heading": null,
      "description": "Drain and rinse the chickpeas. Dice the paneer into 2cm cubes and finely chop the garlic."
    },
    {
      "heading": null,
      "description": "Heat the oil in a pan over a medium heat. Add the mustard and cumin seeds and cook for about 30 seconds until fragrant and popping. Stir in the chopped garlic and cook for another 30 seconds until golden."
    },
    {
      "heading": null,
      "description": "Pour in the spinach purée and tip in the chickpeas. Stir through the chilli powder, if using, and add the paneer. Bring everything to a gentle simmer for 3-4 mins. Pick the coriander."
    },
    {
      "heading": null,
      "description": "Take the pan off the heat and leave to cool slightly. Then stir through the Greek yoghurt and season to taste with salt and black pepper."
    },
    {
      "heading": null,
      "description": "To serve, spoon into Tupperware containers and top with coriander and a sprinkle of nigella seeds, if you fancy. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
  ],
