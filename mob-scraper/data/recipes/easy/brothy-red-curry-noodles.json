  "method": [
    {
      "heading": null,
      "description": "Add the rice noodles to a heatproof bowl and cover with boiling water. Let them sit for 4 mins until softened, then drain and rinse under cold water. Set aside."
    },
    {
      "heading": null,
      "description": "Dice the tofu into bite-sized cubes. Halve any large mushrooms and trim the broccoli into bite-sized florets."
    },
    {
      "heading": null,
      "description": "Add a third of the coconut milk to a large, heavy-bottomed saucepan set over a medium heat. Let it cook for 4–5 mins until the fat begins to separate from the milk."
    },
    {
      "heading": null,
      "description": "Stir in the red curry paste and cook for 4–5 mins, stirring regularly, until fragrant. Add the sugar and cook for another 2 mins. Stir through half of the fish sauce."
    },
    {
      "heading": null,
      "description": "Pour in the remaining coconut milk along with water. Bring to a simmer."
    },
    {
      "heading": null,
      "description": "Add the mushrooms and tofu and cook for 2 mins. Add the broccoli and prawns and simmer for a final 3 mins until the prawns are cooked through."
    },
    {
      "heading": null,
      "description": "Squeeze in half of the lime and season the broth with the remaining fish sauce. Taste and adjust with more salt or lime juice, if needed."
    },
    {
      "heading": null,
      "description": "Divide the noodles between two bowls and ladle over the brothy curry. Finish with lime wedges and a handful of chopped coriander."
    }
  ],
