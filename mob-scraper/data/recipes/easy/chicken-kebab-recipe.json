  "method": [
    {
      "heading": null,
      "description": "Dice the chicken into bite-sized pieces and tip into a bowl. Sprinkle in the cumin seeds, dried mint and 1 tbsp olive oil and season really well with salt and cracked black pepper. Mix well then leave to marinate for at least 1 hour, but overnight would be great."
    },
    {
      "heading": null,
      "description": "Make the tahini sauce by adding the tahini to a large bowl, half and squeeze in the juice of the lemon, peel and finely grate in the garlic and add a pinch of salt and pepper. Spoon in 1-2 tbsp of cold water and whisk to a smooth, drizzle-able sauce. It will thicken slightly as it sits, so bear this in mind."
    },
    {
      "heading": null,
      "description": "Heat your BBQ or a griddle pan over a high heat. Carefully thread the chicken pieces onto 4 metal skewers and put onto a plate."
    },
    {
      "heading": null,
      "description": "Lay the skewers straight onto the BBQ or into the griddle pan and cook for 4-5 minutes on each side until charred and cooked through."
    },
    {
      "heading": null,
      "description": "Serve the chicken stuffed into pitta halves with sliced tomatoes, red onion, lettuce and crumbled feta,a good spoon of the tahini sauce and an extra sprinkle of dried mint."
    }
  ],
