  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 230°C. Put the whole potatoes into a large saucepan filled with cold water. Bring to the boil over a high heat and cook for 10 mins."
    },
    {
      "heading": null,
      "description": "Drain the potatoes, pat dry and set each one on a square of foil. Add a drizzle of oil and a pinch of salt on top and wrap them up well. Transfer to a baking tray and roast in the oven for 40 mins. Alternatively, lightly coat your potatoes in olive oil and salt, wrap in foil and air fry at 200C for 40 mins)."
    },
    {
      "heading": null,
      "description": "Meanwhile, get started on the coronation chicken filling. Dice the chicken into chunks and transfer to a large bowl. Add the curry powder, garlic powder and yoghurt. Mix well."
    },
    {
      "heading": null,
      "description": "Set a frying pan over a medium-high heat, add the chicken and cook for 5-7 mins. Alternatively, grill the chicken instead at 180°C for 15 mins total, 7 mins each side."
    },
    {
      "heading": null,
      "description": "Dice the red onion and tear the coriander, then transfer to a large bowl with the mayonnaise and mango chutney. Add the cooked chicken, season to taste with salt and pepper and mix well."
    },
    {
      "heading": null,
      "description": "Once the jacket potatoes are done, split them open, fill with a little butter and a light dusting of curry powder, then top with the coronation filling. Finish with a sprinkle of grated cheese on top, then air-fry or grill the tops at 200°C for 5 mins to get a melty finish."
    },
    {
      "heading": null,
      "description": "Serve with salad, crisps and dip on the side."
    }
  ],
