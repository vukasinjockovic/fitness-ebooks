  "method": [
    {
      "heading": null,
      "description": "Slice an onion. Peel your carrot and thinly slice. Chop your spring onions at an angle (about 3cm lengthways). Finely slice your garlic. Prep your mangetout and give it a wash."
    },
    {
      "heading": null,
      "description": "Pop the noodles in a heatproof bowl and cover with boiling water until the noodles are cooked. This should take around 18 mins."
    },
    {
      "heading": null,
      "description": "Cut your steak into three pieces then thinly slice across the line to shorten the fibre of the meat. Add to a bowl and mix the rest of the ingredients for the beef together until evenly coated."
    },
    {
      "heading": null,
      "description": "Blanch your beansprouts in a pot of boiling water for just a few mins."
    },
    {
      "heading": null,
      "description": "Coat your wok with 3 tbsp of oil then pour most of it away. Fry the beef slices on high heat for two mins, then add your garlic, carrot, onion and mangetout."
    },
    {
      "heading": null,
      "description": "Fry for a few mins then add your cooked noodles, beansprouts and fry for another 2 mins, making sure to toss the noodles well."
    },
    {
      "heading": null,
      "description": "Mix your sauce in a separate bowl and then slowly add it to the noodles and mix well."
    },
    {
      "heading": null,
      "description": "Add your spring onions to your noodles and plate up!"
    }
  ],
