  "method": [
    {
      "heading": null,
      "description": "Pile coals over to one side of your BBQ to create a hot, direct cooking side, and a warm, indirect cooking side."
    },
    {
      "heading": null,
      "description": "Mix the mustard, ketchup and mayo in a bowl. Finely dice the shallots and add to the sauce with a good few dashes of Tabasco. Mix thoroughly."
    },
    {
      "heading": null,
      "description": "Split your mince into four roughly equal balls. Form each one into a patty, roughly 3cm thick and just wider than your buns. Set aside."
    },
    {
      "heading": null,
      "description": "Pop a frying pan onto the BBQ over the coals and drop in the bacon along with a shot of olive oil. Fry until golden brown and crispy before flashing on the BBQ for a little smoke. Move over to the indirect side of the BBQ to rest."
    },
    {
      "heading": null,
      "description": "Drop the burgers onto the hot side of the grill and sear for 3-4 mins each side. Add a slice of cheese to each burger, then shift over to the indirect side. Add a lid and leave to slowly melt for 1-2 mins. Meanwhile, finely shred the lettuce."
    },
    {
      "heading": null,
      "description": "Briefly toast the buns on the grill before adding a dollop of sauce to each side. Top with a burger and a couple of slices of bacon. Add some shredded lettuce and pickles. Serve straight away."
    }
  ],
