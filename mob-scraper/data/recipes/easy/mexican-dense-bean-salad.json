  "method": [
    {
      "heading": null,
      "description": "Drain and rinse the black beans and kidney beans. Drain the sweetcorn. Drain and slice the roasted peppers."
    },
    {
      "heading": null,
      "description": "Peel and finely slice the red onion. Add it to a small bowl with the juice of one lime and a pinch of salt. Massage and set aside."
    },
    {
      "heading": null,
      "description": "Halve the cherry tomatoes. Peel, pit and dice the avocados. Add the beans, sweetcorn, peppers, tomatoes and avocado to a large mixing bowl."
    },
    {
      "heading": null,
      "description": "Add the silken tofu to a high-speed blender with most of the coriander, the juice of the remaining two limes and the jalapeños (seeds removed if you’re not into spice). Grate in the garlic, add the tahini and season generously with salt and pepper. Blitz until smooth."
    },
    {
      "heading": null,
      "description": "Pour the dressing over the bean mixture, then add the pickled onions. Toss well to coat everything, taste and adjust seasoning if needed."
    },
    {
      "heading": null,
      "description": "Scatter with the remaining coriander and serve. If making ahead box up for later and chill until needed. \nThe salad will keep for 3 days in the fridge."
    }
  ],
