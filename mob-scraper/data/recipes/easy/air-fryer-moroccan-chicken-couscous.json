  "method": [
    {
      "heading": null,
      "description": "Heat the air fryer to 200°C. Put the chicken, 1 tbsp oil, garlic purée, spices and onion granules into a bowl. Squeeze in the lemon juice, season, then mix well. Transfer everything to the air fryer and cook for 15-17 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, put the couscous, turmeric and hot stock in a heatproof bowl. Stir, then cover with cling film and set aside while the chicken is cooking."
    },
    {
      "heading": null,
      "description": "Chop the sun dried tomatoes, cucumber and basil leaves, then set aside."
    },
    {
      "heading": null,
      "description": "When the chicken is done, add the remaining ingredients to the couscous, fluff-up the grains with a fork, slice the chicken and serve with a salad of your choice."
    }
  ],
