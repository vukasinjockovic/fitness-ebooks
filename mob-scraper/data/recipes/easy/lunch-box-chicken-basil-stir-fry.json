  "method": [
    {
      "heading": null,
      "description": "Start by making the sauce. Add the oyster sauce, soy, fish sauce and sugar to a bowl. Mix until the sugar dissolves, then set aside."
    },
    {
      "heading": null,
      "description": "Finely slice the shallots and chilli, and mince the garlic."
    },
    {
      "heading": null,
      "description": "Set a large wok or frying pan over a medium heat and drizzle in the oil. Add the garlic, shallots and chilli, and stir-fry for 2–3 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Add the chicken mince and cook for 3 mins, breaking it up with a spoon as you go. Pour in the sauce and let it bubble away for another 2 mins."
    },
    {
      "heading": null,
      "description": "Tip in the green beans and pour in the chicken stock. Cook for 3–4 mins until the beans are tender and most of the liquid has reduced. Add the basil and stir through to wilt."
    },
    {
      "heading": null,
      "description": "For the eggs, either boil for 7 mins, then peel and store in the fridge, or fry them fresh when you’re ready to eat."
    },
    {
      "heading": null,
      "description": "To portion, divide the cooked rice between four containers, then top with the chicken mince. This’ll keep in the fridge for up to 4 days. Reheat until piping hot before serving."
    },
    {
      "heading": null,
      "description": "To serve, top with your egg of choice, a wedge of lime and a drizzle of sriracha."
    }
  ],
