  "method": [
    {
      "heading": null,
      "description": "Heat your oven grill to high."
    },
    {
      "heading": null,
      "description": "Cut the chicken thighs into quarters. Peel and finely slice the onions. Peel and grate the garlic."
    },
    {
      "heading": null,
      "description": "Chuck the chicken, onions, chipotle paste, garlic, oregano, cumin, olive oil, salt and pepper into a large bowl. Toss until everything is coated."
    },
    {
      "heading": null,
      "description": "Spread the chicken mix onto a baking tray in an even layer. Slide under the grill on the top shelf and cook for 15–20 mins, turning halfway, until the chicken is cooked through and starting to char at the edges."
    },
    {
      "heading": null,
      "description": "While the chicken cooks, peel and finely chop the remaining garlic. Melt the butter in a large saucepan over a medium heat. Add the garlic and fry for 1 min until fragrant."
    },
    {
      "heading": null,
      "description": "Add the kale and cook for 2–3 mins until starting to wilt. Stir in the rice, water, a good pinch of salt and the zest of half the lemon."
    },
    {
      "heading": null,
      "description": "Bring to the boil, cover with a lid and turn the heat down to low. Cook for 12 mins, then remove from the heat and leave to steam, covered, for 5 mins. Fluff up the rice with a fork and squeeze over the juice of the lemon."
    },
    {
      "heading": null,
      "description": "Serve the chipotle chicken over the rice with a wedge of lime, some grated Cheddar and a big dollop of yoghurt."
    }
  ],
