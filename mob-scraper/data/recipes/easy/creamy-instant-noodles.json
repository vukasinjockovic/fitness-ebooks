  "method": [
    {
      "heading": null,
      "description": "Start by mincing the garlic. Transfer to a serving bowl with the chilli flakes."
    },
    {
      "heading": null,
      "description": "Add a splash of oil to a pan and heat on high for 1-2 mins, until the oil is shimmering. Carefully pour the hot oil into the garlic and chilli bowl, then stir to combine. Add the egg yolk, the mayonnaise and the soup sachet that came with the noodles. Stir vigorously until all is combined."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of water to the boil. Meanwhile, slice the spring onions as finely as possible. Once boiling, cook the noodles following pack instructions (I like to do 1 min less for chewier noodles)."
    },
    {
      "heading": null,
      "description": "Once cooked, add the noodles straight from the pan, followed by the water. Give it a thorough stir until all the sauce at the bottom is combined. Add the spring onions and slice of cheese (the heat from the noodles will melt it slightly). Enjoy!"
    }
