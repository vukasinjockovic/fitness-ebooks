  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C fan. Line a 12-hole muffin tin with paper cases or lightly oil the holes."
    },
    {
      "heading": null,
      "description": "Tip the frozen spinach into a heatproof bowl and cover with boiling water. Leave to defrost fully, then drain and squeeze out as much liquid as possible."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onions and coarsely grate the cheese."
    },
    {
      "heading": null,
      "description": "Add the drained spinach, peas, sweetcorn and spring onions to a large bowl. Stir in the flour, baking powder and a pinch of salt. Crack in the eggs, pour in the milk and melted butter, and mix to combine. Fold through three-quarters of the grated cheese."
    },
    {
      "heading": null,
      "description": "Divide the mixture evenly between the muffin cases and top with the remaining cheese."
    },
    {
      "heading": null,
      "description": "Bake for 20-25 mins until golden and cooked through. Let them cool slightly before eating."
    }
  ],
  "tips": [
    "Great cold or warm — perfect for lunchboxes.",
    "Freeze well — defrost overnight or reheat from frozen in a low oven.",
    "You can sub in grated courgette or carrot if you’re low on greens."
