  "method": [
    {
      "heading": null,
      "description": "Peel and grate the garlic into a bowl. Stir in the paprika and Greek yoghurt. Cut the chicken into 2–3cm chunks and add to the bowl with a pinch of salt. Mix well to coat."
    },
    {
      "heading": null,
      "description": "If using skewers, thread on the chicken and grill under a hot grill for 6 mins, flip and cook for another 2 mins until charred and cooked through. Alternatively, air fry at 220°C for 8-10 mins."
    },
    {
      "heading": null,
      "description": "Finely slice the red onion and mix with a pinch of salt, lemon juice and sumac, if using. Set aside to pickle slightly."
    },
    {
      "heading": null,
      "description": "Quarter the cherry tomatoes and chop the cucumber into bite-sized chunks. Add to the onions and mix well."
    },
    {
      "heading": null,
      "description": "In a small bowl, crumble in the feta and stir through the remaining yoghurt until combined. Season to taste."
    },
    {
      "heading": null,
      "description": "Toast the flatbreads in a dry pan or under the grill until warm and slightly charred."
    },
    {
      "heading": null,
      "description": "To serve, spread the feta-yoghurt mixture over the flatbreads, pile on the paprika chicken, then spoon over the tomato salad. Finish with fresh parsley, mint, dried oregano and a lemon wedge."
    }
  ],
