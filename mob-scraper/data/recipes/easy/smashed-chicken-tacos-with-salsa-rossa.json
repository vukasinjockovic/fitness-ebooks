  "method": [
    {
      "heading": null,
      "description": "To make the salsa rossa, halve the cherry tomatoes, peel and roughly chop half the onion, and smash one-third of the garlic. Chuck everything onto a tray with the chillies and grill for 6–8 mins until nicely charred."
    },
    {
      "heading": null,
      "description": "Transfer to a blender with half of the coriander and the juice of half of the limes. Blitz until smooth — or leave it chunky if that’s more your vibe. You can also chop it all if you fancy something rustic."
    },
    {
      "heading": null,
      "description": "Grate the remaining onion and add to a bowl with the chicken mince, cumin, oregano, garlic powder, salt and remaining garlic cloves. Mix well and divide into even-sized balls."
    },
    {
      "heading": null,
      "description": "Finely shred the cabbage and mix in a bowl with the yoghurt, juice of half a lime, and a good pinch of salt. Stir through half of the remaining coriander."
    },
    {
      "heading": null,
      "description": "Place a ball of chicken mince onto each tortilla and press to flatten into an even layer, right to the edges."
    },
    {
      "heading": null,
      "description": "Heat a medium frying pan over a high heat. Once hot, spray lightly with oil. Lay in the tortillas, chicken side down, and cook for 4–6 mins until golden and crisp. Flip and toast the other side for 1–2 mins."
    },
    {
      "heading": null,
      "description": "Serve the smash tacos with the slaw, a big spoonful of salsa rossa, the rest of the coriander, and extra lime wedges for squeezing."
    }
  ],
