  "method": [
    {
      "heading": null,
      "description": "Grate the garlic and finely chop the red chillies."
    },
    {
      "heading": null,
      "description": "Heat up a glug of vegetable oil in a pan and fry off the garlic and chilli for 30 seconds. Pour in the vegetable stock. Add in three quarters of the kimchi, ramen noodles and give it a good mix."
    },
    {
      "heading": null,
      "description": "Very gently take out the silken tofu from its packaging and slice it into large pieces."
    },
    {
      "heading": null,
      "description": "Once the stock has dissolved and the ramen is halfway cooked, add your tofu into the soup. Keep the soup on a gentle simmer and try not to stir it too much to avoid breaking up the tofu."
    },
    {
      "heading": null,
      "description": "Finely chop the spring onions."
    },
    {
      "heading": null,
      "description": "Serve the soup into bowls being careful not to break the tofu. Sprinkle with spring onions, your remaining kimchi and a drizzle of sesame oil."
    }
