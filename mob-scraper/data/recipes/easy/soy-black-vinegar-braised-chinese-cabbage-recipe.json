  "method": [
    {
      "heading": null,
      "description": "Cut the cabbage in half lengthways, then in half lengthways again. Cut the cabbage into 6cm chunky pieces. Peel and finely chop the garlic, then peel and finely chop the ginger."
    },
    {
      "heading": null,
      "description": "Heat a glug of vegetable oil in a large, deep frying pan or wok set over a high heat. Add the cabbage and fry for 4-5 mins, tossing regularly until charred and beginning to soften."
    },
    {
      "heading": null,
      "description": "Turn the heat to low and add the garlic, ginger, cumin seeds, Sichuan peppercorns and chilli flakes. Toss for 2 mins until smelling amazing."
    },
    {
      "heading": null,
      "description": "Pour in the chicken stock, soy sauce, vinegar and sugar and simmer away gently for 30 mins until the cabbage is meltingly tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, roughly chop the peanuts or cashews and finely chop the chives."
    },
    {
      "heading": null,
      "description": "To serve, scatter the nuts and chives over the cabbage."
    }
  ],
