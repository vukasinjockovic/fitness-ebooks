  "method": [
    {
      "heading": null,
      "description": "Start by making your noodle sauce. Add your Sriracha to a glass along with soy sauce, sugar and water. Mix together with a fork. Set aside."
    },
    {
      "heading": null,
      "description": "Crack your eggs into a separate bowl and whisk. Set aside."
    },
    {
      "heading": null,
      "description": "Place your rice noodles into a bowl of cold water, making sure they are completely covered. Set aside to soak for 15 mins until they're soft but still have some bite to them."
    },
    {
      "heading": null,
      "description": "Cut the chicken into bite-sized pieces. Thinly slice up your spring onions, chilli and carrots. Set aside."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of olive oil in a wok set over a high heat. Pour in your beaten eggs and allow the eggs to cook whilst stirring and breaking them up with your spoon."
    },
    {
      "heading": null,
      "description": "Once the eggs are cooked through, add in the chicken pieces and cook until the meat is white all over. Add your noodle sauce and grate in your garlic cloves."
    },
    {
      "heading": null,
      "description": "Drain and add the noodles to the wok and stir everything together. Add the sliced veggies and the beansprouts. Toss everything together and allow it to cook for 5 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, crush up ½ the peanuts and set aside."
    },
    {
      "heading": null,
      "description": "Add the remaining whole peanuts to the wok and give everything a good mix."
    },
    {
      "heading": null,
      "description": "Time to serve up! Divide the noodles between plates. Finish with a scattering of crushed peanuts and a a squeeze of lime."
    }
  ],
