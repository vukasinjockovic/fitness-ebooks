  "method": [
    {
      "heading": null,
      "description": "Finely chop the dill and parsley, reserving a few leaves for garnish. Peel and finely dice the shallots and garlic."
    },
    {
      "heading": null,
      "description": "Set a large lidded frying pan over a medium heat with the olive oil. Once hot, add the shallots and garlic with a pinch of salt and cook for 3 mins until soft and translucent."
    },
    {
      "heading": null,
      "description": "Tip in the orzo and stir to coat. Pour in the water, bring to a boil, then reduce the heat and simmer for 3 mins, stirring occasionally."
    },
    {
      "heading": null,
      "description": "Add the spinach and peas to the pan and mix through until wilted."
    },
    {
      "heading": null,
      "description": "Season the cod fillets with salt and pepper, then nestle them into the orzo. Cover with a lid and cook on low for 4–5 mins, until the fish is opaque and flakes easily and the orzo is al dente."
    },
    {
      "heading": null,
      "description": "Squeeze over the juice of half a lemon and stir gently. Taste and season as needed."
    },
    {
      "heading": null,
      "description": "Plate or box up the orzo and top with the cod. If eating later, store the yoghurt and herbs separately in an airtight container. If eating now, add a dollop of yoghurt, the reserved herbs and a lemon wedge. It will keep in the fridge for 3-4 days."
    }
  ],
