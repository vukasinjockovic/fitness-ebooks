  "method": [
    {
      "heading": null,
      "description": "Mince the garlic and finely chop the shallot. Add a big glug of vegetable oil to a wok set over a medium-high heat, then add the garlic and shallot along with the sambal. Stir-fry for 1-2 mins."
    },
    {
      "heading": null,
      "description": "Slice the chicken into thin strips then add to the wok and fry for 4 mins. Add some more oil, if needed."
    },
    {
      "heading": null,
      "description": "Meanwhile, chop the tofu in half and slice the tomato into wedges."
    },
    {
      "heading": null,
      "description": "Add the fresh egg noodles to the wok along with the sauces and seasonings, tomato and tofu, toss everything together to coat the noodles evenly for 1 minute (you want the noodles to be slightly smoky for wok hei)."
    },
    {
      "heading": null,
      "description": "Wash the choy sum and chop into three parts lengthways, and add to the wok. Push everything in the wok to the side and crack the eggs in. Wait for the eggs to slightly cook, then lightly scramble them."
    },
    {
      "heading": null,
      "description": "Wash the beansprouts, add to the wok and stir-fry for a few mins until the vegetables are slightly wilted (but make sure not to overcook the noodles)."
    },
    {
      "heading": null,
      "description": "Serve your mee goreng mamak with crispy shallots, crushed peanuts, extra sambal and a wedge of lime, enjoy!"
    }
  ],
