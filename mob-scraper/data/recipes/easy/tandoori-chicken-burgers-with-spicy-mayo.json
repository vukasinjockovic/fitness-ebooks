  "method": [
    {
      "heading": null,
      "description": "Put the chicken pieces into a large bowl with the curry powder, tandoori paste, juice of the lemon, yoghurt and a pinch of salt and pepper. You can leave it to marinate briefly or use it straight away."
    },
    {
      "heading": null,
      "description": "Heat a large lidded frying pan over a medium heat, then add the chicken. Fry for 5 mins on each side, until golden all over."
    },
    {
      "heading": null,
      "description": "Meanwhile, combine the sauce ingredients in a small bowl. Set aside."
    },
    {
      "heading": null,
      "description": "Slice the red onion into rings and add them to the chicken pan. Cook for 3 mins until charred."
    },
    {
      "heading": null,
      "description": "Top the chicken with the cheese slice, then put a lid on the pan and leave for 5 mins, so the cheese melts."
    },
    {
      "heading": null,
      "description": "Meanwhile, chop the lettuce and tomatoes."
    },
    {
      "heading": null,
      "description": "To assemble, split the burger buns into halves. Spread a light layer of mayo over each bun half, then toast the bun halves, mayo-side down, in a frying pan over a low-medium heat for 2 mins. Spread one burger half with sauce, add some chicken and charred onion, then finish with the shredded lettuce and sliced tomato on top. Top with a bun half and enjoy!"
    }
  ],
