  "method": [
    {
      "heading": null,
      "description": "Thinly slice the beef steak (skip this step if you’re using pre-sliced beef). Finely mince the garlic. Thinly slice the white onion, shiitake mushroom and radish. Cut the stem off the pak choi and separate the leaves. Finely slice the spring onion and set aside for the garnish."
    },
    {
      "heading": null,
      "description": "Add a splash of sesame oil and the minced garlic to a medium pan. Set it over a high heat and sauté for 1 min, or until fragrant."
    },
    {
      "heading": null,
      "description": "Add in the beef, onion, mushroom, radish and chilli powder and fry for a further 2 mins."
    },
    {
      "heading": null,
      "description": "Pour in the beef stock, gochujang and wakame and then put the lid on and boil for 3 mins."
    },
    {
      "heading": null,
      "description": "Add in the udon and pak choi then cook for a further 3 mins."
    },
    {
      "heading": null,
      "description": "Add the miso paste and a tbsp of broth to a bowl then stir until combined into a runny paste. Take the soup off the heat then pour in the miso paste and stir to combine."
    },
    {
      "heading": null,
      "description": "Divide the soup between large deep bowls and garnish with generous amounts of spring onion."
    }
  ],
