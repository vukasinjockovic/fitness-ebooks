  "method": [
    {
      "heading": null,
      "description": "Chuck the feta in the freezer — it’ll grate way easier later."
    },
    {
      "heading": null,
      "description": "Score the chicken breasts in a criss-cross pattern. Peel and finely chop the garlic, then zest one of the lemons and squeeze in the juice of half. Add the olive oil, dried oregano and season well with salt and pepper. Toss the chicken in the marinade and leave for 20 mins or up to 4 hrs."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the quinoa according to pack instructions."
    },
    {
      "heading": null,
      "description": "Peel and finely slice the red onion. Squeeze over the juice of the remaining half of the first lemon. Season with salt and pepper, scrunch with your hands and set aside to pickle."
    },
    {
      "heading": null,
      "description": "Heat a grill pan over medium-high heat. Grill the chicken for about 5 mins per side until charred and cooked through. Rest for a few mins, then slice."
    },
    {
      "heading": null,
      "description": "Dice the cucumber. Toss it in a bowl with the pickled onions and pomegranate seeds. Pick in most of the dill, season with salt and pepper and give it all a mix."
    },
    {
      "heading": null,
      "description": "Zest the second lemon into a bowl and stir through the Greek yoghurt. Grate in the frozen feta and mix well."
    },
    {
      "heading": null,
      "description": "To serve, spoon the quinoa onto plates. Top with the sliced chicken, the cucumber salad and a dollop of the lemon feta yoghurt. Sprinkle with the rest of the dill. Serve with lemon wedges."
    }
  ],
