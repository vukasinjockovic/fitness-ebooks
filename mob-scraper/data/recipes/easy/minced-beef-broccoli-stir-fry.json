  "method": [
    {
      "heading": null,
      "description": "Mix all the sauce ingredients together in a bowl and set aside."
    },
    {
      "heading": null,
      "description": "Mince the garlic and ginger. Cut the broccoli into bite-sized florets."
    },
    {
      "heading": null,
      "description": "Place the broccoli in a heatproof bowl with the water. Cover and microwave for 3 mins until just tender. Drain and set aside. Alternatively, blanch it in boiling water for 2 mins."
    },
    {
      "heading": null,
      "description": "Place a wok or large frying pan over a high heat with the vegetable oil. Once hot, add the beef mince and stir-fry for 3–4 mins until browned."
    },
    {
      "heading": null,
      "description": "Add the ginger and garlic to the pan and cook for 2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Tip in the broccoli and pour over the sauce. Toss everything together for 2–3 mins until the sauce thickens and coats the beef and veg."
    },
    {
      "heading": null,
      "description": "Drizzle over the sesame oil and toss again. Remove from the heat."
    },
    {
      "heading": null,
      "description": "Serve topped with sesame seeds and extra white pepper if you fancy."
    }
