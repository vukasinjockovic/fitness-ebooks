  "method": [
    {
      "heading": null,
      "description": "Heat the oven to fan 180°C. Line a large baking tray with baking paper. Break the chocolate into 1-2cm chunks."
    },
    {
      "heading": null,
      "description": "Whisk the oil, water and sugar together until incorporated and thick."
    },
    {
      "heading": null,
      "description": "In another bowl, mix together the sugar, flour, baking powder, bicarbonate of soda, salt and chocolate chunks. Tip this flour mixture into the sugar and water mixture and stir until combined."
    },
    {
      "heading": null,
      "description": "Portion out 2 tbsp of cookie dough and roll into a ball then place on the prepared baking tray. Repeat for all the cookies, making sure to space them out. Finish with a sprinkle of flaky sea salt and bake for 10-15 mins, until golden and crisp on the edges."
    },
    {
      "heading": null,
      "description": "Let the cookies cool for 5-10 mins before serving."
    }
