  "method": [
    {
      "heading": null,
      "description": "Wash the spelt thoroughly in cold water then drain and transfer to the bottom of the steamer. Add cold water at a ratio of 2:1 water to spelt."
    },
    {
      "heading": null,
      "description": "Set the steamer over a medium heat and bring to a boil then cook, uncovered, for 40 mins."
    },
    {
      "heading": null,
      "description": "While the spelt is cooking, chop the courgette, red pepper and yellow pepper into 2cm chunks."
    },
    {
      "heading": null,
      "description": "For the dressing, combine the tahini, harissa, juice of the lemon, honey and olive oil in a mixing bowl. Slowly mix in enough warm water to achieve a creamy drizzling consistency."
    },
    {
      "heading": null,
      "description": "When the 40 mins of spelt cooking time is up, pop the top of the steamer over the base. Add the courgette, peppers and kale to the top of the steamer then cover with a lid and steam for 10 mins until the veggies and spelt are tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the parsley and dill."
    },
    {
      "heading": null,
      "description": "Remove the steamer from the heat. Season the spelt generously with sea salt then transfer to a large mixing bowl along with the veggies and most of the sauce, saving an extra drizzle of sauce for the top."
    },
    {
      "heading": null,
      "description": "To serve, divide the spelt and veggies between bowls and top with the remaining sauce, the chopped herbs and a drizzle of olive oil."
    }
  ],
