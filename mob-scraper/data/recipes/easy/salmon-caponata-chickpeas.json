  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion and celery and cut the aubergine into bite-sized chunks."
    },
    {
      "heading": null,
      "description": "Heat the olive oil in a deep frying pan over a medium heat. Add the veg along with a pinch of salt. Cook, stirring occasionally, for 10 mins until softened."
    },
    {
      "heading": null,
      "description": "Meanwhile, slice the olives, pick the basil leaves and finely slice the stalks."
    },
    {
      "heading": null,
      "description": "Add the basil stalks and tomato purée to the pan. Give everything a good stir and cook for 1 min, then tip in the chickpeas along with their liquid. Add the olives and sultanas. Give everything a good stir, simmer away for 5 mins then stir through most of the basil leaves and season with salt, pepper and vinegar to taste."
    },
    {
      "heading": null,
      "description": "Season the salmon fillets. Place the fish on top of the chickpeas and cover the pan with a lid (if you don’t have a lid that fits, you can use a large baking tray). Cook for 8-10 mins until the fish is cooked through – it should flake into large chunks. Scatter over the remaining basil and drizzle with a little extra olive oil, to serve."
    }
  ],
