  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Chop the cabbage into 2–3cm chunks. Chop the spring onion whites into 2cm pieces and thinly slice the greens. Thinly slice the chicken breasts, then toss in a bowl with the cornflour. Season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Pour half the olive oil into a large baking tray and tilt to coat the base and sides. Tip in the chicken, cabbage and spring onion whites, drizzle over the remaining oil and season with salt and pepper, toss together. Slide into the oven for 10–15 mins, until the veggies have softened and the chicken is cooked."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely grate the garlic and ginger into a small bowl. Add the orange juice, soy sauce, vinegar, honey and cornflour. Stir to combine, then taste and season if needed."
    },
    {
      "heading": null,
      "description": "Once the traybake is cooked, toss through the noodles and sauce. Return to the oven for another 5–10 mins until everything is hot and coated in the thickened sauce."
    },
    {
      "heading": null,
      "description": "Toss once more before serving the noodles between plates. Finish with a scattering of spring onion greens. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
  ],
