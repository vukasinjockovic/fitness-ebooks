  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C fan."
    },
    {
      "heading": null,
      "description": "Cut the cauliflower into bite-sized florets and tip into a large roasting tin. Toss with half of the turmeric, plus all of the cumin and coriander with a drizzle of olive oil and a big pinch of salt. Roast for 25–30 mins until golden and tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, peel and finely slice the garlic."
    },
    {
      "heading": null,
      "description": "Place a medium saucepan over a medium heat with a drizzle of olive oil. Fry the garlic for 1 min, then stir through the rice and remaining turmeric until coated."
    },
    {
      "heading": null,
      "description": "Pour in the stock, bring to the boil, then cover with a lid. Reduce the heat to low and cook for 10–12 mins until the liquid has been absorbed and the rice is fluffy."
    },
    {
      "heading": null,
      "description": "While the rice and cauliflower cook, mix the yoghurt, tamarind paste and honey in a small bowl until smooth."
    },
    {
      "heading": null,
      "description": "Slice the cucumber into thin half-moons and roughly chop the coriander."
    },
    {
      "heading": null,
      "description": "Pack the rice into lunchboxes, top with the roasted cauliflower, spoon over the tamarind yoghurt and finish with cucumber and coriander."
    }
  ],
