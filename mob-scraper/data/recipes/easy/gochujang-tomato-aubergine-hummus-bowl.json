  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Gochujang Tomato &amp; Sweet Onion Sauce."
    },
    {
      "heading": null,
      "description": "Heat the oven to 220°C fan."
    },
    {
      "heading": null,
      "description": "Trim the aubergines and chop into 2cm chunks. Tip onto a baking tray lined with baking paper, drizzle with olive oil and season with salt. Slide into the oven and roast for 20–25 mins, until soft and golden."
    },
    {
      "heading": null,
      "description": "Meanwhile, add the chickpeas and Gochujang Tomato &amp; Sweet Onion Sauce to a saucepan. Pick the coriander leaves and set aside. Finely slice the corinader stems, then stir them through the chickpeas. Trim and finely slice the spring onion. Toast the sourdough."
    },
    {
      "heading": null,
      "description": "Once the aubergines are cooked, tip them into the saucepan with the chickpeas. Set over a medium heat and stir until piping hot."
    },
    {
      "heading": null,
      "description": "Spoon the hummus into shallow bowls and spread it out to make a base. Top with the stew, then scatter over the spring onion, coriander leaves and sesame seeds. Serve with the toast on the side and get stuck in."
    }
  ],
