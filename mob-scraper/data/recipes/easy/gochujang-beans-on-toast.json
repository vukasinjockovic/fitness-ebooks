  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion and mince the garlic."
    },
    {
      "heading": null,
      "description": "Heat a medium pot with a drizzle of olive oil and add the onions with a pinch of salt. Cook over a medium heat for 3-4 mins, then add the garlic and ginger. Stir and cook for another 2 mins before adding the chopped tomatoes, drained beans, soy sauce, gochujang, sugar and paprika."
    },
    {
      "heading": null,
      "description": "Simmer over a low heat for about 10 mins until slightly thickened. Taste and adjust seasonings, adding plenty of black pepper, more soy sauce or gochujang, if you like."
    },
    {
      "heading": null,
      "description": "Meanwhile, toast the bread and thinly slice the spring onion."
    },
    {
      "heading": null,
      "description": "To serve, spoon the beans over the toast, add a spoon of yoghurt, top with the spring onion, sesame seeds and coriander. Finish with a good squeeze of lime and a final drizzle of sesame oil, if using."
    },
    {
      "heading": null,
      "description": "The beans keep well in the fridge for up to three days."
    }
  ],
