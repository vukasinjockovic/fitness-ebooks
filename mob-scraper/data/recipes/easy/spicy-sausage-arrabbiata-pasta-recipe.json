  "method": [
    {
      "heading": null,
      "description": "Squeeze out the sausagemeat from the sausages and transfer to a bowl. Finely chop the garlic, then halve the chillies, remove the seeds and finely chop. Finely chop the basil stalks. Crush the tomatoes with your hands."
    },
    {
      "heading": null,
      "description": "Heat a dash of olive oil in a frying pan over a medium heat. Add the sausagemeat and mash with a spoon until crumbly. Cook until golden then remove from the pan."
    },
    {
      "heading": null,
      "description": "Add the garlic, chilli and basil stalks to the pan, then cook for 1-2 mins. Tip in the tomatoes, bring to a simmer and cook for 5 mins. Return the sausagemeat to the pan, mix well, then cook for 5 mins. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the pasta following pack instructions. Drain, saving some of the cooking water."
    },
    {
      "heading": null,
      "description": "Tip the pasta into the ragù with a slosh of cooking water, then mix well. Serve with Parm and the basil leaves."
    }
  ],
