  "method": [
    {
      "heading": null,
      "description": "Cut the chicken and halloumi into bite-sized cubes and toss with the peri peri seasoning, a drizzle of olive oil and a pinch of salt."
    },
    {
      "heading": null,
      "description": "Set a large frying pan over a medium heat. Once hot, add the chicken and cook for 6-8 mins until golden and cooked through. Remove to a plate, then add the halloumi to the same pan and cook for 2 mins on each side until golden."
    },
    {
      "heading": null,
      "description": "Finely shred the cabbage using a knife or peeler. Chuck it into a bowl with the yoghurt, a good squeeze of lemon juice and a pinch of salt. Roughly chop the parsley and mix it through."
    },
    {
      "heading": null,
      "description": "Toast the flatbreads in a dry pan until warm and slightly charred."
    },
    {
      "heading": null,
      "description": "Load them up with a generous spoonful of slaw, then pile on the chicken and halloumi. Finish with a squeeze of lemon and a drizzle of hot sauce, if you like."
    }
  ],
