  "method": [
    {
      "heading": null,
      "description": "Finely slice your onions. Finely chop your garlic and ginger."
    },
    {
      "heading": null,
      "description": "Add a good glug of vegetable oil to a sauté pan. Add your onions and cook for 15 mins over a medium heat, until they are fully softened and have just begun to caramelise. Add your garlic, ginger and tomato purée, then cook for 2 mins."
    },
    {
      "heading": null,
      "description": "Tip in your chilli powder, garam masala and dried coriander, then add your water and your cream. Bring to a gentle simmer and simmer for 5 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, cut your tofu into large chunks. Remove the outer leaves from the cauliflower and cut it into chunky florets."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a medium heat. Add a big splash of olive oil and add your tofu chunks and cook for 5 mins until each piece is golden on all sides."
    },
    {
      "heading": null,
      "description": "Pour your sauce into a blender, then blitz until you have a smooth consistency."
    },
    {
      "heading": null,
      "description": "Pour the sauce back into the pan over a medium heat. Tip in the cauliflower florets and add 100ml of water. Cover with a lid and cook for 15 mins until the cauliflower is cooked through. Stir through your tofu. Add your butter, then season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Finish your curry with a drizzle of kefir and some coriander leaves."
    }
  ],
