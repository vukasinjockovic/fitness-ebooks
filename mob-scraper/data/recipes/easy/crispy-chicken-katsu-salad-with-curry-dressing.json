  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 210°C. Add the fish fingers to a baking tray and bake for 15 mins, turning halfway. You can also air-fry them at 180°C for 10 mins."
    },
    {
      "heading": null,
      "description": "Peel and finely slice the red onion. Add to a bowl with a big pinch of salt and the juice of half a lemon. Massage gently and set aside to pickle."
    },
    {
      "heading": null,
      "description": "Heat the olive oil in a small pan over a low heat. Grate in the garlic and cook for 30 secs until fragrant. Stir in the curry powder, cook for another 10 secs, then take it off the heat."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix together the yoghurt, mayonnaise and mango chutney. Add the garlic curry oil and stir to combine. Loosen the dressing with a splash of water (one tablespoon at a time) until it’s the consistency of double cream. Season with salt and pepper to taste."
    },
    {
      "heading": null,
      "description": "Quarter the radishes. Halve the cucumber lengthways, then again into quarters. Chop into small chunks."
    },
    {
      "heading": null,
      "description": "Finely shred the hispi cabbage and add to a large bowl with the remaining lemon juice, sesame oil and a pinch of salt. Massage for 1 min until it just starts to soften."
    },
    {
      "heading": null,
      "description": "Heat the rice according to pack instructions. Tip into the cabbage bowl along with the cucumber and radish, then toss everything together."
    },
    {
      "heading": null,
      "description": "To serve, divide the salad between plates. Top with crispy fish fingers, a generous drizzle of curry dressing, the pickled onions, sesame seeds and fresh coriander."
    }
  ],
