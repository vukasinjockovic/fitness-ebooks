  "method": [
    {
      "heading": null,
      "description": "Peel and chop the chorizo into small chunks. Chuck it into a medium deep frying pan over a medium heat and cook for about 3 mins, stirring often, until it releases its oil and starts to crisp. Scoop out a few crispy bits to use as a garnish."
    },
    {
      "heading": null,
      "description": "Peel and finely slice the garlic and stir it into the pan. Cook for 1 min until softened, then pour in the tomatoes and the cannellini beans — liquid and all. Bring to the boil."
    },
    {
      "heading": null,
      "description": "Cut the fish into bite-sized chunks. Add the fish and prawns to the pan, then scatter the spinach over the top. Cover with a lid and simmer gently for 3–4 mins, or until the prawns are pink and the fish is opaque and cooked through."
    },
    {
      "heading": null,
      "description": "Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Pick the parsley leaves."
    },
    {
      "heading": null,
      "description": "Dish up the stew, scatter over the crispy chorizo bits and top with parsley. Serve with crusty bread, if you fancy."
    }
  ],
