  "method": [
    {
      "heading": null,
      "description": "Season the cod generously with salt and pepper and leave in the fridge for 15 mins. Meanwhile, slice ½ of the lime and slice the pak choi. Peel the garlic and ginger."
    },
    {
      "heading": null,
      "description": "Heat the grill to high. Drizzle the cod with oil and pop under the grill for 8 mins until cooked through. Set aside."
    },
    {
      "heading": null,
      "description": "Meanwhile, blitz the thai red curry paste, garlic, ginger and ½ the coconut milk in a blender. Heat a large pan over a medium heat and pour in the blended mixture along with the drained chickpeas and the rest of the coconut milk. Season with the fish sauce and simmer for 10 mins. Add the edamame and leave to simmer for 1 min, then add the pak choi and stir until it starts to wilt."
    },
    {
      "heading": null,
      "description": "Squeeze in the juice of ½ the limes. Taste and adjust seasoning with salt and pepper, if needed."
    },
    {
      "heading": null,
      "description": "Plate up the chickpea curry and top with the cod. Garnish with coriander, a wedge of lime and some sliced spring onions if using."
    }
  ],
