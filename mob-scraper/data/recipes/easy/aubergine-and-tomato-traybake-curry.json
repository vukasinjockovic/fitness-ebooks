  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 200°C/400°F."
    },
    {
      "heading": null,
      "description": "Cut your aubergines into batons."
    },
    {
      "heading": null,
      "description": "Toss them into a large roasting tray along with your cherry tomatoes. Grate in your garlic and ginger, then add the coriander, cumin, turmeric and chilli powder. Drizzle with veg oil and salt. Give it a good toss to coat. Roast for 35 mins."
    },
    {
      "heading": null,
      "description": "Remove your tray from the oven. Add your chickpeas, chopped tomatoes and coconut milk and stir to combine. Return to the oven for another 25 mins, by which time your sauce should be nice and thick."
    },
    {
      "heading": null,
      "description": "Finely slice your green chillies and chop your coriander."
    },
    {
      "heading": null,
      "description": "Season the curry to taste, then sprinkle with green chillies and coriander. Serve either over rice or with flatbreads."
    }
