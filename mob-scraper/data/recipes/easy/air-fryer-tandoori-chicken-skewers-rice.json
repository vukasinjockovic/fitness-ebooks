  "method": [
    {
      "heading": null,
      "description": "Chop the chicken into chunks. Put all of the spices, yoghurt, tomato purée, garlic and ginger into a bowl. Squeeze in the lemon juice and add a dash of red food colouring, if you like. Add the chicken and coat well."
    },
    {
      "heading": null,
      "description": "Thread the chicken chunks onto skewers and cook them in the air fryer at 200°C for 17 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, put the fat-free yoghurt, juice of both limes, the mint and a pinch of salt and pepper into a blender. Whizz until smooth."
    },
    {
      "heading": null,
      "description": "Serve the chicken skewers with the yoghurt dip and flatbreads or rice."
    }
  ],
