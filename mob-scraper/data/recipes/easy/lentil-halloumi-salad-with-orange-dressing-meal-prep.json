  "method": [
    {
      "heading": null,
      "description": "Heat grill to high. In a large bowl, whisk together the olive oil, red wine vinegar, and the juice of half the orange. Season with salt and pepper. Finely chop the shallot and add it to the bowl."
    },
    {
      "heading": null,
      "description": "Drain and rinse the lentils, then tip them into the bowl with the shallot. Finely chop the parsley and dice the beetroot, then add both to the bowl. Toss to combine."
    },
    {
      "heading": null,
      "description": "Slice the halloumi into thick pieces and place them on a tray lined with foil. Grill for 3–4 mins on each side until golden and crisp around the edges."
    },
    {
      "heading": null,
      "description": "Add the grilled halloumi and rocket to the salad. Toss everything together until coated in the dressing, then taste and adjust the seasoning if needed."
    },
    {
      "heading": null,
      "description": "Spoon your salad into your Tupperware containers. Box up and pop in the fridge, ready for when you need it. These keep for 3 days in the fridge."
    }
  ],
