  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C fan. Dice the broccoli into small pieces. Cook the rice following pack instructions, adding the broccoli 3 mins before the end of the cooking time."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the spring onions. Dice the chicken into 3cm pieces. In a bowl or flat tray, mix the garlic powder, chilli powder, flour and a pinch of salt."
    },
    {
      "heading": null,
      "description": "Toss the chicken in the mix to coat evenly, then transfer to a baking tray and drizzle with olive oil. Slide into the hot oven to roast for 10 mins."
    },
    {
      "heading": null,
      "description": "Mince the garlic then add to a bowl along with the gochujang, soy sauce, honey and the juice of the limes. Mix to combine then pour over the chicken and pop it back in the oven for another 5 mins until sticky."
    },
    {
      "heading": null,
      "description": "Box or plate up the broccoli rice, top with the sticky chicken, and drizzle over any remaining sauce. Scatter over the spring onions and sesame seeds. It will keep well in the fridge for 3 days."
    }
  ],
