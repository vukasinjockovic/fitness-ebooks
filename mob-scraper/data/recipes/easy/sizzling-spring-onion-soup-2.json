  "method": [
    {
      "heading": null,
      "description": "Set a pot of water over a medium-high heat and bring to the boil. Add the wontons and noodles, then cook following pack instructions."
    },
    {
      "heading": null,
      "description": "Heat the broth in a pot over medium-high heat and bring to a boil, then turn the heat down and let it simmer."
    },
    {
      "heading": null,
      "description": "Meanwhile, combine all the seasonings in one bowl. Mince the garlic and slice the spring onion greens. Divide the garlic, spring onions and coriander between two serving bowls, then add half of the seasoning mixture to each bowl."
    },
    {
      "heading": null,
      "description": "Heat the vegetable oil in a pot set over a medium-high heat for 2 mins (keep your eye on the oil and make sure no water touches it!), then pour the hot oil over your seasonings and mix well."
    },
    {
      "heading": null,
      "description": "Add half the cooked noodles to each bowl, pour half the broth on top of each serving, then finish with the cooked wontons and a drizzle of chilli oil."
    }
  ],
