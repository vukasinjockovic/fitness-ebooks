  "method": [
    {
      "heading": null,
      "description": "Chop the halloumi blocks into 2cm chunks. Trim the chilli and finely chop. Trim, peel, and grate the garlic and ginger."
    },
    {
      "heading": null,
      "description": "Place a large frying pan on medium heat with a splash of oil. Once hot, add the halloumi and sear on all sides until golden, 5-8 mins. Set your halloumi aside afterwards."
    },
    {
      "heading": null,
      "description": "Add a fifth of your spinach into a blender with the yoghurt and 20ml of water, blend until completely smooth."
    },
    {
      "heading": null,
      "description": "Add another splash of oil into the now-empty frying pan on medium heat. Tip the garlic, ginger and chilli into the hot oil, season with salt and cook stirring for 2-3 mins. Add the garam masala and black pepper through, cook for 1 min."
    },
    {
      "heading": null,
      "description": "Add the rest of the spinach, a handful at a time, into the spiced mixture and cook until wilted, 4-5 mins. Then, add the frozen peas and cook until hot, 2-3 mins. Remove from the heat then stir in the blended spinach yoghurt. Add the halloumi back in and season with salt, pepper and lemon juice."
    },
    {
      "heading": null,
      "description": "Cook the rice according to package instructions. Serve the rice and the super green spiced halloumi with lemon wedges on the side."
    }
  ],
