  "method": [
    {
      "heading": null,
      "description": "Cook your brown rice according to packet instructions and leave to cool. Peel and cut your mango into wedges."
    },
    {
      "heading": null,
      "description": "Place your cucumbers, spring onions, coriander and jalapeños onto a board and chop into even-sized pieces. Add the mango, avocado, and prawns to the chopping board and continue to chop."
    },
    {
      "heading": null,
      "description": "Tip your chopped ingredients into a bowl along with the brown rice and add ¾ of the tortilla chips, roughly crushing them in your hand."
    },
    {
      "heading": null,
      "description": "Make the dressing by mixing together the jalapeño juice from the jar along with your honey, oil, and salt. Shake it forcefully inside of the jar to emulsify."
    },
    {
      "heading": null,
      "description": "Pour the dressing into the bowl and toss it all together."
    },
    {
      "heading": null,
      "description": "Serve with the remaining tortilla chips crushed on top."
    }
