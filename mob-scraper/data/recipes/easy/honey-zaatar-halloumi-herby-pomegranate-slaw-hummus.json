  "method": [
    {
      "heading": null,
      "description": "Slice the cabbage in half lengthways and finely shred. Thinly slice the red onion. Roughly chop three-quarters of the dill. Add everything to a large bowl."
    },
    {
      "heading": null,
      "description": "Drizzle over the pomegranate molasses, squeeze in the juice of half a lemon, and add the olive oil. Season with salt and pepper, then mix well to combine. Let the slaw sit and lightly pickle while you cook the halloumi."
    },
    {
      "heading": null,
      "description": "Cut the halloumi into 2cm cubes. Set a frying pan over medium-high heat (no oil needed). Fry the halloumi cubes for 1–2 mins on each side until golden and crisp. Drizzle in the honey and sprinkle over the za’atar. Cook for 30 seconds, tossing to coat, then take off the heat."
    },
    {
      "heading": null,
      "description": "Divide the hummus between two containers or plates. Spoon over the herby slaw, top with the sticky halloumi and finish with the remaining dill."
    }
  ],
