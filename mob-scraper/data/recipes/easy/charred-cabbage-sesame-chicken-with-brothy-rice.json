  "method": [
    {
      "heading": null,
      "description": "Trim and thinly slice the spring onions, separating the whites and greens. Chop the cabbage into 2–3cm chunks. Thinly slice the chilli, if using."
    },
    {
      "heading": null,
      "description": "Pour the chicken stock into a saucepan and add the chicken breasts, spring onion whites and half the sesame oil. Season with salt and pepper, then place over a high heat. Bring to the boil, cover with a lid and turn the heat down to low. Poach the chicken for 10–15 mins or until cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, heat a frying pan over a high heat (no oil needed). Add the cabbage, season with salt and cook, stirring occasionally, until it starts to wilt and char in spots. Set aside."
    },
    {
      "heading": null,
      "description": "Shred the chicken. In a small bowl, stir a splash of the hot broth into the miso to make a loose paste, then pour it back into the stock. Taste and adjust seasoning with salt and pepper, if needed."
    },
    {
      "heading": null,
      "description": "Toss the shredded chicken with the sesame seeds, chilli and ½ of the remaining sesame oil. Taste and season again if needed."
    },
    {
      "heading": null,
      "description": "Reheat the rice and divide between bowls. Ladle the broth over the top, then spoon on the chicken and cabbage. Finish with a sprinkle of spring onion greens and a drizzle of the remaining sesame oil."
    }
  ],
