  "method": [
    {
      "heading": null,
      "description": "Remove the stems from the fresh jalapeńos then cut into strips. Peel and dice the carrots and peel the garlic cloves. Peel and halve the shallots lengthways, leaving the root ends intact so each half holds as one piece. Cut the cauliflower into tiny florets."
    },
    {
      "heading": null,
      "description": "Heat the sunflower oil in a large saucepan set over a medium heat. Add all the vegetables and fry for around 5 mins, stirring constantly."
    },
    {
      "heading": null,
      "description": "Add the white wine vinegar, water, salt, oregano, peppercorns and bay leaves. Cook over low heat for 10 mins, stirring constantly."
    },
    {
      "heading": null,
      "description": "Turn the heat off and leave the mixture to fully cool. Once cooled, transfer to a sterilized glass jar. Keep in the fridge and enjoy whenever you like!"
    }
  ],
