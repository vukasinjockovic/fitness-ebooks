  "method": [
    {
      "heading": null,
      "description": "Roughly chop the garlic and grind the black pepper."
    },
    {
      "heading": null,
      "description": "Add the garlic, black pepper, chilli flakes and butter to a pan and cook for 5 mins on low-medium heat until the garlic is lightly toasted."
    },
    {
      "heading": null,
      "description": "Add in 2 tbsp of water and all the spinach. Allow the spinach to wilt down for 5 mins and then continue cooking to draw out most of the water. This should take around 10 mins."
    },
    {
      "heading": null,
      "description": "Grate in the Parmesan and add a big pinch of salt."
    },
    {
      "heading": null,
      "description": "Stir this together until creamy and serve with more Parmesan and black pepper. Meanwhile, toast your bread and make your crispy garlic eggs."
    },
    {
      "heading": null,
      "description": "Thinly slice the garlic and fry in a generous glug of olive oil in a frying pan set over a medium heat, until starting to crisp. Crack in the eggs and spoon over the crispy garlic oil as they cook, until the whites are set."
    },
    {
      "heading": null,
      "description": "Once your bread is toasted, heap your cheesy spinach mixture evenly onto every slice. Top with the eggs and more Parmesan."
    }
