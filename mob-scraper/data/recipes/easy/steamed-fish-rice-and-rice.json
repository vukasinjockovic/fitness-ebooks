  "method": [
    {
      "heading": null,
      "description": "Rinse the rice in cold water until it runs clear. Add it to a small saucepan along with 200ml of water and a tin of coconut milk. Bring to the boil, then cover with a lid, turn the heat down and simmer for 10 mins. Remove from the heat and let it sit until you’re ready to serve."
    },
    {
      "heading": null,
      "description": "Get a pan of water on and pop in the tenderstem and fish. Steam for 5 mins, until the fish is cooked through and tenderstem is al dente."
    },
    {
      "heading": null,
      "description": "To the rice, add the juice of ½ a lime and season well with salt. Fluff up with a fork to mix."
    },
    {
      "heading": null,
      "description": "Serve up on a plate topped with finely chopped coriander and drizzle with green chilli oil."
    }
