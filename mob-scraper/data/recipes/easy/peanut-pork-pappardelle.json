  "method": [
    {
      "heading": null,
      "description": "Whisk together the peanut butter, soy sauce, half of the chilli oil, the juice from 2/3 limes and a splash of water to create a loose sauce."
    },
    {
      "heading": null,
      "description": "Finely shred the cabbage and put a pot of water on to boil. Season with salt."
    },
    {
      "heading": null,
      "description": "Preheat a wok or large frying pan over a high heat. Add a shot of olive oil and tip in the pork mince. Break up with a spoon and fry until brown and crispy."
    },
    {
      "heading": null,
      "description": "While the pork sizzles away, finely slice the garlic and onion and cut the ginger into thin matchsticks. Once the pork is crispy, tip them into the pan and stir fry through the meat for 2-3 mins."
    },
    {
      "heading": null,
      "description": "Tip in the cabbage and cook until wilted. Drop the pappardelle into the boiling water and cook until al dente."
    },
    {
      "heading": null,
      "description": "Transfer the cooked pasta to the pork and pour over the peanut sauce. Toss together to coat the pasta and loosen with cooking water if needed. Cut the chives into 3cm lengths and toss most through the pasta."
    },
    {
      "heading": null,
      "description": "Divide between warm bowls and serve with the remaining chilli oil, lime wedges, thinly sliced spring onions and the remaining cut chives."
    }
  ],
