  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 180°C. Season your chicken breasts with salt, pepper and a good drizzle of olive oil."
    },
    {
      "heading": null,
      "description": "Put your chicken breasts on a baking tray and cook in the oven for 30 mins until cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely dice your cucumber and avocado, finely chop your basil, and grate your Parmesan."
    },
    {
      "heading": null,
      "description": "When your chicken is cooked, chop it into even-sized pieces. Combine it with all the remaining ingredients in a large mixing bowl."
    },
    {
      "heading": null,
      "description": "Now it’s time to ‘smoosh’ the mixture over a few slices of toast, a pitta bread, a bagel, or whatever you fancy."
    }
