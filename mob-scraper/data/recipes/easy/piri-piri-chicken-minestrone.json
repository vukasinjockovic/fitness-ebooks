  "method": [
    {
      "heading": null,
      "description": "Finely dice the carrot, celery and onion."
    },
    {
      "heading": null,
      "description": "Place a pot over a medium-high heat. Once hot, add the olive oil followed by the diced veg. Cook for 5–7 mins until softened."
    },
    {
      "heading": null,
      "description": "Meanwhile, chuck all the piri-piri sauce ingredients into a blender and blitz until smooth."
    },
    {
      "heading": null,
      "description": "Pour the piri-piri sauce into the pot along with the chicken stock. Season with salt and bring to the boil. Once boiling, add the chicken breasts, cover with a lid and reduce the heat to low. Let the chicken poach for 10–15 mins or until cooked through."
    },
    {
      "heading": null,
      "description": "Roughly snip the watercress using scissors."
    },
    {
      "heading": null,
      "description": "Transfer the cooked chicken to a board and turn the heat back up. Once the soup is boiling again, add the pasta and cook following pack instructions until al dente."
    },
    {
      "heading": null,
      "description": "Meanwhile, shred the chicken."
    },
    {
      "heading": null,
      "description": "When the pasta is ready, remove the pot from the heat and stir through the shredded chicken and watercress until wilted. Taste and season with salt and pepper if needed."
    },
    {
      "heading": null,
      "description": "Ladle into bowls and get stuck in."
    }
  ],
