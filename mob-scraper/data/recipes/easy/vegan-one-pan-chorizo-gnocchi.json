  "method": [
    {
      "heading": null,
      "description": "Break your plant-based sausages up into small chunks and start to fry in a large pan. Add in the chilli powder and paprika, cook for a few minutes until you have a fragrant red oil."
    },
    {
      "heading": null,
      "description": "Chop your peppers into cubes and add them to the pan, stirring them and allowing them to fry in the spicy paprika oil."
    },
    {
      "heading": null,
      "description": "Once the plant bases sausages and peppers begin to cook, add your cherry tomatoes whole. Stir and continue to cook on a high heat. Slice your red chili and garlic and add them to the pan."
    },
    {
      "heading": null,
      "description": "In a separate bowl, cover your gnocchi with boiling water and allow it to soak for 10 mins."
    },
    {
      "heading": null,
      "description": "While the gnocchi is soaking, pour the red wine vinegar into the frying pan and stir it in with the plant-based cream cheese. You should now have a creamy sauce. Add a pinch of salt and pepper to taste. Roughly chop your basil and throw that in there too."
    },
    {
      "heading": null,
      "description": "Drain your gnocchi and thoroughly mix it into your sauce. Serve up with a sprinkling of fresh basil. Get stuck in."
    }
  ],
