  "method": [
    {
      "heading": null,
      "description": "Pour the water out of the top of the chickpea jar into a jug then tip the remaining chickpeas and their liquid into a blender or food processor. Add the tahini, finely grate in the garlic if using and add the ground cumin and the juice of ½ the lemon, then blitz."
    },
    {
      "heading": null,
      "description": "You want to keep blitzing the hummus until it is silky smooth. If still a little coarse, add a little more chickpea liquid and blitz again. Season to taste with salt, pepper and more lemon juice if you like."
    },
    {
      "heading": null,
      "description": "Spoon or pour the hummus into a bowl, top with a generous drizzle of extra virgin olive oil and a sprinkling of za’atar. Serve with everything. Obvs."
    }
