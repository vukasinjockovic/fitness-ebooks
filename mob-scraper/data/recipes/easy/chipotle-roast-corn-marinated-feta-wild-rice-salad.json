  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C fan. Drain the sweetcorn really well, then spread it out on a baking tray. Drizzle over half of the olive oil, season with salt and pepper, and roast for 15–20 mins, tossing halfway, until golden and crisp at the edges."
    },
    {
      "heading": null,
      "description": "Toast the cumin seeds in a dry frying pan over medium heat for 1–2 mins until fragrant, then tip into a bowl. Crumble in the feta into big bite-sized chunks. Zest and juice in one of the limes, add the remaining olive oil, and stir gently. Set aside to marinate at room temperature while the corn roasts."
    },
    {
      "heading": null,
      "description": "Heat the rice pouch according to pack instructions. Tip into a large bowl, season with salt and pepper, then zest and juice in the second lime. Stir through the chipotle paste and baby spinach while the rice is still warm to help it wilt slightly."
    },
    {
      "heading": null,
      "description": "Divide the chipotle rice between containers or bowls. Top with the roasted corn, marinated feta and a scattering of fresh coriander."
    }
  ],
