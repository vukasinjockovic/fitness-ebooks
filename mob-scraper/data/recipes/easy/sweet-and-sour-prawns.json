  "method": [
    {
      "heading": null,
      "description": "Wash your Tilda Easy Cook Long Grain Rice, and pop it in a pan. Cover with cold water and cook for 10 minutes until tender. Drain the rice and allow to cool."
    },
    {
      "heading": null,
      "description": "Chop up the onions and peppers into large pieces. Roughly chop the garlic, spring onions and red chilli. Whisk the three eggs in a bowl. Combine 1 tsp of cornflour with 2 tbsps of water into a cup to make a slurry."
    },
    {
      "heading": null,
      "description": "Add your pineapple juice, apple cider vinegar, sugar, soy sauce and ketchup to a medium sized saucepan set over a medium heat. Bring to a boil, then let it simmer for 2 minutes until your sugar dissolves. Pour in the cornflour slurry and cook until it thickens, about 3 minutes."
    },
    {
      "heading": null,
      "description": "In a bowl mix the prawns, white sugar, white pepper powder and a pinch of salt. Then crack in the egg and give it a good mix. Add in 50g of cornflour and mix well and set aside."
    },
    {
      "heading": null,
      "description": "Heat a good glug of oil in a wok over a medium-high heat. Fry your prawns for 1 minute or until crisp and starting to curl. Remove from the pan and drain on kitchen paper."
    },
    {
      "heading": null,
      "description": "Heat up a large wok and add in a big glug of oil. Add your onion and red pepper and stir fry for a few minutes until softened and starting to char. Tip your prawns and sauce. Give the mixture a really good mix and cook for 3 minutes until it is piping hot. Put into a serving dish."
    },
    {
      "heading": null,
      "description": "For the egg fried rice, heat up a large wok until it starts to smoke. Pour in a large glug of oil and add in the garlic. Fry for 30 seconds until fragrant."
    },
    {
      "heading": null,
      "description": "Pour in your eggs and scramble until they are fluffy for 1 minute."
    },
    {
      "heading": null,
      "description": "Push the eggs to the side and add in your cooked rice. Push the rice down to separate the grains. Add in the soy sauce, sesame oil and white pepper. Mix well so the rice is well coated."
    },
    {
      "heading": null,
      "description": "Finally, add the spring onions and chilli. Stir fry for 1 minute so they are well dispersed in the rice."
    },
    {
      "heading": null,
      "description": "Spoon the egg fried rice in a bowl, pour over your sweet and sour prawns and enjoy."
    }
  ],
