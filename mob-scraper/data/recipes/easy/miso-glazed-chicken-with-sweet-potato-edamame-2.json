  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Peel and finely chop the garlic. Add it to a shallow bowl with the miso paste, soy sauce, honey and crunchy chilli oil. Whisk until smooth."
    },
    {
      "heading": null,
      "description": "Score the chicken breasts in a criss-cross pattern to help the marinade sink in and speed up cooking. Add to the bowl and coat well. Transfer to a roasting tray."
    },
    {
      "heading": null,
      "description": "Peel and cut the sweet potatoes into 3cm chunks, then toss them through the marinade."
    },
    {
      "heading": null,
      "description": "Tip the potatoes into the roasting tray and slide into the oven. Roast for 18–20 mins, giving the sweet potato a toss halfway through."
    },
    {
      "heading": null,
      "description": "With 5 mins to go, drizzle the broccoli with olive oil and season with salt and pepper. Add the broccoli and edamame to the tray with the chicken and sweet potato."
    },
    {
      "heading": null,
      "description": "Divide the sweet potato, edamame, broccoli and chicken between Tupperware containers. Scatter over the mint leaves and sesame seeds. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
  ],
