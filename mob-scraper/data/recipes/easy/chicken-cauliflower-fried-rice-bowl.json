  "method": [
    {
      "heading": null,
      "description": "Peel and finely slice the ginger into matchsticks. Peel and finely chop the garlic."
    },
    {
      "heading": null,
      "description": "Heat half of the sesame oil in a large nonstick frying pan over a medium-high heat. Add the chicken mince and cook for about 4 mins, breaking it up with a wooden spoon until no longer pink. Add half the soy sauce and half the gochujang, stir to coat, then transfer to a plate."
    },
    {
      "heading": null,
      "description": "Add the remaining sesame oil to the pan. Add the ginger and garlic and cook for 1 min until fragrant."
    },
    {
      "heading": null,
      "description": "Tip in the frozen red peppers and edamame and stir-fry for 2–3 mins until heated through. Push everything to one side of the pan and spritz a little olive oil spray onto the empty space. Crack in the eggs and scramble them with a spoon, then fold through the veg."
    },
    {
      "heading": null,
      "description": "Add the cooked chicken back to the pan along with the frozen cauliflower rice, remaining gochujang and soy sauce. Stir everything together and cook for 2–3 mins until piping hot. Season to taste. Pick the coriander leaves."
    },
    {
      "heading": null,
      "description": "Spoon the rice into bowls, scatter over the coriander and serve with lime wedges."
    }
  ],
