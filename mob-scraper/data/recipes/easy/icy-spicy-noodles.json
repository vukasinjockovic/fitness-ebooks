  "method": [
    {
      "heading": null,
      "description": "Quarter the spring onions, slice the ginger and smash the garlic cloves. Place in a saucepan with the beef stock, pear juice and soy sauce."
    },
    {
      "heading": null,
      "description": "Bring to a simmer over high heat, reduce the heat to medium and cook for 15 mins."
    },
    {
      "heading": null,
      "description": "Strain the stock into a large mixing bowl, add the ice cubes and stir to combine."
    },
    {
      "heading": null,
      "description": "Season with salt, to taste, then store in the fridge until ready to use."
    },
    {
      "heading": null,
      "description": "Slice the cucumber into small matchsticks."
    },
    {
      "heading": null,
      "description": "Place in a bowl and toss with 1 tsp salt, then add the rice vinegar and sugar and toss to combine."
    },
    {
      "heading": null,
      "description": "If you’re making the spicy sauce, place the gochujang, soy sauce, sugar and gochugaru in a bowl."
    },
    {
      "heading": null,
      "description": "Grate in the garlic and pear and mix to combine."
    },
    {
      "heading": null,
      "description": "Last bit of cooking. Bring a large pot of water to the boil. Season with salt, add the noodles and cook according to the packet instructions."
    },
    {
      "heading": null,
      "description": "Drain, rinse with cold water and drain again."
    },
    {
      "heading": null,
      "description": "To assemble, place the noodles in a bowl. Top with some of the pickled cucumber and a pinch of kimchi."
    },
    {
      "heading": null,
      "description": "Ladle in the cold broth and add some of the spicy sauce."
    },
    {
      "heading": null,
      "description": "Add a couple of ice cubes, stir to combine, then tuck in and enjoy."
    }
  ],
