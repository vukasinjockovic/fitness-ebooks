  "method": [
    {
      "heading": null,
      "description": "Put the flour, a big pinch of salt and a generous grind of pepper into a large bowl. Set aside."
    },
    {
      "heading": null,
      "description": "Put the milk, mustard, dill, and half the parsley into a blender, then whizz until smooth and well combined. Crack in the eggs and whisk. Slowly pour this mixture into the flour, whisking all the time, until you get a smooth batter. Set aside for 30 mins."
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Put the sausages onto a large, deep roasting tin and drizzle with a half of the olive oil. Cook in the oven for 10 mins, turning once, until really golden."
    },
    {
      "heading": null,
      "description": "When the sausages are golden, carefully remove the tray from the oven and pour the batter over. Quickly transfer it back to the oven and cook for 30-35 mins until puffed and golden."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the salad by finely slicing the red onion and fennel. Add to a bowl with the sumac, juiced lemon, the remaining olive oil and remaining parsley, leaves picked and stalks discarded. Mix the harissa with the yoghurt and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "When the toad is done, remove from the oven and allow to cool before serving (or topping) with the fennel salad."
    }
  ],
