  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 190°C. Finely slice the onions and lay them out on a large baking tray in a thin layer. Season with salt and pepper and a good drizzle of olive oil."
    },
    {
      "heading": null,
      "description": "Slice the cauliflower in half and season each half with za’atar, plenty of olive oil, salt and pepper, getting into all of the grooves. Place the cauliflower onto the baking tray with the onions. Cover the tray tightly with foil and bake for 30 mins."
    },
    {
      "heading": null,
      "description": "Remove the foil, add the balsamic vinegar and stir well. Return to the oven for 15-20 mins until the onions are caramelised and the cauliflower is starting to char."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the hummus. Drain the chickpeas, reserving half of the water from the jar. Put the reserved water, chickpeas, tahini, lemon juice, garlic and olive oil into a blender and blitz until smooth. Keep the hummus in the blender until the onions and cauliflower are ready."
    },
    {
      "heading": null,
      "description": "When the onions and cauliflower are cooked, add four heaped spoons of the onions to the hummus and blend again until smooth. Taste and adjust seasonings."
    },
    {
      "heading": null,
      "description": "To make the herby drizzle, finely chop the parsley and add to a small bowl. Zest the lemon into the bowl and add half of the juice, the pine nuts, chilli flakes and plenty of olive oil, plus salt and pepper to finish."
    },
    {
      "heading": null,
      "description": "To plate up, spread the hummus over a platter and top with the remaining onions and the cauliflower. Drizzle some extra tahini and the herby drizzle on top."
    }
  ],
