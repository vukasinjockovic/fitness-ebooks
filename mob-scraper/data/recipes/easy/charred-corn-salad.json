  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Place your cobs of corn in a baking dish, cover in olive oil, salt and pepper and bake for 40 minutes."
    },
    {
      "heading": null,
      "description": "Meanwhile, break apart the chorizo sausage into a non-stick pan and stir until cooked. Remove the chorizo, place in a bowl and set aside. Leave the chorizo fat in the pan."
    },
    {
      "heading": null,
      "description": "Chop your spring onions into evenly sized pieces and cook in the leftover chorizo fat. Add the chorizo back into the pan and give it a good stir."
    },
    {
      "heading": null,
      "description": "Slice your sweet peppers into rings and slice up the lettuce. Roughly chop the almonds. Remove the corn from the oven and use a knife to slice the corn off the cob."
    },
    {
      "heading": null,
      "description": "Add all of your ingredients into a large bowl. Break your Saint Agur into chunks, finely chop your parsley and scatter both into the salad bowl."
    },
    {
      "heading": null,
      "description": "Dressing time. In a jar, mix 6 tablespoons of olive oil with red wine vinegar, salt and pepper. Shake well with the lid on to ensure the dressing is fully mixed. Drizzle this all over your salad bowl."
    },
    {
      "heading": null,
      "description": "With tongs, toss the salad, making sure all the ingredients are combined. Dish up with extra Saint Agur and get stuck in."
    }
  ],
