  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Trim the woody ends of the asparagus and toss with olive oil, salt and pepper. Add to a baking tray and roast for 9-10 mins until tender and caramelised."
    },
    {
      "heading": null,
      "description": "While the asparagus is roasting, grab a pestle and mortar. Add the garlic clove and a big pinch of salt. Smash the garlic down and grind into a paste."
    },
    {
      "heading": null,
      "description": "Roughly chop the green and black olives, finely chop the shallot and add the lot to the mortar."
    },
    {
      "heading": null,
      "description": "Remove the flesh from the preserved lemons and finely slice the rind. Roughly chop the mint and add both to the salsa."
    },
    {
      "heading": null,
      "description": "Now bring everything together with a squeeze of lemon juice and plenty of olive oil."
    },
    {
      "heading": null,
      "description": "Pile the roasted asparagus onto a plate and top with plenty of olive salsa."
    }
