  "method": [
    {
      "heading": null,
      "description": "The first thing you’re going to want to do is de-seed your cucumbers. Now, get out a chopping board and chop up the peppers, cucumbers, and sugar snap peas into even-sized pieces."
    },
    {
      "heading": null,
      "description": "Add your prawns, avocado, mango, coriander, and mint onto the same chopping board and chop again. Add all your ingredients into a large mixing bowl."
    },
    {
      "heading": null,
      "description": "Heat up your quinoa according to package instructions and add it to the bowl with the rest of your chopped ingredients."
    },
    {
      "heading": null,
      "description": "Squeeze the juice from your limes and combine with the rest of the dressing ingredients. Add the dressing into the bowl and toss vigorously. Serve and enjoy."
    }
  ],
