  "method": [
    {
      "heading": null,
      "description": "Zest half the lemon and squeeze in ½ the juice (cut the remaining into wedges for serving). Blitz the cottage cheese, sriracha, lemon zest and juice in a blender until smooth and creamy. Transfer to a bowl, season with salt and pepper, and fold through the prawns."
    },
    {
      "heading": null,
      "description": "Finely slice the cornichons and finely chop the spring onions. Stir most of them through the prawn mix, saving a few for garnish."
    },
    {
      "heading": null,
      "description": "Wash and separate the baby gem leaves. Slice the avocado and quarter the cherry tomatoes."
    },
    {
      "heading": null,
      "description": "Mound the lettuce into serving bowls and top with the prawns, avocado and cherry tomatoes. Top with the remaining cornichons and spring onions, then dust with paprika. Serve with extra lemon wedges on the side."
    }
  ],
