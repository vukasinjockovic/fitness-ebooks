  "method": [
    {
      "heading": null,
      "description": "Heat the olive oil in a nonstick frying pan over a medium heat. Add the rice, season with salt and pepper and cook, stirring occasionally, for about 15 mins until starting to crisp."
    },
    {
      "heading": null,
      "description": "Chop the chives. Zest the lemon, then juice it. Add both to a small blender with the cottage cheese, most of the chives and sriracha. Blend until smooth, adding 1–2 tablespoons of water to loosen if needed. Season to taste with salt and pepper, then tip into a large bowl."
    },
    {
      "heading": null,
      "description": "Drain the tuna and chuck it into the bowl. Thinly slice the celery and radishes. Finely chop the red onion. Add them all to the bowl along with the chickpeas."
    },
    {
      "heading": null,
      "description": "Slice the avocado in half, remove the stone and chop the flesh into chunks. Fold it through the salad."
    },
    {
      "heading": null,
      "description": "To serve, divide the tuna salad between bowls and top with the crispy rice, scatter with the remaining chives and drizzle with more sriracha, if you like."
    }
  ],
