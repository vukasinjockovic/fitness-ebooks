  "method": [
    {
      "heading": null,
      "description": "Cut the pepper and half of the spring onions into strips. Set the spring onion strips aside for later and chop the remaining spring onions horizontally into coins. Crush the garlic cloves."
    },
    {
      "heading": null,
      "description": "Set a non-stick frying pan over a medium heat, then add the spring onion coins, peppers and garlic. Cook for a few minutes, then add the beef mince and fry for around 7 mins until cooked through."
    },
    {
      "heading": null,
      "description": "Add the teriyaki sauce, honey and soy sauce to the beef along with water. Stir and simmer for a few minutes over a medium heat until sticky."
    },
    {
      "heading": null,
      "description": "Combine the beef mix with half of the grated cheese in a large bowl. Wipe the frying pan clean."
    },
    {
      "heading": null,
      "description": "Heat up the tortilla wraps in the microwave to make them more flexible, then reheat the frying pan to a medium heat while dipping each wrap into the mix to cover the outside. Place each wrap, one at a time and saucy-side down, into the pan and add one-eighth of the beef mix plus one-eighth of the remaining grated cheese onto one half of the wrap, then fold over."
    },
    {
      "heading": null,
      "description": "Cook for a few minutes, then flip it over to cook the other side. Meanwhile, prepare your toppings by roughly chopping the coriander and slicing the red chilli."
    },
    {
      "heading": null,
      "description": "Once cooked, set the cooked tacos aside for a few minutes to cool, then top with the spring onion strips, chilli and coriander."
    }
  ],
