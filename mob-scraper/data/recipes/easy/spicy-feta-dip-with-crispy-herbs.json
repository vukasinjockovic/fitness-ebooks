  "method": [
    {
      "heading": null,
      "description": "Cut the top off the chillies and roughly chop, keeping the seeds in!"
    },
    {
      "heading": null,
      "description": "Add the feta, yoghurt, chopped chillies to the bowl of a food processor. Finely grate in the garlic and the zest and juice of one lemon. Add a glug of olive oil and whizz until smooth."
    },
    {
      "heading": null,
      "description": "Pick the herbs from their stems. Cover the base of a frying pan with olive oil and set over a medium heat. Add a basil leaf, and when it starts to fry and crackle, add a few more, they’ll fizz around a bit and when they stop, they’re done. Lift them out onto a paper towel to drain."
    },
    {
      "heading": null,
      "description": "Repeat with the remaining herbs, be careful that the oil doesn’t get too hot. Once your herbs are fried, sprinkle them with fine salt."
    },
    {
      "heading": null,
      "description": "Spread your dip out onto a platter and top with a drizzle of olive oil. Scatter with the crispy herbs and Aleppo pepper."
    },
    {
      "heading": null,
      "description": "Serve with steamy pitta breads and raw veggies for dipping."
    }
