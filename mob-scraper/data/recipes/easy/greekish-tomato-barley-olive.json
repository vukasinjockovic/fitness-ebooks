  "method": [
    {
      "heading": null,
      "description": "Rinse the pearl barley. Finely slice the garlic. Heat 2 tbsp olive oil in a pan over a medium heat and fry the garlic for 2 mins. Add the tomato purée, fennel seeds and cinnamon and cook for 1 min. Add the canned tomatoes, barley and stock, season with salt and pepper, bring to the boil then simmer for 45 mins, stirring often to prevent it from sticking to the bottom."
    },
    {
      "heading": null,
      "description": "Heat the grill and grill the broccoli for 8 mins, turning halfway. Meanwhile, finely slice the red onion and tip it into a bowl with the lemon juice. Tear the olives in half, chop the dill and add both to the bowl along with the broccoli. Give it a mix and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Divide the barley between your Tupperware containers and top with your broccoli and olive mix. Once they've cooled a bit, box up and pop in the fridge.\nThese will keep for up to 3 days in the fridge."
    }
  ],
