  "method": [
    {
      "heading": null,
      "description": "Start by mixing the miso paste, rice vinegar and sugar in a bowl. Rub the mixture all over the chicken breasts and set aside to marinate while you prep everything else."
    },
    {
      "heading": null,
      "description": "Rinse the rice 2–3 times under cold water until it runs clear. Add to a lidded saucepan with the water and a pinch of salt. Set over a medium heat. Once simmering, pop the lid on, reduce the heat to low and cook for 10 mins. Turn off the heat and leave to steam for another 10 mins. Fluff with a fork."
    },
    {
      "heading": null,
      "description": "Cut the broccoli into bite-sized florets and place in a heatproof bowl with a splash of water. Cover and microwave for 2½ mins until tender. Drain and toss with the soy sauce and sesame seeds."
    },
    {
      "heading": null,
      "description": "Heat the butter and vegetable oil in a large frying pan over a medium heat. Once sizzling, add the chicken breasts and cook for 4 mins on one side. Flip and cook for another 4–5 mins until golden and cooked through. Turn off the heat and leave to rest in the pan for 3–4 mins."
    },
    {
      "heading": null,
      "description": "Slice the chicken and plate everything up into Tupperware containers — fluffy rice, sesame broccoli and juicy miso chicken. Spoon over any buttery pan sauce and finish with a lemon wedge. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
  ],
