  "method": [
    {
      "heading": null,
      "description": "Dice the chicken breast, then season it with salt, pepper and the mixed herbs. Wrap it in foil and air fry at 180°C for 15 mins, then set aside.⁣"
    },
    {
      "heading": null,
      "description": "Meanwhile, halve the cherry tomatoes and dice the red onion. Combine all the sauce ingredients in a bowl and set aside."
    },
    {
      "heading": null,
      "description": "Tip the cooked chicken into the sauce bowl and set aside. Put the gnocchi into the air fryer, spray with the olive oil, then cook for around 12 mins at 190°C until crispy."
    },
    {
      "heading": null,
      "description": "Once the gnocchi is crispy, add the onion, tomatoes, chicken and sauce to the air fryer with the gnocchi. Roughly mix together, then top with the cheese and pine nuts and return to the air fryer for another 5 mins until bubbly.⁣"
    }
  ],
