  "method": [
    {
      "heading": null,
      "description": "Bring a saucepan of salted water to the boil. Gently lower in the eggs and boil for 6 mins. Cool in iced water and peel once chilled."
    },
    {
      "heading": null,
      "description": "Toast the fennel seeds in a dry pan, then grind in a pestle and mortar. Add the garlic and smash together."
    },
    {
      "heading": null,
      "description": "Finely chop the chives, slice the chilli and zest the lemon."
    },
    {
      "heading": null,
      "description": "In a bowl mix together the lemon zest, red chilli, chives, crushed fennel and garlic, oregano, balsamic vinegar, olive oil, salt and pepper."
    },
    {
      "heading": null,
      "description": "Place the peeled eggs in a clean jar or container. Pour over the marinade and top up with a little extra olive oil to fully cover."
    },
    {
      "heading": null,
      "description": "Chill for at least 4 hrs, ideally overnight. The oil will separate, totally normal. You’ll end up with half the egg deeply brown and vinegared. Really delicious."
    },
    {
      "heading": null,
      "description": "Serve halved with a spoonful of marinade, crusty bread and something salty."
    }
  ],
