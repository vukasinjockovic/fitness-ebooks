  "method": [
    {
      "heading": null,
      "description": "Heat oven to 190°C."
    },
    {
      "heading": null,
      "description": "Blitz the drained roasted peppers with water until smooth."
    },
    {
      "heading": null,
      "description": "Finely chop the onion, garlic and rosemary. Squeeze the sausages out of their casings into a pan set over a medium heat. Using the back of a spoon, crumble the sausage into pieces and cook until golden. Using a slotted spoon, remove the sausages and add in a glug of oil along with the onion and garlic and chilli flakes, if using. Add a pinch of salt and cook that out for 8 mins. Add the fennel seeds and rosemary and cook for two more minutes."
    },
    {
      "heading": null,
      "description": "Tip in the blitzed peppers along with the tinned tomatoes. Add the sausages back in, along with a handful of basil leaves. Season with salt and pepper, then bring to a simmer."
    },
    {
      "heading": null,
      "description": "Blanche the fresh lasagne sheets for 1 minute in boiling water, then drain."
    },
    {
      "heading": null,
      "description": "Nestle the lasagne sheets into the ragù, then dot with mascarpone before tearing over the mozzarella and grating over the Parmesan. Slide into the oven and cook for 35-40 mins or until bubbling and golden."
    },
    {
      "heading": null,
      "description": "Remove from the oven and allow to rest for 5 mins before serving."
    }
  ],
