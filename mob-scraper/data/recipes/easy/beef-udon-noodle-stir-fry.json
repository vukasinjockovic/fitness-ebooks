  "method": [
    {
      "heading": null,
      "description": "Thinly slice the steak and season with a little salt and plenty of black pepper. Thinly slice the chilli and cut the spring onions into four pieces each. Peel and thinly slice the garlic. Peel the ginger and cut into matchsticks."
    },
    {
      "heading": null,
      "description": "Place a wok or large deep frying pan over a medium-high heat with the sunflower oil. Once hot, add the steak and cook for 1-2 mins per side until just browned, then move it to one side of the pan."
    },
    {
      "heading": null,
      "description": "Add the spring onions to the empty side of the pan and stir-fry for 1 min until fragrant. Add the chilli, garlic and ginger and toss for 1 min."
    },
    {
      "heading": null,
      "description": "Chuck in the stir-fry veg and toss everything together. Cook for 2 mins until the veg starts to soften."
    },
    {
      "heading": null,
      "description": "Add the udon noodles and toss again. Pour in the soy sauce, honey and the juice of half the lime. Stir-fry for another 1-2 mins until everything is piping hot."
    },
    {
      "heading": null,
      "description": "Divide between bowls and top with the coriander, if using."
    }
  ],
