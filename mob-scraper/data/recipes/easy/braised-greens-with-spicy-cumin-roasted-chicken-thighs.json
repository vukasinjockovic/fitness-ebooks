  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Peel all the garlic, pull out 4 cloves and grate them into a bowl. Add in the cumin and chilli flakes with a large glug of oil and mix together."
    },
    {
      "heading": null,
      "description": "Rub this onto the chicken thighs and set aside."
    },
    {
      "heading": null,
      "description": "Chop up the leeks and pull apart the leaves of the chicory."
    },
    {
      "heading": null,
      "description": "Add the kale, leeks, chicory and remaining peeled garlic into a large baking tray a. Rub with salt and pepper then pour in 1 litre of chicken stock."
    },
    {
      "heading": null,
      "description": "Pop the chicken thighs on top and generously sprinkle with salt. Pop this in the oven for 20 mins then increase the heat to 200°C for 15 mins to get the skin extra crispy."
    },
    {
      "heading": null,
      "description": "Meanwhile, toast your flaked almonds with some oil on a very low heat until golden brown."
    },
    {
      "heading": null,
      "description": "Top the chicken thighs with the almond flakes and tuck in."
    }
