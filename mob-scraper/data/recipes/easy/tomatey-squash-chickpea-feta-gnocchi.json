  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 210°C. Pick the sage leaves, toss them with the olive oil and pop in the oven for 3 to 4 mins until crisp but not coloured. Remove the sage and set aside, leaving the oil in the tray."
    },
    {
      "heading": null,
      "description": "Peel, deseed and cut the butternut into 1cm pieces. Drain the chickpeas."
    },
    {
      "heading": null,
      "description": "Add the squash, garlic cloves (left in their skins) and gnocchi to the tray with the oil. Place the lemon half cut-side down. Roast for 20 mins, giving the tray a shake halfway through."
    },
    {
      "heading": null,
      "description": "After 20 mins, add the cherry tomatoes, chickpeas and nestle in the feta. Roast for another 10 mins, or until the squash is tender and the tomatoes are starting to burst."
    },
    {
      "heading": null,
      "description": "Squeeze the garlic from its skins, mash and fold it through the traybake."
    },
    {
      "heading": null,
      "description": "Serve up!Kids Plate: Scoop out a kids’ portion, grate over some cheddar cheese.Parents Plate: Dish up the adults and crumble over half of the crispy sage and squeeze over the caramelised lemon."
    }
  ],
