  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids ServingsHeat the oven to 180°C fan."
    },
    {
      "heading": null,
      "description": "Peel the butternut squash, remove the seeds and cut it into bite-sized cubes. Halve the tomatoes and cherry tomatoes. Peel and finely slice the red onion and garlic."
    },
    {
      "heading": null,
      "description": "Tip the squash, tomatoes, onion and garlic into a large roasting tin. Add the curry powder, turmeric, a good drizzle of olive oil and a big pinch of salt. Toss everything together and roast for 30 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, drain and rinse the lentils."
    },
    {
      "heading": null,
      "description": "After 30 mins, take the tray out of the oven. Stir in the lentils and coconut milk, then return to the oven for 15 mins, until bubbling and golden at the edges."
    },
    {
      "heading": null,
      "description": "Taste and season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Serve with a dollop of yoghurt, a spoonful of mango chutney, and fresh coriander. Warm flatbreads or rice on the side are essential for mopping it all up."
    }
  ],
