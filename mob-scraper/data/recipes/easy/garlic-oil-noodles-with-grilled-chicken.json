  "method": [
    {
      "heading": null,
      "description": "Soak the noodles. Place the dried pho noodles in a bowl of cold water and soak for 30 mins. Set aside."
    },
    {
      "heading": null,
      "description": "Marinate the chicken. In a bowl, mix the chicken thighs with turmeric, soy sauce, fish sauce, oyster sauce, brown sugar, and cracked black pepper. Stir until the chicken is well-coated."
    },
    {
      "heading": null,
      "description": "Cook the chicken. Heat a griddle or frying pan over medium-high heat. Add the vegetable oil and cook the chicken for 3–4 mins on each side, pressing gently for even browning. Remove from the heat and let rest."
    },
    {
      "heading": null,
      "description": "Prep the aromatics. While the chicken is cooking, peel and mince the garlic cloves and shallot. Slice the Thai chilli thinly."
    },
    {
      "heading": null,
      "description": "Make the garlic oil. Heat a glug of vegetable oil in a small saucepan over medium heat. Add the minced garlic, shallot, and sliced chilli. Gently fry for 2–3 mins until just golden. Stir in the soy sauce, fish sauce, oyster sauce, and brown sugar. Mix well to dissolve the sugar, then set aside."
    },
    {
      "heading": null,
      "description": "Cook the noodles. Bring a saucepan of water to a boil. Cook the soaked noodles for 1 minute less than the packet instructions. Drain and rinse under cool water until warm but not cold."
    },
    {
      "heading": null,
      "description": "Prep the toppings. Thinly slice the brown onion and spring onion. Roughly chop the coriander and Thai basil. Cut the lime into wedges."
    },
    {
      "heading": null,
      "description": "Assemble the bowl. Add the noodles to a large bowl and spoon over the garlic oil. Slice the grilled chicken into strips and arrange on top. Garnish with brown onion, spring onion, coriander, Thai basil, and fried shallots. Serve with a lime wedge."
    }
  ],
  "tips": [
    "Chicken and garlic oil can be made ahead and stored in the fridge for up to 3 days.",
    "Noodles should be cooked fresh but can be soaked in advance.",
    "To reheat: Warm the chicken in a pan or microwave. Flash the noodles in hot water for 30 seconds, then drain and toss with garlic oil.",
    "Chicken (cooked or raw-marinated) can be frozen for up to 2 months.",
    "Garlic oil freezes well – store in an ice cube tray and defrost as needed.",
    "Fresh herbs and noodles are best made fresh."
  ],
