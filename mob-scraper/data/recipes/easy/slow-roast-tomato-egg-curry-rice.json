  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C fan."
    },
    {
      "heading": null,
      "description": "Toss the halved tomatoes with salt, garam masala, black pepper, and two-fifths of melted ghee or oil. Mix well and spread onto a baking tray."
    },
    {
      "heading": null,
      "description": "Roast for 30-40 mins until soft and slightly caramelised."
    },
    {
      "heading": null,
      "description": "Cook the rice according to package instructions."
    },
    {
      "heading": null,
      "description": "Meanwhile, heat the remaining ghee in a pan over medium heat. Add the curry leaves, finely sliced garlic, nigella seeds, mustard seeds, and chopped chilli. Cook for 1-2 mins until fragrant, then remove from heat."
    },
    {
      "heading": null,
      "description": "Bring a pot of water to a boil. Add the eggs and cook for 7 mins for soft yolks. Drain and cool under cold water before peeling."
    },
    {
      "heading": null,
      "description": "In a bowl, mix the finely sliced red onions with lime juice and a pinch of salt. Massage gently with your hands and set aside to pickle."
    },
    {
      "heading": null,
      "description": "To serve, divide the rice into bowls. Top with roasted tomatoes, eggs, coriander, and pickled onions. Drizzle the spiced ghee and roasting juices over the dish."
    }
  ],
  "tips": [
    "Storage: Keep refrigerated in airtight containers for up to 3 days. Reheat gently before serving.",
    "Substitutions: Swap white rice for brown rice or quinoa for extra fibre. Use smoked paprika instead of garam masala for a different flavour.",
    "Serving Ideas: Pair with a side of yoghurt or flatbread for a complete meal."
  ],
