  "method": [
    {
      "heading": null,
      "description": "Wash and thoroughly dry the okra, then trim and slice it into 1cm chunks. Transfer to a bowl with a sprinkle of salt, then toss and set aside."
    },
    {
      "heading": null,
      "description": "Toast the cumin seeds in a dry pan until dark and aromatic. Transfer to a pestle and mortar or electric spice grinder with the green chilli. Grate in the coconut, then coarsely grind."
    },
    {
      "heading": null,
      "description": "Heat the coconut oil in a frying pan and add the mustard seeds. Once they crackle, add the okra with a pinch of salt and the curry leaves. Stir-fry for 4-5 mins."
    },
    {
      "heading": null,
      "description": "Add the turmeric and asafoetida and cook for 1 min. Add the cumin and coconut mixture and cook for 2-3 mins."
    },
    {
      "heading": null,
      "description": "Remove the okra from the heat. Mix the yoghurt with water and add to the cooked okra – add a splash more water if needed. Stir well, then taste and season with salt, if needed."
    },
    {
      "heading": null,
      "description": "Before serving, make the tarka. Heat the coconut oil in a small pan over a medium heat. Add the mustard seeds, curry leaves and dried chilli. Once they sizzle, pour it all over the pachadi and serve."
    }
  ],
