  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C fan."
    },
    {
      "heading": null,
      "description": "Spread the flaked almonds onto a baking tray and toast for 12 mins until golden. Set aside."
    },
    {
      "heading": null,
      "description": "Chuck the oats into a bowl with the yoghurt, milk, vanilla extract, half the almond extract and the protein powder, if using. Mix well to combine, then set aside."
    },
    {
      "heading": null,
      "description": "In a small bowl, stir together the almond butter, the remaining almond extract, two-thirds of the maple syrup and a pinch of salt. Set aside."
    },
    {
      "heading": null,
      "description": "Tip the frozen cherries into a small saucepan with the rest of the maple syrup. Set over a low-medium heat and cook until the cherries have defrosted and are starting to release their juices. Roughly mash with a potato masher, leaving a few chunky bits."
    },
    {
      "heading": null,
      "description": "Spoon the cherry mixture into the bottom of your containers. Top with the oats, then drizzle over the almond butter mixture. Finish with a scattering of toasted flaked almonds."
    },
    {
      "heading": null,
      "description": "Cover and place in the fridge overnight."
    }
  ],
