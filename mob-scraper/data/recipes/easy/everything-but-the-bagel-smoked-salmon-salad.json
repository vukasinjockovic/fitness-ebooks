  "method": [
    {
      "heading": null,
      "description": "Whisk the cream cheese and water in a bowl until light and fluffy. Stir in the poppy seeds, sesame seeds, and onion granules. Season with a pinch of salt and set aside."
    },
    {
      "heading": null,
      "description": "Using a mandolin or sharp knife, finely slice the fennel, cucumber, and red onion. Pick the dill fronds and discard the stalks. If you want, chuck them all into a bowl of ice water while you prep the rest – it makes everything extra crispy. Tear the salmon into bite-sized chunks."
    },
    {
      "heading": null,
      "description": "Zest a quarter of the lemon into a bowl, squeeze in the juice and slowly whisk in the olive oil until emulsified. Season with salt, black pepper, and a pinch of sugar. Taste as you go."
    },
    {
      "heading": null,
      "description": "Drain the veg if using ice water. Toss it all together with the rocket, capers, torn-up salmon, and croutons until coated in the dressing."
    },
    {
      "heading": null,
      "description": "Swipe a generous dollop of your whipped cream cheese onto plates and top each the salad."
    }
  ],
