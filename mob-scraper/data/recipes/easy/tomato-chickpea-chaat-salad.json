  "method": [
    {
      "heading": null,
      "description": "Chop the tomatoes into bite-sized chunks. Chuck them onto a plate, season with salt and leave to sit while you prep everything else."
    },
    {
      "heading": null,
      "description": "Thinly slice the red onion. Rinse it in a sieve under cold water to mellow out the flavour, then add into a bowl of ice water to crisp up."
    },
    {
      "heading": null,
      "description": "For the chutney, pick the mint leaves and discard the stalks. Add the coriander (stalks and all), mint, chillies, ginger, ground cumin, water and ice cubes to a blender. Blitz until smooth, then season with lemon juice, salt, sugar and pepper. Stir through the yoghurt and taste again, it should be punchy and fresh."
    },
    {
      "heading": null,
      "description": "Pick the remaining coriander leaves and finely slice the stalks. Mix the tamarind purée with the honey and season with salt. Add a splash of water to loosen if needed – you're after a sweet-sour dressing."
    },
    {
      "heading": null,
      "description": "Drain the chickpeas and toss with the coriander stalks, drained onions, and tomatoes (with their juices) into the tamarind dressing."
    },
    {
      "heading": null,
      "description": "Dollop the chutney yoghurt onto plates, pile the salad on top, then scatter over the Bombay mix for a big crunch finish."
    }
  ],
