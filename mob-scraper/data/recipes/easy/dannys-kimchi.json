  "method": [
    {
      "heading": null,
      "description": "Cut the cabbage into quarters lengthways and sprinkle generously with salt between the leaves. Set aside."
    },
    {
      "heading": null,
      "description": "Roughly chop the spring onions, apple, radishes, carrot, chives and set aside."
    },
    {
      "heading": null,
      "description": "To a blender, add the onion, garlic, ginger, gochugaru flakes, fish sauce, oyster sauce, soy sauce, rice vinegar and water and blitz to a paste."
    },
    {
      "heading": null,
      "description": "Rinse the salt off the cabbage and get it in a mixing bowl, along with the spring onions, apples, radishes, carrots and chives. Pour over the blended paste and massage it into the veggies."
    },
    {
      "heading": null,
      "description": "Put your cabbage mix in a sterilised jar and push down to compress the cabbage slightly."
    },
    {
      "heading": null,
      "description": "Let the jar sit at room temperature for 2-5 days until it’s fermented to your liking. When you’re happy with the taste, get it in the fridge where it will last up to 3 months."
    }
  ],
