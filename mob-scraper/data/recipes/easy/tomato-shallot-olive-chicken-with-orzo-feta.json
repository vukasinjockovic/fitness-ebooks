  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Zest the lemon into a bowl. Add the chilli flakes, oregano, a big pinch of salt, some black pepper and a generous drizzle of olive oil. Rub all over the chicken thighs and set aside to marinate while you prep the rest."
    },
    {
      "heading": null,
      "description": "Halve the cherry tomatoes, peel and halve the shallots, then chuck both into a roasting tray with the olives. Season, drizzle with olive oil and toss to coat. \nNestle the chicken thighs skin-side up on top of the veg. Roast for 35–40 mins until the chicken is golden and cooked through, and the tomatoes are soft and jammy."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the orzo following pack instructions. Drain, season with olive oil, salt and pepper, and set aside."
    },
    {
      "heading": null,
      "description": "Thinly slice the red onion. Squeeze over the juice of half the lemon and a pinch of salt. Leave to lightly pickle for 5 mins, then stir through the chopped parsley."
    },
    {
      "heading": null,
      "description": "Remove the chicken and shallots from the tray and stir the roasted tomatoes, olives and all those lovely juices through the orzo."
    },
    {
      "heading": null,
      "description": "Divide the orzo between bowls, top with the chicken, shallots, pickled onions and crumbled feta. Enjoy!"
    }
  ],
