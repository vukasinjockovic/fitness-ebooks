  "method": [
    {
      "heading": null,
      "description": "Thinly slice the beef against the grain. Add to a bowl with the bicarbonate soda then cover with cold water and mix to combine. Set aside for 15 mins to tenderise the meat."
    },
    {
      "heading": null,
      "description": "Meanwhile, thinly slice the garlic. Wash the spring onions and choy sum. Chop the ends off the spring onions then chop into three chunks, separating the whites to greens. Chop the ends off the choy sum and then chop into three smaller pieces."
    },
    {
      "heading": null,
      "description": "Place the fresh ho fun noodles on a heatproof plate and heat in a microwave or steamer for a few mins until soft. Remove and gently separate with your hands."
    },
    {
      "heading": null,
      "description": "In a bowl, mix together all the stir-fry sauce ingredients and set aside."
    },
    {
      "heading": null,
      "description": "Rinse the beef to remove the excess bicarbonate soda. Combine the beef marinade ingredients in a separate bowl. Add the beef, massage the marinade into the meat and set aside."
    },
    {
      "heading": null,
      "description": "Heat a generous glug of vegetable oil in a wok set over a medium-high heat. Add the marinated beef and fry for 1-2 mins until mostly cooked then remove and set aside. Add the garlic and the spring onion whites to the same wok and stir fry for 1-2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Add the cooked ho fun noodles and choy sum to the wok then immediately add the prepared sauce, pouring from the edge of the wok. Mix well until evenly coated. Add the beef and mix again."
    },
    {
      "heading": null,
      "description": "Add the beansprouts and the spring onion greens and stir-fry for 30 seconds."
    },
    {
      "heading": null,
      "description": "Serve with crispy chilli oil and enjoy!"
    }
  ],
