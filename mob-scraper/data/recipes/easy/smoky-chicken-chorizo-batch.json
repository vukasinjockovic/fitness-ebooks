  "method": [
    {
      "heading": null,
      "description": "Remove the bones from the chicken thighs. Pat the chicken skin dry with kitchen paper, then drizzle with half the olive oil and season generously with salt."
    },
    {
      "heading": null,
      "description": "Pop the chicken into the air fryer skin-side down and cook for 6 mins at 200ºC. Flip the chicken over and cook for 10 mins, then remove."
    },
    {
      "heading": null,
      "description": "Meanwhile, cut the tomatoes and red onion into wedges and finely chop the rosemary. Add the tomatoes, onions, chorizo, olives, rosemary and paprika to the air fryer along with the remaining olive oil, then season with salt and pepper. Turn the air fryer on to 180ºC and cook for 15 mins, making sure the chorizo is on top and turning it over halfway."
    },
    {
      "heading": null,
      "description": "Warm through the chicken for the last few minutes if eating immediately, or pop it all into containers to put in the fridge."
    }
  ],
