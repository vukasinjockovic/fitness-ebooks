  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 150°C fan. Grease a 1lb loaf tin and line with baking paper."
    },
    {
      "heading": null,
      "description": "If your bananas aren’t ripe, place them onto a baking tray and bake in the oven for 10-15 mins until blackened and soft to the touch."
    },
    {
      "heading": null,
      "description": "Add the bananas into a bowl and mash until smooth. Melt the butter in a small pan over a low heat."
    },
    {
      "heading": null,
      "description": "Whisk the eggs and melted butter into the bananas. Add the milk and mix to combine."
    },
    {
      "heading": null,
      "description": "In another bowl, mix together the caster sugar, ground almonds, buckwheat flour, gluten-free flour, gluten-free oats, chia seeds, gluten-free baking powder, bicarbonate of soda and salt. Fold this dry mixture into the banana mixture until just combined."
    },
    {
      "heading": null,
      "description": "Pour the batter into the prepared tin (it should fill until almost to the top – leave 2cm). Slice the banana in half lengthways and pop it on top of the cake batter, along with the pecans and demerara sugar."
    },
    {
      "heading": null,
      "description": "Bake for 50-60 mins or until a toothpick inserted comes out clean. Transfer to a wire rack to cool. Enjoy at room temp or toasted and topped with a pat of cold butter, if you like."
    }
  ],
