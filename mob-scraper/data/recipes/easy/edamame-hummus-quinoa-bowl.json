  "method": [
    {
      "heading": null,
      "description": "Cook the eggs in a small saucepan of boiling water for 7 mins, until jammy in the centre. Drain and cool under cold running water until easy to peel."
    },
    {
      "heading": null,
      "description": "Boil the peas and edamame in salted water according to pack instructions. Drain and run under cold water to stop the cooking."
    },
    {
      "heading": null,
      "description": "Zest and juice the lemons. Peel the garlic."
    },
    {
      "heading": null,
      "description": "Add half of the edamame and peas to a food processor along with the cottage cheese, tahini, lemon zest and juice, garlic and water. Season with salt and black pepper, then blitz until super smooth."
    },
    {
      "heading": null,
      "description": "Warm the quinoa following pack instructions, or use cold if you prefer. Tip it into a bowl with the remaining edamame and peas. Finely chop most of the mint and stir it through the quinoa. Season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "To serve, spread the hummus over your plates. Spoon the quinoa salad on top, then halve the eggs and place on each bowl. Crumble over the feta and finish with the reserved mint leaves."
    }
  ],
