  "method": [
    {
      "heading": null,
      "description": "Tip the berries into a saucepan set over a medium heat. Cook for 5-7 mins until juicy, then stir in the lemon juice and mash to your desired jam consistency. Add the chia seeds and honey, cook for a few minutes until thickened, then set aside to cool."
    },
    {
      "heading": null,
      "description": "Combine the milk and protein powder in a shallow dish to form a paste. Add the egg and egg whites, then whisk together with the protein paste until smooth."
    },
    {
      "heading": null,
      "description": "Heat a non-stick frying pan and soak both sides of each slice of bread in the egg mixture. Once the pan is hot, add the soaked bread to the pan. Cook over a medium heat for a few minutes each side."
    },
    {
      "heading": null,
      "description": "Load the slices of toast onto a plate, then add the yoghurt, peanut butter and jam. Drizzle with the honey and the extra peanut butter, then scatter the crushed peanuts on top."
    },
    {
      "heading": null,
      "description": "Assemble and add your toppings!"
