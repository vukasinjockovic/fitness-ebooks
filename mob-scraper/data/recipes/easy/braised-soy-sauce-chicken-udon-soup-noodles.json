  "method": [
    {
      "heading": null,
      "description": "Sear the chicken. Heat a splash of vegetable oil in a saucepan over high heat. Add the chicken thighs and sear for 2 mins per side until golden. Remove from the pan and reduce the heat to medium."
    },
    {
      "heading": null,
      "description": "Prep and braise. Peel and thinly slice the onion and add it to the pan. Pour in the soy sauce, mirin, sake (if using), and cold water. Stir gently and cook for 3–5 mins until the onion softens and takes on the soy colour."
    },
    {
      "heading": null,
      "description": "Return the chicken to the pan and pour in the dashi or chicken stock. Bring to a gentle simmer over medium-high heat and cook for 10 mins. Once cooked, remove the chicken and turn the heat to low."
    },
    {
      "heading": null,
      "description": "Make the toppings. While the chicken cooks, slice the spring onions into thin strips and submerge them in a bowl of ice water. Zest the lime and grate the ginger."
    },
    {
      "heading": null,
      "description": "Shred and mix. Shred the chicken and combine it in a bowl with the lime zest, sesame oil, sesame seeds, grated ginger, and drained spring onions. Mix to coat."
    },
    {
      "heading": null,
      "description": "Cook the noodles. Bring the broth back to a boil. Add the frozen udon noodles and cook according to packet instructions."
    },
    {
      "heading": null,
      "description": "Divide the noodles between two bowls. Ladle the broth over until the noodles are submerged. Top with a generous pile of shredded chicken and garnish with a wedge of lime and a sprinkle of shichimi togarashi, if using."
    }
  ],
  "tips": [
    "Chicken and broth can be made ahead and stored for 3 days in the fridge.",
    "Reheat broth until piping hot before adding fresh-cooked udon.",
    "Spring onion garnish best added fresh."
  ],
