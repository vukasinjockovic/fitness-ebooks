  "method": [
    {
      "heading": null,
      "description": "Cook your noodles according to package instructions then rinse with cold water. Save the water for later."
    },
    {
      "heading": null,
      "description": "Grate your cheese into a bowl."
    },
    {
      "heading": null,
      "description": "Finely slice your carrots and spring onions, set them aside in separate bowls. Cut the stems off your pak choi, give it a wash and also set aside."
    },
    {
      "heading": null,
      "description": "Get a wok on medium heat, pop your curry block in with a tablespoon of oil. Once the mix starts to melt, pour in the water. Give it a good mix and bring the sauce to a boil. Then add your sliced carrots for a minute then your pak choi."
    },
    {
      "heading": null,
      "description": "Once the carrots and pak choi are softish, add your grated cheese, most of your spring onions and noodles. Season with salt and pepper and give it another mix."
    },
    {
      "heading": null,
      "description": "Plate up your noodles, top with spring onions and enjoy!"
    }
