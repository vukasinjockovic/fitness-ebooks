  "method": [
    {
      "heading": null,
      "description": "Cook the linguine in salted boiling water following packet instructions."
    },
    {
      "heading": null,
      "description": "Add the sun-dried black olives and toasted pine nuts to a blender. Peel the garlic clove and roughly slice the Parmesan, then add in. Add juice of your lemon and season generously with salt and pepper. Add the squid ink, if using."
    },
    {
      "heading": null,
      "description": "Add ⅓ of olive oil and begin to blend, then continue to add olive oil until you get to a thick pesto consistency."
    },
    {
      "heading": null,
      "description": "Drain the cooked linguine, reserving a cup of the cooking pasta, and return the linguine to the pan. Stir through the pesto, add a splash of cooking water and mix until thoroughly combined."
    },
    {
      "heading": null,
      "description": "Divide the pasta between bowls and top with some fresh parsley and extra Parmesan, if you like."
    }
