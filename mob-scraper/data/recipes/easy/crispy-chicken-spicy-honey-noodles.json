  "method": [
    {
      "heading": null,
      "description": "Season both sides of the chicken with salt. Add the chicken thighs, skin-side down, to a cold frying pan, then turn the heat to medium. Don’t touch or move the chicken (this keeps the skin crispy and helps to render the fat) for around 7 mins."
    },
    {
      "heading": null,
      "description": "Flip the chicken onto the meat side and cook for a further 3 mins. Turn off the heat and remove the chicken from the pan. Set both the chicken and pan aside."
    },
    {
      "heading": null,
      "description": "Dice the red onion, slice the chilli and spring onion, then transfer it all to a bowl. Add three-quarters of your soy sauce along with half of the apple cider vinegar, half of the honey, and all the sesame seeds. Crush half of your garlic cloves into the bowl. Stir well to combine until the honey is dissolved. Set aside."
    },
    {
      "heading": null,
      "description": "In a separate bowl, combine the gochujang with the chilli powder, the remainder of your soy sauce, all the mirin, all the oyster sauce, a few cracks of black pepper, the rest of your honey, the rest of your apple cider vinegar, the other half of the crushed garlic, and water. Mix to combine."
    },
    {
      "heading": null,
      "description": "Boil a saucepan of water, add the instant noodles and cook for 1 ½ mins shy of cooking instructions. Drain, reserving the cooking water."
    },
    {
      "heading": null,
      "description": "Set the frying pan you used for the chicken over a medium heat and add the gochujang sauce. Fry for 1 min or until the sauce turns a darker red. Add the instant noodles and a splash of the soy pickling liquid. Stir until the sauce coats the noodles, adding more pickling liquid, if needed."
    },
    {
      "heading": null,
      "description": "Slice the chicken thighs. Plate up the noodles and add the chicken thighs on top. Using a strainer or spoon, drain the red onion mixture ensuring there is no liquid, then sprinkle on top. Enjoy."
    }
  ],
