  "method": [
    {
      "heading": null,
      "description": "To make your pesto, add basil, mint, sunflower seeds, peeled garlic, peas, green chillies, the zest of one lemon, the juice from two lemons, 2 sheets of nori and miso to a food processor. Add most of your parmesan to your processor along with a large glug of olive oil (enough to bring it all together to a smooth consistency). Season with salt and pepper then blitz until smooth."
    },
    {
      "heading": null,
      "description": "Cook your udon according to package instructions, reserving some of the noodle-cooking water for later."
    },
    {
      "heading": null,
      "description": "Mix your pesto with the udon, adding a small ladle of noodle-cooking water at a time (enough to bring it all together)."
    },
    {
      "heading": null,
      "description": "Top each plate of udon with torn pieces of nori, grated parmesan and chilli oil. Enjoy!"
    }
  ],
