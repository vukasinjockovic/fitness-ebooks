  "method": [
    {
      "heading": null,
      "description": "Cut the cod into bite-sized pieces and set aside."
    },
    {
      "heading": null,
      "description": "Peel and finely grate the garlic and ginger. Finely slice the kaffir lime leaves, discarding the tough stems."
    },
    {
      "heading": null,
      "description": "Heat a large nonstick frying pan over a medium heat and give it a couple of sprays of olive oil. Add the garlic, ginger and a splash of water. Let that cook for 1 min to soften, then stir in the laksa paste and cook for 1 more min until fragrant."
    },
    {
      "heading": null,
      "description": "Pour in the coconut milk and water, then bring it all to a gentle simmer. Add the sliced makrut lime leaves and let everything bubble away for 5 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, separate the pak choi leaves, trim the ends, and slice each leaf and stem in half lengthwise."
    },
    {
      "heading": null,
      "description": "Add the pak choi and cod to the pan. Simmer gently for 5 mins, stirring a couple of times, until the cod is opaque and flakes easily. Stir in the soy sauce and fish sauce."
    },
    {
      "heading": null,
      "description": "Cook the udon noodles following pack instructions, then divide between bowls. Ladle over the laksa and finish with picked coriander leaves."
    }
  ],
