  "method": [
    {
      "heading": null,
      "description": "Start by making the pesto: add the sun-dried tomatoes and red chilli to a blender with the smoked almonds. Peel the garlic clove and roughly slice the Parmesan, then add in. Add the harissa paste and lemon juice and season generously with salt and pepper. Add ⅓ of olive oil and begin to blend, then continue to add olive oil until you get to a thick pesto consistency."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of salted water to the boil. Add the gnocchi and cook for 2 mins. Drain, reserving a cup of the water."
    },
    {
      "heading": null,
      "description": "Add a splash of olive oil into a large frying pan over a high heat. Add the gnocchi and toss until crispy, around 2-3 mins. Spoon in the pesto and toss well. Add some of the cooking and keep tossing so the sauce coats the gnocchi. Taste and season."
    },
    {
      "heading": null,
      "description": "Tip into bowls, top with grated Parmesan, basil and a drizzle of olive oil. Finish with a crack of black pepper."
    }
  ],
