  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Trim, halve and scoop the seeds out of the pumpkin. Chop it into 3cm thick chunks then place in a large baking dish."
    },
    {
      "heading": null,
      "description": "Get the chicken thighs in a cold frying pan, skin side down. Set it over a medium heat and cook for 10-mins without turning until the skin is golden brown. Transfer the thighs to the baking dish, resting them on top of the pumpkin."
    },
    {
      "heading": null,
      "description": "Meanwhile, pick the coriander leaves and add the stems into a blender with the curry paste, coconut milk, crumbled chicken stock cube, water, fish sauce and sugar. Blend until smooth then taste and season with more fish sauce or sugar, if needed."
    },
    {
      "heading": null,
      "description": "Pour the sauce over the chicken and pumpkin. Pop it in the oven for 35-40 mins until the pumpkin is tender and the chicken is cooked through."
    },
    {
      "heading": null,
      "description": "Before serving, reheat the rice."
    },
    {
      "heading": null,
      "description": "Serve the chicken and pumpkin curry with the rice. Garnish with a lime wedge and the coriander leaves."
    }
  ],
