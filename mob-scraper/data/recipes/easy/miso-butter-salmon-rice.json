  "method": [
    {
      "heading": null,
      "description": "Rinse the sushi rice until the water runs clear, then cook with the measured water using your preferred method (rice cooker or saucepan). Set aside with the lid on to steam."
    },
    {
      "heading": null,
      "description": "Season the salmon fillets with salt and leave to sit while you prep the rest."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix the softened butter with the white miso until smooth and combined."
    },
    {
      "heading": null,
      "description": "Finely slice the cucumber and add to a bowl with the rice vinegar, sugar, soy sauce and the juice of half a lemon. Toss together and leave to lightly pickle."
    },
    {
      "heading": null,
      "description": "Trim and thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "Pat the salmon dry with kitchen paper and spread the miso butter evenly over the top of each fillet. Place under a hot grill for 4–6 mins until golden and cooked through, with the butter bubbling."
    },
    {
      "heading": null,
      "description": "Fluff the rice and divide between bowls. Top each portion with a salmon fillet and any of the miso butter from the tray. Finish with the sliced spring onion and a pile of the pickled cucumber."
    }
