  "method": [
    {
      "heading": null,
      "description": "Finely dice your onion, mince your garlic, chop both your chives (for the noodles, and the panko topping) and thinly slice the mushrooms."
    },
    {
      "heading": null,
      "description": "Pound the chicken to an even thickness and season both sides with salt, pepper and garlic powder."
    },
    {
      "heading": null,
      "description": "Heat a glug of vegetable oil in a large frying pan set over a medium heat. Add the chicken and pan fry it for 6-8 mins on each side, depending on thickness, until cooked through. Don't overcrowd the pan; do it in batches if necessary."
    },
    {
      "heading": null,
      "description": "While the chicken cooks, bring a large pot of salted water to the boil, add the tagliatelle and cook until al dente following packet instructions. Drain the tagliatelle, reserving a mug of the pasta cooking water, and rinse the tagliatelle in cold water."
    },
    {
      "heading": null,
      "description": "Meanwhile, add the butter, onion and garlic to another large pan set over a medium heat. Fry for a few minutes until softened then add the sliced mushrooms to the pan and cook until they release their moisture and become tender (this should take about 5 mins)."
    },
    {
      "heading": null,
      "description": "Add the chilli oil, gochujang, tomato purée to the pan and mix to combine. Stir through the double cream and sundried tomatoes. Add the honey and the juice of the lime. Bring the sauce to a simmer and let it gently bubble away while the pasta and chicken finish cooking."
    },
    {
      "heading": null,
      "description": "Add the cooked noodles and a ladle of the pasta water to the sauce. Season with salt and pepper and add the chives then mix to combine."
    },
    {
      "heading": null,
      "description": "To make the chive panko, melt butter in a pan, then add the chopped chives and panko. Stir well to combine and cook until the panko is golden and crispy."
    },
    {
      "heading": null,
      "description": "To serve, divide the tagliatelle between bowls then top with chicken, panko and some extra chilli oil."
    }
  ],
