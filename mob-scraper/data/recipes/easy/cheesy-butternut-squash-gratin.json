  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Wash and finely slice your leek, roughly chop the sage. Place a\nsaucepan over medium heat and add 2 tbsp of olive oil. Add the\nleeks and sage and sweat down for 5 mins until soft and golden."
    },
    {
      "heading": null,
      "description": "While the leeks cook, wash and slice your Ocado Own Range\nbutternut squash into roughly half centimetre thick slices and\nset aside. Grate the cheddar and also set aside."
    },
    {
      "heading": null,
      "description": "Drain both tins of butter beans and add to the leeks along with\nthe mustard and cream, mix well and season with salt and\npepper."
    },
    {
      "heading": null,
      "description": "In a large oven dish, spread a layer of squash, followed by half of\nthe butter bean mix and roughly a third of the grated cheddar."
    },
    {
      "heading": null,
      "description": "Repeat with a second layer of squash, butter beans and cheddar,\nthen a final layer of squash and the remaining cheddar."
    },
    {
      "heading": null,
      "description": "Place into the oven for 40 mins until the squash is tender and\nthe cheese is golden brown."
    },
    {
      "heading": null,
      "description": "Allow to rest for 5 mins before serving."
    }
  ],
