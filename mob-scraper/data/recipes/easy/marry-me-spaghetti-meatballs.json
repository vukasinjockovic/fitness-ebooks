  "method": [
    {
      "heading": null,
      "description": "Finely dice the onion, crush the garlic cloves and slice the sundried tomatoes into bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Pour a glug of oil from the sundried tomato jar into a large pan over a medium heat. Add the meatballs and fry for about 10 mins or until the meatballs are nicely browned and cooked through. Transfer the meatballs to a plate and set aside."
    },
    {
      "heading": null,
      "description": "Meanwhile, set a large saucepan of boiling water over a high heat then add the stock cube and stir to dissolve."
    },
    {
      "heading": null,
      "description": "Return the empty meatball pan to the hob and reduce the heat to low-medium. Add another splash of the sundried tomato oil then add the onion and garlic and fry for about 7 mins until softened."
    },
    {
      "heading": null,
      "description": "Drop your spaghetti into the boiling water and cook following packet instructions."
    },
    {
      "heading": null,
      "description": "Add the sundried tomatoes, oregano, thyme, pesto, salt and pepper to the pan with the onion and garlic. Toss the meatballs back in and stir to coat then pour in the cream and a couple of ladles of pasta water. Stir and bring to a gentle simmer."
    },
    {
      "heading": null,
      "description": "Meanwhile, roughly chop the basil."
    },
    {
      "heading": null,
      "description": "Drain the cooked spaghetti then add to the pan with the sauce, along with ½ the chopped basil and a splash of the pasta cooking water. Mix well to combine."
    },
    {
      "heading": null,
      "description": "To serve, divide the spaghetti between bowls and top with the remaining basil and some grated Parmesan."
    }
  ],
