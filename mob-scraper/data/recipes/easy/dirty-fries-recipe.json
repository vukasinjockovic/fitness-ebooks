  "method": [
    {
      "heading": null,
      "description": "Heat the oven and cook the french fries following pack instructions."
    },
    {
      "heading": null,
      "description": "Peel and finely chop the garlic. Thinly slice the spring onions. Roughly chop the kimchi."
    },
    {
      "heading": null,
      "description": "Meanwhile, heat a shot of vegetable oil in a large frying pan over a high heat and add in the mince. Use the back of a spoon to reak it up into small pieces. Fry for around 8 mins until the liquid has evaporated and the mince is starting to get really crisp. Turn the heat to low and scrape in the chopped garlic and half of the sesame seeds. Fry for 2 minutes until smelling amazing, then stir in half of the gochujang and remove from the heat. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "In a small bowl, whisk together the mayonnaise,rice vinegar and the rest of the gochujang. Add a pinch of salt and whisk again."
    },
    {
      "heading": null,
      "description": "Turn the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Arrange the fries on a large baking tray lined with baking parchment, then scatter over the mince. Add the chopped kimchi. Sprinkle over the cheese and then the remaining sesame seeds. Put into the oven for 10-12 mins until the cheese is golden and bubbling."
    },
    {
      "heading": null,
      "description": "Spoon over the gochujang mayo and scatter with the sliced spring onions and coriander leaves to serve."
    }
  ],
