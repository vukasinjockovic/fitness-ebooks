  "method": [
    {
      "heading": null,
      "description": "Drain and rinse the butter beans. Drain the artichokes and roughly chop them. Drain and chop the pickled peppers. Drain and chop the sundried tomatoes. Drain the mozzarella. Dice the salami. Zest the lemon and set aside."
    },
    {
      "heading": null,
      "description": "Bring a pot of salted water to the boil. Add the green beans and cook for 1 min, then drain and cool under cold water. Drain again and set aside."
    },
    {
      "heading": null,
      "description": "Grab a large mixing bowl. Squeeze in the lemon juice and finely grate in the garlic. Add the olive oil, balsamic vinegar and honey, then whisk until smooth. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Add the butter beans, artichokes, pickled peppers, mozzarella, sundried tomatoes, salami and green beans to the bowl. Add in the lemon zest. Give everything a good mix, taste and adjust seasoning. If making ahead, share between Tupperware containers and chill until needed.\nThe salad will last for up to 3 days in the fridge."
    }
  ],
