  "method": [
    {
      "heading": null,
      "description": "Finely chop the anchovies (keeping the oil in the jar), garlic and parsley stalks (keep the leaves separate)."
    },
    {
      "heading": null,
      "description": "Heat the anchovy oil from the tin in a pan and add the chilli flakes, chopped garlic, and anchovies. Simmer this down until the anchovies begin to dissolve."
    },
    {
      "heading": null,
      "description": "Whack in your parsley stalks and pour in your tinned tomatoes and chickpeas. Break up the tomatoes with a wooden spoon and mix together with the tomato purée. Leave to simmer for 10 minutes until the chickpeas soften and you get a lovely thick, rich sauce."
    },
    {
      "heading": null,
      "description": "Add in your capers and olives."
    },
    {
      "heading": null,
      "description": "Stir through your parsley leaves (saving some for garnish)."
    },
    {
      "heading": null,
      "description": "Season with salt and pepper then serve with some parsley leaves scattered on top and a drizzle of olive oil. Enjoy!"
    }
