  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Grease and line a 20 x 30cm roasting tin. Make up the coffee and leave it to cool. Make sure your butter is at room temperature."
    },
    {
      "heading": null,
      "description": "In a large mixing bowl, use an electric whisk to beat together the olive oil, sugar &amp; vanilla extract."
    },
    {
      "heading": null,
      "description": "Crack in the eggs and add the milk and beat gently until well combined."
    },
    {
      "heading": null,
      "description": "In a separate bowl, sift together the flour, cocoa powder, bicarb and salt. Sir until evenly combined, then beat into the batter until smooth."
    },
    {
      "heading": null,
      "description": "Slowly add the cooled coffee and mix until just combined evenly."
    },
    {
      "heading": null,
      "description": "Pour the cake batter into the prepared tin and bake for 25-30 mins or until a toothpick inserted in the centre comes out clean. Leave to cool for 10 mins in the tin then transfer to a wire rack to cool completely."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the chocolate buttercream. Beat the butter alone for 4–5 mins on high speed. Sift in the cocoa powder and beat until you have a paste. Beat in the icing sugar and add the vanilla, salt, milk and most of the cream then beat together slowly at first on a low speed to bring it together. Beat on high for another 2–3 mins until it’s a smooth consistency. Add more cream if desired."
    },
    {
      "heading": null,
      "description": "Spread a generous layer of the chocolate buttercream over the sponge and top with sprinkles of your choice."
    }
  ],
