  "method": [
    {
      "heading": null,
      "description": "Finely slice onion, red chilli, cloves of garlic, the coriander stalks and the ginger. Set them aside."
    },
    {
      "heading": null,
      "description": "Trim, peel and de-seed the butternut. Then, chop into 2cm chunks. Trim and gently bash the lemongrass to release it's oils."
    },
    {
      "heading": null,
      "description": "Get a large pan on the heat and pour in a glug of olive oil. Add your onion, ginger, garlic, coriander stalks and 1/2 of the chilli. Fry until softened, then add the lemongrass stalk. Mix it in and add your squash."
    },
    {
      "heading": null,
      "description": "Stir it about. Pour both the coconut milk and stock in, bring the mixture to the boil and place a lid on. Reduce the heat down to medium and let simmer, until the butternut has softened, 15-20 mins."
    },
    {
      "heading": null,
      "description": "Discard the lemongrass stalk. Take a hand blender and blitz the squash mixture."
    },
    {
      "heading": null,
      "description": "Turn up the heat and bubble the soup down until thickened to your liking. Taste and season with salt."
    },
    {
      "heading": null,
      "description": "When ready, pour soup into bowls, scatter with coriander leaves, some of the reserved chilli and drizzle over some olive oil. Enjoy!"
    }
  ],
