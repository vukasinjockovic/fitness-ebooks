  "method": [
    {
      "heading": null,
      "description": "Get a medium-sized pan of salted water on to the boil. Top and tail the green beans, then add to the boiling water along with the edamame. Cook for 3 mins."
    },
    {
      "heading": null,
      "description": "Pop some ice in a large bowl filled with cold water, then spoon the cooked beans straight in with a slotted spoon. Let them chill in there, then drain and pat dry."
    },
    {
      "heading": null,
      "description": "Add the miso paste to a bowl along with the tahini, vinegar, honey, sesame oil and water. Grate in the ginger and squeeze in the juice of the lime, then give it a good whisk until it comes together as a smooth dressing. Season with salt to taste."
    },
    {
      "heading": null,
      "description": "Add the spinach to a large bowl, then tip in the cooked beans. Cut the avocado into chunks, then add this too. Break the mackerel into pieces and pop into the bowl, then drizzle over the dressing. Toss until combined."
    },
    {
      "heading": null,
      "description": "Spoon the salad into bowls, then sprinkle over the sesame seeds and coriander leaves. Serve it up."
    }
  ],
