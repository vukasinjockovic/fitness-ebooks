  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Bash the chicken breasts between two sheets of baking paper until about 1cm thick. Drizzle with half the olive oil, sprinkle over the piri piri seasoning and season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Transfer to a baking tray lined with foil and bake for about 12 mins, or until fully cooked. Set aside then slice before serving."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely slice the garlic. Using a vegetable peeler, peel off a few strips of lemon zest. Finely slice the red chilli, if using."
    },
    {
      "heading": null,
      "description": "Heat the rest of the olive oil in a large frying pan set over a medium heat. Add the garlic and cook for a couple of minutes until just golden. Stir through the fennel seeds and chilli and let them sizzle for 30 seconds."
    },
    {
      "heading": null,
      "description": "Pour in the chickpeas along with all their liquid, add the lemon zest strips and season well with salt and pepper. Mix, then cover with a lid and simmer gently for 10 mins."
    },
    {
      "heading": null,
      "description": "Finely chop the parsley. Take the pan off the heat and stir through the Greek yoghurt and most of the chopped parsley."
    },
    {
      "heading": null,
      "description": "Slice the cooked chicken and serve it on top of the creamy chickpeas. Finish with a bit more parsley if you fancy."
    }
  ],
