  "method": [
    {
      "heading": null,
      "description": "Finely chop the garlic. Chop the broccoli into small florets, smaller than you would usually."
    },
    {
      "heading": null,
      "description": "Add half the olive oil to a large saucepan with a lid and set over a medium heat. Chuck in the garlic and cook for a couple of minutes until fragrant."
    },
    {
      "heading": null,
      "description": "Tip in the rice and pour in the chicken stock. Bring to the boil, then cover with the lid, reduce the heat to low and cook for 4 mins."
    },
    {
      "heading": null,
      "description": "After 4 mins, scatter the broccoli over the top. Give everything a quick stir, replace the lid and cook for another 8 mins. Turn off the heat and leave the rice to steam for 10 mins while you crack on with the chicken."
    },
    {
      "heading": null,
      "description": "Place one of the chicken breasts between two sheets of baking paper and bash it with a rolling pin until about 1cm thick. Repeat with the rest of the chicken. Add the flattened chicken to a bowl with the remaining olive oil, ground cumin, a generous pinch of salt and pepper. Toss to coat."
    },
    {
      "heading": null,
      "description": "Heat a large frying pan over a high heat. Once hot, add the chicken and cook for 3-4 mins on each side until well charred and cooked through. Transfer to a piece of foil, squeeze over the juice of the lemon and loosely seal to keep warm."
    },
    {
      "heading": null,
      "description": "Finely chop the dill and stir it through the rice. Taste and season with more salt and pepper if needed."
    },
    {
      "heading": null,
      "description": "Slice the chicken and serve it over the rice with a generous dollop of cottage cheese. Grate over a little lemon zest if you fancy."
    }
  ],
