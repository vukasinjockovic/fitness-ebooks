  "method": [
    {
      "heading": null,
      "description": "Cut the cod into two large pieces and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Place a medium, deep nonstick frying pan over a medium-high heat. Chuck in the cherry tomatoes and cook for 5 mins, tossing occasionally, until they start to burst. Add splashes of water if they begin to catch."
    },
    {
      "heading": null,
      "description": "Stir through the curry paste and cook for 1 min until fragrant. Add the frozen peppers and drained chickpeas, coating them in all that curry goodness. Pour in the coconut milk then bring everything to a simmer."
    },
    {
      "heading": null,
      "description": "Nestle in the cod pieces, cover with a lid and cook gently for 8 mins until the fish is opaque and flakes easily. About halfway through, scatter over the spinach and let it wilt, then gently fold it through the soup."
    },
    {
      "heading": null,
      "description": "Meanwhile, microwave the poppadoms following pack instructions — no need for oil."
    },
    {
      "heading": null,
      "description": "Ladle the curry into bowls and lightly crush the poppadoms over the top or serve them whole on the side for scooping."
    }
  ],
