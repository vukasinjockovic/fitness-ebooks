  "method": [
    {
      "heading": null,
      "description": "Cut the chilli in half, remove the seeds and finely dice. Pick the mint leaves, finely chop them and finely dice the onion."
    },
    {
      "heading": null,
      "description": "Defrost the peas either in the microwave or by pouring boiling water over them. Add the peas to a bowl along with the chilli, mint and onion. Add the capers, balsamic vinegar, a splash of oil and a pinch of salt to the bowl and stir well. Set aside in the fridge."
    },
    {
      "heading": null,
      "description": "For the batter, put the flour into a bowl along with ½ tsp salt and ½ tsp black pepper. Add the beer and whisk until smooth."
    },
    {
      "heading": null,
      "description": "Cut the cod into chunky fingers about 4cm wide and pat dry."
    },
    {
      "heading": null,
      "description": "Cover the bottom of a large, deep frying pan with neutral oil and heat to 180°C. When the oil is ready, immerse the cod fingers in the batter until fully coated and lay directly into the pan. Repeat the process without overfilling the pan. Cook on each side for 3-4 mins or until golden, then transfer to a cooling rack or plate lined with kitchen paper."
    },
    {
      "heading": null,
      "description": "For the curry mayo, combine the mayonnaise, curry powder, lemon juice and a pinch of salt in a bowl. Stir until fully incorporated. Heat the tacos following pack instructions and remove the pea salsa from the fridge."
    },
    {
      "heading": null,
      "description": "Assemble by spreading some mayonnaise over a taco, then add a fish finger and a generous helping of pea salsa on top."
    }
  ],
