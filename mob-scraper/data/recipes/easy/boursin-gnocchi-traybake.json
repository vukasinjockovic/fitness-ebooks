  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 200°C fan."
    },
    {
      "heading": null,
      "description": "Tip the gnocchi into a large tray. Slice the broccoli into 3cm- 5cm lengths and add to the tray. Snuggle the Boursin in. Drizzle with olive oil and season well. Slide into the oven and bake for 15-20 mins."
    },
    {
      "heading": null,
      "description": "Remove from the oven and stir to combine. Add the spinach along with a big splash of boiling water. Keep string, adding enough boiling water to wilt the spinach. Add the juice of the lemon and then finely grate most of the Parmesan into the tray and stir to make a silky cheesy sauce."
    },
    {
      "heading": null,
      "description": "Spoon into bowls, finely grate the remaining Parmesan over the top, then finish with a crack of black pepper."
    }
