  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C fan."
    },
    {
      "heading": null,
      "description": "Cut the aubergines into 2cm slices and cut the tomatoes into irregular pieces."
    },
    {
      "heading": null,
      "description": "Place the tomatoes in a sieve over a bowl, season with salt, and set aside to drain."
    },
    {
      "heading": null,
      "description": "Toss the aubergine slices with olive oil, salt, and black pepper, then spread onto a baking tray. Roast for 35 mins, flipping for the final 10 mins, until soft and charred."
    },
    {
      "heading": null,
      "description": "Heat ½ tbsp olive oil in a pan over medium heat. Add the breadcrumbs and toast until golden. Remove from heat, then stir in the lemon zest and season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "In a bowl, whisk together the yoghurt, honey, Dijon mustard, lemon juice, and grated parmesan. Season with salt and black pepper. For a smoother consistency, blend the dressing until fully combined."
    },
    {
      "heading": null,
      "description": "Add the butter beans to a bowl along with the roasted aubergine and drained tomatoes. Toss to combine. If using, mix in the rocket."
    },
    {
      "heading": null,
      "description": "To serve, divide into boxes or plates, drizzle with the parmesan dressing, and sprinkle with crispy breadcrumbs. Garnish with fresh basil and extra parmesan. If packing for meal prep, store the breadcrumbs separately and add just before serving."
    }
  ],
  "tips": [
    "Storage: Keep refrigerated in airtight containers for up to 3 days. Store breadcrumbs separately to keep them crispy.",
    "Substitutions: Swap butter beans for chickpeas or cannellini beans. Use pecorino instead of parmesan for a sharper flavour.",
    "Serving Ideas: Enjoy warm or cold. Pair with crusty bread or a simple green salad."
  ],
