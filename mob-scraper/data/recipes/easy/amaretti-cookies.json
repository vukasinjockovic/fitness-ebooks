  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 150°C. Line a large baking tray with baking paper. Sift the icing sugar into a small bowl and set aside."
    },
    {
      "heading": null,
      "description": "In a separate mixing bowl, mix together the caster sugar, salt and ground almonds. Zest in the lemons and mix thoroughly."
    },
    {
      "heading": null,
      "description": "In another mixing bowl, use an electric whisk to beat the egg whites and honey together until thick and glossy with stiff peaks forming."
    },
    {
      "heading": null,
      "description": "Use a spoon or spatula to gently fold the egg whites into the ground almond mix. Use a spoon or your hands to portion out the dough into roughly 25g pieces and roll them into balls."
    },
    {
      "heading": null,
      "description": "Coat the cookies in some icing sugar and place them on the prepared baking tray."
    },
    {
      "heading": null,
      "description": "Gently press an almond into the centre of each cookie then slide the tray into the oven to bake for 15-20 mins, until cracked on the surface. Let them cool down fully before serving."
    }
  ],
