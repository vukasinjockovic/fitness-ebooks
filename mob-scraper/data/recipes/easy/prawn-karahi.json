  "method": [
    {
      "heading": null,
      "description": "Remove the tops off the peppers and their seeds. Cut into 4cm pieces. Peel and cut the onion into similar-sized pieces. Trim the ends off the green beans and cut into 4cm pieces. Scrape everything into a bowl. Finely dice the tomatoes and finely slice the green chilli, then set both aside."
    },
    {
      "heading": null,
      "description": "Spoon the turmeric, coriander and cumin into a shallow bowl, then drain the prawns really well and add to the bowl. Add a pinch of salt, then toss really well."
    },
    {
      "heading": null,
      "description": "Heat half of the vegetable oil in a large frying pan, karahi or wok set over a high heat. Once hot, carefully add the prawns and stir-fry for 2 mins until turning pink and slightly charred. Scoop out onto a plate. Tip in the chunky chopped vegetables along with the remaining vegetable oil and fry for 5 mins, stirring every now and again until softening and caramelised. Scrape in the tomatoes and sprinkle in half the green chilli along with the water. Turn the heat to medium and cook for 10 mins until the tomatoes have collapsed and the veg is cooked."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the lime pickle and stir it through the yoghurt."
    },
    {
      "heading": null,
      "description": "Add the prawns back to the pan, spoon in the garam masala, half and squeeze in the lemon and stir through the coriander. Season to taste."
    },
    {
      "heading": null,
      "description": "Spoon the prawn stir-fry into a serving bowl, spoon over some of the yoghurt and sprinkle over the remaining chilli and a few coriander leaves."
    }
  ],
