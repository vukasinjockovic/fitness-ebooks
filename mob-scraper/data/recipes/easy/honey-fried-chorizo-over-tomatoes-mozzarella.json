  "method": [
    {
      "heading": null,
      "description": "Slice the tomatoes into large 3cm chunks, then transfer to a bowl with a pinch of salt, pepper and the red wine vinegar. Allow to sit for 15 mins."
    },
    {
      "heading": null,
      "description": "Very thinly slice the red onion, then transfer to a bowl with ice-cold water and set aside."
    },
    {
      "heading": null,
      "description": "Slice open the chorizo sausages, then crumble the sausagemeat into small chunks. Place a frying pan over a medium-high heat. Once hot, add the oil and the chorizo. Fry for 3-4 mins until crisp and the oil is bright red. Turn off the heat and add the honey. Allow to cool a little (2 mins) before transferring to the tomato bowl."
    },
    {
      "heading": null,
      "description": "Drain the mozzarella balls then tear them onto a plate. Spoon over the tomato and chorizo. Drain the onions then scatter them on top. Serve with bread for scooping."
    }
