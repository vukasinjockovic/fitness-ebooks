  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to fan 190°C. Ensure your butter is very cold."
    },
    {
      "heading": null,
      "description": "Pat the chicken wings dry, and place them into a bowl with the oil and cornflour. Season generously with salt and toss together. Space them out onto a large baking tray lined with baking paper, and roast for 30-35 mins."
    },
    {
      "heading": null,
      "description": "Add the sugar, bourbon, vanilla extract, tomato ketchup, vinegar and cayenne into a saucepan and place over a medium-high heat. Bring to the boil, then reduce the heat to medium and simmer for 8-12 mins or until reduced by half. Take it off the heat, and whisk through the cold butter. Taste and season with salt, pepper and an extra dash of vinegar, if needed."
    },
    {
      "heading": null,
      "description": "Meanwhile, pick the coriander leaves and thinly slice the stems. Thinly slice the chives then toss all the herbs together with the crispy onions."
    },
    {
      "heading": null,
      "description": "Once the wings are baked, transfer to a bowl and toss with the glaze. Toss ½ the herb mixture through."
    },
    {
      "heading": null,
      "description": "Plate up and top with the remaining herb mix."
    }
  ],
