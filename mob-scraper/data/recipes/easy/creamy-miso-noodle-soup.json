  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C fan."
    },
    {
      "heading": null,
      "description": "Tear or slice the mushrooms into 1cm chunks, then spread them out on a baking tray. Drizzle with olive oil and ½ the soy sauce. Season with black pepper. Slide into the oven to roast for 30-35 mins, flipping halfway, until golden brown."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of water to the boil, then lower in the eggs and cook for 7 mins. Drain and cool under running water before peeling."
    },
    {
      "heading": null,
      "description": "Bring another pan of salted water to the boil. Add the soba noodles and edamame beans and cook following packet instructions. Drain and set aside."
    },
    {
      "heading": null,
      "description": "Blitz the silken tofu and water together in a blender until smooth. Pour into a saucepan set over a medium heat and stir in the stock cube. Place the miso in a small sieve and partially submerge it in the soup. Use the back of a teaspoon to stir and dissolve the miso into the soup. Season with soy sauce to taste."
    },
    {
      "heading": null,
      "description": "Thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "To serve, divide the noodles and edamame between bowls, then ladle over the miso broth. Halve the eggs and add them to the bowls, along with the roasted mushrooms. Top with spring onions, a drizzle of chilli oil and a sprinkling of sesame seeds."
    }
  ],
