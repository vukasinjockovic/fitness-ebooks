  "method": [
    {
      "heading": null,
      "description": "Slice the chicken thigh fillets into chunk strips. Season with salt and pepper and toss well to coat. In a small bowl, combine the harissa paste (add less if you want a little less spice)and balsamic vinegar with water."
    },
    {
      "heading": null,
      "description": "Place a pot of salted water to the boil. Once boiling, tip the couscous in and cook according to package instructions. Then, drain and set aside."
    },
    {
      "heading": null,
      "description": "Heat a splash of vegetable oil in a large sauté pan over medium heat. Add the chicken and cook, tossing occasionally, for 10 mins, or until cooked through. Add the harissa mixture and cook for a further 2 mins, or until the chicken is nicely coated in the sauce."
    },
    {
      "heading": null,
      "description": "Share the couscous between plates and top with the chicken. Drizzle the yoghurt over the top and finish with the pomegranate kernels and picked coriander leaves then tuck in and enjoy."
    }
  ],
