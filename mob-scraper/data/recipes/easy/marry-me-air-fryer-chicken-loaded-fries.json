  "method": [
    {
      "heading": null,
      "description": "Use a sharp knife to cut the potatoes into even-sized skinny chips. Transfer them to a microwave-safe container and cook them on a medium-high setting in the microwave for 7 mins until softened."
    },
    {
      "heading": null,
      "description": "Meanwhile dice the chicken into bite-sized chunks, crush the garlic cloves, and slice the sundried tomatoes into bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Heat the air fryer to 190°C. Transfer the softened chips to the air fryer basket. Spray with the low calorie cooking spray and season with the paprika, mixed herbs and salt and pepper. Shake to coat the fries then cook in the air fryer for around 20 mins until golden."
    },
    {
      "heading": null,
      "description": "Spray a large frying pan with the low calorie cooking spray and set it over a medium heat. Add the chicken and pan fry for about 7 mins or until cooked through. Add the garlic and sundried tomatoes and cook for another couple of minutes until fragrant and softened."
    },
    {
      "heading": null,
      "description": "Add the ground thyme, ground oregano, ground basil, red pesto, cream cheese and water. Mix to combine and bring to a gentle simmer. Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Tip the chips into a bowl and top with the creamy chicken. Scatter over some chopped fresh basil and dig in!"
    }
  ],
