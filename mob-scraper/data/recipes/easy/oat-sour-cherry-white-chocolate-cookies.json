  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C fan. Line a baking tray with baking parchment. Break the white chocolate up into small 2-3cm chunks."
    },
    {
      "heading": null,
      "description": "Add the butter and both sugars to a bowl and use an electric whisk to beat them together for 5-7 mins until pale and fluffy. Crack the egg in and beat until incorporated."
    },
    {
      "heading": null,
      "description": "In a separate bowl, whisk together the flour, cornflour, malt powder, ground cardamom, bicarbonate of soda and salt. Tip into the beaten butter and egg mix and stir to combine. Then stir in the oats, sour cherries and white chocolate."
    },
    {
      "heading": null,
      "description": "Use your hands to portion the mixture into cookies – around 70g per cookie – and spread them out in a baking tray, making sure there’s room between each one."
    },
    {
      "heading": null,
      "description": "Bake for 12-15 mins until golden. Leave them to cool for 10-15 mins before serving."
    }
  ],
