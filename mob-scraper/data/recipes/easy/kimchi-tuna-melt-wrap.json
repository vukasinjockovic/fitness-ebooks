  "method": [
    {
      "heading": null,
      "description": "Finely slice the spring onions, roughly chop the kimchi, and finely dice the celery. Add to a medium mixing bowl along with the drained tuna, cream cheese, mayo and sriracha. Mix everything together until well combined."
    },
    {
      "heading": null,
      "description": "Finely slice the red onion using a mandoline or sharp knife. If you prefer a milder flavour, soak it in iced water for a few minutes, then drain well. Grate the Cheddar and set aside."
    },
    {
      "heading": null,
      "description": "Choose your base – wraps, pitas, flatbreads, or even bread all work well."
    },
    {
      "heading": null,
      "description": "Spread a layer of the tuna mix onto your chosen base, followed by a layer of red onion. Top with grated mozzarella and Cheddar."
    },
    {
      "heading": null,
      "description": "Toast in a non-stick pan or pop in the air fryer for 6 mins until crispy and the cheese is melted. Serve immediately."
    }
  ],
