  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Blend up the Puy Lentils, 4 cloves of garlic, 3 spring onions, and a chilli with 2 tbsp of soy sauce and the juice of a lime to form a smooth paste. Then add in the breadcrumbs and give it a good mix. Taste the mixture and add a pinch of salt if needed."
    },
    {
      "heading": null,
      "description": "Roll the mixture into golf ball-sized balls. Pop these onto a baking tray and bake for 30 mins."
    },
    {
      "heading": null,
      "description": "Chop the onions and peppers into large chunks."
    },
    {
      "heading": null,
      "description": "Finely chop the remaining garlic and finely slice the spring onions."
    },
    {
      "heading": null,
      "description": "Add a glug of oil into a pan and then fry the onions and peppers for 3 mins. Add in the garlic and then cook for 1 minute."
    },
    {
      "heading": null,
      "description": "Add in the pineapple juice, apple cider vinegar, ketchup and light brown sugar. Give it a good mix and bring it to a boil."
    },
    {
      "heading": null,
      "description": "Make a cornflour slurry by mixing 2 tbsp of cornflour with 2 tbsp of water. Add this into the pan and cook for 3 mins."
    },
    {
      "heading": null,
      "description": "Add in your now-cooked meatballs and give it a good mix."
    },
    {
      "heading": null,
      "description": "Serve with steamed rice and a sprinkle of sliced spring onions."
    }
  ],
