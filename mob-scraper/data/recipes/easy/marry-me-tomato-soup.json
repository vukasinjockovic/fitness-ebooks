  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Slice the vine tomatoes into quarters and the onion and peppers into large chunks. Slice the bulb of garlic horizontally."
    },
    {
      "heading": null,
      "description": "Place the chopped vegetables in a deep oven-proof dish, along with the whole cherry tomatoes. Place the bulb of garlic face-up in the centre. Drizzle with a glug of olive oil and season generously with salt and pepper. Roast in the oven for 35 mins."
    },
    {
      "heading": null,
      "description": "Remove the tray from the oven and transfer all the veggies and their juice to a large saucepan, squeezing out the roasted garlic cloves and discarding the skins. Add the crème fraîche, pesto, torn fresh basil and 500ml vegetable stock and blitz with a hand blender until smooth."
    },
    {
      "heading": null,
      "description": "Turn up the heat and warm through the soup until piping hot, stirring occasionally. Divide into bowls and serve with toasted ciabatta."
    }
