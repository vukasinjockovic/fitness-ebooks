  "method": [
    {
      "heading": null,
      "description": "In a small blender, pulse the pine nuts into a crumb. Mince the garlic, then add along with a pinch of salt and pulse again. Add the basil and pulse until smooth. Add half of the Parmesan, and pulse again to combine. Repeat with the remaining Parmesan."
    },
    {
      "heading": null,
      "description": "Empty the contents of the blender into a bowl and stream in the extra virgin olive oil whilst stirring continuously."
    },
    {
      "heading": null,
      "description": "Cook the gnocchi and green beans in boiling salted water until the gnocchi start to float to the surface. Drain and reserve some of the cooking water."
    },
    {
      "heading": null,
      "description": "Toss the gnocchi with the pesto and add splashes of cooking water until you reach a creamy consistency."
    }
