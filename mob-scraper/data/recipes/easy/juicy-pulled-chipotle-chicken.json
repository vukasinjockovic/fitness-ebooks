  "method": [
    {
      "heading": null,
      "description": "Finely dice the onion, grate the garlic and thinly slice the peppers."
    },
    {
      "heading": null,
      "description": "Set a large saucepan (a shallow casserole pot is best) over a medium heat with a drizzle of olive oil. Add the onion and peppers. Cook for 5–7 mins until softened, then add the garlic, coriander, cumin, chipotle paste and tomato purée. Cook for 2 mins until fragrant and slightly darkened."
    },
    {
      "heading": null,
      "description": "Add the chicken thighs to the pan and pour in the chicken stock. Season with salt and pepper. Bring to the boil, over a medium heat for 25–30 mins until the chicken is tender and the sauce has thickened. Add a splash of water if you want it saucier, or let it reduce more if you want it thicker."
    },
    {
      "heading": null,
      "description": "Use two forks to shred the chicken directly in the pan. Stir it all together so everything’s coated in that smoky sauce."
    },
    {
      "heading": null,
      "description": "If prepping ahead, let it cool to room temp and then spoon into a container and chill until needed."
    }
