  "method": [
    {
      "heading": null,
      "description": "Finely grate the ginger, trim and finely dice the onion and thinly slice the coriander, stalks and all."
    },
    {
      "heading": null,
      "description": "Combine all the ingredients in a large bowl (except the oil or ghee) to make a thin batter. Let it sit for 10 mins. Once rested, add more water if required – the batter needs to be very thin to achieve those characteristic dosa holes."
    },
    {
      "heading": null,
      "description": "Heat a non-stick pan over a medium-high heat. Add a ladle full of the batter in and cook for 30 seconds. Don’t swirl the pan – just add a few more tablespoons of batter to any areas that haven’t already been covered."
    },
    {
      "heading": null,
      "description": "Drizzle over some oil or ghee and allow the dosa to cook for 2-3 mins until the edges turn golden. Scrape off any excess batter for a super-crisp and thin dosa, if you like."
    },
    {
      "heading": null,
      "description": "Peel the dosa off the pan and serve with your favourite chutneys. Check out my coconut and tomato chutney recipes (also on mob.co.uk) for inspiration."
    }
  ],
