  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 210°C fan."
    },
    {
      "heading": null,
      "description": "Whisk the gochujang, soy sauce and hot honey together in a small bowl. Set aside."
    },
    {
      "heading": null,
      "description": "Cut the cabbage into sixth wedges, keeping the core intact so the leaves stay together. Trim the spring onions but leave them whole."
    },
    {
      "heading": null,
      "description": "Chuck the cabbage, spring onions and frozen peppers into a medium roasting tin. Brush generously with most of the gochujang glaze, saving a bit back for the salmon. Spritz everything with olive oil and season with salt and pepper. Roast for 10 mins."
    },
    {
      "heading": null,
      "description": "Carefully turn the veg, then nestle the salmon fillets into the tin. Brush them with the remaining glaze and return to the oven for 8-10 mins, or until the salmon is cooked through and flakes easily."
    },
    {
      "heading": null,
      "description": "Serve up the roasted salmon and veg. Pick over the coriander, sprinkle with sesame seeds if you like, and serve with lime wedges on the side."
    }
  ],
