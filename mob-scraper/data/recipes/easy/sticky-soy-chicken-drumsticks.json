  "method": [
    {
      "heading": null,
      "description": "Pre-heat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Grab a bowl. Add some baking powder, salt and pepper. Coat your chicken in this mixture."
    },
    {
      "heading": null,
      "description": "Put the chicken drumsticks on an oven tray. Place in the oven for 50 minutes, or until golden-brown and crispy."
    },
    {
      "heading": null,
      "description": "Whilst waiting, pit and cut your avocados. Finely chop up your bunch of coriander and your spring onions. Whack it all into a bowl and smash. Halve a lime and squeeze all the juices into the bowl. Mix again."
    },
    {
      "heading": null,
      "description": "When the chicken is done, grab a large saucepan. Add a knob of grated ginger, chopped garlic cloves and a splash of olive oil. Cook until softened."
    },
    {
      "heading": null,
      "description": "Add sweet chilli sauce, light soy sauce, dark soy sauce and cook until the sauce is sticky."
    },
    {
      "heading": null,
      "description": "Add your cooked drumsticks and toss!"
    },
    {
      "heading": null,
      "description": "Serve the drumsticks with the guac on the side. Enjoy MOB!"
    }
