  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Lay a streaky bacon rasher on a chopping board and use the back of a large knife to stretch the rasher so it becomes elongated (you want it to be about 1.5 times its normal length). Repeat with the remaining rashers."
    },
    {
      "heading": null,
      "description": "Season the chicken breasts lightly with salt and cracked black pepper. Taking one rasher at a time, wrap the rasher around the chicken breast, slightly overlapping it as you go, then repeat with another rasher so that the chicken is wrapped in two slices of bacon. Repeat with the remaining chicken breasts and bacon rashers. Put the chicken breasts into a roasting tin and into the oven for 25 mins."
    },
    {
      "heading": null,
      "description": "While the chicken roasts, use a sharp knife to finely slice the chives, then set aside and finely grate the cheddar."
    },
    {
      "heading": null,
      "description": "Mix the Worcestershire sauce and the BBQ sauce together, then spoon over the chicken, and scatter over the cheddar. Put back into the oven for 5 mins until the cheese and sauce are bubbling. Remove from the oven and top with the finely chopped chives."
    }
  ],
