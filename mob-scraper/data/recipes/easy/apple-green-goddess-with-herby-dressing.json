  "method": [
    {
      "heading": null,
      "description": "Add the herbs, crème fraîche, peeled garlic, olive oil, Dijon and ½ the lime to a blender, then season with salt and pepper. Blitz until smooth, then taste and adjust seasoning as needed."
    },
    {
      "heading": null,
      "description": "Slice the apple into matchsticks, then the sugar snaps into 2cm pieces on a diagonal."
    },
    {
      "heading": null,
      "description": "Cook the edamame in boiling water for 7 mins then drain."
    },
    {
      "heading": null,
      "description": "Using a veg peeler, finely shred the green cabbage and peel, pit and slice the avocado."
    },
    {
      "heading": null,
      "description": "Squeeze the rest of the lime juice into a bowl with the cabbage, seasoning with salt. Massage until it just starts to soften. Then add the edamame, sugar snaps, drained beans and apple mixing well."
    },
    {
      "heading": null,
      "description": "Box up the slaw. If eating immediately, drizzle with the dressing. If not, box the dressing up for later."
    }
  ],
