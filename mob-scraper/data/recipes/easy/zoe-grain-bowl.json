  "method": [
    {
      "heading": null,
      "description": "Finely slice the red onion and add to a jar or bowl with a sprinkle of salt. Pour over the apple cider vinegar and enough water to cover the onions then place in the fridge for at least 30 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, chop the broccoli into florets, slice the mushrooms and dice the tofu. Pan-fry them, one ingredient at a time, with a drizzle of olive oil over a medium-high heat until crispy. Season with salt."
    },
    {
      "heading": null,
      "description": "To make the dressing, mix together the tahini, lime juice and soy sauce and grate in the garlic and ginger. Taste to check the seasoning and add more soy sauce for saltiness or lime juice for acid if needed."
    },
    {
      "heading": null,
      "description": "Dice the cucumber and halve the cherry tomatoes."
    },
    {
      "heading": null,
      "description": "To build your bowls, start with the grains at the bottom and top with the crispy tofu, broccoli and mushrooms. Add the cucumber, cherry tomatoes and pickled onions then drizzle over the dressing and sprinkle over the hemp seeds."
    }
  ],
