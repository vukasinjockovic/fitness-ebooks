  "method": [
    {
      "heading": null,
      "description": "Add your parsley, mint, tahini, the juice of your lemon, olive oil and the water to a blender with a pinch of salt. Blitz to a really smooth sauce."
    },
    {
      "heading": null,
      "description": "Pour 1/3 of this mixture into a bowl along with your za’atar and a good pinch of salt. Add your chicken and mix to combine. Leave to marinade."
    },
    {
      "heading": null,
      "description": "Very finely slice your courgettes using a mandoline, if you’ve got one, or a sharp knife."
    },
    {
      "heading": null,
      "description": "Cut the ends off your baby gem and separate the leaves. Give them a wash to remove any dirt."
    },
    {
      "heading": null,
      "description": "Heat a griddle pan over a medium-high heat. Once hot, add your chicken and fry for about 5 mins on each side until it is totally cooked through. Remove from the pan to rest for 10 mins."
    },
    {
      "heading": null,
      "description": "Once your chicken has cooled enough to handle, slice it into pieces."
    },
    {
      "heading": null,
      "description": "Add your lettuce to a bowl along with your sliced courgettes and chicken. Pour over your remaining dressing, then toss to combine."
    },
    {
      "heading": null,
      "description": "Top with your crispy shallots, then serve."
    }
  ],
