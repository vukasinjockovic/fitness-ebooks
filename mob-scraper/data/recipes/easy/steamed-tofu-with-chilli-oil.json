  "method": [
    {
      "heading": null,
      "description": "Grab your tofu and carefully cut along the edge of the packaging. If there’s excess liquid, carefully drain over the sink. Place a plate over the open end of the tofu container, then carefully flip. Cut small holes in all four diagonal corners to let air in, then slowly release the tofu from the packaging."
    },
    {
      "heading": null,
      "description": "To prepare your steaming set up, fill a wok with 3cm water and bring to the boil. Turn the heat to low-medium, place the tofu on a heatproof plate and slice into 1 ½ cm pieces, cover with a lid and steam for 6 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, mince the garlic and finely slice the spring onions and chillies. Roughly chop the coriander. Add the minced garlic and spring onion whites to a heatproof bowl."
    },
    {
      "heading": null,
      "description": "Pour a glug of vegetable oil into a pot set over medium-high heat. When the oil starts to lightly smoke, add it to the heatproof bowl with the garlic and spring onion. Add the spring onion greens, chillies, coriander, remaining seasonings and sauces, and mix well."
    },
    {
      "heading": null,
      "description": "Serve the tofu with some crushed peanuts, crispy shallots and chilli oil (and leftover rice if you have any). Enjoy!"
    }
  ],
