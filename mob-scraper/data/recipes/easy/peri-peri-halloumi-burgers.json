  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Cut your peppers and red onion into chunky 2-inch pieces (make sure they're not too small)."
    },
    {
      "heading": null,
      "description": "Get the peppers and red onion chunks on a baking tray. Add the lemon half to the tray, cut side down. Drizzle with olive oil and season with salt and black pepper. Slide the tray into the oven to bake for 45 mins until the peppers are beginning to char."
    },
    {
      "heading": null,
      "description": "Remove the tray from the oven. To a blender, add ⅔ of the peppers, all the onions and the squeezed out pulp of the roasted lemon."
    },
    {
      "heading": null,
      "description": "To the same blender, add the paprika, oregano, red wine vinegar, whole red chilli, garlic clove and a glug of olive oil. Season with salt and pepper and blitz until smooth. This is your peri peri."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix your blitzed peri peri with the mayonnaise."
    },
    {
      "heading": null,
      "description": "Cut the halloumi into 1cm slices. Heat a large frying pan over a medium-high heat then add the halloumi and cook for 4 mins on each side until golden brown and crispy."
    },
    {
      "heading": null,
      "description": "Cut your burger buns in half and quickly toast them, cut side down, in the hot pan until lightly toasted."
    },
    {
      "heading": null,
      "description": "Time to assemble. Take your base bun and spread over a layer of peri peri mayo. Top with some halloumi, some roasted peppers, a small handful of salad leaves, more mayo, more halloumi and finally the bun top. Tuck in and enjoy!"
    }
  ],
