  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C."
    },
    {
      "heading": null,
      "description": "Peel your sweet potatoes, chop them into small chunks then spread evenly on a pan. Finely slice your leeks and add them to a roasting tray with a bulb of garlic in the centre. Drizzle with oil and top with dots of butter, season well and cook for 25 mins, or until nice and soft. You don’t want them to catch."
    },
    {
      "heading": null,
      "description": "Remove the sweet potato chunks and leeks from the oven and add these to large saucepan or casserole dish."
    },
    {
      "heading": null,
      "description": "Dissolve your stock cube into the boiling water and add into the sweet potato and leek mix. Deglaze the tray you used to cook your veggies and add the liquid from that tray into your vegetable stock. Now, add in the flesh of your roasted garlic bulb and thyme. Leave it to simmer while you prepare your bread."
    },
    {
      "heading": null,
      "description": "Cut the sourdough into thin slices and lightly toast."
    },
    {
      "heading": null,
      "description": "Butter your toast and finely grate your cheddar over the top. Place in the oven until the cheese has melted. Set aside."
    },
    {
      "heading": null,
      "description": "Time to blend. Take a hand blender and blend the sweet potato and leek mix until thick and smooth. Add some apple cider vinegar for a bit of acid."
    },
    {
      "heading": null,
      "description": "To finish, ladle the soup into your bowl and season. Tuck in with a side of delicious grilled cheddar toast!"
    }
  ],
