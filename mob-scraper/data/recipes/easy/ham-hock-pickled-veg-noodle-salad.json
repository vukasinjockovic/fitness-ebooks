  "method": [
    {
      "heading": null,
      "description": "Whisk the vinegar, boiling water and sugar in a bowl until the sugar has dissolved. Season generously with salt."
    },
    {
      "heading": null,
      "description": "Finely slice the radishes and carrots (you can use a mandolin if you’ve got one) then cut into matchsticks. Finely slice the chillies. Add the sliced veg and chillies to the pickling liquid and set aside to pickle. The longer they sit, the punchier they’ll be."
    },
    {
      "heading": null,
      "description": "Cook the rice noodles following pack instructions. Once cooked, rinse under cold water and drain well."
    },
    {
      "heading": null,
      "description": "Slice the chives and coriander stalks into 2cm lengths. Pick the mint and coriander leaves, discarding the mint stems. Then pull apart your ham hock into thin pieces."
    },
    {
      "heading": null,
      "description": "Divide the noodles between bowls and drizzle over some of the pickling liquid."
    },
    {
      "heading": null,
      "description": "Toss the pickled veg, herbs and ham together, then pile on top of the noodles. Finish with a scattering of crispy onions and a drizzle of olive oil."
    }
  ],
