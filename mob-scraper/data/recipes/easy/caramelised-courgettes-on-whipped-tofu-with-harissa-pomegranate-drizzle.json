  "method": [
    {
      "heading": null,
      "description": "Use a mandoline or very sharp knife to thinly slice the courgettes. Finely grate the garlic. Place the courgettes into a deep frying pan with a good drizzle of olive oil and plenty of salt and pepper. Add the grated garlic and cook over a low-medium heat for about 10-15 mins until very soft. Stir through the za’atar."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the whipped tofu. Squeeze the lemon juice into a blender, add the remaining ingredients and blend until smooth. Season with salt and pepper to taste."
    },
    {
      "heading": null,
      "description": "Whisk all of the harissa drizzle ingredients together in a small bowl. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Lightly toast the pine nuts."
    },
    {
      "heading": null,
      "description": "To serve, spread the whipped tofu onto a platter, pile up the courgettes and drizzle over the harissa pomegranate sauce. Finish with an extra drizzle of olive oil, salt and pepper and the toasted nuts."
    }
  ],
