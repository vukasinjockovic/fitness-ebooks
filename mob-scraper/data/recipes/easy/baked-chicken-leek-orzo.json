  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids ServingsHeat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Finely slice the leeks and garlic. Cut the chicken thighs into bite-sized chunks."
    },
    {
      "heading": null,
      "description": "Place a large frying pan over a medium heat with a drizzle of olive oil. Add the chicken, season well with salt and black pepper, and fry for 5–6 mins until golden on the outside. Transfer to a plate and set aside."
    },
    {
      "heading": null,
      "description": "Add the leeks and garlic to the same pan and fry for 8–10 mins until soft and golden. Stir in the flour and cook for 1 min, stirring constantly."
    },
    {
      "heading": null,
      "description": "Tip the orzo into a deep roasting tin or ovenproof casserole dish. Add in the cooked chicken and leek mixture, pour over the stock and stir well to combine. Cover tightly with a lid or foil and bake for 25 mins."
    },
    {
      "heading": null,
      "description": "Remove from the oven, stir through the double cream and most of the parmesan. Scatter the rest of the cheese on top, then return to the oven uncovered for 10 mins until golden and bubbling."
    },
    {
      "heading": null,
      "description": "Leave to cool for 5 mins before serving. Or, if freezing, divide into containers once cool, cover and freeze for another day."
    }
  ],
