  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Chop up your bacon into bite-size chunks and add this to a frying pan on a medium heat."
    },
    {
      "heading": null,
      "description": "Squeeze the meat out of your sausages and roll them into small balls. Add them to the bacon."
    },
    {
      "heading": null,
      "description": "Chop up your mushrooms and add to the pan, giving everything a good stir. Add your tomatoes (whole) and stir. Allow everything to cook."
    },
    {
      "heading": null,
      "description": "As everything begins to brown and the tomatoes are cooked, grate your garlic into the pan. Add a good grinding of pepper and salt. Add the spinach and stir until it begins to wilt. Take the pan off the heat."
    },
    {
      "heading": null,
      "description": "Egg time! Crack all of your eggs into a large mixing bowl. Pour in your milk, add salt and pepper and whisk until smooth."
    },
    {
      "heading": null,
      "description": "Pour the whisked egg into the frying pan, making sure you cover all of the food. Place the pan in the oven for 13 minutes."
    },
    {
      "heading": null,
      "description": "Once it’s done, serve with a slice of sourdough and tuck into this wonderful breakfast."
    }
