  "method": [
    {
      "heading": null,
      "description": "Halve and finely slice the onion; finely chop the garlic."
    },
    {
      "heading": null,
      "description": "Add the oil and butter to a large, non-stick pan and set over a medium heat. Add the onion with a pinch of salt and cook for 10–15 mins, stirring often, until soft, sticky, and golden."
    },
    {
      "heading": null,
      "description": "Add the garlic and cook for 1–2 mins. Stir in the rice and pour over the water. Cover with a lid and cook on low heat for about 10 mins, until the rice is tender and water absorbed. Stir gently, cover, and let steam off the heat for 10 more minutes."
    },
    {
      "heading": null,
      "description": "Meanwhile, prepare the broccoli salad. Trim the florets from the broccoli and finely slice each one (or shave with a mandoline). In a bowl, whisk together the olive oil, lemon juice, yoghurt, za’atar (if using), tahini, salt and pepper. Add the broccoli and toss to coat. Taste and adjust seasoning."
    },
    {
      "heading": null,
      "description": "Season the salmon with salt. Heat a frying pan over high heat with a glug of oil. Once hot, add the salmon skin-side down. Press down gently on the flesh so the skin makes even contact with the pan. Cook for 5–6 mins until the skin is crisp, then flip the fillets, turn off the heat, and let the residual heat finish cooking."
    },
    {
      "heading": null,
      "description": "Serve the salmon over the caramelised onion rice with the broccoli salad and a sprinkle of extra za’atar, if using."
    }
  ],
