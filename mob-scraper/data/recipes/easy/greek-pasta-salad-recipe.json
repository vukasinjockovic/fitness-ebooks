  "method": [
    {
      "heading": null,
      "description": "Thinly slice the red onion. Place in a bowl and cover with the red wine vinegar. Add a pinch of salt, mix well, and let it sit for at least 30 minutes to pickle, stirring occasionally."
    },
    {
      "heading": null,
      "description": "Meanwhile, bring a pan of salted water to the boil. Cook the orzo according to the package instructions until al dente, then drain and rinse with cold water to cool it down quickly."
    },
    {
      "heading": null,
      "description": "Halve or quarter the cherry tomatoes, depending on their size. Dice the cucumber. Halve the kalamata olives, removing the pips if they have them."
    },
    {
      "heading": null,
      "description": "Make the dressing, Whisk the olive oil, juice of the lemon, and honey together. Season with salt and pepper to taste."
    },
    {
      "heading": null,
      "description": "In a large bowl, combine the cooked orzo, cherry tomatoes, cucumber, kalamata olives, and mint leaves. Add the pickled red onions (drained) and crumble the feta cheese over the top. Sprinkle chilli flakes and dried oregano over the salad."
    },
    {
      "heading": null,
      "description": "Pour the dressing over the salad and toss everything together until well combined. Spoon the salad into bowls and serve."
    },
    {
      "heading": null,
      "description": "Optional: If batch cooking for the week, transfer the salad to containers and store in the fridge until ready to serve."
    }
  ],
