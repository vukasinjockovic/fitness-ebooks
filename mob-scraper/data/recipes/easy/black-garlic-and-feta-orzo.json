  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Drop your baby plum tomatoes into a large baking tray so they are all lying flat and pop your block of feta on top."
    },
    {
      "heading": null,
      "description": "In a bowl combine your black garlic paste, oregano, chilli flakes, red wine vinegar, a pinch of salt, few cracks of black pepper and 3 tbsp olive oil."
    },
    {
      "heading": null,
      "description": "Pour your olive oil sauce over the feta and tomatoes and bake in the oven for 30 mins."
    },
    {
      "heading": null,
      "description": "After 30 minutes, crack up the heat to 200°C to char the tomatoes for 15 mins."
    },
    {
      "heading": null,
      "description": "Cook your orzo for 6 mins in boiling salted water."
    },
    {
      "heading": null,
      "description": "Mash up the tomatoes and feta with a fork to form a creamy sauce. Pour on your cooked orzo and mix well, add some pasta water to loosen the sauce if needed - this usually depends on how juicy your tomatoes were."
    },
    {
      "heading": null,
      "description": "Tear your basil leaves, sprinkle on your pine nuts, and it’s ready to enjoy."
    }
  ],
