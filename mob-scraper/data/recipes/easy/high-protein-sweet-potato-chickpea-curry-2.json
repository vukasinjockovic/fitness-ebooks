  "method": [
    {
      "heading": null,
      "description": "Dice the onion and peel and mince the ginger and garlic. Wash and roughly chop the sweet potato into bite-sized chunks. Pick the coriander leaves, roughly chop them, discard the stems and set aside for garnish."
    },
    {
      "heading": null,
      "description": "Heat a generous glug of oil in a non-stick pan over a medium heat. Once hot, add the onion and fry until it begins to develop some colour. Add the ginger, garlic and a pinch of salt, then fry for 1 min. Stir in the spices, tossing frequently until they are toasted – take care not to burn them."
    },
    {
      "heading": null,
      "description": "Add the sweet potato, drained chickpeas and chopped tomatoes. Stir until well combined, then bring the mixture to a simmer."
    },
    {
      "heading": null,
      "description": "Meanwhile, blend the coconut milk and silken tofu in a blender until smooth."
    },
    {
      "heading": null,
      "description": "Pour the coconut milk mixture into the pan, mix until fully combined, then bring it back to a simmer. Allow to simmer for about 15 mins, or until the sweet potatoes are fork-tender. Turn off the heat, then use a fork to smush about one-third of the chickpeas. Season to taste, stir in the lemon juice, and let the dish sit for 10 mins."
    },
    {
      "heading": null,
      "description": "Top with the chopped coriander, then serve with rice and a dollop of vegan coconut yoghurt."
    }
  ],
