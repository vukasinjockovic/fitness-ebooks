  "method": [
    {
      "heading": null,
      "description": "Beat 4 whole eggs together in a bowl and set aside."
    },
    {
      "heading": null,
      "description": "Heat up a non-stick frying pan with a tbsp sesame oil and add your diced onion. Sauté on a medium heat."
    },
    {
      "heading": null,
      "description": "Add the peas and sauté for a couple of minutes with the onions."
    },
    {
      "heading": null,
      "description": "After a couple of minutes move these ingredients to the side of the wok."
    },
    {
      "heading": null,
      "description": "Add the whisked eggs gradually to the empty side of the wok, giving your eggs room to cook."
    },
    {
      "heading": null,
      "description": "Stir in the Tilda Pure Basmati Rice, allowing each grain to be evenly covered with egg mixture. Add soy sauce, salt and pepper and mix well."
    },
    {
      "heading": null,
      "description": "Take off the heat and serve the fried rice into four bowls. Separate your 4 egg yolks and place on top of each portion of rice. Garnish the bowl with a sprinkle of sesame seeds and sliced spring onions."
