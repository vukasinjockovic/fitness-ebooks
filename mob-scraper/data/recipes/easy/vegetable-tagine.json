  "method": [
    {
      "heading": null,
      "description": "Finely slice the red onions. Heat a half of the oil in a large saucepan or casserole dish set over a medium heat. Scrape in the onions with some seasoning. Cook for 8-10 mins, stirring occasionally until soft."
    },
    {
      "heading": null,
      "description": "Meanwhile, peel the carrots and sweet potatoes and cut into medium 3cm-sized chunks. Finely chop the garlic cloves."
    },
    {
      "heading": null,
      "description": "Add the carrot, sweet potato and garlic to the onion along with the remaining oil. Cook, stirring for a couple of minutes then stir in the tomato purée, smoked paprika, cumin, turmeric and cinnamon. Cook, stirring for 2 mins more."
    },
    {
      "heading": null,
      "description": "Tip in the plum tomatoes and the chickpeas along with their water, then refill one of the tins with water and pour that in, too. Bring everything up to the boil, using the back of your spoon to break up the tomatoes a little."
    },
    {
      "heading": null,
      "description": "Finely chop the preserved lemons, and add half to the pan. Once boiling, reduce the heat and simmer away for 20-25 mins until the sweet potato is tender whilst holding its shape."
    },
    {
      "heading": null,
      "description": "Meanwhile, scrape the remaining preserved lemon into a small bowl. Stir in the yoghurt, then season with salt, pepper and lemon juice to taste."
    },
    {
      "heading": null,
      "description": "Roughly chop all the parsley (stalks and all), along with the prunes or dried apricots. Stir the fruit and most of the parsley through the tagine then season to taste, adding any remaining lemon juice."
    },
    {
      "heading": null,
      "description": "Serve the tagine with couscous or flatbreads, the preserved lemon yoghurt spooned over, along with the remaining parsley and toasted flaked almonds, if you like."
    }
  ],
