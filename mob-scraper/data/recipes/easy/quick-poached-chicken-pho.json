  "method": [
    {
      "heading": null,
      "description": "Peel and slice the ginger, roughly chop the onion and smash the garlic cloves with the side of a knife."
    },
    {
      "heading": null,
      "description": "Rinse the chicken breasts under cold water."
    },
    {
      "heading": null,
      "description": "Pour the chicken broth into a large saucepan. Add the ginger, garlic, onion, sugar, salt, MSG and star anise. Drop in the chicken breasts and set the pan over a medium heat."
    },
    {
      "heading": null,
      "description": "Once it starts to simmer, turn the heat down to low and poach the chicken gently — it should stay just below a simmer. Cook for 10–12 mins until the chicken is cooked through."
    },
    {
      "heading": null,
      "description": "Lift the chicken out and set aside to rest. Strain the broth into a clean pan or bowl, discarding the solids. Stir in the fish sauce and keep the broth hot."
    },
    {
      "heading": null,
      "description": "Meanwhile, soak the noodles in freshly boiled water for 3 mins until just tender. Drain and rinse under cold water to stop them cooking."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onions. Pick the mint and coriander leaves. Thinly slice the chillies if using."
    },
    {
      "heading": null,
      "description": "Shred the rested chicken using two forks."
    },
    {
      "heading": null,
      "description": "To serve, divide the noodles between bowls, pour over the hot broth, and top with the shredded chicken, beansprouts, herbs and spring onions. Add chilli oil or bird’s eye chillies if you fancy a kick."
    }
  ],
