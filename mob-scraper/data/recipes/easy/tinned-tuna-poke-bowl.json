  "method": [
    {
      "heading": null,
      "description": "Drain the tuna and chuck it into a bowl with the mayo, sriracha and soy sauce. Mix well and set aside."
    },
    {
      "heading": null,
      "description": "Peel and shred the carrots. Finely slice the red cabbage. Blanch the edamame in boiling water for 3 mins, then drain."
    },
    {
      "heading": null,
      "description": "In a small bowl, whisk together the miso paste, rice vinegar, soy sauce and honey. Add a splash of water to loosen if it’s too thick."
    },
    {
      "heading": null,
      "description": "Mix the carrot and cabbage with two-thirds of the miso dressing and toss to coat."
    },
    {
      "heading": null,
      "description": "To build your bowls, start with a layer of warm rice. Top with the dressed slaw, spicy tuna and edamame beans."
    },
    {
      "heading": null,
      "description": "Drizzle over the remaining dressing, sprinkle with sesame seeds and serve with lime wedges."
    },
    {
      "heading": null,
      "description": "Tear up the nori and use it to scoop up all the good stuff."
    }
  ],
