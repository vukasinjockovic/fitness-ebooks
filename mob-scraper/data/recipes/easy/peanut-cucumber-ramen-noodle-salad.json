  "method": [
    {
      "heading": null,
      "description": "Put the edamame in a heatproof bowl and cover with hot water to defrost. Meanwhile, cook the noodles following pack instructions. Rinse the cooked noodles under cold water and set aside."
    },
    {
      "heading": null,
      "description": "For the sauce, peel and mince the ginger and transfer to a small bowl. Add the soy sauce, peanut butter, sesame oil, lime juice, agave, water and gochujang, then whisk to combine. Set aside."
    },
    {
      "heading": null,
      "description": "Slice the cucumber in half lengthwise and scoop out the watery seeds with a spoon (you can drain the water out of this and drink it, if you like!). Slice the cucumber into 0.5cm diagonal slices and transfer to a large bowl."
    },
    {
      "heading": null,
      "description": "Roughly chop the coriander leaves and finely chop the stems. Pick the mint leaves. Roughly chop the peanuts. Finely slice the spring onion."
    },
    {
      "heading": null,
      "description": "Add all of the herbs to the cucumber bowl along with the edamame, spring onion, dressing and noodles. Toss well."
    },
    {
      "heading": null,
      "description": "Finish with a drizzle of sesame oil and top with the peanuts and kimchi."
    }
  ],
