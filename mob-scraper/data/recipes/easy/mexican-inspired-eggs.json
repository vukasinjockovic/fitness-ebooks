  "method": [
    {
      "heading": null,
      "description": "Finely dice the onion, peppers and chorizo and add to a large pan on a medium heat. Sauté for 10 minutes or until the peppers have softened and the chorizo is crispy. Add 1 tsp of chopped red chillies and stir to coat the peppers and chorizo. Set aside to load up later."
    },
    {
      "heading": null,
      "description": "Drain your beans and add to another large pan on a medium heat. Drizzle olive oil over the beans and add a good crack of black pepper. Lightly crush your beans with a spoon. Add 1 tsp of chopped red chillies to the beans with a pinch of salt and cook for 5 minutes, stirring often until the bean mixture thickens slightly."
    },
    {
      "heading": null,
      "description": "Time for those eggs! Add a generous amount of oil to a pan and fry your eggs until the whites are slightly crispy and the yolks are runny. A great way to ensure this is to cover the eggs in the oil with a spoon."
    },
    {
      "heading": null,
      "description": "Place your tortillas in a hot, dry pan one by one to warm through."
    },
    {
      "heading": null,
      "description": "Time to build that bad boy. Slice your avocadoes, chop the coriander and halve the lime. Spoon the beans onto the tortilla, followed by the chorizo and pepper mixture. Place a sliced avocado half on top and load on that fried egg. Crumble 1 tbsp of feta over the egg with a pinch of coriander, a squeeze of lime and a quarter tsp of chopped red chillies. Repeat for your MOB. Enjoy!"
    }
  ],
