  "method": [
    {
      "heading": null,
      "description": "Dice the shallots, then wash and roughly chop the mushrooms. Heat a good drizzle of sesame oil in a pan set over a low heat. Once hot, add the diced shallots and sauté for 3-4 mins until fragrant and translucent."
    },
    {
      "heading": null,
      "description": "Add the mushrooms and soy sauce, then sauté until the mushrooms have lost most of their water and are starting to sizzle and turn brown. Turn off the heat."
    },
    {
      "heading": null,
      "description": "Put half of the cooked mushrooms into a blender, along with the miso paste, tofu and stock. Blend until creamy and smooth."
    },
    {
      "heading": null,
      "description": "Return the blended soup to the pan, mix with the remaining mushrooms, and warm through."
    },
    {
      "heading": null,
      "description": "Serve with a drizzle of chilli oil, a small handful of coriander and crusty toasted sourdough."
    }
  ],
