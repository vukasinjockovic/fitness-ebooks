  "method": [
    {
      "heading": null,
      "description": "Heat oven to 200°C."
    },
    {
      "heading": null,
      "description": "Add the chicken thighs to a bowl with the ancho chilli paste and 1 tbsp olive oil, season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Slice the peppers, removing the seeds. Cut the onions into wedges. Tip both onto a large baking tray with 1 Tbsp olive oil, the cumin, oregano, smoked paprika, cayenne and garlic granules. Season with salt and pepper and toss to coat."
    },
    {
      "heading": null,
      "description": "Place the chicken thighs on top of the veg. Spoon over any leftover marinade from the bowl."
    },
    {
      "heading": null,
      "description": "Roast for 30 mins until the chicken is cooked through. Remove the chicken from the tray and return the peppers to the oven for another 10 mins until slightly charred."
    },
    {
      "heading": null,
      "description": "Once the peppers are softened and slightly blackened, remove the tray from the oven. Drain and rinse the black beans, then mix them through the peppers on the tray."
    },
    {
      "heading": null,
      "description": "Serve with rice, wraps, or salad this traybake works with just about anything! \nIf you're making this as batch, transfer the cooked chicken to a separate container. Store the beans and peppers in another, ready to upgrade more meals throughout the week."
    }
  ],
