  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Mix the peri peri marinade with the maple syrup and a small pinch of salt in a bowl."
    },
    {
      "heading": null,
      "description": "Slice each block of tofu in half lengthways to make four pieces. Hasselback the tofu by making deep cuts across the surface, being careful not to slice all the way through. Brush each piece with half the marinade and drizzle with a little olive oil. Transfer to a lined baking tray and roast for 25 mins, brushing again halfway through with the remaining marinade."
    },
    {
      "heading": null,
      "description": "While the tofu roasts, finely slice the green chilli and mince the garlic. Add them to a heatproof bowl with the cumin and turmeric."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of oil in a small pan over a medium heat. Once hot, pour it over the spice mix – it should sizzle. Heat the rice pouches following pack instructions, then tip into a large bowl. Mix through the hot spiced oil and season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Bring a small pot of water to the boil. Add the peas and cook for 3 mins. Drain and return to the pan."
    },
    {
      "heading": null,
      "description": "Finely chop the parsley and mint. Toss the herbs through the peas along with a drizzle of olive oil, salt, pepper and a pinch of chilli flakes, if using."
    },
    {
      "heading": null,
      "description": "Slice the lemon into wedges."
    },
    {
      "heading": null,
      "description": "Spoon the rice into bowls, top with the peri peri tofu and herby peas. Serve with lemon wedges for squeezing."
    }
  ],
