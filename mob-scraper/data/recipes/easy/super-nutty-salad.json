  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 180°C."
    },
    {
      "heading": null,
      "description": "Add the nuts and seeds to a baking tray and roast for 12 mins, or until golden and fragrant. Set aside to cool."
    },
    {
      "heading": null,
      "description": "Make the dressing. Peel and grate the ginger and garlic into a small bowl. Whisk together with the olive oil, soy sauce, juice of 3 limes, and rice wine vinegar. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Rinse the quinoa and cook according to pack instructions. With 9 mins left on the timer, add the edamame to the pot. With 2 minutes left, add in the broccoli florets. Drain and rinse under cold water to stop the cooking, then leave to cool completely."
    },
    {
      "heading": null,
      "description": "Prep the salad. Peel the carrot and cut into fine matchsticks. Finely chop the coriander."
    },
    {
      "heading": null,
      "description": "In a large bowl, toss together the cooled quinoa mix, carrot, chopped coriander, rocket, and roasted nuts and seeds. If eating immediately, drizzle over the dressing and mix well. If meal prepping, store the dressing separately and add just before eating."
    }
  ],
