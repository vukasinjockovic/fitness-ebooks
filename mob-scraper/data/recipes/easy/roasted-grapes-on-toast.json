  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 190°C."
    },
    {
      "heading": null,
      "description": "Behead the bulb of garlic, add a drizzle of olive oil and a pinch of sea salt, wrap in foil and roast in the oven for 40 mins."
    },
    {
      "heading": null,
      "description": "Add all the grapes, thyme, and red chilli to a baking tray and toss to coat in the balsamic oil, agave, and olive oil. Add to the oven for 20 mins into the same roasting tin as the garlic, bake till sticky and caramelised. Allow the grapes to cool for 10 mins."
    },
    {
      "heading": null,
      "description": "Zhuzh up the cream cheese by adding in finely chopped parsley and chives with a squeeze of lemon juice."
    },
    {
      "heading": null,
      "description": "Toast the sourdough bread and spread the roasted garlic on it before layering it with a generous spread of vegan cream cheese. Finally, top your slices of toast with the sticky roasted grapes. Enjoy."
    }
