  "method": [
    {
      "heading": null,
      "description": "Place a pot of water on to boil. Once boiling, gently drop the eggs in and cook for 6 mins until jammy. Leave for longer if you want them cooked more. Drain and run cold water over the eggs until cooled down, or transfer them to an ice bath. Peel and half once cool."
    },
    {
      "heading": null,
      "description": "Meanwhile, drain the tuna and butter beans. Chop the tomatoes into bite-sized chunks and season with salt."
    },
    {
      "heading": null,
      "description": "For the dressing, finely dice the shallot, then strip the oregano leaves from the stems and mince. Add both to a small bowl with the juice of the lemon and mix. Let it sit for a couple of minutes before stirring the mustard and vinegar through. Slowly whisk in the olive oil. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Toss the tuna, beans, olives, greens and tomatoes together with the dressing. Share between bowls and top each with two egg halves."
    }
  ],
