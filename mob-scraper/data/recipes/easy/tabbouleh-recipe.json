  "method": [
    {
      "heading": null,
      "description": "Cook the bulgur wheat following pack instructions then drain really well through a fine sieve. Leave to cool slightly."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the parsley leaves, then pick the mint leaves and finely chop those too. Scrape everything into a large bowl."
    },
    {
      "heading": null,
      "description": "Very finely chop the spring onions and add these to the bowl. Dice the tomatoes into 1cm cubes, then cut the cucumber into similar sized pieces and add both to the bowl."
    },
    {
      "heading": null,
      "description": "Drizzle in the olive oil, squeeze in the lemon juice and tip in the cooked and strained bulgur."
    },
    {
      "heading": null,
      "description": "Use a spoon to mix all the ingredients together, then season really well with salt and black pepper and stir again."
    },
    {
      "heading": null,
      "description": "Tip the flaked almonds into a small frying pan and put over a medium heat. Fry for 3-4 minutes, tossing regularly until evenly golden brown. Tip into the bowl and toss again."
    }
