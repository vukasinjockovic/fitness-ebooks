  "method": [
    {
      "heading": null,
      "description": "Grate a large thumb of ginger. Finely chop your cloves of garlic, green chillies and brown onions."
    },
    {
      "heading": null,
      "description": "Fry the garlic, green chillies and ginger in a pan for 1 minute. Add your chopped onions and fry on a medium heat until soft."
    },
    {
      "heading": null,
      "description": "Add your cumin, ground coriander, garam masala and turmeric. Then, add your diced chicken thighs."
    },
    {
      "heading": null,
      "description": "Once the meat has browned add the tins of chopped or plum tomatoes. Fill the empty tins halfway with water and pour that into the curry."
    },
    {
      "heading": null,
      "description": "Turn the curry onto a medium heat, and let it bubble away for 15 minutes, or until it is thick and the chicken is cooked through."
    },
    {
      "heading": null,
      "description": "Serve on steaming hot basmati rice. Enjoy!"
    }
