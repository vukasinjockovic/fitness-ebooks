  "method": [
    {
      "heading": null,
      "description": "Finely dice your onion, carrot and celery."
    },
    {
      "heading": null,
      "description": "Cut a cross on the skin of your tomatoes, then place in a bowl of boiling water for one minute. Once cool enough to handle, peel back the skins. Cut into quarters."
    },
    {
      "heading": null,
      "description": "Add your pancetta to a large heavy-bottomed casserole dish and fry until crisp."
    },
    {
      "heading": null,
      "description": "Tip your onion, carrot and celery. Cook for 15 mins more until your pancetta has rendered its fat and become crispy, and your soffritto is soft."
    },
    {
      "heading": null,
      "description": "Add your Napolina Tomato Purée and cook out for a minute before adding your quartered tomatoes. Cook for 5 mins until the tomatoes are breaking down and becoming jammy."
    },
    {
      "heading": null,
      "description": "Pour your chickpeas into the pan and add 1 litre of water. Chuck in your rosemary sprig and parmesan rind, then simmer for 20 mins."
    },
    {
      "heading": null,
      "description": "Remove the parmesan rind and rosemary sprig. Pour ⅓ of the liquid into a blender and blitz until smooth. Return the liquid to the pan."
    },
    {
      "heading": null,
      "description": "Season the liquid to taste with salt and pepper. Add your macaroni and cook for 8 mins more, stirring to stop it from sticking and adding more water where necessary."
    },
    {
      "heading": null,
      "description": "Portion up into bowls, then sprinkle with a little more parmesan and a drizzle of Napolina Extra Virgin Olive Oil. Serve."
    }
  ],
