  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Peel the carrots, halve them lengthwise, then chop into smaller chunks. Transfer to a bowl, then drizzle over 1 tbsp oil. Add the paprika, garlic granules, onion granules and 1 tsp salt, then toss to combine. Grate the Parmesan, and then set it aside."
    },
    {
      "heading": null,
      "description": "Spread the Parmesan over a large, shallow plate. Tip the carrots on top, then coat them in the Parmesan really well. Lay the carrots, flat-side down, onto a lightly oiled baking tray. Bake in the oven for 25 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, combine the mayo, honey and chilli oil in a small bowl."
    },
    {
      "heading": null,
      "description": "Serve the crispy Parmesan carrots with the hot honey mayo on the side."
    }
