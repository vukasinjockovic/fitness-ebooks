  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Super Greens &amp; Garlic Sauce."
    },
    {
      "heading": null,
      "description": "Halve the tomatoes and add them to a mixing bowl. Season with salt and a splash of sherry vinegar, then set aside to marinate."
    },
    {
      "heading": null,
      "description": "Thinly slice the cheddar. Toast the sourdough in a toaster or under a hot grill until golden."
    },
    {
      "heading": null,
      "description": "Add the Super Greens &amp; Garlic Sauce and the butter beans to a saucepan. Set over a medium heat and warm through gently, stirring often. Taste and season with salt and black pepper, if needed."
    },
    {
      "heading": null,
      "description": "Divide the creamy beans between bowls and swirl through the yoghurt."
    },
    {
      "heading": null,
      "description": "Toss the sliced cheddar through the tomatoes, then spoon the salad over the beans. Serve with the toast on the side for dipping and scooping."
    }
