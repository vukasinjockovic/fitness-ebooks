  "method": [
    {
      "heading": null,
      "description": "Prepare the chicken stock according to the package instructions and tip into a saucepan. Bring to a boil and then reduce to a simmer. Add the soy and then drop the chicken thighs in for 9-10 mins, or until the chicken is completely cooked."
    },
    {
      "heading": null,
      "description": "Remove the chicken from the broth and cut into bite size pieces. Bring the broth back to a boil and drop the noodles in for 2 mins before adding the peas and tenderstem broccoli. Once cooked, remove from the heat and add the chicken back to the pan."
    },
    {
      "heading": null,
      "description": "Thinly slice the spring onions and chillies and set aside. Finish the broth with the juice of one lime and then divide between large bowls. Serve topped with the sliced spring onions, chillies and extra lime wedges."
    }
