  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kid Servings\nHeat the oven to 160°C."
    },
    {
      "heading": null,
      "description": "Grab the biggest mixing bowl you’ve got and chuck in the rolled oats, mixed seeds, chopped nuts, flaxseed and chia seeds. Add the cinnamon and ginger — they just give a gentle warmth and natural sweetness, nothing spicy."
    },
    {
      "heading": null,
      "description": "Melt the coconut oil in a small saucepan over a low heat. Pour it into the bowl with the apple juice, honey or maple syrup and egg whites. Give everything a really good mix so it’s evenly coated."
    },
    {
      "heading": null,
      "description": "Line a large baking tray (or two smaller ones) with baking paper. Spread out the granola in an even layer and bake for 30–40 mins, giving it a stir every 10 mins until golden and crisp. Leave to cool completely."
    },
    {
      "heading": null,
      "description": "Once cool, stir through the raisins and tip into airtight jars or containers."
    },
    {
      "heading": null,
      "description": "Serve up!\nKids &amp; Parents Plate: Dish out the granola into bowls with cold milk, spooned over yoghurt, or on top of pancakes, whatever works for your crew."
    }
  ],
  "tips": [
    "Save the egg yolks and use them in a carbonara later — parent reward.",
    "If your kids aren't nut fans, just swap them out for extra seeds.",
