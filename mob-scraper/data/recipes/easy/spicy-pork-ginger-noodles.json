  "method": [
    {
      "heading": null,
      "description": "Cook the rice noodles according to packet instructions, then drain and rinse under cold water."
    },
    {
      "heading": null,
      "description": "Thinly slice the spring onions, separating the whites and greens. Shred the ginger into matchsticks and finely chop the garlic. Chop the pak choi."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of oil in a pan. Fry the spring onion whites, garlic and the ginger for 1–2 mins, then add the pork mince. Cook until browned, breaking it up as you go."
    },
    {
      "heading": null,
      "description": "Add the dark soy, light soy, black vinegar and chilli oil. Let everything bubble for a minute, then add the chopped pak choi for the final 2 mins to wilt."
    },
    {
      "heading": null,
      "description": "Divide the rice noodles between bowls, spoon over the mince, veg and sauce and top with the spring onion greens and extra chilli oil if you like."
    }
  ],
