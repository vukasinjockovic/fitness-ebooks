  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Using a pair of kitchen scissors, cut the backbone out of the chicken. Flip it over and press firmly on the breast to flatten the chicken, then turn out the legs so they are facing outwards."
    },
    {
      "heading": null,
      "description": "For the marinade, squeeze the orange, lemon and lime juice into a large bowl. Crush and add the garlic and coriander seeds, along with the brown sugar, miso paste and dried tarragon."
    },
    {
      "heading": null,
      "description": "Place the chicken in the marinade, skin side down, and optionally leave to marinate for 30 mins to 1 hr, but no longer, as the citrus can start to cure the chicken."
    },
    {
      "heading": null,
      "description": "Place the potatoes and peeled whole shallots on a large baking tray and dot with knobs of butter. Put the chicken on top of the potatoes and pour the marinade over the top."
    },
    {
      "heading": null,
      "description": "Roast in the oven for 45 mins, spooning the marinade over every 15 mins."
    },
    {
      "heading": null,
      "description": "Once the chicken is cooked and the juices run clear, remove from the oven and place on a chopping board. Leave to rest for 15 mins. Meanwhile return the potatoes and shallots to the oven for a further 15 mins to crisp up."
    },
    {
      "heading": null,
      "description": "To make the dressing, finely chop the chives and place in a heatproof bowl."
    },
    {
      "heading": null,
      "description": "Toast the sesame seeds in a small pan until golden."
    },
    {
      "heading": null,
      "description": "Pound the chillies, salt and garlic in a pestle and mortar (alternatively, you can use a mini food processor, or finely chop or grate the chillies and garlic by hand)."
    },
    {
      "heading": null,
      "description": "Add the oil to the sesame seeds along with the pounded garlic mix. Allow to sizzle for 2 mins, then pour over the chives in the bowl. Stir in the rice vinegar."
    },
    {
      "heading": null,
      "description": "Once the chicken has rested, slice it into thighs, legs, wings and breast. Serve on top of the potatoes and shallots, and spoon over the tangy chive mix."
    }
  ],
