  "method": [
    {
      "heading": null,
      "description": "Place a frying pan over a medium heat and add a glug of olive oil. Drain the black beans and add to the pan with a pinch of salt. Cook, stirring occasionally, for about 3 mins."
    },
    {
      "heading": null,
      "description": "Add the cumin and paprika and cook for another 2 mins."
    },
    {
      "heading": null,
      "description": "While the beans are frying, dice up the tomato and finely chop the coriander. Add both to a small bowl along with the chilli powder and lime juice, mix well and set aside."
    },
    {
      "heading": null,
      "description": "Once the beans are ready, grab four tacos and divide the beans equally between them."
    },
    {
      "heading": null,
      "description": "Rinse out the pan, add the butter and a splash of olive oil and place over a medium heat."
    },
    {
      "heading": null,
      "description": "Finely chop the spring onions, add to the pan and sizzle for a couple of mins."
    },
    {
      "heading": null,
      "description": "Whisk the eggs in a bowl with a pinch of salt and pour into the pan. Keep them moving and adjust the heat as necessary until you have just set, soft scrambled eggs."
    },
    {
      "heading": null,
      "description": "Spoon the eggs over the beans, then top with the tomato salsa and a few shakes of hot sauce (if you like). Add a spoonful of the sour cream, fold up and tuck in."
    }
  ],
