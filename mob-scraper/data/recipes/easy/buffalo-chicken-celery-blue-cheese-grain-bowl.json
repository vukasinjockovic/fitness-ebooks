  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Add the chicken thighs to a baking tray and drizzle with olive oil. Sprinkle over the smoked paprika, garlic granules, brown sugar, salt and pepper. Drizzle with a bit more oil and spread into an even layer, skin-side up. Roast for 45 mins until cooked through and golden crisp."
    },
    {
      "heading": null,
      "description": "Drizzle your hot sauce (we used Frank's Red Hot Sauce) over the cooked chicken and return to the oven for 5 more mins. Set aside to rest while you prep everything else."
    },
    {
      "heading": null,
      "description": "Finely dice the celery and add to a large bowl. Crumble the blue cheese into bite-sized chunks and add to the bowl. Heat the grain pouches according to pack instructions, then tip the grains into the same bowl."
    },
    {
      "heading": null,
      "description": "Add the natural yoghurt, apple cider vinegar and garlic granules. Season with salt and pepper, then mix well. Tear in most of the dill and gently fold through."
    },
    {
      "heading": null,
      "description": "Divide the grain salad between containers or bowls and top each with 2 buffalo chicken thighs. Finish with the remaining dill and a little extra drizzle of hot sauce, if you like."
    }
  ],
