  "method": [
    {
      "heading": null,
      "description": "Stir the Lebanese 7-spice and 1 tablespoon of olive oil together in a large bowl. Season with salt and pepper, then toss the chicken thighs through the marinade. Set aside to marinate."
    },
    {
      "heading": null,
      "description": "Cook the quinoa following pack instructions. Once done, set aside to cool slightly."
    },
    {
      "heading": null,
      "description": "Finely mince the parsley and coriander (stalks and all). Tip into a bowl with the quinoa and pomegranate seeds. Roughly crush the walnuts and add those in too. Stir through the olive oil, season with salt, and squeeze over the juice of the lemon. Give everything a good mix and adjust the seasoning to taste."
    },
    {
      "heading": null,
      "description": "Set a frying pan over a medium heat. Once hot, add the chicken thighs and cook for 10–15 mins, turning halfway, until golden and cooked through."
    },
    {
      "heading": null,
      "description": "Pour in the pomegranate molasses and honey. Take the pan off the heat and baste the chicken in the sticky glaze for a minute or two until coated and glossy."
    },
    {
      "heading": null,
      "description": "Spoon the quinoa salad onto plates. Top with the glazed chicken and any juices from the pan. Serve with any leftover lemon wedges on the side."
    }
  ],
