  "method": [
    {
      "heading": null,
      "description": "Bring a large pot of water to the boil. Cook your noodles following pack instructions, reserving the starchy cooking water. Crush the peanuts and set aside."
    },
    {
      "heading": null,
      "description": "Add a splash of vegetable oil to a frying pan set over a medium heat along with the pork mince and dark soy sauce. Fry for around 6 mins until cooked. Set aside."
    },
    {
      "heading": null,
      "description": "Meanwhile, mix all the seasoning ingredients together in a small bowl. Divide this mixture between two serving bowls and add a ladle of the starchy noodle-cooking water to each bowl. Mix well."
    },
    {
      "heading": null,
      "description": "Divide the cooked noodles between the serving bowls, mix everything together and top with the cooked pork mince, coriander, crushed peanuts and a drizzle of chilli oil."
    }
