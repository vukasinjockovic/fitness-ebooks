  "method": [
    {
      "heading": null,
      "description": "Remove the sausages from their skins and break them into small, roughly 2cm chunks. Finely chop the onion, carrot and courgette, and cut the peppers into bite-sized pieces. Finely chop the garlic."
    },
    {
      "heading": null,
      "description": "Set a deep frying pan or large saucepan over a medium-high heat with a good glug of olive oil. Add the sausage pieces and fry for 3-4 mins, tossing regularly until golden all over. Scoop out onto a plate and set aside."
    },
    {
      "heading": null,
      "description": "Tip the onion, carrot, courgette and peppers into the same pan with another drizzle of oil, if needed. Season with a small pinch of salt and cook for 8-10 mins until softened and starting to caramelise."
    },
    {
      "heading": null,
      "description": "Stir in the tomato purée and garlic. Cook for 2 mins until fragrant. Pour in the tinned tomatoes, drained beans and water, then add the sausages back into the pan. Bring to a gentle simmer and cook for 30 mins, stirring occasionally, until the stew is thickened and rich."
    },
    {
      "heading": null,
      "description": "Taste and season with salt, pepper and a squeeze of lemon juice."
    },
    {
      "heading": null,
      "description": "Serve up!Kids Plate:  Spoon into bowls for the kids. Parents Plate: Top with parsley leaves, a few slices of red chilli and a spoonful of yoghurt. Serve with toast on the side."
    }
  ],
