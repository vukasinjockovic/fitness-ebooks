  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Cook the macaroni in lightly salted boiling water for about 10 mins, or a few minutes less than the recommended cooking time on the packet. It will finish cooking in the sauce in the oven."
    },
    {
      "heading": null,
      "description": "Melt the butter in a large saucepan and stir in the plain flour. Cook this mixture for about 2 mins. Then slowly drizzle in the milk in three additions, making sure to whisk well after each addition."
    },
    {
      "heading": null,
      "description": "Grate in the Cheddar and red Leicester, and add the slices of American cheese, and mix until all the cheese has melted. Finely chop the jalapeños then add to the pan along with the pickling liquid and cooked pasta. Stir everything together and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Pour the cheesy pasta mixture into a baking dish and top it with the crushed tortilla chips, crispy shallots and a generous sprinkle of grated Parmesan."
    },
    {
      "heading": null,
      "description": "Bake for 20 mins, or until it's golden and bubbling. Allow to rest for 5 mins, and enjoy."
    }
  ],
