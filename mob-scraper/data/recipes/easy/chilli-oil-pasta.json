  "method": [
    {
      "heading": null,
      "description": "Bring a pot of salted water to the boil. Add the pasta and cook until al dente. Drain the cooked pasta, reserving some of the starchy cooking water."
    },
    {
      "heading": null,
      "description": "Meanwhile, mince the shallot and garlic. Grate the Parmesan, and then set it aside."
    },
    {
      "heading": null,
      "description": "Tip the Sichuan peppercorns into a small frying pan and toast over a low-medium heat for a few mins until fragrant and starting to smoke. Remove from the heat and grind in a pestle and mortar."
    },
    {
      "heading": null,
      "description": "Add the butter to the same pan and, once melted, add the minced garlic and shallot. Fry until softened. Add the chilli oil and fry for 2 mins. Add the ground Sichuan peppercorns, tomato purée, double cream, the juice of both limes, the honey and soy sauce. Mix well until the sauce starts to thicken."
    },
    {
      "heading": null,
      "description": "Roughly chop the coriander and add three-quarters of it to the sauce along with 3/4 of the grated Parmesan. Stir well. Add the pasta and a ladle of starchy water, mixing until glossy. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Add the olive oil to a separate pan set over a low-medium heat, then tip in the panko and fry until golden. Remove from the heat and add the remaining coriander and parmesan."
    },
    {
      "heading": null,
      "description": "Top your pasta with coriander panko and enjoy."
    }
  ],
