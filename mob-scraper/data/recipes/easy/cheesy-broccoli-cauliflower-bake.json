  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Cut the broccoli and cauliflower into florets, then tip them onto a baking tray and roast for 15 mins."
    },
    {
      "heading": null,
      "description": "Slice the garlic. Heat 1 tbsp of olive oil in a pan over a medium heat, then add the garlic, cooking gently for around 3 mins. Add the beans, their water and the additional water. Blitz in a blender to make a smooth sauce, then add the mustard and season generously with salt and pepper."
    },
    {
      "heading": null,
      "description": "Heat the grill to medium-high. Pick the thyme. Grate the lemon skin into a bowl, then add 2 tbsp oil, the thyme and breadcrumbs. Season with salt and pepper. Mix well and set aside."
    },
    {
      "heading": null,
      "description": "Tip the roasted broccoli and cauliflower into a baking dish, pour over the sauce, then top with torn mozzarella. Grate over the Parmesan and scatter with breadcrumbs before sliding under the grill for 5-10 mins until golden and bubbling."
    }
  ],
