  "method": [
    {
      "heading": null,
      "description": "Freeze the goats cheese overnight."
    },
    {
      "heading": null,
      "description": "The next day, roughly chop the hazelnuts. Melt the butter in a pan over a low-medium heat and add the hazelnuts. Keep a close eye on it, as you don’t want the butter to burn. Cook until the hazelnuts are golden, then remove and set aside."
    },
    {
      "heading": null,
      "description": "Chop the courgettes into irregular, 4cm shapes. Transfer to a bowl with some olive oil, salt and pepper. Heat a large frying pan over a high heat and add the courgettes in a single layer, cut side down. Cook for 2 mins each side until nice and charred, then remove from the pan to cool to room temperature."
    },
    {
      "heading": null,
      "description": "Meanwhile, pick the mint leaves and set aside."
    },
    {
      "heading": null,
      "description": "Add the courgettes to a serving plate or bowl then spoon over the buttery hazelnuts and drizzle with the hot honey. Grate over the frozen goats cheese and scatter with mint."
    }
