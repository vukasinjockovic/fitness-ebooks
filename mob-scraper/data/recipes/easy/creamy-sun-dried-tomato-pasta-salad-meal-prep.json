  "method": [
    {
      "heading": null,
      "description": "Bring a pot of salted water to the boil and cook the pasta according to the packet instructions until al dente. Drain, reserving a splash of the pasta water, and leave to cool slightly. Finely chop the sun-dried tomatoes and garlic."
    },
    {
      "heading": null,
      "description": "While the pasta cooks, heat the sun-dried tomato oil in a frying pan over a medium heat. Add the garlic and chopped sun-dried tomatoes, cooking gently for 1–2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Pop the spinach into a colander or sieve and pour over two kettles of boiling water to wilt it. Squeeze out any excess moisture."
    },
    {
      "heading": null,
      "description": "Stir the cottage cheese, pasta, wilted spinach, and most of the basil through the sun-dried tomato mix. Add a splash of the reserved pasta water if needed to loosen, and season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve topped with Parmesan shavings and the remaining basil. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
  ],
