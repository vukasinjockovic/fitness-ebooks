  "method": [
    {
      "heading": null,
      "description": "Preheat the air fryer to high (240°C)."
    },
    {
      "heading": null,
      "description": "Dice the salmon into medium-sized cubes (about 3 per fillet). Season the salmon with salt and pop into a parchment lined pan or a tray. Mix together the chutney and the chipotle paste and tip over the salmon. Pop into the airfryer for 6-8 mins or until fully cooked, spooning any extra marinade over the fish as it cooks."
    },
    {
      "heading": null,
      "description": "Thinly slice the cabbage and red onion and chuck into a bowl. Dress with a little salt and lime juice and toss through chopped dill. Thinly slice the scotch bonnet, season with salt and squeeze a little lime juice over the top."
    },
    {
      "heading": null,
      "description": "Heat the tacos according to the package instructions."
    },
    {
      "heading": null,
      "description": "Pull the fish out of the oven, it should be cooked and glazed in the spicy, smoky mango chipotle mix. (Flake it into smaller pieces, if you like.)"
    },
    {
      "heading": null,
      "description": "Build your tacos starting with the shells, topped with sour cream, some fish, a handful of slaw, the chillies and chopped spring onion and radishes. Get stuck in."
    }
  ],
