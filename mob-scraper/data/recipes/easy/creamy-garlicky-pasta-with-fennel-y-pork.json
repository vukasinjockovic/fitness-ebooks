  "method": [
    {
      "heading": null,
      "description": "Place a large pot of salted water on to boil."
    },
    {
      "heading": null,
      "description": "Once boiling, add the spinach and half of the basil. Blanch for 1 min until wilted and dark green, then use a slotted spoon to transfer to a colander. Leave to cool for a couple of minutes, then squeeze out any excess water."
    },
    {
      "heading": null,
      "description": "Chuck the blanched greens into a blender with the garlic cloves and the cottage cheese. Season with salt and pepper, add a splash of cold water, and blitz until smooth."
    },
    {
      "heading": null,
      "description": "Add the pasta to the boiling water and cook following pack instructions."
    },
    {
      "heading": null,
      "description": "Meanwhile, set a frying pan over a medium-high heat with the olive oil. Once hot, add the pork mince, fennel seeds and three-quarters of the chilli flakes. Cook for 7–10 mins, breaking it up with a spoon, until golden and cooked through. Pour in the Worcestershire sauce, season with salt and pepper, and stir."
    },
    {
      "heading": null,
      "description": "Once the pasta is al dente, use a slotted spoon to transfer it into the pan with the mince, off the heat. Stir through the green sauce and the remaining cottage cheese until hot, turn the heat up to medium, if needed. Add a splash of pasta water if it needs loosening. Taste and season again if needed."
    },
    {
      "heading": null,
      "description": "Serve in bowls, then top with the remaining basil leaves and chilli flakes."
    }
  ],
