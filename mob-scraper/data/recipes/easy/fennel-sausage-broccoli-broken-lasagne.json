  "method": [
    {
      "heading": null,
      "description": "Remove the skins from the sausages and add them to a hot pan with a shot of olive oil. Use a spatula or wooden spoon to smash ‘em up, and cook them until nice and crispy."
    },
    {
      "heading": null,
      "description": "While the sausages brown, finely chop the onion and fennel bulb and finely mince the garlic. Whip the sausage meat out of the pan and add another shot of oil. Tip in the onion and fennel and cook with a pinch of salt for 5-6 mins."
    },
    {
      "heading": null,
      "description": "Add the garlic, chilli and fennel seeds and cook for a minute or two before adding a splash of water to deglaze the pan. Tip in the tomatoes, return the sausage to the sauce and bring to a simmer. Cook for 10 mins."
    },
    {
      "heading": null,
      "description": "Roughly chop the broccoli and preheat the oven to 190°C."
    },
    {
      "heading": null,
      "description": "Nestle the lasagne sheets into the sauce along with the chopped broccoli, leaving a few bits of pasta exposed out of the sauce to go crispy."
    },
    {
      "heading": null,
      "description": "Top with torn mozzarella and lots of grated Parmesan cheese. Slide into the oven for 35-40 mins or until bubbling and golden."
    },
    {
      "heading": null,
      "description": "Allow to rest for 5 mins before serving."
    }
  ],
