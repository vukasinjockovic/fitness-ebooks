  "method": [
    {
      "heading": null,
      "description": "Finely grate the cheddar. Pick the coriander leaves and thinly slice the stalks. Thinly slice the onions and garlic. Drain the grilled peppers and roughly chop. Shred the turkey. Drain and rinse the beans."
    },
    {
      "heading": null,
      "description": "Add one-third of the sliced onion to a small bowl with the juice of half a lime. Season with salt and set aside to pickle."
    },
    {
      "heading": null,
      "description": "Set a large saucepan over a medium heat with a drizzle of olive oil. Once hot, add the rest of the onion and cook for 5–7 mins until soft and translucent."
    },
    {
      "heading": null,
      "description": "Stir in the rosemary, garlic, coriander stalks, smoked paprika and cumin. Cook for 1–2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Tip in the chopped tomatoes, grilled peppers, kidney beans and chicken stock. Bring to the boil, then turn the heat down and let it simmer for 15–20 mins until thickened slightly — it should be like a loose stew."
    },
    {
      "heading": null,
      "description": "Stir the turkey through the chilli and cook for 3–4 mins until piping hot. Taste and season with salt, pepper or more lime juice if needed."
    },
    {
      "heading": null,
      "description": "Ladle the chilli into bowls and top with grated cheddar, pickled onions and coriander leaves. Serve with any extra lime wedges on the side."
    }
  ],
