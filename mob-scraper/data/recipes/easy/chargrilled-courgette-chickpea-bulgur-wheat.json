  "method": [
    {
      "heading": null,
      "description": "Toast the bulgur wheat in a hot pan with a drizzle of olive oil on medium heat for 2-3 mins until it smells fragrant and toasted. Add water and crumble in the stock cube. Bring to a boil, then lower to a simmer, cover and cook for 8 mins, or until the water has evaporated and the grains are soft and fluffy. Drain the beans and add them to the bulghur."
    },
    {
      "heading": null,
      "description": "Meanwhile, chop the top and tail off the courgettes and slice them thinly lengthways, about 0.5cm thick. Drizzle them with olive oil and season with salt and pepper. Place on a hot griddle pan and cook for about 4-5 mins on each side until charred."
    },
    {
      "heading": null,
      "description": "To make the dressing, whisk all of the dressing ingredients together and season well with salt and pepper. Roughly chop the herbs."
    },
    {
      "heading": null,
      "description": "To serve, pile up the bulgur and top with the dressing. Finish with the flaked almonds and herbs and plenty of pepper."
    }
  ],
