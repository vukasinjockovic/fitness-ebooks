  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Combine the spices in a bowl and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Drain and rinse the chickpeas and add 1 Tbsp of the fajita spice mix and a glug of oil. Toss to coat and bake until crispy and caramelised. This will take around 15 mins."
    },
    {
      "heading": null,
      "description": "To make your spicy mayo, combine the vegan mayo with one finely grated garlic clove, a pinch of chopped coriander, 1 tsp of the spice mix and the juice of a lime. Give it a mix."
    },
    {
      "heading": null,
      "description": "Dice up your onion, finely chop the coriander stems and roughly chop the mushrooms."
    },
    {
      "heading": null,
      "description": "Preheat a wok over a high heat. Add the mushrooms and the remaining fajita spice mix. Cook until crispy, roughly 10 mins, then remove from the wok."
    },
    {
      "heading": null,
      "description": "Preheat the wok again and add the onion with a splash of oil. Add the leftover rice and stir fry for 5 mins. Add the mushrooms and coriander stalks. Toss together and season to taste."
    },
    {
      "heading": null,
      "description": "Divide between warm bowls and top with a dollop of your spicy mayo, crispy chickpeas and extra lime juice and coriander."
    }
  ],
