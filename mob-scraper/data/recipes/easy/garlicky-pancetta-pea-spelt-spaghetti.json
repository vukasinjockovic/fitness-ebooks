  "method": [
    {
      "heading": null,
      "description": "Place a saucepan over a medium heat and add the olive oil, the pancetta and finely chopped onion and cook for 5 mins until the onion is soft and the pancetta has rendered its fat."
    },
    {
      "heading": null,
      "description": "Meanwhile, put your pasta to boil in plenty of well-salted boiling water."
    },
    {
      "heading": null,
      "description": "Finely chop and add the garlic, cook for 2 mins and then pour in the frozen peas and the water and stir well. Cook until the peas are tender."
    },
    {
      "heading": null,
      "description": "Remove half of the mixture and add it to a blender along with 2 tbsp of pasta cooking water, half of the ricotta, and the parsley. Blend until almost smooth."
    },
    {
      "heading": null,
      "description": "By this point, your pasta should be al dente so drain it and transfer to the pan with the peas."
    },
    {
      "heading": null,
      "description": "Pour in your pea cream too and mix everything well. Taste and season, spoon into a bowl and then top each one with a nice spoon of ricotta, black pepper and a drizzle of olive oil."
    }
