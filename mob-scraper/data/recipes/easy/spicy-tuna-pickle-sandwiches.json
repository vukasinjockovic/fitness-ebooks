  "method": [
    {
      "heading": null,
      "description": "Peel and dice the potatoes into 2cm cubes. Bring a pan of very salty water to the boil, add the eggs and potatoes and cook for 6 mins. Drain and rinse under cold water, then peel and slice the eggs into quarters."
    },
    {
      "heading": null,
      "description": "Meanwhile, halve the brioche buns and melt the butter in a frying pan over a medium heat. Toast the brioche in the pan for a couple of minutes each side until golden. Roughly chop the parsley."
    },
    {
      "heading": null,
      "description": "Spread the buns with harissa, load up with sliced boiled eggs, potatoes, tuna, olives, parsley, and pickles and squeeze over the lemon. Drizzle with olive oil and eat immediately."
    }
