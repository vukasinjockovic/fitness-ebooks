  "method": [
    {
      "heading": null,
      "description": "Bring a saucepan of water to the boil. Lower in the eggs and boil for 8 mins. Drain and transfer to cold water to cool. Once cool enough to handle, peel and set aside."
    },
    {
      "heading": null,
      "description": "Finely chop the shallot and add it to a large bowl with the zest and juice of the lemon. Season generously with salt and let it sit to mellow."
    },
    {
      "heading": null,
      "description": "Microwave the rice pouch following pack instructions, or heat in a pan until piping hot."
    },
    {
      "heading": null,
      "description": "Meanwhile, drain and rinse the lentils. Halve the cherry tomatoes. Halve the cucumber lengthways, scoop out the seeds and finely chop. Finely chop the dill."
    },
    {
      "heading": null,
      "description": "Toss the hot rice into the lemony shallot bowl and mix well. Stir through the lentils, tomatoes, cucumber and dill. Taste and adjust the seasoning with salt and pepper."
    },
    {
      "heading": null,
      "description": "Halve the boiled eggs."
    },
    {
      "heading": null,
      "description": "To serve, spoon the salad into bowls with a big dollop of cottage cheese on the side. Season the cottage cheese with salt and pepper, and top each bowl with the halved egg."
    }
  ],
