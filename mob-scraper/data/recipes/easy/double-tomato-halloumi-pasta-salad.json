  "method": [
    {
      "heading": null,
      "description": "Bring a pot of salted water to the boil. Once boiling, tip the pasta in and cook following pack instructions until al dente. Fully drain once cooked."
    },
    {
      "heading": null,
      "description": "Finely grate half the tomatoes into a bowl. Thinly slice the halloumi (use a mandoline if you have one) and add to the grated tomatoes."
    },
    {
      "heading": null,
      "description": "Pour the olive oil into a frying pan set over a medium heat. Add the flaked almonds and cook until golden. Drop the fennel seeds and pul biber in, give everything a stir and pour into the halloumi bowl. Stir, then taste and season with salt, pepper and sherry vinegar."
    },
    {
      "heading": null,
      "description": "Roughly chop the sun-dried tomatoes, pick the parsley and tear any big basil leaves. Wedge the nectarines and chop the remaining tomatoes into bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Toss the sun-dried tomatoes, chopped tomatoes, herbs, nectarine and pasta through the halloumi bowl and serve."
    }
  ],
