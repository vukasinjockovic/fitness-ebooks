  "method": [
    {
      "heading": null,
      "description": "Finely slice the garlic cloves and finely grate the ginger. Add a splash of sesame oil to a large pan and drop in the garlic and ginger. Sauté for 2-3 mins before adding the spinach and cooking to wilt. Add water and bring to a boil."
    },
    {
      "heading": null,
      "description": "Using a hand blender, whizz the mixture until smooth-ish. Bring back to a boil before adding the orzo. Cook according to package instructions, stirring occasionally, until the orzo has sucked up all of that excess moisture and is looking green, glossy and fabulous. If your mixture is looking dry, add a splash of water."
    },
    {
      "heading": null,
      "description": "While the orzo cooks, add the breadcrumbs and sesame seeds to a pan and toast until golden brown."
    },
    {
      "heading": null,
      "description": "Finish the orzo by mixing through 3/4 of the crème fraîche and white miso. Then add the juice and zest of the lemon."
    },
    {
      "heading": null,
      "description": "Spoon into bowls and garnish with the remaining crème fraîche and the crunchy sesame breadcrumbs."
    }
  ],
