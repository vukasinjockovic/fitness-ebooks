  "method": [
    {
      "heading": null,
      "description": "Using a sharp knife, very finely chop the Thai basil, fresh coriander, spring onions, garlic cloves and red chilli. Add to a medium-sized bowl along with the minced chicken, tamari, sesame oil and fish sauce, and mix to combine. (Pro tip: heat up a tiny splash of oil in a frying pan and cook a teaspoon of the mixture to check the seasoning, then season to taste if needed.)"
    },
    {
      "heading": null,
      "description": "Start wrapping your dumplings. Fill a small bowl with water. Add a small spoonful of filling to a dumpling wrapper, then moisten the edge of the wrapper with a bit of water and carefully fold it into triangles, making sure there is no air trapped inside. Repeat until the filling is used up."
    },
    {
      "heading": null,
      "description": "To cook the dumplings, either steam them in a lined bamboo steamer basket for about 10-12 mins, or bring a large pot of water to a boil, then reduce the heat to medium, and gently simmer them for about 8-10 mins."
    },
    {
      "heading": null,
      "description": "In a separate pot, bring the stock to a boil and then reduce to a gentle simmer. Once the dumplings are cooked, divide them across 4 bowls and top with the hot stock. Serve with an extra splash of soy sauce, a drizzle of chilli oil and a sprinkle of sesame seeds."
    }
  ],
