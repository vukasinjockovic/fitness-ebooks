  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Bring a pot of water to boil, add a generous pinch of salt."
    },
    {
      "heading": null,
      "description": "Start by prepping the vegetables. Finely chop the broccoli, thinly slice the garlic cloves and finely chop the chives. Set aside."
    },
    {
      "heading": null,
      "description": "Add the pasta and broccoli to the boiling water. Cook the pasta and broccoli for half the cooking time stated on the package. Drain once cooked."
    },
    {
      "heading": null,
      "description": "Heat the frying pan on medium."
    },
    {
      "heading": null,
      "description": "Add olive oil to the pan, along with the sliced garlic. Sauté the garlic for 30 seconds, until soft and slightly coloured. Add the gochujang, fry for a further minute until the oil turns a reddish hue."
    },
    {
      "heading": null,
      "description": "Add the double cream and mix to combine."
    },
    {
      "heading": null,
      "description": "Add the king prawns followed by the pasta and mascarpone, season with a pinch of salt and sugar, mix thoroughly."
    },
    {
      "heading": null,
      "description": "Add the mixture to a high edged oven dish. Tear the mozzarella into strips and thoroughly cover the top. Grate the Parmesan on top, ensuring every bit is covered."
    },
    {
      "heading": null,
      "description": "Put the dish into the oven for 20 mins or until golden brown on top. Sprinkle over the chives and serve."
    }
  ],
