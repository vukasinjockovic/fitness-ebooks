  "method": [
    {
      "heading": null,
      "description": "Break your chorizo ring into small chunks and start to fry in a large pan. Chop your peppers into cubes and add them to the pan, stirring them and allowing them to fry in the chorizo fat."
    },
    {
      "heading": null,
      "description": "Once the chorizo and peppers begin to cook, add your cherry tomatoes whole. Stir and continue to cook on a high heat. Slice your red chilli and garlic and add them to the pan."
    },
    {
      "heading": null,
      "description": "In a separate bowl, cover your gnocchi with boiling water and allow it to soak for 10 minutes."
    },
    {
      "heading": null,
      "description": "While the gnocchi is soaking, pour the red wine vinegar into the frying pan and stir it in with the mascarpone. You should now have a creamy sauce. Add a pinch of salt and pepper to taste. Roughly chop your basil and throw that in there too."
    },
    {
      "heading": null,
      "description": "Drain your gnocchi and thoroughly mix it in to your sauce. Serve up with a sprinkling of parmesan and more fresh basil. Get stuck in, MOB! Enjoy!"
    }
  ],
