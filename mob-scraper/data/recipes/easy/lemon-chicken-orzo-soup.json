  "method": [
    {
      "heading": null,
      "description": "Dice the carrot, onion, and carrot to create a veg base mix. Heat the olive oil in a medium saucepan over a medium heat. Add the veg base mix and cook until softened but not coloured, about 5 mins."
    },
    {
      "heading": null,
      "description": "Peel and crush the garlic, then stir it through the veg for 1 min until fragrant. Pour in the chicken bone broth and bring everything to the boil."
    },
    {
      "heading": null,
      "description": "Tip in the orzo, shred over the leftover chicken and add the chickpeas (including their liquid). And simmer for 7- 8  mins, stirring occasionally, until the orzo is tender."
    },
    {
      "heading": null,
      "description": "Pick and roughly chop the dill, then stir it through the soup with plenty of black pepper."
    },
    {
      "heading": null,
      "description": "Ladle into bowls and serve with lemon wedges for squeezing over the top."
    }
  ],
