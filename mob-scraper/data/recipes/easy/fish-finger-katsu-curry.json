  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids Servings\nCook the fish fingers in the oven following pack instructions."
    },
    {
      "heading": null,
      "description": "Finely dice the onion and pepper. Finely slice the garlic. Peel and grate the ginger. Peel and grate the carrots. Grate the courgette."
    },
    {
      "heading": null,
      "description": "Place a medium saucepan over a medium heat with a drizzle of olive oil. Fry the onion, pepper, garlic, ginger, carrot and courgette for 5-6 mins until soft."
    },
    {
      "heading": null,
      "description": "Stir in the curry powder and ground turmeric, then sprinkle in the flour. Cook for 1 min, stirring constantly."
    },
    {
      "heading": null,
      "description": "Slowly pour in the stock, stirring as you go to avoid lumps. Add the honey, soy sauce and coconut milk. Bring to the boil, then simmer for 10-12 mins until the sauce is smooth and slightly thickened."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the rice following pack instructions. Thinly slice the cucumber."
    },
    {
      "heading": null,
      "description": "Use a stick blender to blitz the curry sauce until smooth. Season with a pinch of salt."
    },
    {
      "heading": null,
      "description": "Serve up!\nKids Plate: Dish out the rice topped with the fish fingers, a generous ladle of curry sauce and the sliced cucumber on the side.\nParent Plate: Do the same and garnish with thinly sliced red onion."
    }
  ],
  "tips": [
    "If you’re veggie, swap to plant-based fish fingers and use veg stock.",
    "Sauce can be made ahead and reheated.",
    "Blitzed curry sauce keeps in the fridge for 2-3 days."
  ],
