  "method": [
    {
      "heading": null,
      "description": "Dice red onion and garlic cloves. Roughly chop the sun dried tomatoes. Pit the kalamata olives and roughly chop them."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil on a non-stick pan over medium-high heat. Once the olive oil is hot add red onion and fry until it begins to develop some colour. Add garlic, a pinch of salt and let cook for another 2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Add the tomato paste, sun dried tomatoes and kalamata olives and harissa paste. Leave to cook 2-3 mins and let the flavours infuse. If the mixture starts to dry out, add a ladle of vegetable stock."
    },
    {
      "heading": null,
      "description": "Add the chickpeas, previously drained from their stock, and vegetable stock. Cook over a medium-high heat for 15-20 mins or until the sauce starts to thicken. Turn off the heat. If you'd like it saucier, add a splash of water."
    },
    {
      "heading": null,
      "description": "Add in the spinach and nutritional yeast and stir until the spinach has wilted completely. Season with salt and pepper to taste and let the dish sit for 5 mins before serving."
    },
    {
      "heading": null,
      "description": "Divide into bowls and serve with toasted sourdough bread."
    }
  ],
