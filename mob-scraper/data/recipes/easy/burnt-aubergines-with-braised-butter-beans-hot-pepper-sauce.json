  "method": [
    {
      "heading": null,
      "description": "Split the chilli in half lengthways and finely chop the shallot, fennel, garlic and rosemary."
    },
    {
      "heading": null,
      "description": "In a large frying pan, sweat the halved chilli and the shallots and fennel in plenty of olive oil for 10-12 mins."
    },
    {
      "heading": null,
      "description": "Add the garlic and rosemary and cook for a further 3-4 mins. Add the butterbeans and the liquid from the jar, season and bring to a simmer. Turn down the heat and let it bubble away for 20 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, char your aubergines over the flame of a gas hob, on a barbecue or under a hot grill until collapsing and thoroughly burnt. Add them to a bowl and cover to steam for 5-6 mins."
    },
    {
      "heading": null,
      "description": "Peel the blackened skin off of the aubergines and keep warm in the covered bowl."
    },
    {
      "heading": null,
      "description": "Once your beans have bubbled away, they should have thickened up a little. Roughly chop the roasted pepper and add to the beans with the sherry vinegar."
    },
    {
      "heading": null,
      "description": "Now finely chop the herbs and hot peppers and add to a small mixing bowl, season with salt and add plenty of oil and the pickling liquor. Mix to a beautiful salsa."
    },
    {
      "heading": null,
      "description": "Warm a serving plate and add the beans to the base, top with the burnt aubergines and finish with plenty of the hot pepper salsa. Get stuck in."
    }
  ],
