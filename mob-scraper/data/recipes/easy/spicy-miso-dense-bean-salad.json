  "method": [
    {
      "heading": null,
      "description": "Bring a pot of salted water to the boil. Add the edamame beans and boil for 5 mins, then drain and rinse under cold water. Drain and rinse the cannellini beans."
    },
    {
      "heading": null,
      "description": "Slice the romaine lettuce. Halve the cucumber lengthways, scoop out the seeds and slice. Finely slice the spring onions."
    },
    {
      "heading": null,
      "description": "In a large bowl, whisk together the white miso, gochujang, maple syrup and rice vinegar until smooth."
    },
    {
      "heading": null,
      "description": "Add the cannellini beans, edamame, quinoa, lettuce, cucumber and spring onions. Toss everything together and season with salt to taste."
    },
    {
      "heading": null,
      "description": "Top with the toasted sesame seeds and torn coriander leaves before serving.If making ahead, box up and chill until needed. The salad will keep for up to 3 days in the fridge. Store the dressing separately to keep the salad fresh."
    }
  ],
