  "method": [
    {
      "heading": null,
      "description": "Fill a pot with heavily salted water and get it on a good roiling boil."
    },
    {
      "heading": null,
      "description": "Trim the green beans and chop them in half. Chunk up your courgette. Add the beans, courgette chunks, and pasta to the pan. Cook for 12 mins. While your pasta is cooking, chop up your basil."
    },
    {
      "heading": null,
      "description": "Once the pasta is cooked, drain the mixture and reserve a mug of the pasta water for later. Add your pasta, courgette, and green beans back to the pot with two-thirds of your grated Parmesan and most of your chopped basil. Add in your olive oil, salt, pepper, and a three-quarters of your favourite chilli oil."
    },
    {
      "heading": null,
      "description": "Rigorously mix the contents of the pot until the Parmesan has melted. Put the lid on it and let it sit for 5 mins. Serve your plates with more grated Parmesan on top and more fresh basil, chilli oil, and olive oil."
    }
