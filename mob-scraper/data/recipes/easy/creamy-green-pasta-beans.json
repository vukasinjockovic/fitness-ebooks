  "method": [
    {
      "heading": null,
      "description": "Drain and rinse the butter beans. Remove the cavolo nero leaves from their stems and roughly chop. Finely chop the garlic."
    },
    {
      "heading": null,
      "description": "Bring a large pan of salted water to the boil and cook the pasta following pack instructions. Once cooked, drain and reserve the cooking water."
    },
    {
      "heading": null,
      "description": "While the pasta is cooking, heat the olive oil in a large frying pan over a medium heat. Add the garlic and cook for 1-2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Add the cavolo nero and edamame to the pan with a good pinch of salt. Pop a lid on and cook for 3-5 mins, until the leaves have wilted and the edamame is bright green."
    },
    {
      "heading": null,
      "description": "Transfer the cooked greens to a blender with a couple of tablespoons of the butter beans and a splash of the pasta water. Blend until smooth, adding more water as needed to loosen. Season to taste with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Stir the green sauce through the pasta along with the remaining butter beans. Spoon into bowls and top with the basil and a crack of black pepper."
    }
  ],
