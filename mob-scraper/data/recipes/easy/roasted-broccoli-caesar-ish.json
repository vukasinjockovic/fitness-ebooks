  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C fan. Cut the broccoli in half from lengthways, then cut each piece in half again so you have 4 big wedges. Repeat with the second broccoli head."
    },
    {
      "heading": null,
      "description": "Place the broccoli onto a lined baking tray and drizzle with plenty of olive oil and rub in some salt and pepper. Cook for 20 mins on the middle shelf."
    },
    {
      "heading": null,
      "description": "To make the caesar-ish sauce, finely chop ⅔ of the capers until they are almost minced. Add them to a bowl along with the rest of the sauce ingredients, including the juice of the lemon, and whisk until combined. Season well with plenty of salt and pepper. Adjust the flavour to your liking by adding more capers for texture, lemon juice for acidity or dijon or miso for more depth."
    },
    {
      "heading": null,
      "description": "Toast the seeds in a small frying pan on medium heat for a couple of minutes until starting to brown. Add the sesame oil and olive oil and cook for another minute or two, then add the chilli flakes, smoked paprika and a pinch of salt and pepper."
    },
    {
      "heading": null,
      "description": "To serve, spoon most of the sauce onto the bottom of a large plate and arrange the broccoli on top. Drizzle over the remaining sauce and the seedy drizzle and a few of the remaining capers, if you like."
    }
  ],
