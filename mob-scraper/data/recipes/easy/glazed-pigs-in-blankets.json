  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 190°C/374°F."
    },
    {
      "heading": null,
      "description": "Chop the ends off your Brussels sprouts and cut them in half."
    },
    {
      "heading": null,
      "description": "Make your glaze. Combine your Lee Kum Kee Plum Sauce, Lee Kum Kee Premium Oyster Sauce, sugar, lemon juice, 1 tbsp of vegetable oil and water in a bowl. Set aside."
    },
    {
      "heading": null,
      "description": "Take a sausage and twist it in half. Cut the central point with scissors to create two mini sausages, then repeat with your remaining sausages. Wrap each sausage in one slice of bacon."
    },
    {
      "heading": null,
      "description": "Pour your sprouts into a large baking dish and arrange your pigs in blankets over the top. Pour over your glaze, season with pepper, then roast for 25-30 mins."
    },
    {
      "heading": null,
      "description": "Serve alongside all your other Christmas classics."
