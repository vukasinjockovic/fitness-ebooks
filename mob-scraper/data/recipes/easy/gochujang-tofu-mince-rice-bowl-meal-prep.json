  "method": [
    {
      "heading": null,
      "description": "Pat the tofu dry, then crumble it into small mince-sized pieces with your hands."
    },
    {
      "heading": null,
      "description": "Heat the sesame oil in a large non-stick pan over a medium-high heat. Add the tofu and cook for 5–10 minutes, stirring occasionally, until browned and crispy at the edges."
    },
    {
      "heading": null,
      "description": "Grate the garlic and ginger — no need to peel. Peel and cut the carrot into matchsticks, and slice the cucumber into thin matchsticks too. Finely slice the spring onions, pick the mint leaves."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix together the gochujang, soy sauce, honey, garlic, gochujang, ginger and water. Pour the sauce into the pan with the crispy tofu. Stir-fry for a couple of minutes until glossy and well-coated."
    },
    {
      "heading": null,
      "description": "Heat the rice according to the packet instructions, then spoon it into your Tupperware containers. Top with the gochujang tofu “mince,” edamame, carrot, and cucumber."
    },
    {
      "heading": null,
      "description": "Finish with spring onion, lime wedges, mint and sesame seeds, if using. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
  ],
