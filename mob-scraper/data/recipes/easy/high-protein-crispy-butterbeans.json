  "method": [
    {
      "heading": null,
      "description": "Heat the air fryer to 160°C. Drain and rinse the butterbeans."
    },
    {
      "heading": null,
      "description": "Tip the beans onto a clean tea towel or long piece of kitchen roll. Wrap them up and pat them dry, making sure to move them around. The less moisture, the crispier the bean!"
    },
    {
      "heading": null,
      "description": "Add the beans to a mixing bowl and toss with the oil, garlic granules and salt. Tip them into the basket of the air fryer and cook for 20-25 mins. Halfway through cooking, tip the beans back into the same bowl, mix with the harissa and smoked paprika then return to the air fryer."
    },
    {
      "heading": null,
      "description": "Remove the beans from the air fryer when golden and crispy. Serve hot or at room temperature."
    }
