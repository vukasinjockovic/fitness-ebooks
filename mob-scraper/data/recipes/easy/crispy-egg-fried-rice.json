  "method": [
    {
      "heading": null,
      "description": "Rinse your rice. Boil it in 2 times the amount of water."
    },
    {
      "heading": null,
      "description": "Grate carrots and the ginger. Finely slice one red chilli, cloves of garlic, the coriander stalks and the onion. Slice up your pak choi, keeping the white stalks and the leaves separate."
    },
    {
      "heading": null,
      "description": "Pour some vegetable oil into a large pan. Fry the onions and garlic until softened. Add the grated ginger and the sliced red chilli. Allow to soften. Add the coriander stalks and the grated carrot. Mix everything together, cook for a further minute or so. Add the cooked rice."
    },
    {
      "heading": null,
      "description": "Mix together and add the Nasi Goreng Paste. Mix it all in."
    },
    {
      "heading": null,
      "description": "Add the pak choi stalks. Allow to cook for 3 minutes and then add the pak choi leaves."
    },
    {
      "heading": null,
      "description": "Mix everything together. Cook for a further minute and remove from the heat."
    },
    {
      "heading": null,
      "description": "Serve the rice steaming hot and place the fried eggs on top. Cut into those runny yolks and enjoy!"
    }
