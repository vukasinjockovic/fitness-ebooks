  "method": [
    {
      "heading": null,
      "description": "Mix the rice with a small amount of water to separate the grains. Dice the onion, mince the garlic and slice the spring onions (separating your whites and greens). Slice the Chinese sausage."
    },
    {
      "heading": null,
      "description": "Add the sausage with a splash of vegetable oil to a wok set over medium-low heat and cook for 3-5 mins."
    },
    {
      "heading": null,
      "description": "Remove the sausage from the wok and add the onion, garlic and spring onion whites with a glug of vegetable oil. Fry over a low-medium heat for a few mins until softened."
    },
    {
      "heading": null,
      "description": "Turn the heat to medium, then add the rice, soy sauces, oyster sauce, sesame oil, sugar and white pepper. Fry for 2-3 mins over a medium-high heat. Add the frozen peas, give it a toss for 30 seconds then add the sausage. Mix well and remove from the heat."
    },
    {
      "heading": null,
      "description": "Fry the eggs to your liking in a separate pan. Add the fried eggs to the rice and garnish with coriander, toasted sesame seeds and chilli oil."
    }
  ],
