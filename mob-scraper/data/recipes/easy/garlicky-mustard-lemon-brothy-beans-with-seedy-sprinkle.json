  "method": [
    {
      "heading": null,
      "description": "Thinly slice the leek then rinse well in cold water. Thinly slice the garlic."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil in a large pan set over a medium heat. Add the leek, garlic and a pinch of salt and cook for 10-15 mins until softened. Meanwhile, remove the tough stems from the kale and tear the remaining kale into bite size pieces."
    },
    {
      "heading": null,
      "description": "Add the kale, cannellini beans and their liquid, stock, nutritional yeast (if using) and wholegrain mustard to the pan. Give everything a good stir then simmer for another 10 mins. Season to taste with salt, pepper and lemon juice."
    },
    {
      "heading": null,
      "description": "Meanwhile, for the seedy topping, toast all the seeds in a dry frying pan set over a medium heat for a few minutes until fragrant. Stir through the chilli flakes and plenty of salt and pepper."
    },
    {
      "heading": null,
      "description": "To serve, spoon the creamy beans into bowls and top with the seedy mix. Finish with a glug of olive oil and some lemon zest and juice. Serve with some extra mustard, if you like."
    }
  ],
