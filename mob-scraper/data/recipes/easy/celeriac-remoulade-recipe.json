  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Season the chicken thighs all over with salt, pepper and the smoked paprika then drizzle over a splash of olive oil. Put onto a roasting tray and into the oven for 40-45 mins until the skin is crisp and puffed up and the chicken is super tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, peel the celeriac then, using a sharp knife, cut into thin slices. Cut each slice into matchsticks (this will take a while - be patient as the better you chop the celeriac the nicer the remoulade texture will be)."
    },
    {
      "heading": null,
      "description": "Spoon the crème fraîche, mayonnaise and mustard into a large salad bowl. Add the matchstick celeriac, toss to coat."
    },
    {
      "heading": null,
      "description": "Chop all the herbs (stalks and all). Slice the cornichons. Add everything to the celeriac, along with the capers. Toss together, season with salt, pepper and lemon juice to taste."
    },
    {
      "heading": null,
      "description": "Serve the celeriac remoulade alongside the roasted chicken thighs. Unreal."
    }
