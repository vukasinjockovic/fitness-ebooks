  "method": [
    {
      "heading": null,
      "description": "Blend up the onion, ginger, garlic and scotch bonnet in a food processor to make a chunky paste."
    },
    {
      "heading": null,
      "description": "Finely chop the spring onions."
    },
    {
      "heading": null,
      "description": "Add a glug of oil into a pan and then fry off the onion mixture for 10 mins until fragrant and the onions are translucent."
    },
    {
      "heading": null,
      "description": "Add in the tomato purée and cook this out for 5 mins until the colour darkens."
    },
    {
      "heading": null,
      "description": "Crumble the stock cube into a jug and add in 800ml boiling water."
    },
    {
      "heading": null,
      "description": "Pour in the coconut milk and vegetable stock, bring this to a gentle simmer."
    },
    {
      "heading": null,
      "description": "Pour the desiccated coconut, cornflour and oat milk into three separate bowls. Season each bowl with a pinch of salt."
    },
    {
      "heading": null,
      "description": "Add a large glug of oil into a saucepan."
    },
    {
      "heading": null,
      "description": "Chop up the tofu into small pieces. Dredge each individual piece in the cornflour, then the oat milk, and then finally press it into the desiccated coconut."
    },
    {
      "heading": null,
      "description": "Fry the tofu until golden brown and crispy."
    },
    {
      "heading": null,
      "description": "Add the pak choy into the soup and cook for 2 mins."
    },
    {
      "heading": null,
      "description": "Cook the noodles in boiling water according to package instructions."
    },
    {
      "heading": null,
      "description": "Add the cooked noodles to a bowl then add in the soup. Top with pak choi, crispy tofu and finally the spring onions."
    }
  ],
