  "method": [
    {
      "heading": null,
      "description": "Preheat your grill on full power."
    },
    {
      "heading": null,
      "description": "Finely chop the rosemary, mint and garlic and add to a mixing bowl (reserving a tbsp of the chopped mint) with the yoghurt, lemon zest, chilli, sumac, a tbsp of olive oil and 1 tbsp of salt (remember this is a marinade not a dip!). Cut the chicken into roughly 1 inch cubes and add to the bowl, mix well and set aside at room temperature."
    },
    {
      "heading": null,
      "description": "Finely slice the onions and chilli and finely chop the parsley. Add everything to a bowl with the lemon juice, sumac, a pinch of salt, and drizzle of olive oil. Mix well and set aside."
    },
    {
      "heading": null,
      "description": "Roughly chop the tomatoes and slice the cucumber and add to a bowl with the reserved mint. Cut both ‘cheeks’ off the lemon and squeeze the middle over the tomatoes and cucumber, add a big pinch of salt and drizzle of olive oil and mix well."
    },
    {
      "heading": null,
      "description": "Thread the chicken onto skewers and set them over a high-sided oven dish so the meat is suspended. Place under the grill as close as you can get it to the element without touching."
    },
    {
      "heading": null,
      "description": "Cook for 3 mins, flip the skewers and cook for another three minutes. They should be charred and golden on the outside and cooked through but still juicy in the centre."
    },
    {
      "heading": null,
      "description": "Spread the hummus over a large platter and top with the skewers. Drain any liquid from the onion and tomato salads and plate them up alongside the skewers. Finish with a drizzle of olive oil and serve with warm flatbreads, lemon slices, extra fresh herbs and sumac and the tzatziki on the side."
    }
  ],
