  "method": [
    {
      "heading": null,
      "description": "Finely chop the onion and garlic, and slice the roasted peppers. Heat the olive oil in a large pan over a medium heat, then add the onion and garlic. Season with salt, cook for 5 mins until softened and just turning golden."
    },
    {
      "heading": null,
      "description": "Drain and rinse the beans, then add them to the pan along with the chipotle paste, oregano, and roasted peppers. Cook for 2 mins to let the flavours meld, then tip in the chopped tomatoes. Bring to a simmer and cook for 15 mins, stirring occasionally."
    },
    {
      "heading": null,
      "description": "Stir in the spinach and cook for another 2 mins until just wilted. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, blitz the silken tofu in a blender until smooth. Season with salt and pepper, then zest in the lime and mix well. Stir half of the whipped tofu through the chilli, keeping the rest for serving."
    },
    {
      "heading": null,
      "description": "Cut the lime into wedges. Serve the chilli in bowls, topped with the remaining whipped tofu, fresh coriander, and a squeeze of lime."
    }
  ],
