  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Cut the potatoes into wedges, skin and all. Toss with olive oil, a tiny bit of salt\nand pepper and lay out on a roasting tray. Slide into the oven and roast for 25-30\nmins until golden brown and crispy."
    },
    {
      "heading": null,
      "description": "While the potatoes are roasting, add 3 tbsp of oil to a small frying pan. Set over a\nmedium heat and when the oil is hot, drop in the picked rosemary leaves and\nsizzle for 30 seconds. Drain on kitchen paper and allow to cool. Now scrunch\nthem into 2 tsp of fine sea salt."
    },
    {
      "heading": null,
      "description": "Remove the potatoes from the oven and season with the rosemary salt."
    }
