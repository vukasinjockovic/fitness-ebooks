  "method": [
    {
      "heading": null,
      "description": "Grate ½ the onion. Combine with breadcrumbs in a large mixing bowl and leave to sit and hydrate for 5 mins."
    },
    {
      "heading": null,
      "description": "Roughly chop your parsley."
    },
    {
      "heading": null,
      "description": "Into the mixing bowl with the breadcrumbs, add your lamb mince, parsley, cinnamon, and plenty of salt and pepper. Combine with your hands."
    },
    {
      "heading": null,
      "description": "Roll into golf-ball sized balls. Fry for about 3 mins until they have taken on some colour on the outside, but aren’t totally cooked through. Set aside."
    },
    {
      "heading": null,
      "description": "Finely slice your remaining onion. Finely chop your garlic."
    },
    {
      "heading": null,
      "description": "Add a glug of olive oil to a wide casserole dish, then tip in your onions. Cook for about 15 mins on a medium heat until caramelised."
    },
    {
      "heading": null,
      "description": "Add the garlic and chilli flakes in with the caramelised onions, and cook for another 2 mins. Pour in your white wine and let it reduce by half. Add your passata and the water, then simmer for 15 mins on a low heat."
    },
    {
      "heading": null,
      "description": "Bring a large pan of salted water to the boil."
    },
    {
      "heading": null,
      "description": "Tip your orzo into the water and cook for 7 mins."
    },
    {
      "heading": null,
      "description": "Add your meatballs to the tomato sauce and gently simmer for another 5 mins."
    },
    {
      "heading": null,
      "description": "Drain your orzo. Gently mix with the sauce and meatballs to combine, adding some pasta water to loosen it up where necessary. Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Combine the zest and juice of ½ the lemon in a bowl with your crème fraîche. Drizzle this over the top of the orzo, then top with grated parmesan, fresh basil leaves and more black pepper."
    },
    {
      "heading": null,
      "description": "Serve and enjoy."
    }
  ],
