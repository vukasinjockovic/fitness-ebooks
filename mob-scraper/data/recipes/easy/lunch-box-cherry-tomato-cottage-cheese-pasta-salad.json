  "method": [
    {
      "heading": null,
      "description": "If your pasta isn’t already cooked, bring a large pan of salted water to the boil and cook the fusilli following pack instructions. Drain, rinse under cold water and set aside to cool."
    },
    {
      "heading": null,
      "description": "Halve the cherry tomatoes and finely slice the courgette. Grate the Parmesan. Toast the pine nuts in a dry frying pan over medium heat for 2–3 mins until golden. Tear the basil leaves. Shred or dice the cooked chicken."
    },
    {
      "heading": null,
      "description": "Tip the cooled pasta into a large mixing bowl. Add the cherry tomatoes, sundried tomato paste, cottage cheese, chicken and most of the basil. Season generously with salt and black pepper, then toss everything together until well combined."
    },
    {
      "heading": null,
      "description": "Divide between bowls or containers. Finish with the toasted pine nuts, a scattering of Parmesan and the rest of the basil."
    }
  ],
