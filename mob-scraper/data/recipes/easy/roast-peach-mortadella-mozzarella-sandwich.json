  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200℃. Halve and pit the peaches, then transfer to a baking tray. Drizzle with 1 tbsp olive oil, the honey, thyme and a pinch of salt, then roast in the oven for 20 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, slice the focaccia rolls in half, then spread the bottom halves with the pesto."
    },
    {
      "heading": null,
      "description": "To assemble, tear the mozzarella and add on top of the pesto. Layer up the mortadella in ruffles, then top with the peaches. Cover with rocket, then spread mustard over the top bread halves. Close the sandwich, press down and slice through the middle."
    }
