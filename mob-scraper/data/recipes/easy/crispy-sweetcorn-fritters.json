  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kid Servings\nFinely slice the spring onions. Peel and finely chop the ginger."
    },
    {
      "heading": null,
      "description": "Drain the sweetcorn and add into a large mixing bowl. Add the spring onions, ginger, turmeric and cumin. Crack in the eggs and give everything a good whisk."
    },
    {
      "heading": null,
      "description": "Add the flour, baking powder, milk and a pinch of salt. Whisk to make a smooth, thick batter."
    },
    {
      "heading": null,
      "description": "Place a large non-stick frying pan over a medium-high heat and melt a knob of butter. Once hot, spoon in the batter to make fritters roughly 10cm wide."
    },
    {
      "heading": null,
      "description": "Fry for 1-2 mins until golden underneath, then flip and cook for another 1-2 mins. Repeat with the rest of the batter, adding a little more butter if needed."
    },
    {
      "heading": null,
      "description": "Roast the cherry tomatoes in a drizzle of oil at 220°C for 10–15 mins until jammy."
    },
    {
      "heading": null,
      "description": "Serve up! \nKids Plate: Dish out the fritters with a spoonful of yoghurt and a handful of the roasted cherry tomatoes.\nParent's Plate: Serve up your fritters with the yoghurt, jammy tomatoes, squeeze over the lime juice with an extra scattering of chopped spring onion and a spoonful of chilli oil, if you fancy."
    }
  ],
  "tips": [
    "You can batch-cook these and reheat in the toaster or oven.",
    "They freeze well — just defrost and reheat until piping hot.",
    "These last for up to 3 days in the fridge."
  ],
