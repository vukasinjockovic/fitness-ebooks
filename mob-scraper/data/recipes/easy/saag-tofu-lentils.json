  "method": [
    {
      "heading": null,
      "description": "Preheat your oven to 180°C. Pat the tofu dry, then tear into pieces. Toss with half of the olive oil, a pinch of salt, and some pepper. Spread out on a baking tray and roast for 15 mins, until golden and crisp around the edges. Toss with the lime pickle."
    },
    {
      "heading": null,
      "description": "While the tofu cooks, finely dice the onion, ginger and garlic. Heat the remaining olive oil in a large saucepan over medium heat. Add the onion, garlic and ginger and cook for 5 mins until soft and starting to turn golden."
    },
    {
      "heading": null,
      "description": "Stir in the curry powder. Cook for another 30 secs until fragrant. Add the lentils, stock cube, coconut milk, and water. Season with salt and pepper. Bring to the boil, then reduce to a simmer and cook for 20 mins, stirring occasionally, until the lentils are tender and creamy."
    },
    {
      "heading": null,
      "description": "Stir through the spinach and cook for 2–3 mins until wilted."
    },
    {
      "heading": null,
      "description": "Spoon into bowls, top with tofu and scatter with fresh coriander."
    }
  ],
