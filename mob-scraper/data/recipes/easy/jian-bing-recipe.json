  "method": [
    {
      "heading": null,
      "description": "Add the frozen paratha to a frying pan set over a medium heat and cook following pack instructions until it's golden brown and crispy. Remove and set aside."
    },
    {
      "heading": null,
      "description": "Meanwhile, whisk the egg and finely chop the spring onion. Add the spring onions to the bowl of whisked egg."
    },
    {
      "heading": null,
      "description": "Add a splash of vegetable oil to the now-empty pan along with the egg mixture. Fry for 30 seconds on each side."
    },
    {
      "heading": null,
      "description": "While the egg is frying, spread the hoisin and sriracha onto one side of the cooked paratha."
    },
    {
      "heading": null,
      "description": "When both sides of the egg are cooked, place the paratha directly onto the omelette, sauce-side down, until it sticks, then remove and set aside."
    },
    {
      "heading": null,
      "description": "Slice the tomato and tear the lettuce leaf into small pieces. Finely chop the coriander."
    },
    {
      "heading": null,
      "description": "Crush the peanuts."
    },
    {
      "heading": null,
      "description": "Top the paratha with the tomato, lettuce, crushed peanuts, coriander, sesame seeds and chilli oil. Enjoy!"
    }
