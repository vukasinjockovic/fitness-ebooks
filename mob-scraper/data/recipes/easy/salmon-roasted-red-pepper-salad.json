  "method": [
    {
      "heading": null,
      "description": "Microwave the rice according to packet instructions."
    },
    {
      "heading": null,
      "description": "Meanwhile, drain the red peppers and thinly slice. Cut the kernels off the corn, pick the leaves off the herbs and finely slice the stems. Peel and finely dice the onion. Halve the tomatoes."
    },
    {
      "heading": null,
      "description": "Add the onion into a large bowl with the zest of half a lemon and the juice of both. Season with salt and pepper, stir in 30ml of olive oil. Set aside."
    },
    {
      "heading": null,
      "description": "Place a frying pan over a high heat, with no oil. Once hot, add half the corn kernels and cook until starting to char, 3-4 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, lay the salmon skin-side down, in a cold non-stick frying pan. Place over a medium heat and cook for 10 mins until the skin is crisp and most of the salmon is pale pink. Flip over and remove the pan from the heat."
    },
    {
      "heading": null,
      "description": "Add all the corn, roasted peppers, tomatoes, rice, chopped stems and herbs into the onion dressing, toss together. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Share the salad between your plates and top with the salmon and a drizzle of oil."
    }
  ],
