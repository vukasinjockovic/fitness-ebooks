  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Put the two chicken breasts on a tray and drizzle with a little olive oil. Season well and slide into the oven and bake for 20 mins, until cooked through. Set aside until cool."
    },
    {
      "heading": null,
      "description": "Tear the bread into chunky croutons, whack on a baking tray and drizzle with olive oil. Season with salt and pepper. Slide into the oven for 15 mins."
    },
    {
      "heading": null,
      "description": "Bring a pan of salted water to the boil, drop in the Tenderstem broccoli and cook for 2 mins, then remove and set aside on a plate to cool."
    },
    {
      "heading": null,
      "description": "Add the romaine lettuce halves to a board with the cooked chicken, Tenderstem broccoli and parmesan cheese. Chop together, then slide into a large bowl. Combine the dressing ingredients, then add the croutons and capers and drizzle with the dressing. Toss well then tip onto plates. Top with an extra grating of parmesan cheese."
    }
