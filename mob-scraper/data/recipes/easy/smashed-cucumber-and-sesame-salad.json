  "method": [
    {
      "heading": null,
      "description": "Gently bash the cucumbers with a rolling pin until they break up into large pieces. Chop these up into bite-sized pieces then trim and thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "Chop up the halloumi into 2cm chunks and pan-fry them with a glug of olive oil until golden brown and crispy, 3-5 mins."
    },
    {
      "heading": null,
      "description": "In a large bowl, add in your tahini, soy sauce, rice vinegar and crispy chilli oil. Stir together and add 1 tbsp of cold water at a time until the dressing is smooth. Taste and season with salt, if needed."
    },
    {
      "heading": null,
      "description": "Add the cucumbers, halloumi and spring onions to the dressing. Toss well and serve up in bowls with some more chilli oil, enjoy!"
    }
