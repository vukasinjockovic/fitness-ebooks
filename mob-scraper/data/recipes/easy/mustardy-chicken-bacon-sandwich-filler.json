  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Add the chicken to a roasting tray, drizzle with olive oil and season well with salt and pepper. Roast for 25 mins, then rest for 10 mins before dicing."
    },
    {
      "heading": null,
      "description": "Turn on the grill. Lay the bacon onto a tray and cook for 5–10 mins until crispy. Chop into shards."
    },
    {
      "heading": null,
      "description": "Finely chop the chives and cornichons."
    },
    {
      "heading": null,
      "description": "In a bowl, mix the yoghurt, mayonnaise, Dijon mustard, honey and apple cider vinegar. Add the chopped chives, cornichons, diced chicken and crispy bacon. Mix well and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve however you like, but we love this filling stuffed between tiger bread with rocket and juicy tomatoes.\nIf you're making ahead, pop the filling into the fridge in Tupperware (it will keep for up to 3 days)."
    }
  ],
  "tips": [
    "You can swap bacon for turkey rashers for a lighter version.",
    "Make sure the chicken is cool before mixing to keep the dressing creamy."
  ],
