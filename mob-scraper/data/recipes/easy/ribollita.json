  "method": [
    {
      "heading": null,
      "description": "Chop your onion, celery, carrot and garlic into a fine dice (this will form your sofrito) and add to a pan with a glug of olive oil and the sprig of rosemary. Season with salt and pepper and sauté the sofrito for 10 mins."
    },
    {
      "heading": null,
      "description": "Add the Parmesan rind, pearl barley, tinned tomatoes and borlotti and cannellini beans along with their liquid. Cover with a lid and cook for 30-40 mins until the pearl barley is cooked, adding a splash of extra water if it’s drying out."
    },
    {
      "heading": null,
      "description": "Chop the cavolo nero and spring greens and add to the pan then continue to cook for another 10 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the red chilli and grate the Parmesan."
    },
    {
      "heading": null,
      "description": "To serve, place a piece of stale sourdough in the bottom of each bowl and ladle over the ribollita. Top with the fresh chilli, thyme leaves, grated Parmesan and a drizzle of olive oil."
    }
  ],
