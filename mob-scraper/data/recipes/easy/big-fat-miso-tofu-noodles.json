  "method": [
    {
      "heading": null,
      "description": "Cut the tenderstem broccoli in half lengthways."
    },
    {
      "heading": null,
      "description": "Bring a saucepan of water to the boil, then gently lower in the eggs and cook for 7 mins. Drain and cool under running water. Once cool enough to handle, peel and set aside."
    },
    {
      "heading": null,
      "description": "Bring another pan of salted water to the boil. Add the noodles, broccoli and edamame, then cook following the noodle pack instructions. Drain and set aside."
    },
    {
      "heading": null,
      "description": "Add the silken tofu and water to a blender and blitz until smooth. Pour into a saucepan set over a medium heat, then stir in the stock cube until fully dissolved."
    },
    {
      "heading": null,
      "description": "Place the miso into a small sieve and dip it into the hot tofu broth. Use the back of a spoon to stir and dissolve the miso into the soup. Season with soy sauce, rice vinegar, salt and black pepper to taste."
    },
    {
      "heading": null,
      "description": "Thinly slice the spring onions."
    },
    {
      "heading": null,
      "description": "To serve, divide the noodles and edamame between bowls, then ladle over the hot miso broth. Halve the eggs and pop them on top. Finish with a scattering of spring onion, sesame seeds and a pinch of shichimi togarashi or chilli flakes, if using."
    }
  ],
