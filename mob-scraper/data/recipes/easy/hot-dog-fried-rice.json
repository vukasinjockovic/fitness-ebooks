  "method": [
    {
      "heading": null,
      "description": "Thinly slice the hot dogs and finely dice the celery and onions. Very finely chop the red chillies (leaving seeds in if you like it hot!) and garlic cloves. Cut the chives into 2-3 cm batons."
    },
    {
      "heading": null,
      "description": "Preheat a large frying pan or wok over a high heat. Once smoking hot, add a shot of sesame oil and the hot dogs. Cook, tossing regularly, for 2-3 mins or until crispy. Tip the hot dogs out onto a plate and add a little more oil."
    },
    {
      "heading": null,
      "description": "Once the oil is hot, tip in the celery and onion and cook, stirring occasionally so they catch and become charred and a little smoky. Add the garlic and chillies and stir fry for 2-3 mins before tipping out."
    },
    {
      "heading": null,
      "description": "Add a little more oil and the rice to the pan. Stir fry briefly and then crack the eggs in. Scramble the eggs and toss through the rice. Add the hot dogs and cooked veggies and stir through the rice."
    },
    {
      "heading": null,
      "description": "Toss through the sugar, white pepper, and soy sauce. Finish with the chives and serve."
    },
    {
      "heading": null,
      "description": "Garnish with hot sauce and crispy onions, if you like."
    }
  ],
