  "method": [
    {
      "heading": null,
      "description": "Trim the base of the cauliflower, keeping any small, tender leaves. Cut into roughly 4cm florets, then cut the stem into 2cm cubes. Trim the top off the pepper, remove the seeds and cut into long, 2cm-wide strips. Cut two-thirds of the spring onions into 4cm pieces and very thinly slice the remaining spring onion. Peel and finely chop the garlic, then peel and finely chop the ginger, too."
    },
    {
      "heading": null,
      "description": "Heat the sesame oil in a large frying pan or wok set over a medium-high heat. Add the cashews and fry for 2-3 mins until turning golden and smelling amazing. Use a slotted spoon to scoop out onto a small plate."
    },
    {
      "heading": null,
      "description": "Tip the cauliflower florets, leaves and stem into the pan along with the pepper pieces and fry for 6-8 mins, stirring regularly, until caramelised and charred. Add the spring onion pieces to the pan along with the garlic, ginger and chilli flakes, then fry for 2 mins while stirring."
    },
    {
      "heading": null,
      "description": "Spoon the hoisin, rice vinegar and soy sauce into the pan along with the water and cook for 10 mins until the cauliflower is cooked through and the sauce is clinging to everything. Add a splash of water if too thick. Meanwhile, cook the noodles following packet instructions."
    },
    {
      "heading": null,
      "description": "Tip the cashews back into the stir-fry pan, toss well and season with a little salt and black pepper."
    },
    {
      "heading": null,
      "description": "To serve, divide the noodles between bowls and top with the stir-fry. Scatter over the thinly sliced spring onion."
    }
  ],
