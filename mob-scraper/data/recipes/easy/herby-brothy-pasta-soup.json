  "method": [
    {
      "heading": null,
      "description": "Finely dice the onion and thinly slice the fresh dill, parsley and coriander, stalks and all."
    },
    {
      "heading": null,
      "description": "Melt the butter in a saucepan set over a medium heat. Add the onion and cook for 4-5 mins until softened and translucent. Then add the herbs and dried mint and stir until wilted (this will be very quick)."
    },
    {
      "heading": null,
      "description": "Pour over the stock and let the mixture come to the boil. Drop in the pasta and cook following packet instructions."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the drizzle. Heat the olive oil in a saucepan set over a medium heat. Add the nigella and sesame seeds and cook until toasted, then tip into a bowl and stir through the sumac. Set aside."
    },
    {
      "heading": null,
      "description": "Once the pasta has finished cooking, give the soup a stir and season with lemon juice, salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve into bowls and grate over some fresh halloumi. Finish with a drizzle of the nigella mixture."
    }
  ],
