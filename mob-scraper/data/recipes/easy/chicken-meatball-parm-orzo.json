  "method": [
    {
      "heading": null,
      "description": "Tip the chicken mince into a mixing bowl. Add 2 Tbsp breadcrumbs, the Italian seasoning, a generous pinch of salt and plenty of black pepper. Mix until just combined, then shape into meatballs. Chill on a plate in the fridge for 10 mins to help them firm up."
    },
    {
      "heading": null,
      "description": "Finely chop the onion and thinly slice the garlic."
    },
    {
      "heading": null,
      "description": "Heat a glug of olive oil in a large, deep ovenproof frying pan set over a medium-high heat. Add the meatballs and fry for 5 mins, turning regularly, until browned all over. Scoop them onto a plate and turn the heat down to medium."
    },
    {
      "heading": null,
      "description": "Get the garlic bread in the oven and bake it following the pack instructions."
    },
    {
      "heading": null,
      "description": "Chuck the onion and garlic into the pan and cook for 6–8 mins until soft and golden. Stir through the tomato purée and orzo and cook for 1 min. Pour in the passata and water, season with salt and pepper, and bring it all to a simmer."
    },
    {
      "heading": null,
      "description": "Nestle the meatballs back into the pan. Let everything bubble away for around 12 mins, or until the orzo is cooked through and the sauce is thickened."
    },
    {
      "heading": null,
      "description": "Once the garlic bread’s out, heat the grill to high. Scatter over the remaining 3 Tbsp breadcrumbs and all the mozzarella, then whack it under the grill for 2–3 mins until golden and bubbling."
    },
    {
      "heading": null,
      "description": "Tear over the basil, finish with a pinch of chilli flakes and serve with big chunks of garlic bread on the side."
    }
  ],
