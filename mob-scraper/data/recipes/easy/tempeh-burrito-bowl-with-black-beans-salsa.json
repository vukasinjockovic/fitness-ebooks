  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "If making a tortilla bowl, press the wrap into an ovenproof bowl to form a bowl shape. Bake for 10 mins until golden and crisp, then remove and cool. Or, simply serve with tortilla for scooping."
    },
    {
      "heading": null,
      "description": "Heat the rice according to pack instructions. Drain and rinse the black beans, then stir them through the rice with a pinch of salt and black pepper. Set aside."
    },
    {
      "heading": null,
      "description": "Peel and finely dice the onion. Halve the tomato, scoop out the seeds, then finely dice the flesh. Chop the coriander and combine it all in a bowl with the juice of half the lime and a pinch of salt and pepper. Slice the roasted peppers."
    },
    {
      "heading": null,
      "description": "Crumble the tempeh into mince-sized pieces. Heat a drizzle of oil in a frying pan over a medium heat. Add the tempeh and fry for 5–6 mins until golden and crisp. Add the paprika, cumin and chilli powder, then stir for 30 seconds until fragrant."
    },
    {
      "heading": null,
      "description": "To build your bowl, spoon in the rice and beans, top with the spiced tempeh, fresh salsa and sliced roasted peppers. Finish with a dollop of yoghurt, a scattering of coriander and a lime wedge on the side."
    }
  ],
