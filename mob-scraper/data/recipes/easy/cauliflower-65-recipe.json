  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C. Thinly slice the green chillies for the marinade and transfer to a bowl. Add the remaining marinade ingredients, season with salt and mix well."
    },
    {
      "heading": null,
      "description": "Trim the cauliflower, then rub the marinade all over. Place onto an oiled baking tray, transfer to the oven and roast for 30-35 mins until tender. Crank the oven temperature up to 200°C and roast for another 5 mins to get some colour onto the cauliflower."
    },
    {
      "heading": null,
      "description": "Meanwhile, add a glug of oil to a small frying pan and place over a medium-high heat. Once hot, drop the curry leaves in and fry until darkened (they’ll splutter, so be careful). Transfer to a plate lined with kitchen paper."
    },
    {
      "heading": null,
      "description": "Once the cauliflower is cooked, plate up and drizzle over the pan juices. Finish with a scattering of crispy curry leaves."
    }
