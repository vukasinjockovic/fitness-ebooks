  "method": [
    {
      "heading": null,
      "description": "Guac first. Grab a bowl. Add peeled avocados, chopped spring onions, a chopped red chilli, a chopped handful of coriander and the juice of a lime. Add a splash of olive oil. Season with salt and pepper. Mash everything together."
    },
    {
      "heading": null,
      "description": "Crack 6 eggs into a bowl and season with salt and pepper. Dunk in your crumpets, squeezing them so they absorb the egg. Leave in the egg mixture for 2 minutes so it is properly absorbed."
    },
    {
      "heading": null,
      "description": "Heat a pan with some olive oil. Fry the eggy crumpets for 4 minutes on each side."
    },
    {
      "heading": null,
      "description": "Serve the crumpets with a big dollop of guacamole on top. Add some hot sauce, grate over some parmesan and tuck in!"
    }
