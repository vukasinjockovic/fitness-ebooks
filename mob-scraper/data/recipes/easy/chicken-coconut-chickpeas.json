  "method": [
    {
      "heading": null,
      "description": "Slice the cucumber on an angle, then add to a bowl with the juice of one of the limes and a pinch of salt. Toss and set aside."
    },
    {
      "heading": null,
      "description": "Drizzle a little olive oil over the chicken and season with salt and pepper. Place a frying pan over a medium-high heat and add the chicken. Cook for 10 mins, turning halfway through, until golden-brown on both sides. While it’s cooking, peel the garlic and ginger and drain the chickpeas. Remove the chicken from the pan and set aside on a plate to rest."
    },
    {
      "heading": null,
      "description": "Add a splash of olive oil to the pan, turn the heat down to medium and grate the garlic and ginger directly into the pan. Add the turmeric, then stir to cook for a minute. Add the chickpeas along with the coconut milk, season with fish sauce and pepper and simmer for 10 mins until thickened. Before serving, taste and season with fish sauce, if needed. Add the juice of half a lime, cutting the other half into two wedges to serve."
    },
    {
      "heading": null,
      "description": "Slice the chicken, then spoon the chickpeas into the bowl and top with the sliced chicken and cucumber salad. Scatter with coriander leaves and top with a pinch of chilli flakes. Serve with a lime wedge on the side of each bowl."
    }
