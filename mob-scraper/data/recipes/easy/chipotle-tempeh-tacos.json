  "method": [
    {
      "heading": null,
      "description": "Crumble the tempeh into mince-sized pieces. Heat the oil in a frying pan set over a medium-high heat. Add the tempeh and fry for 4–5 mins until golden and crisp at the edges. Stir in the soy sauce and chipotle paste, and cook for another couple of minutes until everything’s well coated."
    },
    {
      "heading": null,
      "description": "Strip the cavolo nero leaves from their stalks, then finely slice them. Add to a bowl with a pinch of salt and the juice of half the lime. Use your hands to massage the cavolo until it softens and darkens in colour."
    },
    {
      "heading": null,
      "description": "Char the tortillas in a dry frying pan or directly over a gas flame for 20–30 seconds on each side until soft and blistered."
    },
    {
      "heading": null,
      "description": "Pick the coriander leaves."
    },
    {
      "heading": null,
      "description": "To assemble, spread the yoghurt onto each tortilla, then layer up with the cavolo nero and smoky chipotle tempeh. Finish with pickled onions and a scattering of coriander leaves. Serve with the remaining lime on the side for squeezing."
    }
  ],
