  "method": [
    {
      "heading": null,
      "description": "Bash up your peanuts and set aside."
    },
    {
      "heading": null,
      "description": "Slice your ginger into strips, and finely slice your red chilli. Throw them into a hot wok with a good glug of vegetable oil."
    },
    {
      "heading": null,
      "description": "Allow to soften, and then add your cloves of crushed garlic."
    },
    {
      "heading": null,
      "description": "Mix together, and then add 4 finely sliced spring onions. Allow to soften, and then throw in the chopped pak choi stalks (save the leaves for later) and leave to cook for 3-4 or until softened ."
    },
    {
      "heading": null,
      "description": "Mix it up, and then add your peanut butter. Mix with the vegetables, and then add 200ml of vegetable stock. Once the peanut butter has dissolved, allow the sauce to bubble away for 2 minutes."
    },
    {
      "heading": null,
      "description": "At this point, add your honey and soy sauce."
    },
    {
      "heading": null,
      "description": "Mix together, and then throw in your rice noodles. Move them around in the sauce, and then add your pak choi leaves."
    },
    {
      "heading": null,
      "description": "Mix together, and then add a large handful of chopped coriander, and the juice of a lime."
    },
    {
      "heading": null,
      "description": "Once the pak choi leaves have wilted (30 seconds) add a large handful of chopped peanuts, mix them in, and then remove the wok from the heat."
    },
    {
      "heading": null,
      "description": "Serve the noodles in a bowl, and top with more peanuts, chopped spring onion and coriander leaves! Enjoy!"
    }
  ],
