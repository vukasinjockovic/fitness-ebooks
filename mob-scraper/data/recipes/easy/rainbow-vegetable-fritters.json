  "method": [
    {
      "heading": null,
      "description": "Using a grater (or a mandolin or food processor if you have one), finely shred or slice the cabbage, sprouts, carrot, courgette, spring onions and red chilli. Add to a bowl with the drained sweetcorn a pinch of salt."
    },
    {
      "heading": null,
      "description": "Sprinkle in the chickpea flour, a couple of tablespoons at a time, mixing with your hands until it starts to bind together and adding more chickpea flour as needed (you might need more than the specified weight depending on how wet the veg are)."
    },
    {
      "heading": null,
      "description": "To make the dipping sauce, mince the garlic and finely chop the parsley and juice the lemon then combine with the rest of the dipping sauce ingredients in a small bowl."
    },
    {
      "heading": null,
      "description": "Heat a splash of olive oil in a large frying pan set over a medium heat. Drop a tbsp or so of mixture into the pan and fry for a couple of mins on each side until golden and crispy. Serve with the dipping sauce."
    }
  ],
