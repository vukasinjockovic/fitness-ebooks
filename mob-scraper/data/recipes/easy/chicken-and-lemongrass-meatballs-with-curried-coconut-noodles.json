  "method": [
    {
      "heading": null,
      "description": "For the meatballs, add the chicken mince into a bowl with the green curry paste, soy sauce and fish sauce. Grate in the ginger and garlic, stir until evenly combined. Roll or spoon the mixture into walnut sized meatballs."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of vegetable oil in a wide pan set over a medium heat. Fry the chicken meatballs for 2-3 mins until nicely coloured but not yet fully cooked through. Add the sugar and stir well to coat, then cook for about 30 seconds until the sugar caramelises. Remove to a plate and wipe out the pan."
    },
    {
      "heading": null,
      "description": "For the curried coconut broth, chop the garlic and finely grate the ginger. Heat a drizzle of vegetable oil in the same pan you used to cook the meatballs, set over a medium heat. Add the garlic and ginger and cook for about 30 seconds until aromatic. Add the curry paste and cook for another 30 seconds, giving the saucepan a good stir."
    },
    {
      "heading": null,
      "description": "Add the coconut milk and water and bring to the boil. Thinly slice the lime leaves, discarding the central rib, and add them to the pan."
    },
    {
      "heading": null,
      "description": "Add the chicken balls to the sauce and bring it to the boil, then lower the heat and gently simmer uncovered for about 10-15 mins until the chicken balls are cooked through. Season with fish sauce and soy sauce according to taste."
    },
    {
      "heading": null,
      "description": "Meanwhile, cook the noodles following the instructions on the pack."
    },
    {
      "heading": null,
      "description": "Divide the noodles between bowls. Top each serving of noodles with some chicken balls and coconut sauce, then top with coriander, along with plenty of crispy onions and a wedge of lime."
    }
  ],
