  "method": [
    {
      "heading": null,
      "description": "Heat the grill to high."
    },
    {
      "heading": null,
      "description": "Add half of the tikka paste to a bowl. Tear the tofu into chunky pieces and toss it through the paste. Season well with salt and pepper. Spread out on a foil-lined baking tray and slide under the grill for about 15 mins until golden and lightly charred."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop the onion, garlic and ginger."
    },
    {
      "heading": null,
      "description": "Heat the olive oil in a large frying pan set over a medium heat. Add the onion, garlic and ginger and cook for about 10 mins until soft and golden."
    },
    {
      "heading": null,
      "description": "Stir in the remaining tikka paste and cook for a couple of minutes until fragrant."
    },
    {
      "heading": null,
      "description": "Pour in the chopped tomatoes and coconut milk. Bring to the boil, then reduce the heat and simmer for 10 mins. You can blitz the sauce smooth here with a stick blender if you want it silky or you can just leave it chunky."
    },
    {
      "heading": null,
      "description": "Drain and rinse the chickpeas, then add them to the pan along with the grilled tofu. Simmer for another 5 mins to warm through."
    },
    {
      "heading": null,
      "description": "Squeeze over the lemon juice, then serve up and scatter with fresh coriander leaves. Once cooled, box up and pop in the fridge, ready for tomorrow’s lunch — they’ll keep for up to 3 days."
    }
  ],
