  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Grate the garlic and finely slice the sundried tomatoes."
    },
    {
      "heading": null,
      "description": "Put the canned tomatoes, garlic and 'nduja into a large roasting tin (preferably one with a lid). Mix well and break up the plum tomatoes if using instead of chopped. Add the cherry tomatoes, butter beans, sundried tomatoes and plenty of salt and pepper. Mix well."
    },
    {
      "heading": null,
      "description": "Cut the cabbage in half, then cut each half into four wedges, keeping the stem intact. Arrange the cabbage into the tomatoes snugly, drizzle with olive oil and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Place the lid on or cover the tin tightly with foil. Bake for 30 mins."
    },
    {
      "heading": null,
      "description": "To serve, drizzle with lots of tahini, lemon juice and zest and some more 'nduja. Finish with a drizzle of olive oil, fresh herbs and nuts."
    }
  ],
