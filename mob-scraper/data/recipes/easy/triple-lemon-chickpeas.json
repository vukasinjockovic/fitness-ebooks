  "method": [
    {
      "heading": null,
      "description": "Place a large frying pan over a medium high heat. Slice the lemon in half horizontally and place one half, cut-side down in the pan, cook for 3-4 mins, until charred. Remove and set aside."
    },
    {
      "heading": null,
      "description": "Peel and finely slice the garlic. Finely chop the preserved lemon. Give the pan a clean, then return to the heat. Add a splash of olive oil, then add the garlic and fennel seeds. Sizzle for a minute, then add the preserved lemon. Add the chickpeas and their liquid to the pan. Season with salt and turn up the heat to high. Bubble for 5-10 mins, until most of the water has evaporated. Stir in the crème fraîche and finely grate in the Parmesan. Bubble until the sauce is coating the chickpeas, then stir in the spinach."
    },
    {
      "heading": null,
      "description": "Add the juice of the charred lemon and the remaining uncharred lemon. Taste and season with salt and pepper. Spoon into bowls, top with za’atar and mint and a drizzle of olive oil to serve."
    }
  ],
