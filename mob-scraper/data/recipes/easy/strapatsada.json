  "method": [
    {
      "heading": null,
      "description": "Heat the grill to high. Halve your tomatoes and pop them on a tray, then drizzle with oil, a scattering of oregano, and season with salt and pepper. Grill the tomatoes for 10 mins until charred and juicy."
    },
    {
      "heading": null,
      "description": "Crack your eggs into a bowl and whisk well. Finely slice the garlic."
    },
    {
      "heading": null,
      "description": "Add the butter to a pan over a medium heat, once melted add in the garlic, cooking for a couple of minutes until fragrant. Add the tomato purée and cook for another minute, then reduce the heat to low. Pour in the egg and gently cook whilst stirring so you get soft curds and a dreamy texture. Take it off the heat and fold through the tomatoes before seasoning with salt and pepper."
    },
    {
      "heading": null,
      "description": "Toast your bread, top with your eggs, feta, dill, and another crack of black pepper."
    }
  ],
