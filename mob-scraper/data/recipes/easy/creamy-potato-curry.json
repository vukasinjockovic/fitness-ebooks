  "method": [
    {
      "heading": null,
      "description": "1 Adult Serving = 2 Kids Servings\n\nFinely dice the onion. Finely slice the garlic."
    },
    {
      "heading": null,
      "description": "Place a large lidded saucepan over a medium heat with a drizzle of olive oil. Add the onion, garlic and ginger and fry for 5–6 mins until softened."
    },
    {
      "heading": null,
      "description": "Stir in the curry powder and turmeric. Cook for 1–2 mins until fragrant."
    },
    {
      "heading": null,
      "description": "Peel the potatoes and chop into bite-sized chunks. Tip them into the pan, then pour in the chopped tomatoes, coconut milk and water. Stir well."
    },
    {
      "heading": null,
      "description": "Bring to the boil, then reduce the heat to low. Cover with a lid and simmer for 35–40 mins until the potatoes are tender and the sauce has thickened."
    },
    {
      "heading": null,
      "description": "Stir through the frozen spinach and let it wilt for a few mins. Taste and season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve up! \nKids Plate: Dollop the curry over basmati rice. \nParents Plate: For the adults, top the curry and rice with coriander leaves, a squeeze of lime and a spoon of yoghurt and lime pickle, if using."
    }
  ],
  "tips": [
    "You can blend part of the curry to make it extra smooth for fussy kids.",
    "Curry keeps in the fridge for 3 days and freezes beautifully (for up to 3 months)."
  ],
