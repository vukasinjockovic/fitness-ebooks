  "method": [
    {
      "heading": null,
      "description": "Add the taco seasoning, brown sugar and a big pinch of salt to a mixing bowl. Pour in the olive oil and stir to combine. Pat the cod dry and coat it in the marinade."
    },
    {
      "heading": null,
      "description": "To cook, place a non-stick frying pan over a medium-high heat. Once hot, add the cod and fry for 3 mins on each side until blackened and flaky. Alternatively, air-fry at max temp for 6–8 mins until cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the crema. Roughly chop the coriander and add it to a blender with a third of the yoghurt, pickled jalapeños, lime juice and a pinch of salt. Blend until smooth. Add the remaining yoghurt and gently pulse to incorporate."
    },
    {
      "heading": null,
      "description": "Finely shred the cabbage."
    },
    {
      "heading": null,
      "description": "Warm the tortillas in a dry pan for 10–20 seconds on each side until soft and golden."
    },
    {
      "heading": null,
      "description": "To serve, fill the tortillas with shredded cabbage, chunks of blackened cod and a good drizzle of jalapeño crema. Serve with lime wedges."
    }
  ],
