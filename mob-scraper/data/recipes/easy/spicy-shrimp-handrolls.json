  "method": [
    {
      "heading": null,
      "description": "Cook the rice following pack instructions. Remove the shells and veins from the prawns. Roughly chop the green onions."
    },
    {
      "heading": null,
      "description": "Heat a medium pot of water over a medium heat. Add the shrimp and boil them for 2-3 mins until opaque and fully cooked. Drain and pat dry with kitchen paper."
    },
    {
      "heading": null,
      "description": "Roughly chop the shrimp and mix with the mayonnaise, chilli oil and green onions in a bowl."
    },
    {
      "heading": null,
      "description": "Cut the nori sheets in half lengthwise and lay them out on a clean flat surface."
    },
    {
      "heading": null,
      "description": "Add a tbsp of cooked rice to one half of each nori and press down with a fork. Generously top with the shrimp mixture and roll into a cone shape."
    },
    {
      "heading": null,
      "description": "Serve with the remaining shrimp and top with furikake, if you like."
    }
