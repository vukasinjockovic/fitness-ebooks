  "method": [
    {
      "heading": null,
      "description": "Peel and thinly slice the onions. Heat a generous glug of olive oil in a pot or deep pan set over a medium heat. Add the onions and cook for 30 mins, stirring frequently."
    },
    {
      "heading": null,
      "description": "When the 30 mins is up, stir in the butter (or more olive oil if keeping things vegan) and continue stirring for a further 45 mins. At this point, the onions should have reduced significantly in volume and be super fragrant and dark."
    },
    {
      "heading": null,
      "description": "Slice the mushrooms and add them to the pot, stirring for another 20 mins."
    },
    {
      "heading": null,
      "description": "Deglaze the pot with the dry white wine and soy sauce. Continue cooking until the liquid has been absorbed by the onions and mushrooms."
    },
    {
      "heading": null,
      "description": "Pour in the stock and bring the mixture to a boil, then reduce the heat to a simmer, add the pearl couscous, and cook for 15 mins. Season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Meanwhile, slice the spring onions for garnish."
    },
    {
      "heading": null,
      "description": "Divide the dish across four bowls and garnish with sliced spring onions, a drizzle of olive oil, and a dash of single cream (or vegan creamer if you prefer)."
    }
  ],
