  "method": [
    {
      "heading": null,
      "description": "Preheat the air fryer to 200°C. Pick the coriander leaves and discard the stems."
    },
    {
      "heading": null,
      "description": "Chop the tofu into 2cm chunks and toss through the cornflour. Season with salt. Drizzle with olive oil and air-fry for 15–20 mins until golden and crisp. Once cooked, toss the tofu through the kecap manis to glaze."
    },
    {
      "heading": null,
      "description": "Meanwhile, bring a saucepan of water to the boil. Cook the udon noodles following pack instructions. Drain and run under cold water to stop them sticking. If you want the noodles hot, return them to the pan with a splash of water and the peanut curry sauce. Stir over medium heat until warmed through. Otherwise, just mix the sauce straight through the cold noodles."
    },
    {
      "heading": null,
      "description": "Divide the noodles between bowls. Top with the crispy glazed tofu, coriander and a sprinkle of toasted sesame seeds."
    }
