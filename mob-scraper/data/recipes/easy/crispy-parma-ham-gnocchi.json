  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Add the gnocchi, rosemary, cherry tomatoes and vinegar into a baking tray. Finely grate the garlic on top and add half the thyme. Drizzle over some olive oil, season with salt and pepper, toss together. Slide into the oven for 10 mins, until the gnocchi is golden and the tomatoes have softened."
    },
    {
      "heading": null,
      "description": "After 10 mins, lay the parma ham on top, flat. Then, return to the oven for another 7-10 mins, until crispy."
    },
    {
      "heading": null,
      "description": "Transfer the crispy ham onto a plate and crumble. Toss the gnocchi and tomatoes until saucy, adding a splash of water if needed. Taste and season with salt and pepper, if needed."
    },
    {
      "heading": null,
      "description": "Spoon the gnocchi onto plates and top with a dollop of ricotta. Scatter over the parma ham and finish with the remaining thyme leaves."
    }
  ],
