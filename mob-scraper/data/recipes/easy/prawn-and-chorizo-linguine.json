  "method": [
    {
      "heading": null,
      "description": "Slice the chorizo into bite-sized pieces. Add to a frying pan (skillet) over a medium heat and cook until crispy."
    },
    {
      "heading": null,
      "description": "Once crispy, add a pinch of dried chilli flakes and the raw prawns. Cook the prawns until they are pink, then add a chopped garlic clove. Cook for a further 30 seconds, and then pour in the passata."
    },
    {
      "heading": null,
      "description": "Get the linguine on (follow the instructions on the packet)."
    },
    {
      "heading": null,
      "description": "Meanwhile, bubble the sauce down until it is nice and thick. Then throw in a handful of chopped basil (keep some whole leaves to garnish) and season well with salt and pepper."
    },
    {
      "heading": null,
      "description": "Drain your pasta and pour it into the sauce. Mix everything together and serve, with a drizzle of olive oil and the basil leaves scattered on top."
    }
