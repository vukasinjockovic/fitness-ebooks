  "method": [
    {
      "heading": null,
      "description": "Smash the garlic clove and pick the leaves from the thyme stalks. Set both aside. Put the milk and butter into a saucepan and bring to a bare simmer. Roughly chop the onion and add to the pan with the cloves, black peppercorns, smashed garlic clove, thyme and bay leaves. Let the mixture simmer for 15 mins, then remove from the heat and allow to sit for 30 mins."
    },
    {
      "heading": null,
      "description": "Once steeped, pass the mixture through a sieve and return the infused milk back to the pan. Add the breadcrumbs and bring to a simmer. Cook for 5 mins, stirring occasionally. Season with salt and black pepper and serve."
    }
