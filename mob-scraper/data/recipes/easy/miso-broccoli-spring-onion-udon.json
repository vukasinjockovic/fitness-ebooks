  "method": [
    {
      "heading": null,
      "description": "Bring a medium-sized pan of water to the boil. Add eggs and cook for 7 mins. Once done, plunge them in ice-cold water to prevent further cooking."
    },
    {
      "heading": null,
      "description": "Get a cast iron skillet over a medium-high heat. Cut the spring onions into 4cm lengths, then toss them with a little oil and get them in the pan. Cook them for about 3 mins per side. Remove from the pan."
    },
    {
      "heading": null,
      "description": "Toss the broccoli with a little oil, then get it in the skillet pan. Cook for about 4 mins per side, until tender with a light char."
    },
    {
      "heading": null,
      "description": "Grate the Parmesan, crush the garlic and finely chop the ginger. Tip the egg yolks into a large bowl. Add the miso paste, garlic, ginger and Parmesan, then season with lots of black pepper."
    },
    {
      "heading": null,
      "description": "Bring a pan of water to the boil and salt it. Add the udon and cook following pack instructions."
    },
    {
      "heading": null,
      "description": "Drain the udon and, while still hot, tip them into the egg mixture. Add the broccoli and spring onions, then give it a really good mix."
    },
    {
      "heading": null,
      "description": "Transfer the udon to warmed bowls. Peel and halve the eggs, add a half to each bowl and finish with shichimi togarashi. Serve."
    }
  ],
