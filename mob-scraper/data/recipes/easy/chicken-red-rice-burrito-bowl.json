  "method": [
    {
      "heading": null,
      "description": "Cook the rice following packet instructions. Slice the chicken thighs into quarters lengthways. Peel and finely slice two of the onions, and finely dice the remaining one."
    },
    {
      "heading": null,
      "description": "Add the chicken and the sliced onions to a large bowl with the chipotle paste, garlic powder, oregano, ground cumin and olive oil. Season well with salt and mix to combine. Spread evenly on an oven tray, then slide under the grill on the top shelf for 15-20 mins, turning halfway, until cooked through."
    },
    {
      "heading": null,
      "description": "Finely shred the cabbage. If adding avocado crema dress the cabbage with some of the sauce. Roughly chop the coriander and mix with the diced onion in a small bowl. Quarter the cherry tomatoes and toss with a drizzle of olive oil and a pinch of salt."
    },
    {
      "heading": null,
      "description": "If batch cooking, transfer the different components (chicken, rice, onion-coriander mix, cabbage slaw and seasoned tomatoes) to separate containers and store in the fridge. Enjoy cold or reheat the chicken and rice until piping hot before serving."
    },
    {
      "heading": null,
      "description": "To serve, spoon the rice into bowls, then top with chicken and the cabbage slaw. Then sprinkle over the onion-coriander mix. Finish with the tomatoes, crumble over the feta, and serve with lime wedges, hot sauce and more avocado crema (if making)."
    }
  ],
