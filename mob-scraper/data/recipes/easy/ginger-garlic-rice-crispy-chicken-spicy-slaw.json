  "method": [
    {
      "heading": null,
      "description": "Debone the chicken but leave the skin on. Mince the garlic and ginger and thinly slice the shallot."
    },
    {
      "heading": null,
      "description": "Make the rice. Heat the sesame oil and vegetable oil in a saucepan over medium-high heat. Add the shallots and fry for 3–5 mins until golden at the edges. Stir in the garlic, ginger and rice, and toast gently for 2 mins."
    },
    {
      "heading": null,
      "description": "Pour in the chicken stock, add a pinch of salt, and bring to a boil. Cover with a lid, reduce to the lowest heat, and simmer for 18 mins. Once cooked, remove from the heat and let it steam with the lid on until ready to serve."
    },
    {
      "heading": null,
      "description": "Pat the chicken thighs dry with kitchen paper, then season both sides with salt. Lay them skin-side down in a cold non-stick frying pan. Place over medium heat and cook for 7–9 mins until the skin is golden and crisp. Flip and cook for another 3 mins. Set aside to rest."
    },
    {
      "heading": null,
      "description": "Make the slaw. Thinly slice the red cabbage, white cabbage, and bird’s eye chilli. Finely julienne the carrot and finely chop the coriander. In a bowl, combine all the slaw ingredients. Mix well until the sugar dissolves and the cabbage starts to soften."
    },
    {
      "heading": null,
      "description": "Assemble. Slice the chicken into 1–2cm strips. Spoon the rice into bowls, top with the crispy chicken, and serve with a generous side of slaw. Drizzle over extra kecap manis and chilli oil to finish."
    }
  ],
  "tips": [
    "Rice and chicken can be cooked in advance and stored in the fridge for up to 3 days. Reheat chicken in a hot pan or oven to re-crisp the skin.",
    "Slaw is best fresh, but dressing can be made ahead and veg prepped separately.",
    "Great for lunchboxes – pack with rice and chicken on one side, slaw on the other, and drizzle before serving.",
    "Freeze the rice and chicken (sliced) for up to 2 months. Defrost overnight and reheat thoroughly before serving.",
    "Slaw does not freeze well – make fresh."
  ],
