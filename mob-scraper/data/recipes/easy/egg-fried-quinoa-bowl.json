  "method": [
    {
      "heading": null,
      "description": "Cook the quinoa according to package instructions. Five minutes before the end of the cooking time, add the edamame. Drain and set aside."
    },
    {
      "heading": null,
      "description": "Grate your garlic and ginger. Dice your tofu, cut your broccoli into small florets, and roughly chop your coriander."
    },
    {
      "heading": null,
      "description": "In a bowl, toss the diced tofu with olive oil, salt, and white pepper. Air fry at 200°C for 10 minutes until crispy."
    },
    {
      "heading": null,
      "description": "Heat a little oil in a large pan over high heat. Add the broccoli and cook for a few minutes until starting to char."
    },
    {
      "heading": null,
      "description": "Add the garlic and ginger, cooking for another minute, then pour in the soy sauce and water. Simmer until reduced."
    },
    {
      "heading": null,
      "description": "Push the vegetables to one side of the pan and crack in the eggs. Stir to scramble until just cooked through."
    },
    {
      "heading": null,
      "description": "Mix in the quinoa and edamame, stirring everything together."
    },
    {
      "heading": null,
      "description": "Plate up and top with crispy tofu, sriracha, coriander, and sesame seeds, if using."
    }
  ],
  "tips": [
