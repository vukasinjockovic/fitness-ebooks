  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Slice the sweet potato into 1cm-thick rounds. Trim and halve the Brussels sprouts. Toss both with half the olive oil, season with salt and pepper, and roast for 20 mins until golden and tender. Drizzle with the maple syrup."
    },
    {
      "heading": null,
      "description": "Meanwhile, add the apple cider vinegar to a bowl with the powdered peanut butter and 1 Tbsp water and whisk until you’ve got a drizzly dressing. Season to taste."
    },
    {
      "heading": null,
      "description": "Season the chicken breasts with salt and pepper. Heat the remaining oil in a nonstick frying pan over a medium-high heat. Cook the chicken for 7–8 mins, turning halfway, until golden and cooked through. Set aside to rest for 1 min, then slice."
    },
    {
      "heading": null,
      "description": "Tear the radicchio into bite-sized pieces and chuck it into a large bowl with the rocket. Add the roasted veg and toss with the dressing."
    },
    {
      "heading": null,
      "description": "Plate up the salad, top with the sliced chicken, scatter with pomegranate seeds and crumble over the goats’ cheese."
    }
  ],
