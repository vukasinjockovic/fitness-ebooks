  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Tear the flatbreads into bite-sized chunks and spread them out on a baking tray lined with baking paper. Drizzle with olive oil, season with salt and toss to coat. Roast for 7–10 mins until golden and crispy."
    },
    {
      "heading": null,
      "description": "Chop the watermelon and tomatoes into 3cm chunks. Tip the tomatoes into a large bowl, season with salt and stir through the pomegranate molasses. Set aside to macerate."
    },
    {
      "heading": null,
      "description": "Thinly slice the radishes (a mandolin works well here) and pick the mint leaves, discarding the stems."
    },
    {
      "heading": null,
      "description": "To make the dressing, finely crumble the feta into a large bowl. Squeeze in the juice of the lemon, add the za’atar, and slowly whisk in the olive oil until the dressing emulsifies. Pour in any of the tomato juices as well. Taste and season with salt, pepper, and a pinch of sugar, if needed."
    },
    {
      "heading": null,
      "description": "Toss the watermelon, tomatoes, radishes, grains, and mint through the dressing until everything’s well coated."
    },
    {
      "heading": null,
      "description": "Crumble over the remaining feta, scatter with the crispy flatbread croutons, and serve."
    }
  ],
  "tips": [
    "Swap the mint for parsley or coriander, if you prefer.",
    "If your watermelon is extra juicy, drain some of the liquid before tossing.",
    "Add crispy chickpeas for extra crunch."
  ],
