  "method": [
    {
      "heading": null,
      "description": "Remove the beef from the fridge 30 mins before you plan to start cooking."
    },
    {
      "heading": null,
      "description": "Line the air fryer basket with foil and set the heat to 205°C for 5 mins to heat up. Pour the oil over the beef and spread so it’s even, then season with plenty of salt and pepper."
    },
    {
      "heading": null,
      "description": "Put the beef onto the foil, fat-side up, and air fry for 10 mins until the fat is starting to crisp."
    },
    {
      "heading": null,
      "description": "Turn the heat down to 170°C and cook for 20 mins."
    },
    {
      "heading": null,
      "description": "Combine the treacle and mustard in a small bowl, then paint it all over the joint of beef."
    },
    {
      "heading": null,
      "description": "Return the beef to the air fryer for a final 15 mins, or until the internal temperature reaches 55°C on a digital thermometer."
    },
    {
      "heading": null,
      "description": "Transfer the beef to a plate, spreading over any glaze left from the foil. Loosely cover with foil and rest for 15 mins before carving into slices."
    }
