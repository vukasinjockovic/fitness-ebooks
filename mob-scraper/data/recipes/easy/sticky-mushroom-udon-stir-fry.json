  "method": [
    {
      "heading": null,
      "description": "Slice up your Portobello mushrooms. Matchstick your carrots. Finely chop your onion. Shred 1/3 of a white cabbage. Finely slice 3 spring onions."
    },
    {
      "heading": null,
      "description": "Add your sesame oil and vegetable oil to a pan."
    },
    {
      "heading": null,
      "description": "Add your carrots, cabbage and onion. Allow to soften for 3 minutes. Throw in your Portobello mushrooms."
    },
    {
      "heading": null,
      "description": "Cook for 1 more minute and add your shiitake mushrooms. Mix everything in and cook for another 2 minutes."
    },
    {
      "heading": null,
      "description": "Add your spring onions. Cook for another 2 minutes and add the udon noodles. Season with pepper, add your soy sauce and mirin."
    },
    {
      "heading": null,
      "description": "Mix everything together, cook for another minute and then your noodles are ready. Remove from the heat and serve whilst hot. Garnish with sliced spring onion and enjoy!"
    }
  ],
