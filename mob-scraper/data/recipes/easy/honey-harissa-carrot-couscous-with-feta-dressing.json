  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 190°C fan. Halve the carrots lengthways and cut into 4cm pieces."
    },
    {
      "heading": null,
      "description": "In a small bowl, mix the honey and harissa."
    },
    {
      "heading": null,
      "description": "Toss the carrots with a splash of olive oil, cinnamon, salt, and black pepper. Spread onto a baking tray and roast for 20-25 mins."
    },
    {
      "heading": null,
      "description": "Pat dry the chickpeas and add them to the baking tray. Roast for another 15 mins until crispy. Once cooked, toss with the harissa-honey mixture."
    },
    {
      "heading": null,
      "description": "Meanwhile, place the couscous in a bowl, season with salt, and cover with boiling water. Place a plate on top to trap the steam and let sit for 5 mins. Fluff with a fork"
    },
    {
      "heading": null,
      "description": "Mix the couscous with chopped parsley and chopped olives Season to taste."
    },
    {
      "heading": null,
      "description": "In a blender, blitz the feta, Greek yoghurt, and lemon juice until smooth. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "To serve, divide the couscous into serving boxes, top with the roasted carrots, roasted chickpeas, and drizzle with the feta dressing. Refrigerate until needed. No need to reheat before serving."
    }
  ],
  "tips": [
    "Storage: Keep in airtight containers in the fridge for up to 3 days. Serve cold.",
    "Substitutions: Swap feta for goat’s cheese or tahini for a dairy-free option. Use quinoa instead of couscous for added protein.",
    "Serving Ideas: Enjoy on its own or pair with grilled chicken or roasted vegetables."
