  "method": [
    {
      "heading": null,
      "description": "In a bowl, add roughly 1 tbsp of pepper, a big pinch of salt and the sugar. Give it a mix and set aside."
    },
    {
      "heading": null,
      "description": "Slice your tofu into 1 inch cubes. Add the cornflour to a bowl and dip the tofu in one by one. Fry time! Pour roughly 1 inch of vegetable oil into a large frying pan on a medium-high heat."
    },
    {
      "heading": null,
      "description": "When the oil is hot, add the tofu and fry until crispy on all sides before removing from the heat and set aside for later."
    },
    {
      "heading": null,
      "description": "Finely chop your spring onions, garlic and chillies. In a new pan, add a glug of vegetable oil and fry the spring onions, garlic and chilli on a medium heat until soft and fragrant."
    },
    {
      "heading": null,
      "description": "Add the tofu and stir to combine with the spring onion mixture. Sprinkle the pepper, salt and sugar over the tofu and stir through until fully coated. Serve and munch!"
    }
