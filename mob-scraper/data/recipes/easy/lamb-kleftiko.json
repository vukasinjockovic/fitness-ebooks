  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 180°C."
    },
    {
      "heading": null,
      "description": "Drizzle the lamb shoulder in a little olive oil and season with salt and pepper. Add to a tray and slide into the oven for 30 mins until starting to colour."
    },
    {
      "heading": null,
      "description": "Meanwhile, dice the vine tomatoes into 1 cm-sized pieces."
    },
    {
      "heading": null,
      "description": "Remove the lamb tray from the oven and add the dried bay leaves, dried oregano and diced tomatoes. Add water to cover the bottom of the tray. Cover with foil, return to the oven and cook for 2 hours further."
