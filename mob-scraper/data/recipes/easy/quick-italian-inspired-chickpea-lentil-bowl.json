  "method": [
    {
      "heading": null,
      "description": "Dice the carrot, onion, celery and garlic. Chop the sun-dried tomatoes. Pit the olives. Chop the fresh basil."
    },
    {
      "heading": null,
      "description": "Heat a good glug of oil on a non-stick pan over a medium heat. Once hot add the carrot, the celery and the onion and the garlic. Let the veggies cook for 5 mins."
    },
    {
      "heading": null,
      "description": "Add the sun-dried tomatoes, black olives and the chilli and leave to cook for another 5 mins, stirring now and then."
    },
    {
      "heading": null,
      "description": "Add the pulses and the chopped tomatoes. Add the pinch of bicarbonate of soda. (You’ll see it react with the chopped tomatoes, removing their acidity and bringing out their sweetness) and cook, stirring occasionally, for about 10 mins (cook for longer if you want a thicker consistency, or at a little water if it’s a bit dry)."
    },
    {
      "heading": null,
      "description": "Remove the pan from the heat and stir through the nutritional yeast."
    },
    {
      "heading": null,
      "description": "To serve, divide between bowls and top with pesto, soy yoghurt and scatter over the fresh basil."
    }
  ],
