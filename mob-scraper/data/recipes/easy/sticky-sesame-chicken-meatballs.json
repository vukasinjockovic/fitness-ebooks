  "method": [
    {
      "heading": null,
      "description": "Crush all the garlic and thinly slice all the spring onions. Combine all the ingredients for the meatballs in a large bowl, then shape into 12 equal-sized balls using wet hands."
    },
    {
      "heading": null,
      "description": "Heat the air fryer or oven to 180°C. Cook the meatballs for 16 mins (air fryer) or 20 mins (oven) until cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, whisk all of the ingredients for the sauce together with 2 tbsp water in a saucepan. Bring to a simmer and cook for around 4 mins until sticky."
    },
    {
      "heading": null,
      "description": "Toss the cooked meatballs into the sauce and stir to coat."
    },
    {
      "heading": null,
      "description": "Serve over rice with broccoli."
    }
  ],
