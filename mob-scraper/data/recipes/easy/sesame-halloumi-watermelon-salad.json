  "method": [
    {
      "heading": null,
      "description": "Halve, then quarter the watermelon and cut away the green rind. Slice into random triangular pieces. Pile the watermelon high on a big salad platter, or divide between four plates."
    },
    {
      "heading": null,
      "description": "Pick the mint leaves and zest the lemon. Squeeze the lemon juice into a bowl, then stir in the honey, sesame seeds, chilli flakes if using, a good pinch of salt and black pepper and 3 tbsp water to make the halloumi dressing."
    },
    {
      "heading": null,
      "description": "Drain and cut the halloumi into thick slices. Get your largest frying pan over a medium-high heat. Add the halloumi and fry for around 2 mins on each side until crisp and golden."
    },
    {
      "heading": null,
      "description": "Turn down the heat to the lowest setting, pour in the sesame honey dressing and cook for 1 min more, using a spoon to baste the halloumi in the dressing."
    },
    {
      "heading": null,
      "description": "Top the watermelon with the halloumi and dressing, then scatter over the mint leaves and lemon zest to serve. Unreal."
    }
