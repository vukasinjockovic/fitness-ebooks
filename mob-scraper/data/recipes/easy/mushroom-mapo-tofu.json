  "method": [
    {
      "heading": null,
      "description": "Peel and finely chop the ginger and garlic. Finely slice the chilli. Mince the Shiitake mushrooms as finely as possible (or use a mini chopper). Mix the cornflour with water and set aside. Finely chop the spring onions. Drain and slice the tofu into 3cm pieces. Drain and rinse the beans."
    },
    {
      "heading": null,
      "description": "Heat a glug of vegetable oil (or another neutral oil) in a wok or a frying pan over a medium heat. Add the Chinese five spice and cook for 30 seconds. Add in the garlic, ginger and chilli and cook for another 30 seconds. Add in the mushrooms, season with salt and cook for a couple of mins until golden."
    },
    {
      "heading": null,
      "description": "Add the bean paste and the black beans, along with the water, and mix well. Make the cornflour slurry by mixing together the cornflour and water in a small bowl then add to the pan. Season with salt, to taste, then simmer for about 5 mins until the sauce is starting to thicken then gently stir through the tofu. Simmer for another 5 mins or until the tofu is hot and the sauce has thickened. Taste and season with salt, if needed."
    },
    {
      "heading": null,
      "description": "Season with, salt, sesame oil, sugar and Chinese black vinegar to taste."
    },
    {
      "heading": null,
      "description": "Divide between plates and top with the sliced spring onions. Serve with crispy chilli oil and cooked rice, if you like."
    }
  ],
