  "method": [
    {
      "heading": null,
      "description": "Finely chop the onions. Heat the vegetable oil in a large saucepan set over a medium-high heat. Add the onions with a big pinch of salt and cook for 10 mins, stirring every so often, until softened and starting to caramelise."
    },
    {
      "heading": null,
      "description": "Meanwhile, peel the ginger and garlic, then grate them using a fine grater."
    },
    {
      "heading": null,
      "description": "Once the onions are caramelised, scrape in the grated garlic and ginger. Cook for 1 min until fragrant, then stir in the spice paste and cook for another minute."
    },
    {
      "heading": null,
      "description": "Pour in the chopped tomatoes, coconut milk and water. Bring to the boil, then turn the heat down and let it simmer gently for 15 to 20 mins, stirring occasionally, until thick and luscious. Season with salt and black pepper. If you prefer a smoother sauce, blitz it with a stick blender at this stage."
    },
    {
      "heading": null,
      "description": "Meanwhile, cut or tear your leftover protein or veg into bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Add the leftovers to the sauce and simmer for 5 mins until heated through. If it’s looking too thick, loosen it with a splash of water."
    },
    {
      "heading": null,
      "description": "Squeeze over a little lemon juice, if using, then scatter with some chopped coriander, if using. Serve with warm basmati rice and naan."
    }
  ],
