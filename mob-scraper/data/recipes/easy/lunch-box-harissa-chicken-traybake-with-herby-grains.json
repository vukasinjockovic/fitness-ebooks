  "method": [
    {
      "heading": null,
      "description": "Heat the oven grill to high."
    },
    {
      "heading": null,
      "description": "Cut the chicken thighs into quarters. Peel and finely slice the onions. Grate the garlic."
    },
    {
      "heading": null,
      "description": "Add the chicken, onions, harissa and grated garlic to a large bowl. Drizzle in some olive oil, season with salt and black pepper, and toss to coat."
    },
    {
      "heading": null,
      "description": "Tip everything onto a baking tray and spread into an even layer. Slide under the grill on the top shelf and cook for 15–20 mins, turning halfway, until the chicken is cooked through and the edges are starting to catch."
    },
    {
      "heading": null,
      "description": "While that grills, dice the courgette. Finely chop the dill and parsley."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of olive oil in a frying pan over a medium heat. Chuck in the courgette and fry for 6–8 mins until golden and soft, seasoning as you go."
    },
    {
      "heading": null,
      "description": "Tip in the grains and stir through until hot. Take off the heat, then stir through the herbs and squeeze in the juice of half a lemon. Taste and tweak the seasoning if it needs it."
    },
    {
      "heading": null,
      "description": "Serve the grilled chicken and onions over the herby grains with a big spoonful of Skyr yoghurt on the side."
    }
  ],
