  "method": [
    {
      "heading": null,
      "description": "Bring a small saucepan of water to the boil and gently lower in the eggs. Boil for 8 mins, then transfer to a bowl of cold water to cool. Once cool enough to handle, peel and halve."
    },
    {
      "heading": null,
      "description": "Halve the cucumber lengthways, then smack it with a rolling pin to break it up. Roughly chop into bite-sized chunks and pop into a colander over a bowl. Sprinkle with a little salt and leave to drain for 10 mins. Pat dry with kitchen paper."
    },
    {
      "heading": null,
      "description": "Grate the garlic into a small bowl. Add the soy sauce, rice vinegar, chilli oil (if using), sesame oil and white pepper. Whisk to combine and set aside."
    },
    {
      "heading": null,
      "description": "Carefully remove the silken tofu from the pack, gently pat dry with kitchen paper and pop into bowls or on plates. Slice the tofu from top to bottom, not going all the way through."
    },
    {
      "heading": null,
      "description": "Finely slice the spring onions and pick the coriander."
    },
    {
      "heading": null,
      "description": "Toss the cucumber with the soy dressing, then spoon over and around the tofu. Top with the crispy onions, sesame seeds, coriander, spring onions and halved eggs."
    }
  ],
