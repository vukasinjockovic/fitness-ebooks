  "method": [
    {
      "heading": null,
      "description": "Start by finely mincing the garlic. Slice the ginger lengthways as thin as possible, then lay it flat and slice into thin strips. Slice the spring onions as thin as possible and transfer to a bowl of ice-cold water."
    },
    {
      "heading": null,
      "description": "Slice the steak as thin as possible and transfer to a bowl. Add the minced garlic, sugar, light soy sauce, sesame seeds and sesame oil to the same bowl with one-third of the mirin. Set aside."
    },
    {
      "heading": null,
      "description": "Heat a frying pan over a high heat for 1 min. Add a splash of oil and the beef. Once in the pan, spread it out evenly and leave to caramelise for around 1 min. Flip over and cook for another minute, then set aside."
    },
    {
      "heading": null,
      "description": "Heat a saucepan over a high heat and add the ginger, sake, the remainder of the mirin, soy sauce, dashi powder (or stock) and water. Bring to the boil. Once boiling, add the udon and stir for around 3 mins until the noodles have separated."
    },
    {
      "heading": null,
      "description": "Divide the udon and soup between two bowls. Add the cooked beef on top. Drain the spring onions and place them on top of the beef, in a mound. Make a small well with your finger in the spring onion and place the egg yolk into the well. Enjoy!"
    }
  ],
