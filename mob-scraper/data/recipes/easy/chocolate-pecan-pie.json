  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 190°C fan."
    },
    {
      "heading": null,
      "description": "Add the pecan pieces to a baking tray (if you’re using whole pecans, roughly chop them first). Once the oven is preheated, toast the nuts for 5-7 mins then set aside to cool."
    },
    {
      "heading": null,
      "description": "Break the chocolate into 2-3cm pieces. Melt the chocolate in a heatproof bowl set over a pan of gently boiling water. Stir until melted then remove the bowl from the heat and leave for a minute or two to cool slightly."
    },
    {
      "heading": null,
      "description": "In a separate bowl, whisk together the butter, sugar, maple syrup, salt, ground cinnamon and ground ginger. Pour in the melted chocolate and mix to combine."
    },
    {
      "heading": null,
      "description": "Use a whisk or spoon to beat together the mixture. Add the soured cream, whole eggs and egg yolk then beat to combine. Stir through the toasted pecan pieces."
    },
    {
      "heading": null,
      "description": "Pour the mixture into the pre-cooked 20cm pastry case. Bake for 10 mins then turn the heat down to 140°C fan and bake for another 25-30 mins until golden brown. The filling should wobble a little in the centre when shaken."
    },
    {
      "heading": null,
      "description": "Remove from the oven and allow to cool fully before serving."
    }
  ],
