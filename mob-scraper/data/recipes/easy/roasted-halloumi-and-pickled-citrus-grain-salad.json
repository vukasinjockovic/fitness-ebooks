  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C fan."
    },
    {
      "heading": null,
      "description": "Time to get prepared. Tear the halloumi into bite-sized shards. Dice the cucumber into 2cm-sized pieces. Thinly slice the shallots, segment your oranges and squeeze the juices remaining from the orange remnants into a bowl. Pick the leaves from the parsley and mint."
    },
    {
      "heading": null,
      "description": "Line a baking tray with parchment paper. Place the cherry tomatoes on the tray and top with the torn halloumi. Roast for 10-15 minutes until the halloumi is golden and the tomatoes are tender."
    },
    {
      "heading": null,
      "description": "Meanwhile, in a bowl, toss the shallots and orange segments with the reserved orange juice and lime juice. Let sit to pickle."
    },
    {
      "heading": null,
      "description": "Add the parsley stems to a blender. Set the parsley and mint leaves aside."
    },
    {
      "heading": null,
      "description": "For the dressing, add the mint, coriander, lime zest, lime juice, kefir, olive oil, and honey to the blender. Blend until smooth. Season to taste with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Reheat the grains and divide them into serving boxes."
    },
    {
      "heading": null,
      "description": "Toss the pickled orange and shallots with the cucumber, roasted halloumi and tomatoes, then spoon over the grains."
    },
    {
      "heading": null,
      "description": "Once cooled, scatter over the parsley and mint leaves. Drizzle with the kefir dressing and refrigerate until needed. No need to reheat before serving."
    }
  ],
  "tips": [
    "Storage: Keep refrigerated in airtight containers for up to 3 days. Serve cold.",
    "Substitutions: Swap halloumi for feta or grilled tofu for a vegetarian alternative. Use bulgur, quinoa, or farro for different grain textures.",
    "Serving Ideas: Pair with grilled chicken or fish for added protein, or serve as a standalone salad."
  ],
