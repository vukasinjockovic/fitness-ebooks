  "method": [
    {
      "heading": null,
      "description": "Pile coals over to one side of your BBQ to create a hot, direct cooking side, and a warm, indirect cooking side."
    },
    {
      "heading": null,
      "description": "Start off by making the rub. Toast the fennel, black pepper and cumin seeds in a dry pan over the hot side of your BBQ. Once fragrant, tip into a pestle and mortar and coarsely grind. Add the oregano, paprika and garlic powder. Mix together."
    },
    {
      "heading": null,
      "description": "Season the chicken well with salt and toss with the mustard. Lay out on a tray and season generously with the spice rub. Grill over the hot side of the BBQ for 9-10 mins, turning regularly until charred and crispy. It won’t be cooked through just yet, so move it to the indirect side of the BBQ and add the lid. Allow to cook gently for 35-40 mins with the lid on."
    },
    {
      "heading": null,
      "description": "Once the chicken has had 35 mins or so, remove the lid and check the texture. It should be pulling away from the bone, super smoky and tender. Mix the ingredients for the glaze in a small bowl and brush over the chicken pieces. Return the lid and allow the glaze to bake onto the chicken for a few minutes."
    },
    {
      "heading": null,
      "description": "Serve with coleslaw, fresh corn, rice and lemon wedges."
    }
  ],
