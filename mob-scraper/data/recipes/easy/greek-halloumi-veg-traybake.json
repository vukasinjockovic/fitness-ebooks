  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 210°C fan. Tip the frozen vegetables into a large roasting tray. Drain and stir through the chickpeas."
    },
    {
      "heading": null,
      "description": "Slice the halloumi into 1cm thick then lay on top of the veg.  Season the whole thing with salt and black pepper, then drizzle with the olive oil."
    },
    {
      "heading": null,
      "description": "Return the tray to the oven and bake for 25 mins until the halloumi is golden and the veg is cooked through."
    },
    {
      "heading": null,
      "description": "Pick the dill. Finely zest over the lemon and cut the lemon into wedges to serve."
    },
    {
      "heading": null,
      "description": "Warm the pittas, then stuff them with a spoonful of tzatziki, a generous helping of the roasted veggie mix and a squeeze of lemon juice."
    }
