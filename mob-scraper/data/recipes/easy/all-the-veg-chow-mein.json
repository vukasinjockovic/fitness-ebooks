  "method": [
    {
      "heading": null,
      "description": "Cook the noodles following pack instructions. Drain well and rinse under cold running water to stop them sticking."
    },
    {
      "heading": null,
      "description": "Finely chop the onion, carrot, courgette and red pepper."
    },
    {
      "heading": null,
      "description": "Heat the sesame oil and a splash of sunflower oil in a large frying pan or wok set over a medium-high heat. Add all the chopped veg and stir-fry for 6-7 mins until soft and starting to caramelise."
    },
    {
      "heading": null,
      "description": "Peel and finely chop the ginger and garlic, then add to the pan. Fry for 1 min until fragrant."
    },
    {
      "heading": null,
      "description": "Add the beansprouts, cooked noodles and soy sauce to the pan. Toss everything together for a couple of mins until the noodles are glossy and evenly coated."
    },
    {
      "heading": null,
      "description": "Serve up! Kids Plate: Dish out the noodles as is.Adults Plate: Top with coriander, a drizzle of crispy chilli oil and a fried egg if you fancy. Add an extra splash of soy sauce to taste."
    }
