  "method": [
    {
      "heading": null,
      "description": "Finely dice the onion and celery, then peel and finely dice the carrots. Tear the cooked chicken into bite-sized pieces."
    },
    {
      "heading": null,
      "description": "Heat a splash of olive oil in a large saucepan over a medium heat then add the finely diced vegetables. Add a big pinch of salt and cook gently for 10-15 mins until really soft but not coloured."
    },
    {
      "heading": null,
      "description": "Pour in 2L of chicken broth and bring to a simmer. Break the angel hair pasta into pieces and cook following packet instructions."
    },
    {
      "heading": null,
      "description": "Scatter in the shredded chicken and leave to reheat for 1 min, then taste and season the broth with salt and cracked black pepper."
    },
    {
      "heading": null,
      "description": "Roughly chop the parsley and pick the dill leaves. Spoon the soup into bowls and top with a scattering of the parsley and dill. Serve with garlic bread, if you like."
    }
