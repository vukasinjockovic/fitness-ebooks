  "method": [
    {
      "heading": null,
      "description": "Peel and finely chop the red onion. Slice the broccoli stems and cut any larger florets in half."
    },
    {
      "heading": null,
      "description": "Heat a small deep nonstick frying pan over a medium heat. Add the onion with a splash of water and cook for 8–10 mins until soft, adding a little more water if it starts to catch."
    },
    {
      "heading": null,
      "description": "Add the broccoli stems and florets, lentils and chickpeas along with a splash of their liquid and gently simmer for 2–3 mins until warmed through."
    },
    {
      "heading": null,
      "description": "Cut the beetroot into 1cm chunks. Flake the mackerel. Pick the dill leaves. Cut the lemon into wedges."
    },
    {
      "heading": null,
      "description": "Spoon the lentils and chickpeas onto plates. Top with the beetroot, mackerel and broccoli. Finish with a dollop of yoghurt, a scattering of dill and a squeeze of lemon."
    }
  ],
