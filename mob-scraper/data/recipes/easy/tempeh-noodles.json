  "method": [
    {
      "heading": null,
      "description": "Crumble the tempeh into small pieces. Roughly chop the mushrooms. Finely slice the spring onions and set aside some of the green tips to serve."
    },
    {
      "heading": null,
      "description": "Put the tempeh, spring onions and mushrooms into a large frying pan over a medium-high heat with a good splash of sunflower oil and a pinch of salt. Stir-fry for about 10 mins until starting to crisp up."
    },
    {
      "heading": null,
      "description": "Meanwhile, make the marinade. Grate the ginger, mince the garlic, and add to a small bowl with the juice of the lime and the remaining ingredients. Whisk well."
    },
    {
      "heading": null,
      "description": "In a separate pan, cook the spinach with a pinch of salt over a medium heat until wilted."
    },
    {
      "heading": null,
      "description": "Add the marinade to the tempeh. Fry for 5-10 mins until the tempeh and mushrooms are browned on the edges and starting to crisp up."
    },
    {
      "heading": null,
      "description": "Cook the noodles following pack instructions, then drain."
    },
    {
      "heading": null,
      "description": "For the noodle sauce, first juice the lime into a bowl. Add all the remaining ingredients and whisk well. Toss the cooked noodles through it."
    },
    {
      "heading": null,
      "description": "Serve the saucy noodles in bowls topped with the tempeh, reserved spring onion greens, sesame seeds, some extra chilli oil and the wilted spinach."
    }
  ],
