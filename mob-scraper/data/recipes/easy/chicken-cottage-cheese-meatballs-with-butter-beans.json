  "method": [
    {
      "heading": null,
      "description": "Heat the grill to high. Peel and finely grate the garlic. Pick the parsley leaves and finely chop them."
    },
    {
      "heading": null,
      "description": "Chuck half the garlic and one-third of the chopped parsley into a mixing bowl with the chicken mince and cottage cheese. Grate over the zest of half the lemon and finely grate in half the Parmesan. Season well with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Shape into golfball-sized meatballs with wet hands and place them onto a foil-lined baking tray."
    },
    {
      "heading": null,
      "description": "Grill the meatballs for about 15 mins, until golden and cooked through."
    },
    {
      "heading": null,
      "description": "Meanwhile, dump the butter beans (liquid and all) into a small frying pan and bring to a simmer. Fold through the spinach to wilt. Tip any juices from the chicken into the beans and season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Grate over the remaining lemon zest and squeeze in the juice from a quarter of the lemon. Cut the rest into wedges for serving."
    },
    {
      "heading": null,
      "description": "Spoon the beans into bowls and top with the meatballs. Sprinkle over the remaining chopped parsley, garlic and chilli flakes then grate over the remaining Parmesan"
    }
  ],
