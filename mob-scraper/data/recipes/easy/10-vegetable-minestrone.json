  "method": [
    {
      "heading": null,
      "description": "Finely chop the onions, garlic, carrot, celery and rosemary leaves. Cut the leek into rounds. Preheat a saucepan over a medium heat and add a glug of olive oil. Tip in the veggies and sauté with a pinch of salt for 5-6 mins. Tip in the tomatoes, Parmesan rind and stock. Bring to a simmer and let blip away for 10-15 mins."
    },
    {
      "heading": null,
      "description": "Now add the pasta and cook for another 8 mins or so. Finish with the peas and green beans for the last 2-3 mins. Season with salt and black pepper."
    },
    {
      "heading": null,
      "description": "Serve with grated Parm and fresh basil leaves."
    }
  ],
