  "method": [
    {
      "heading": null,
      "description": "Take the steak out of the fridge and let it come up to room temp."
    },
    {
      "heading": null,
      "description": "Dice ½ of the peppers and all of the red onion. Add to a bowl with oil, smoked paprika, salt and pepper. Mix well and air fry at 180°C for 5-10 mins. In the meantime, peel and halve the garlic and remove the stem and seeds from the chillies. Add into the tray with the peppers, mix and then air fry for another 10 mins. Remove from the air fryer and blend smooth with ½ the lemon juice and water. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Slice the rest of the red pepper and set aside in a separate bowl."
    },
    {
      "heading": null,
      "description": "Finely chop the rosemary and halve the potatoes. Add to a bowl with the sliced peppers along with the oil, salt and pepper. Cook at 200°C for 15 mins, mixing halfway."
    },
    {
      "heading": null,
      "description": "Pat the steak dry, then rub it with the rest of the oil, salt and pepper. Pop on top of the potatoes and cook for 8-10 more mins, depending on the thickness of the steak."
    },
    {
      "heading": null,
      "description": "Now you can get on with the slaw. Finely chop the parsley. Finely slice the cabbage and remaining red onion, mix in a bowl with the rest of the lemon juice, mustard, parsley and mayo. Season with salt and pepper."
    },
    {
      "heading": null,
      "description": "Once the steak is cooked, remove from the air fryer and let it rest for at least 5 mins before slicing. Get the potatoes and slaw into bowls, then top with the steak and piri piri dressing."
    }
  ],
