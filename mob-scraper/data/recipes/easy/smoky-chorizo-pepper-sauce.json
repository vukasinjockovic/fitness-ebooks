  "method": [
    {
      "heading": null,
      "description": "Finely chop the red onions and thinly slice the garlic. Dice the chorizo. Slice the roasted peppers into strips, about 1–2cm wide. Finely chop the parsley."
    },
    {
      "heading": null,
      "description": "Heat a large saucepan over a medium-high heat with a good glug of olive oil. Add the chorizo and cook for 3–4 mins until starting to crisp and release its oil. Add the onions with a pinch of salt and cook for 4–5 mins until softened. Drop in the sliced garlic and cook for 1 more min."
    },
    {
      "heading": null,
      "description": "Tip in the chopped tomatoes and the sliced peppers. Season with salt and a little black pepper. Simmer for 15–20 mins until thickened."
    },
    {
      "heading": null,
      "description": "Stir through the parsley and taste, adjust the seasoning to your liking."
    },
    {
      "heading": null,
      "description": "Ladle the sauce into a clean, heatproof jar and seal tightly. Let it cool completely. If sealed properly, it’ll keep in a cupboard for up to 1 month. If not, pop it in the fridge and use within 2 weeks. Or whack it in the freezer, it'll last for up to 3 months!"
    }
  ],
