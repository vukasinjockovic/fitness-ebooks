  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Set a shallow oven-proof pan over a medium-high heat with the olive oil. Squeeze the sausage meat out of the skins and break into small pieces over the pan. Cook for 5 mins, stirring  until browned."
    },
    {
      "heading": null,
      "description": "Pick the thyme leaves and add to the pan. Peel and finely chop the garlic.  Take the pan off the heat and stir in the garlic. Pour in the tomato pasta sauce then tip in the ravioli and toss everything together until well coated."
    },
    {
      "heading": null,
      "description": "Nestle in the frozen spinach cubes, no need to defrost!"
    },
    {
      "heading": null,
      "description": "Scatter over the grated mozzarella and cheddar, then bake in the oven for 20 mins until golden and bubbling."
    }
