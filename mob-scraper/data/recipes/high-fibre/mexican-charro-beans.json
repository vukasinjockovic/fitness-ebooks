  "method": [
    {
      "heading": null,
      "description": "Finely dice the tomatoes, white onion, green pepper, bacon, chorizo, fresh coriander and pickled jalapeño. Don't combine these ingredients yet as you'll use them at different times."
    },
    {
      "heading": null,
      "description": "Heat the vegetable oil in a large cast iron pot set over a medium heat. Add the onion and tomato and fry for 2 mins, stirring from time to time. Add the green pepper and continue to fry until the onion is translucent and the tomatoes are mushy."
    },
    {
      "heading": null,
      "description": "Add the bacon and fry for about 3-5 mins until slightly crispy at the edges, stirring constantly to fry it evenly. Add the chorizo and fry everything for another 3 mins until the chorizo releases its fat and starts to turn crisp."
    },
    {
      "heading": null,
      "description": "Finally, add the pinto beans and their juices along with a splash of water, the pickled jalapeño, jalapeño vinegar, fresh coriander and sea salt. Bring to a boil, lower the heat and simmer for 10 mins."
    },
    {
      "heading": null,
      "description": "While the beans simmer, dice the avocado."
    },
    {
      "heading": null,
      "description": "Divide the beans between bowls and garnish with the avocado. Roll a tortilla and enjoy the frijoles charros like a proper Mexican: biting the tortilla and eating a spoonful of beans."
    }
  ],
