  "method": [
    {
      "heading": null,
      "description": "Dice your garlic, ginger, onion and scotch bonnet."
    },
    {
      "heading": null,
      "description": "Fry your diced veg in a large pan with a tbsp of vegetable oil until soft and slightly browned."
    },
    {
      "heading": null,
      "description": "Add your dried spices and stock powder then fry for a few mins. Add a splash of water to deglaze the pan and simmer for another minute."
    },
    {
      "heading": null,
      "description": "Wash your green lentils and set aside."
    },
    {
      "heading": null,
      "description": "Add the fresh thyme, chopped tomatoes, a cup of water, brown sugar and washed lentils to the pan and the simmer on a medium heat for 15 mins. You want the lentils to absorb the liquid and become proper saucy."
    },
    {
      "heading": null,
      "description": "Gradually add the water to the flour and combine into a firm dough, cover and rest for 30 mins."
    },
    {
      "heading": null,
      "description": "Break into 6 equal-sized pieces and roll out thin over a floured surface before dry frying for a minute or 2 on each side."
    },
    {
      "heading": null,
      "description": "Serve up the lentils with freshly cooked roti and enjoy."
    }
