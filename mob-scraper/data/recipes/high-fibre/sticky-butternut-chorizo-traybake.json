  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 210°C."
    },
    {
      "heading": null,
      "description": "Halve your squash, then scoop out the seeds and cut them into large chunks."
    },
    {
      "heading": null,
      "description": "Arrange them on a baking tray and drizzle with olive oil, paprika and salt. Place in the oven to roast for 25 mins."
    },
    {
      "heading": null,
      "description": "Cut your chorizo into discs. Cube your sourdough. Rinse your chickpeas in a colander, then pat them dry."
    },
    {
      "heading": null,
      "description": "Tip your chorizo and chickpeas into your roasting tray, then return to the oven for 15 mins."
    },
    {
      "heading": null,
      "description": "On to your salsa. Finely chop your guindilla chillies and parsley. Add these both to a bowl and zest in your lemon. Add your lemon juice and 4 tbsp of olive oil. Mix to combine, then season to taste with salt."
    },
    {
      "heading": null,
      "description": "Drizzle everything in the tray with honey. Nestle your sourdough bread cubes into the tray, then bake for another 12 mins."
    },
    {
      "heading": null,
      "description": "Spoon your salsa over the top, then plate up and serve!"
    }
