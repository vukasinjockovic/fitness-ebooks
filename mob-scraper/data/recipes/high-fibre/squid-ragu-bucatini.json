  "method": [
    {
      "heading": null,
      "description": "Finely dice the fennel and shallot. Thinly slice the garlic cloves and red chilli."
    },
    {
      "heading": null,
      "description": "Add the fennel seeds to a small pan and dry toast over a medium heat until fragrant. Tip into a pestle and mortar and coarsely grind."
    },
    {
      "heading": null,
      "description": "Grab a large sauté pan and set over a medium heat. Add 4 tbsp of olive oil and tip in the fennel and shallot. Cook in the olive oil with a pinch of salt for 10-12 mins or until soft and translucent. Add the garlic, chilli and fennel seeds and cook for another 3-4 mins."
    },
    {
      "heading": null,
      "description": "Tip in the chopped tomatoes and bring to a boil. Cook for 10-12 mins until reduced by half. Add the whole tins of squid and cook over a low heat while you sort the pasta."
    },
    {
      "heading": null,
      "description": "Cook the bucatini for 7-8 mins in boiling salted water. Transfer the cooked pasta to the squid sauce and tear in the black olives. Halve the lemon and finely chop the parsley. Add the parsley and lemon juice to the pasta and toss together, adding a little pasta water if necessary."
    },
    {
      "heading": null,
      "description": "Divide between bowls and top with crunchy breadcrumbs and a squeeze of lemon."
    }
  ],
