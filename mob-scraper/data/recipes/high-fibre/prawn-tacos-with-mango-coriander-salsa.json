  "method": [
    {
      "heading": null,
      "description": "Preheat the Ninja grill to medium-high."
    },
    {
      "heading": null,
      "description": "Peel and grate the garlic. Place the prawns in a bowl with a drizzle of oil, the ancho chilli, tomato purée and garlic. Season with salt and pepper, stir together and set aside."
    },
    {
      "heading": "For The Pickled Onions",
      "description": "Peel and thinly slice the red onion, add into a bowl with a large pinch of salt and the juice from your limes. Mix together and set aside to pickle."
    },
    {
      "heading": "For The Coriander Salsa",
      "description": "Zest a lime into a bowl. Add the coriander into a food processor with the olive oil. Blitz until the coriander has broken down. Transfer into the bowl, add the zest from 1/3 of your limes into the coriander mixture, season with salt and juice from all the remaining limes."
    },
    {
      "heading": null,
      "description": "Remove the mango cheeks, scoop out the flesh and cut into a rough dice. Stir through the coriander mixture."
    },
    {
      "heading": null,
      "description": "Cook the prawns on the grill until opaque and cooked through, 5-7 mins. Reheat the corn tortillas on the Ninja grill until pliable. Scoop the avocado flesh out of its skin and slice thinly."
    },
    {
      "heading": null,
      "description": "Share the prawns between the tortillas, top with avocado slices, mango and coriander salsa and lime-pickled red onions."
    }
  ],
