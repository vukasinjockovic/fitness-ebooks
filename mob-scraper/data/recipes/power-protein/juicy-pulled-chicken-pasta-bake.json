  "method": [
    {
      "heading": null,
      "description": "Before you begin, make the Juicy Pulled Chipotle Chicken batch recipe."
    },
    {
      "heading": null,
      "description": "Heat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Cook the rigatoni in a large saucepan of salted boiling water until al dente. Drain and reserve a splash of the pasta water."
    },
    {
      "heading": null,
      "description": "Finely chop the shallot and garlic. Grate the mozzarella and cheddar. Finely chop the chives."
    },
    {
      "heading": null,
      "description": "Heat a drizzle of olive oil in a large frying pan set over a medium heat. Add the shallot and a pinch of salt, then fry for 4-5 mins until soft and translucent. Stir in the garlic and cook for 1 min, then add the tomato purée and let it sizzle for a minute."
    },
    {
      "heading": null,
      "description": "Pour in the chopped tomatoes and bring to a simmer. Let it bubble for 5-7 mins until slightly thickened, then season with salt to taste."
    },
    {
      "heading": null,
      "description": "Stir the pulled chicken through the sauce along with a splash of pasta water to loosen. Add the cooked rigatoni and mix well to coat everything in the sauce."
    },
    {
      "heading": null,
      "description": "Tip into a small baking dish and scatter over the cheeses. Bake for 15–20 mins until golden, bubbling and crisp at the edges."
    },
    {
      "heading": null,
      "description": "Top with chopped chives to serve."
    }
  ],
