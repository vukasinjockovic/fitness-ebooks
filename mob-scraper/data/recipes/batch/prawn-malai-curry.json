  "method": [
    {
      "heading": null,
      "description": "In a mixing bowl, toss the prawns, turmeric and 1 tsp of salt. Set aside for 20 mins."
    },
    {
      "heading": null,
      "description": "Meanwhile, finely chop your onions."
    },
    {
      "heading": null,
      "description": "Once the prawns are marinated, heat a glug of oil in a heavy-based shallow pan. Gently fry the prawns and sauté for 2 mins until they change colour slightly, but aren't yet fully cooked through. Immediately take them off the heat and place in a bowl to the side."
    },
    {
      "heading": null,
      "description": "In the same pan, heat another glug of oil and 1 tsp of butter until melted. Add in the bay leaves, cinnamon, cardamom and cloves. Heat for 30 secs until fragrant."
    },
    {
      "heading": null,
      "description": "Add your onions along with 1 tsp of salt and sugar and cook for 10 mins until they're translucent."
    },
    {
      "heading": null,
      "description": "Grate in the ginger and cook for another min."
    },
    {
      "heading": null,
      "description": "Pour in the yoghurt and mix well, allow it to cook for 1 min."
    },
    {
      "heading": null,
      "description": "Stir the coconut milk to remove any lumps from it before pouring it into your onion mixture and cooking for another 3 mins. Once it starts bubbling, lower the heat and add the prawns back in."
    },
    {
      "heading": null,
      "description": "Cook for 4 mins until the prawns are fully cooked through. Finish with the garam masala, coriander leaves and 1 tsp of butter. Turn off the heat, pop on a lid and let it rest for 5 mins."
    },
    {
      "heading": null,
      "description": "Just before serving, gently mix in the garam masala and melted butter and serve with basmati rice."
    }
  ],
