  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180˚C fan. Grease and line two 20cm cake tins."
    },
    {
      "heading": null,
      "description": "Sift the flour into a bowl. Add the sugar, salt and baking powder and whisk together. Use an electric whisk to beat in the butter until it is incorporated and the mixture appears to be evenly coated and looks like a fine crumble mix – 2–3 mins on medium speed."
    },
    {
      "heading": null,
      "description": "Add the eggs and beat, first on medium, then on high, just until incorporated. Add the milk and vanilla and beat, on medium and then on high, for about 2-3 mins until the mixture is smooth and combined; it will appear a bit lighter in colour."
    },
    {
      "heading": null,
      "description": "Divide the mixture between the two prepared cake tins and level out to the edges. Bake in the oven for 25–30 mins, or until a toothpick inserted into the centre comes out clean."
    },
    {
      "heading": null,
      "description": "Remove from the oven and leave to cool in the tins for 10 mins before turning out on to a wire rack to cool completely."
    },
    {
      "heading": null,
      "description": "Spread a generous layer of buttercream on one sponge and a layer of jam on the other, then sandwich the two together. Dust over some icing sugar and enjoy!"
    }
  ],
