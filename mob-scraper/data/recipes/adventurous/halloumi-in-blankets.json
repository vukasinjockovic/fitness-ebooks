  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C/356°F."
    },
    {
      "heading": null,
      "description": "Cut the halloumi into thick sticks - 12 sticks per block. Add them to a large bowl and season with your oregano, dill, a grind of pepper and a drizzle of olive oil. Massage the seasoning in to coat the halloumi."
    },
    {
      "heading": null,
      "description": "Lay one sheet of puff pastry out and evenly spread the harissa paste on top. Slice the puff pastry into 12 even strips. Repeat for your other roll of puff pastry."
    },
    {
      "heading": null,
      "description": "Roll up one stick of halloumi in one strip of puff pastry. Place the pre-cooked halloumi blankets on a baking tray (baking paper is optional here). Repeat for the remaining halloumi pieces."
    },
    {
      "heading": null,
      "description": "Beat two egg yolks together and brush the puff pastry with a coating of egg wash. Season with salt and sprinkle your fennel seeds over the top. Bake for 30 minutes, until golden."
    },
    {
      "heading": null,
      "description": "Meanwhile, make your tzatziki. Pour the yoghurt into a bowl. Halve and deseed your cucumber. Grate the cucumber and squeeze out as much liquid as possible before adding the gratings to the bowl. Finely chop a handful of mint and it to the bowl with the juice of your lemon. Mix well and season with a pinch of salt and pepper."
    },
    {
      "heading": null,
      "description": "Serve the Halloumi in Blankets with your fresh tzatziki and enjoy!"
    }
  ],
