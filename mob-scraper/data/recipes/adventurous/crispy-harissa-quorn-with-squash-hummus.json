  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 200°C."
    },
    {
      "heading": null,
      "description": "Peel and dice the squash into 2-3cm chunks. Toss with olive oil, the ras el hanout and salt and roast for 20-25 mins until just tender."
    },
    {
      "heading": null,
      "description": "Add the squash to a food processor with the garlic, lemon juice, chickpeas, tahini, 45ml of olive oil and a splash of water. Whizz together until super smooth, add a splash more water if you need to. Season to taste."
    },
    {
      "heading": null,
      "description": "Slice the onion as thinly as you can and add to a bowl. Finely chop the parsley and add to the bowl with the sumac and the juice of half a lemon. Add a pinch of salt and scrunch together, set aside to macerate."
    },
    {
      "heading": null,
      "description": "Add the veggie mince to a frying pan. Dice the onion and chuck into the pan with a shot of oil and a pinch of salt. Cook over a high heat until crispy. Grate in the garlic and add the harissa and molasses. Stir together and cook until crispy, sticky and glazed."
    },
    {
      "heading": null,
      "description": "Spread your warm hummus onto a serving plate, top with the crispy mince and sumac onions. Serve with grilled flatbreads or steamy pittas."
    }
  ],
