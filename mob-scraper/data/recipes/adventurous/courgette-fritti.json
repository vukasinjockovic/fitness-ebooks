  "method": [
    {
      "heading": null,
      "description": "Add the feta to a food processor and blend until smooth. Add the extra virgin olive oil, 1-2 tbsp of water, the juice of half a lemon and some salt and blitz again. In a small pan, combine the honey with the oregano and aleppo. Warm to infuse and set aside."
    },
    {
      "heading": null,
      "description": "Fill a large pot just under halfway with vegetable oil and set over a medium heat, bring to 180°C."
    },
    {
      "heading": null,
      "description": "Cut the courgettes into batons."
    },
    {
      "heading": null,
      "description": "Whisk together the rice and plain flours along with the baking powder and caster sugar. Gradually whisk in the sparkling water until you have a loose batter, the texture of double cream."
    },
    {
      "heading": null,
      "description": "Lightly dust the courgettes with rice flour, dunk briefly in the batter and carefully lower into the oil."
    },
    {
      "heading": null,
      "description": "Lightly dust the courgettes with rice flour, dunk briefly in the batter and carefully lower into the oil."
    },
    {
      "heading": null,
      "description": "Tip the feta dip into a bowl and drizzle with the infused honey."
    },
    {
      "heading": null,
      "description": "Serve the hot, crispy courgettes with lemon wedges and the feta honey dip."
    }
