  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 220°C."
    },
    {
      "heading": null,
      "description": "Thinly slice one of the red onions and place in a small bowl. Add the juice of the lemon, season with a good pinch of salt and scrunch with your hand to quick pickle."
    },
    {
      "heading": null,
      "description": "Arrange the Strong Roots Crispy Skinny Fries in a single layer in a large baking tray. Cook according to the package instructions."
    },
    {
      "heading": null,
      "description": "Finely chop the other red onion, garlic and ginger."
    },
    {
      "heading": null,
      "description": "Heat a generous splash of vegetable oil in a saucepan over medium heat. Add the finely chopped red onion, season with salt and cook until caramelised and starting to brown."
    },
    {
      "heading": null,
      "description": "Add the garlic and ginger and cook for 1 min then add the garam masala, cumin, coriander, chilli powder and turmeric and cook for 30 seconds. Precise, I know, but ground spices burn quickly!"
    },
    {
      "heading": null,
      "description": "Add the passata and brown sugar and cook for 5 mins, or until slightly thickened. Set aside."
    },
    {
      "heading": null,
      "description": "Roughly chop the coriander."
    },
    {
      "heading": null,
      "description": "Place the Strong Roots Crispy Skinny Fries in a large bowl. Add the spicy masala sauce and toss well to coat."
    },
    {
      "heading": null,
      "description": "Transfer to a platter and top with the chopped coriander, some quick-pickled onions and a few dollops of yoghurt. Tuck in and enjoy!"
    }
  ],
