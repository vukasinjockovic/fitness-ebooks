  "method": [
    {
      "heading": null,
      "description": "Slice the leeks in half lengthways and rub with a little oil. Season with salt and cook, cut-side down in a large saute pan over a high heat. Cook until well charred and set aside to cool."
    },
    {
      "heading": null,
      "description": "Thinly slice the onions and garlic. Set the same pan, back over a medium heat. Begin to sauté your onions on a low temperature with a shot of oil and plenty of salt and pepper, add your garlic and allow to brown slightly – remove from heat and add to a large mixing bowl."
    },
    {
      "heading": null,
      "description": "Roughly chop the cooled leeks and fold through the onion mixture. Add the cheese and mix it all together. Season to taste with salt and add the lemon juice. Set aside"
    },
    {
      "heading": null,
      "description": "To make the caraway butter, toast the seeds in a pan over a gentle heat until fragrant. Add the butter and let it melt and infuse with caraway flavour. Once everything is mixed and smelling incredible, remove from heat."
    },
    {
      "heading": null,
      "description": "Preheat the oven to 170°C."
    },
    {
      "heading": null,
      "description": "Unroll your pastry and layer a couple together, with butter brushed in between. Spread your filling all over the pastry sheets leaving roughly 1 inch empty around the edges."
    },
    {
      "heading": null,
      "description": "Roll your börek into a tube, and swirl in a spiral shape. Brush generously with egg yolk and bake for 20 mins. Remove from the oven and brush with caraway butter, ensuring there are seeds evenly distributed throughout."
    },
    {
      "heading": null,
      "description": "Bake for a further 5 mins and allow to cool."
    },
    {
      "heading": null,
      "description": "Slice and serve."
    }
  ],
