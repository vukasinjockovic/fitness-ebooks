  "method": [
    {
      "heading": null,
      "description": "Mix the butter with the finely grated garlic cloves, salt and pepper. Grate the parmesan and tip half into the butter."
    },
    {
      "heading": null,
      "description": "Finely chop the parsley, chives and capers and tip into a bowl. Add the zest and juice of a lemon and enough oil to bring it together into a salsa, roughly 80-100ml. Season with salt and pepper and set aside."
    },
    {
      "heading": null,
      "description": "Clean the mushrooms, removing any dirt or soil. Preheat a large frying pan over a high heat fire. Add a dash of oil and toss in the shrooms. Cook with no salt until super brown and crispy. Add a big spoon of garlic butter and salt. Toss the shrooms in the butter until golden brown and delicious."
    },
    {
      "heading": null,
      "description": "Meanwhile, grill your bread over the flames."
    },
    {
      "heading": null,
      "description": "Tip your mushrooms onto a serving plate and plop the egg yolk into the middle. Season the yolk with salt and pepper. Dress the plate with salsa verde and shaved parmesan. Serve with the warm, grilled bread."
    }
  ],
