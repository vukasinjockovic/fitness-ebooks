  "method": [
    {
      "heading": null,
      "description": "Preheat oven to 170°C (fan assisted)."
    },
    {
      "heading": null,
      "description": "Grease an 25 x 20cm baking dish with melted butter."
    },
    {
      "heading": null,
      "description": "For the topping, sift the muscovado sugar and cocoa powder into a mixing bowl and whisk to combine. Set\naside."
    },
    {
      "heading": null,
      "description": "For the cake batter, grab a separate mixing bowl. Sift in all the dry ingredients: the plain flour, caster sugar, cocoa powder, baking powder and pinch of salt. Whisk to combine."
    },
    {
      "heading": null,
      "description": "Gently warm the milk in a small pan over a low heat to no warmer than body temperature. Add the warm milk to a clean mixing bowl along with the butter and whisk to combine. Add the egg and vanilla extract and whisk to combine."
    },
    {
      "heading": null,
      "description": "Add the egg mixture to the dry ingredients and mix well to combine."
    },
    {
      "heading": null,
      "description": "Tip the cake batter into the baking dish and even it out with an off-set spatula or the back of a spoon."
    },
    {
      "heading": null,
      "description": "Scatter over the brown sugar and cocoa topping in an even layer."
    },
    {
      "heading": null,
      "description": "Spoon the boiling water carefully over the top being careful not to create craters. Don't pour from a height using the jug or you'll disturb the cake batter."
    },
    {
      "heading": null,
      "description": "Bake for 25 mins until a skewer comes out clean when poked into a spongey bit."
    },
    {
      "heading": null,
      "description": "Cool for 10 mins then serve warm with a dollop of double cream."
    }
