  "method": [
    {
      "heading": null,
      "description": "Heat your oven to 200°C."
    },
    {
      "heading": null,
      "description": "Cut your aubergines into rounds 3cm thick."
    },
    {
      "heading": null,
      "description": "Lay them on baking trays lined with parchment paper. Drizzle your aubergine slices with olive oil and a pinch of salt, then pop them in the oven for 30 mins."
    },
    {
      "heading": null,
      "description": "Next, make your teriyaki sauce. Add your caster sugar, soy sauce, knob of ginger and the water to a saucepan. Bring to a gentle simmer, stirring until your sugar has dissolved."
    },
    {
      "heading": null,
      "description": "Mix your cornflour in a bowl with 1 tbsp water to form a paste. Pour this into your sauce and stir immediately. Let the mixture come to a boil. After simmering for 5 mins, it should be drizzle-able and glossy. Add your rice wine vinegar and mix to combine. Set aside."
    },
    {
      "heading": null,
      "description": "For the whipped tofu, add your smoked tofu to a blender with your miso paste, water and olive oil. Whizz to a smooth paste, then season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Add your nori sheet to a spice grinder or food processor and whizz to a powder. Combine this with your chilli powder and sesame seeds in a bowl."
    },
    {
      "heading": null,
      "description": "Once the 30 mins for your aubergine is up, flip them over and return them to the oven for another 10 mins."
    },
    {
      "heading": null,
      "description": "Chop the woody ends off your spring onions. Heat a griddle pan over a high heat, and place your spring onions into the pan. Cook for a couple of mins on each side until they have deep char lines. Remove from the pan with tongs, then chop into lengths."
    },
    {
      "heading": null,
      "description": "Spread your whipped smoked tofu onto your chosen serving platter. Top with your roasted aubergine rounds, then pour over your teriyaki sauce. Add your spring onions and your sesame seed powder on top, then serve and enjoy."
    }
  ],
