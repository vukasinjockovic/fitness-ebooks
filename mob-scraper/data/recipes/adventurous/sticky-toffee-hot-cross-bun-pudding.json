  "method": [
    {
      "heading": null,
      "description": "Halve the hot cross buns and spread one side with butter. Nestle into an ovenproof dish around 27cm in diameter."
    },
    {
      "heading": null,
      "description": "Heat the oven to 170°C. Pour the milk and cream into a saucepan and heat until it's just about to boil, then remove from the heat."
    },
    {
      "heading": null,
      "description": "Whisk the eggs, egg yolks, sugar, vanilla and a pinch of salt in a bowl until combined, then gradually add a small amount of the hot cream, whisking to combine. Continue slowly pouring the cream into the eggs while whisking, ensuring not to go too quickly or the eggs might scramble. Pour over the hot cross buns and let it soak for at least 30 mins (1 hr, if possible)."
    },
    {
      "heading": null,
      "description": "Transfer the pudding to the oven and cook for around 40 mins until puffed and golden."
    },
    {
      "heading": null,
      "description": "To make the toffee sauce, put the butter, golden syrup and sugar into a pot. Melt over a low heat until everything has dissolved, then add the cream and a pinch of salt. Keep warm until serving."
    },
    {
      "heading": null,
      "description": "When the pudding is cooked, remove from the oven and let it sit for 5 mins before serving with ice cream and a big drizzle of toffee sauce."
    }
  ],
