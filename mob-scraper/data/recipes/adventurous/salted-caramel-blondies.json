  "method": [
    {
      "heading": null,
      "description": "Heat oven to 160°C."
    },
    {
      "heading": null,
      "description": "Line a 20cm square tin with butter and baking parchment. Melt the butter in a small saucepan or microwave."
    },
    {
      "heading": null,
      "description": "Meanwhile, add your toffees to a small saucepan with 20ml milk. Heat over a low heat until you have a thick caramel. Season with a pinch of salt."
    },
    {
      "heading": null,
      "description": "Whisk your brown sugar into the melted butter, then add your eggs, vanilla bean, Dr Oetker caramel flavouring, sea salt flakes and 50ml milk. Whisk until you have a thick and silky mixture."
    },
    {
      "heading": null,
      "description": "Sift in your flour and baking powder, then fold through the mixture. Add all but a handful of white chocolate chunks and fold these through the mixture."
    },
    {
      "heading": null,
      "description": "Pour your mixture into your tin. Bake for 25 minutes, then remove from the oven and add your remaining white chocolate chunks and a drizzle of your salted caramel. Return to the oven for another 15 minutes. They will have set edges but a slightly jiggly middle when set."
    },
    {
      "heading": null,
      "description": "Leave to cool to room temperature. Chill in the fridge for a couple of hours - this will give them their super fudgy texture. Cut into squares and serve."
    }
  ],
