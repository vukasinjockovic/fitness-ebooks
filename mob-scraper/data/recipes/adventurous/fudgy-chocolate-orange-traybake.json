  "method": [
    {
      "heading": null,
      "description": "Preheat your oven 180°C/354°F."
    },
    {
      "heading": null,
      "description": "Grease a 30cm x 20cm tray with oil, then line with greaseproof paper and coat with a drizzle more oil."
    },
    {
      "heading": null,
      "description": "Slice 4 oranges as thinly as possible, saving the ends and any other pieces that don’t make the cut. Juice the ends and the scraps into a small bowl along with the caster sugar."
    },
    {
      "heading": null,
      "description": "Pour slurry onto the tray and arrange the orange slices on top, overlapping as you go. You could even cut some of them in half to make a clean border around the edge."
    },
    {
      "heading": null,
      "description": "Mix the flour, ground almonds, cocoa powder, bicarbonate of soda, baking powder and salt in a large bowl. Pour in the coconut milk, vinegar, sugar, oil and the juice and zest of the last orange. Mix well until smooth and pour gently over the oranges in the tray."
    },
    {
      "heading": null,
      "description": "Transfer the cake to the oven and bake for 35-40 minutes until a skewer inserted comes out clean."
    },
    {
      "heading": null,
      "description": "Leave to cool for 20 minutes then invert onto a large chopping board."
    },
    {
      "heading": null,
      "description": "Peel off the greaseproof paper and serve with warmed Coconut Collaborative Vanilla Custard."
    }
  ],
