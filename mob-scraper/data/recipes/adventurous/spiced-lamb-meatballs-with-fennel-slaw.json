  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 220°C."
    },
    {
      "heading": null,
      "description": "Get your lamb mince into a large mixing bowl and season with salt."
    },
    {
      "heading": null,
      "description": "Toast the whole spices in a dry pan until fragrant, then coarsely grind in a spice grinder or pestle and mortar."
    },
    {
      "heading": null,
      "description": "Add the breadcrumbs to a bowl and add 60ml of cold water."
    },
    {
      "heading": null,
      "description": "Add the spices, soaked breadcrumbs, raisins and pine nuts to the lamb and give everything a very thorough mix. You want the mix to be a bit sticky. Now roll into golf ball-sized meatballs, pop onto a tray and set aside."
    },
    {
      "heading": null,
      "description": "Drain and rinse the chickpeas and chuck them into a roasting tin with a glug of oil, two whole chillies and half a thinly sliced onion. Thinly slice the other half and save it for later. Roast the chickpeas for 30 mins until crispy, golden and delicious."
    },
    {
      "heading": null,
      "description": "While the chickpeas roast, pan fry the meatballs in a glug of oil over a medium heat until golden on all sides and cooked through. This should take about 15 mins. Add your harissa to the pan for the last couple of mins and finish with a big squeeze of lemon juice. Let the meatballs rest while you finish the other bits."
    },
    {
      "heading": null,
      "description": "Pull the chickpeas out of the oven, deseed and chop the roasted chillies and stir through with lemon juice and a handful of chopped mint."
    },
    {
      "heading": null,
      "description": "Finely slice the fennel and chuck into a bowl with the remaining onion, chillies, mint and finish with salt and lemon juice."
    },
    {
      "heading": null,
      "description": "Mix the yoghurt and tahini with salt, lemon juice and enough water to give a loose, spreadable consistency."
    },
    {
      "heading": null,
      "description": "Spread the yoghurt and tahini on the bottom of a plate, top with the chickpeas and meatballs, plus any beautiful oil and lemon from the pan, and finish with the fennel salad. Get stuck in."
    }
  ],
