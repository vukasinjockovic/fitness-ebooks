  "method": [
    {
      "heading": null,
      "description": "Spoon the buttermilk into a bowl or container along with the hot sauce and plenty of salt and pepper. Add the chicken legs and toss really well to coat. You can leave this to marinate for up to 12 hrs, or you can use it straight away."
    },
    {
      "heading": null,
      "description": "Put the flour into a shallow bowl with the baking powder, garlic powder, paprika and cayenne pepper, plus plenty of salt and pepper. Mix until well combined."
    },
    {
      "heading": null,
      "description": "Take the chicken legs, one at a time, from the buttermilk mix and straight into the flour, really patting to coat. Repeat with the other chicken leg and put onto a plate while you prep the air fryer."
    },
    {
      "heading": null,
      "description": "Line the basket of the air fryer with foil, then lay in the chicken legs, skin-side up. Give the chicken legs a really good spray with oil, to evenly coat, then set the air fryer to 190°C and put the timer on for 45 mins."
    },
    {
      "heading": null,
      "description": "Check and shake the basket every 15 mins or so. Give the chicken legs another spray of oil if they need it."
    },
    {
      "heading": null,
      "description": "Meanwhile, melt the butter in a small pan and add all the sauce ingredients. Whisk together until even – adjust the spice level and seasoning to your liking. Reheat the sauce just before the chicken is ready."
    },
    {
      "heading": null,
      "description": "Once the chicken is super crisp, pour over the sauce and serve with buttered bread and sliced pickles, if you like."
    }
  ],
