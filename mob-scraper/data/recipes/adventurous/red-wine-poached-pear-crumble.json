  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 160°C."
    },
    {
      "heading": null,
      "description": "Peel, halve and remove the stones from the pears. Add them to a pan with ⅔ of the sugar and the wine, bay leaves, orange zest and juice."
    },
    {
      "heading": null,
      "description": "Bring to a simmer and poach cut side down for 5-6 minutes, or until just tender. Remove from the pan and reduce the wine by a third or to a light syrup."
    },
    {
      "heading": null,
      "description": "To a mixing bowl, add the remaining sugar, breadcrumbs, almonds, oats, butter, salt and egg yolk and mix thoroughly. Don’t worry about rubbing anything in with your fingertips, this crumble is dead simple. No faff."
    },
    {
      "heading": null,
      "description": "Add the pears to a baking dish cut side up, cover with the (strained) poaching syrup and the crumble mixture."
    },
    {
      "heading": null,
      "description": "Bake for 45 mins and serve with cold cream."
    }
