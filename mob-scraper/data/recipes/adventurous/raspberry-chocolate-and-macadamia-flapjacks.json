  "method": [
    {
      "heading": null,
      "description": "Preheat the oven to 180°C/354°F. Then line a 20 x 20cm baking tin with dairy-free butter and parchment."
    },
    {
      "heading": null,
      "description": "Roughly chop your macadamias."
    },
    {
      "heading": null,
      "description": "Pour your dairy-free butter, sugar and golden syrup into a large saucepan. Stir over a medium heat until they are all melted into a glossy sauce."
    },
    {
      "heading": null,
      "description": "Allow to cool for 10 minutes, then tip in your rolled oats, macadamias and your Dr. Oetker Jumbo Chocolate Chips. Give it all a good stir until it’s combined."
    },
    {
      "heading": null,
      "description": "Pour half your oat mixture into your lined tin and smooth the surface so it’s even. Push in half of your fresh raspberries and then pour over the remaining mixture. Top with the remaining raspberries and press down to flatten."
    },
    {
      "heading": null,
      "description": "Bake for 35 mins until the top is golden and crisp."
    },
    {
      "heading": null,
      "description": "Whilst they bake, finely chop your Dr. Oetker Extra Dark Chocolate."
    },
    {
      "heading": null,
      "description": "Add your chocolate to a heatproof bowl and heat in the microwave for 2 minutes, pausing and stirring after every 30 seconds until your chocolate is smooth and melted."
    },
    {
      "heading": null,
      "description": "Drizzle your flapjacks with your melted chocolate, then leave to cool. Cut into squares and enjoy!"
    }
  ],
