  "method": [
    {
      "heading": null,
      "description": "Finely chop your leeks and garlic."
    },
    {
      "heading": null,
      "description": "Heat your butter in a large sauté pan and, once melted and foaming, add your leeks. Cook gently for 20 mins until totally softened."
    },
    {
      "heading": null,
      "description": "Bring a large pan of salted water to the boil. Tip in your paccheri and cook for 13 mins, until al dente."
    },
    {
      "heading": null,
      "description": "Back to the sauce. Add garlic to the leeks and cook out for 2 mins. Pour your double cream and milk into the pan and bring them to a gentle simmer."
    },
    {
      "heading": null,
      "description": "Chop your taleggio into rough chunks, then add this to the sauce and stir to melt. Add your nutmeg and most of your parmesan, then season to taste with salt and pepper."
    },
    {
      "heading": null,
      "description": "Tip your pasta into the pan along with a ladle of pasta water. Stir until your sauce clings to your pasta beautifully."
    },
    {
      "heading": null,
      "description": "Spoon your pasta into bowls and sprinkle with a little parmesan, black pepper and olive oil. Serve and enjoy."
    }
