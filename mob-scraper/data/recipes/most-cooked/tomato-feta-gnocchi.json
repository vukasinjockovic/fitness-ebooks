  "method": [
    {
      "heading": null,
      "description": "Heat the oven to 200°C. Tip the cherry tomatoes and gnocchi into a large baking dish. Snuggle the feta into the middle. Sprinkle with the oregano and the chilli flakes. Season with salt and pepper and drizzle with the olive oil. Wrap the garlic bulb in foil and place on the side of the baking tray. Slide into the oven for 40 mins."
    },
    {
      "heading": null,
      "description": "Remove from the oven, unwrap the garlic and snip off the top, then squeeze into the tray."
    },
    {
      "heading": null,
      "description": "Add most of the basil and stir well, mixing the melted feta with the juicy tomatoes to make a smooth sauce, add a splash of water if it looks a little thick. Spoon into bowls, top with the remaining basil and a pinch of chilli flakes."
    }
  ],
