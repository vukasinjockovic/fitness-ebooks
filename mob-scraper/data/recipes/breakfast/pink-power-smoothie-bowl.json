  "method": [
    {
      "heading": null,
      "description": "Chuck the frozen strawberries, raspberries, cherries and banana into a blender with the almond milk, yoghurt, protein powder, lime juice and chia seeds."
    },
    {
      "heading": null,
      "description": "Start blending on a low speed. Use a tamper to push the mixture down towards the blades – it’ll take a minute to get going. Don’t add more liquid unless you absolutely have to. If it really won’t budge, splash in 10ml more almond milk at a time."
    },
    {
      "heading": null,
      "description": "Scoop your thick smoothie into a bowl, then top with whatever you fancy – sliced fruit, coconut flakes, granola, seeds or a drizzle of almond butter."
    }
