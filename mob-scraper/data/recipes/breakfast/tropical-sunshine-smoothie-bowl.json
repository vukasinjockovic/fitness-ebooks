  "method": [
    {
      "heading": null,
      "description": "Chuck the mango, pineapple, banana, milk, yoghurt, juice of the lime, turmeric, ginger and protein powder into a blender."
    },
    {
      "heading": null,
      "description": "Start blending on a low speed. Use a tamper to push the mixture down – it’ll be thick, but that’s what we’re after. Only add more liquid if you really need to. Splash in an extra 10ml of milk at a time if it won’t budge."
    },
    {
      "heading": null,
      "description": "Scoop into a bowl and top with whatever you fancy – banana slices, coconut flakes, granola, seeds or a drizzle of almond butter."
    }
  ],
