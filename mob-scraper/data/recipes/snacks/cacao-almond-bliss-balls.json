  "method": [
    {
      "heading": null,
      "description": "Blitz the almonds in a food processor until they resemble coarse flour – not a paste."
    },
    {
      "heading": null,
      "description": "Add the dates, raisins, cacao powder, almond butter, vanilla and salt. Blend again until the mixture forms a sticky dough."
    },
    {
      "heading": null,
      "description": "If the dough feels too dry, add a little water or coconut oil, one teaspoon at a time, until it comes together."
    },
    {
      "heading": null,
      "description": "Scoop out the mixture and roll into bite-sized balls using your hands. You should get around 12-14 depending on how big you make them."
    },
    {
      "heading": null,
      "description": "Pop the balls into the fridge to chill for 20–30 mins until firm. Once set, transfer them to a Tupperware lined with baking paper – add another sheet between layers if you’re stacking them. Keep in the fridge for up to a week or freeze for up to 3 months."
    }
