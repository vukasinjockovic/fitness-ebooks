  "method": [
    {
      "heading": null,
      "description": "Chuck the almond flour, coconut, almond butter, coconut oil, maple syrup, vanilla extract and salt into a food processor. Blitz until it all comes together in a soft, sticky dough."
    },
    {
      "heading": null,
      "description": "Add the lemon juice and zest, then pulse a few times just to mix through."
    },
    {
      "heading": null,
      "description": "Scoop out the dough and roll into balls using your hands. You should get around 12."
    },
    {
      "heading": null,
      "description": "Break the chocolate into pieces then melt in the microwave in 30 second bursts or in a bain marie. Drizzle over the lemon bliss balls, add a little extra zest to finish if you fancy."
    },
    {
      "heading": null,
      "description": "Pop them in the fridge to chill for 1 hour until set. Ready to go!"
    },
    {
      "heading": null,
      "description": "To store, transfer the bliss balls to a Tupperware lined with baking paper. If stacking, add another sheet between layers. Keep in the fridge for up to a week or freeze for up to 3 months."
    }
  ],
  "tips": [
    "Store in the fridge for up to 1 week in an airtight container.",
    "If freezing, defrost at room temp for 20 mins before eating.",
    "A microplane works best for the lemon zest and try to avoid the bitter white pith."
  ],
