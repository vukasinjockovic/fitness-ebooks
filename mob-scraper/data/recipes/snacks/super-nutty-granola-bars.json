  "method": [
    {
      "heading": null,
      "description": "If you fancy extra depth of flavour, lightly toast the almonds, cashews, pumpkin &amp; sunflower seeds in a dry frying pan over a medium heat for a few mins until golden. Set aside to cool slightly."
    },
    {
      "heading": null,
      "description": "Combine all dry ingredients in a bowl."
    },
    {
      "heading": null,
      "description": "In a small saucepan, gently warm the date syrup, almond butter &amp; vanilla over a low heat until smooth and glossy. \nPour the warm mixture over the dry ingredients and stir quickly to coat everything evenly."
    },
    {
      "heading": null,
      "description": "Line a tray with baking paper. Tip in the mixture and press it down as firmly as you can, use the back of a spoon or your hands."
    },
    {
      "heading": null,
      "description": "Chill in the fridge or freezer for 1–2 hours until set."
    },
    {
      "heading": null,
      "description": "Slice into bars. If you’re feeling fancy, drizzle or dip the bars in melted dark chocolate, then chill again until the chocolate sets. Once ready, wrap the bars in baking paper and chill or freeze until needed (these last for a week in the fridge and 3 months in the freezer)."
    }
  ],
  "tips": [
    "Bars will keep for 1 week in the fridge in an airtight container.",
    "Freeze for up to 1 month – defrost for 20 mins at room temp before eating.",
    "Best pressed super firmly so they hold together when sliced."
  ],
